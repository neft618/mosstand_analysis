{
  "file": "13.05.2026_15_26_32_79629714901_m31_d70079_0.1778675193.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 572.0,
  "segments": [
    {
      "start": 2.08,
      "end": 4.38,
      "speaker": null,
      "text": "Юрий, вы здравствуйте. Это Валерий из Мастент."
    },
    {
      "start": 6.12,
      "end": 12.42,
      "speaker": null,
      "text": "Да, Валерий, смотрите, в Кигором трём часам появились данные по адресу и прочему."
    },
    {
      "start": 12.72,
      "end": 17.82,
      "speaker": null,
      "text": "У нас в итоге что получается? Сейчас секунду открою заново, а то я уже закрыл."
    },
    {
      "start": 19.12,
      "end": 39.82,
      "speaker": null,
      "text": "Так, адрес монтажа, который прислал 3х4 из бруса Косыгина 17."
    },
    {
      "start": 39.82,
      "end": 49.72,
      "speaker": null,
      "text": "Я в секунду прислал 3х4 метра или пупапа? Мы просто по поводу пупапы с вами общались и флагов."
    },
    {
      "start": 55.05,
      "end": 60.97,
      "speaker": null,
      "text": "Давайте я просто заново закажу, чтобы я сейчас всё это записала так же, я просто помню пупапа."
    },
    {
      "start": 64.58,
      "end": 69.73,
      "speaker": null,
      "text": "Прислов из бруса у них написано теперь жека и размер 3х2."
    },
    {
      "start": 71.11,
      "end": 75.34,
      "speaker": null,
      "text": "3х2 метра, ага. Косыгина 14?"
    },
    {
      "start": 76.14,
      "end": 76.52,
      "speaker": null,
      "text": "18."
    },
    {
      "start": 78.06,
      "end": 79.96,
      "speaker": null,
      "text": "А дата какая?"
    },
    {
      "start": 81.23,
      "end": 85.55,
      "speaker": null,
      "text": "Дата у нас девятнадцать, вторник следующее."
    },
    {
      "start": 86.21,
      "end": 90.43,
      "speaker": null,
      "text": "Угу, девятнадцатый именно часа. А по времени когда можно диапазон?"
    },
    {
      "start": 90.75,
      "end": 91.47,
      "speaker": null,
      "text": "Со ссылки до ссылки?"
    },
    {
      "start": 91.75,
      "end": 93.33,
      "speaker": null,
      "text": "Ну, начинаем всё лучше."
    },
    {
      "start": 95.55,
      "end": 100.57,
      "speaker": null,
      "text": "Ну то есть если какое-то мероприятие, там девятнадцатого числа сразу, то хотя бы до ссылки?"
    },
    {
      "start": 101.98,
      "end": 103.2,
      "speaker": null,
      "text": "Ну, до часа."
    },
    {
      "start": 104.22,
      "end": 109.98,
      "speaker": null,
      "text": "А, до часа. То есть с 9 утра, например, можно до часа, да? Ну, до 12 примерно."
    },
    {
      "start": 109.98,
      "end": 114.36,
      "speaker": null,
      "text": "Так, хорошо. Супер. Помимо прислова что-то ещё необходимо будет?"
    },
    {
      "start": 114.36,
      "end": 117.2,
      "speaker": null,
      "text": "Да, сейчас секунду я найду."
    },
    {
      "start": 117.66,
      "end": 118.12,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 120.75,
      "end": 149.13,
      "speaker": null,
      "text": "По папе. Папа ещё секунду."
    },
    {
      "start": 155.02,
      "end": 156.58,
      "speaker": null,
      "text": "Так, один два на три."
    },
    {
      "start": 157.99,
      "end": 158.43,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 160.3,
      "end": 161.96,
      "speaker": null,
      "text": "Сейчас количество уточню."
    },
    {
      "start": 162.36,
      "end": 162.92,
      "speaker": null,
      "text": "Секунду."
    },
    {
      "start": 168.19,
      "end": 168.47,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 168.47,
      "end": 168.99,
      "speaker": null,
      "text": "Один."
    },
    {
      "start": 170.4,
      "end": 172.68,
      "speaker": null,
      "text": "И ещё один, три на три."
    },
    {
      "start": 173.08,
      "end": 174.96,
      "speaker": null,
      "text": "Три на три секунду."
    },
    {
      "start": 177.67,
      "end": 178.61,
      "speaker": null,
      "text": "А не прямые?"
    },
    {
      "start": 178.75,
      "end": 179.57,
      "speaker": null,
      "text": "Заглубы должны быть?"
    },
    {
      "start": 179.59,
      "end": 179.99,
      "speaker": null,
      "text": "Прямые."
    },
    {
      "start": 180.37,
      "end": 180.97,
      "speaker": null,
      "text": "Прямые."
    },
    {
      "start": 183.64,
      "end": 184.28,
      "speaker": null,
      "text": "По папе."
    },
    {
      "start": 184.36,
      "end": 186.78,
      "speaker": null,
      "text": "И всё в целом или флаги ещё будут?"
    },
    {
      "start": 186.98,
      "end": 187.28,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 187.72,
      "end": 188.06,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 188.18,
      "end": 194.52,
      "speaker": null,
      "text": "Флаги, ну, возможно, будут, но по анимизатору информации, поэтому пока не зажим."
    },
    {
      "start": 194.52,
      "end": 198.1,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 198.3,
      "end": 198.56,
      "speaker": null,
      "text": "Понимаю."
    },
    {
      "start": 198.66,
      "end": 202.0,
      "speaker": null,
      "text": "То есть у нас получается прислова с бруса 3 на 2 метра."
    },
    {
      "start": 202.6,
      "end": 206.1,
      "speaker": null,
      "text": "Монтаж 19-го числа с 9 до 12 и кассе 1 на 17."
    },
    {
      "start": 206.4,
      "end": 207.36,
      "speaker": null,
      "text": "По папам нужен?"
    },
    {
      "start": 207.56,
      "end": 209.88,
      "speaker": null,
      "text": "Нужен будет монтаж или сами соберут у вас?"
    },
    {
      "start": 210.94,
      "end": 211.36,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 212.2,
      "end": 215.42,
      "speaker": null,
      "text": "Ну, просто так же 19-го числа привезти, так?"
    },
    {
      "start": 217.55,
      "end": 217.71,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 218.47,
      "end": 218.83,
      "speaker": null,
      "text": "Супер."
    },
    {
      "start": 220.15,
      "end": 225.01,
      "speaker": null,
      "text": "Значит, 19-е число – это у нас рабочий день и получается рабочее время."
    },
    {
      "start": 226.16,
      "end": 226.66,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 227.16,
      "end": 227.66,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 229.26,
      "end": 229.76,
      "speaker": null,
      "text": "И…"
    },
    {
      "start": 229.76,
      "end": 231.98,
      "speaker": null,
      "text": "А макеты у вас уже будут готовы?"
    },
    {
      "start": 232.8,
      "end": 234.26,
      "speaker": null,
      "text": "Макеты есть уже на всё, да."
    },
    {
      "start": 234.52,
      "end": 235.1,
      "speaker": null,
      "text": "А, всё."
    },
    {
      "start": 235.3,
      "end": 235.56,
      "speaker": null,
      "text": "Супер."
    },
    {
      "start": 235.56,
      "end": 236.38,
      "speaker": null,
      "text": "Там ЧБ, всё."
    },
    {
      "start": 238.04,
      "end": 238.9,
      "speaker": null,
      "text": "А, всё."
    },
    {
      "start": 239.06,
      "end": 239.26,
      "speaker": null,
      "text": "Понимаю."
    },
    {
      "start": 240.34,
      "end": 241.7,
      "speaker": null,
      "text": "Они такие должны быть, да?"
    },
    {
      "start": 243.28,
      "end": 244.28,
      "speaker": null,
      "text": "Ну, то есть ЧБ."
    },
    {
      "start": 244.28,
      "end": 245.0,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 245.99,
      "end": 246.25,
      "speaker": null,
      "text": "Ну, да."
    },
    {
      "start": 246.39,
      "end": 247.25,
      "speaker": null,
      "text": "Там сам макет."
    },
    {
      "start": 247.63,
      "end": 249.67,
      "speaker": null,
      "text": "То, что они не хотят."
    },
    {
      "start": 249.87,
      "end": 250.75,
      "speaker": null,
      "text": "Всё чёрно-белое."
    },
    {
      "start": 251.25,
      "end": 252.23,
      "speaker": null,
      "text": "То есть 20-е число."
    },
    {
      "start": 252.33,
      "end": 252.49,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 252.49,
      "end": 253.05,
      "speaker": null,
      "text": "А, ну и всё."
    },
    {
      "start": 253.11,
      "end": 253.29,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 253.59,
      "end": 256.19,
      "speaker": null,
      "text": "Скорее всего у вас же полотно наверняка белое, поэтому"
    },
    {
      "start": 256.19,
      "end": 256.95,
      "speaker": null,
      "text": "только чёрное."
    },
    {
      "start": 257.45,
      "end": 257.71,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 257.89,
      "end": 260.27,
      "speaker": null,
      "text": "Полотно белое, само по себе и там уже печать."
    },
    {
      "start": 260.53,
      "end": 260.99,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 261.13,
      "end": 261.45,
      "speaker": null,
      "text": "Поняла."
    },
    {
      "start": 262.83,
      "end": 265.99,
      "speaker": null,
      "text": "По стоимости в целом ознакомлены на этот папу, я насколько"
    },
    {
      "start": 265.99,
      "end": 268.19,
      "speaker": null,
      "text": "помню, мы с вами решались, вы ориентируетесь"
    },
    {
      "start": 268.19,
      "end": 268.81,
      "speaker": null,
      "text": "на сайт, правильно?"
    },
    {
      "start": 269.9,
      "end": 272.58,
      "speaker": null,
      "text": "Ну, желательно, конечно, поменьше ничего сайта."
    },
    {
      "start": 273.66,
      "end": 277.78,
      "speaker": null,
      "text": "Смотрите, а вы на стоимость, если поп-апу, вы ориентируетесь"
    },
    {
      "start": 278.18,
      "end": 279.52,
      "speaker": null,
      "text": "на классик или на стандарт?"
    },
    {
      "start": 279.8,
      "end": 280.76,
      "speaker": null,
      "text": "Просто для понимания."
    },
    {
      "start": 283.39,
      "end": 284.05,
      "speaker": null,
      "text": "Я не знаю."
    },
    {
      "start": 284.27,
      "end": 285.71,
      "speaker": null,
      "text": "Вот я нашёл обычный поп-ап."
    },
    {
      "start": 286.37,
      "end": 289.37,
      "speaker": null,
      "text": "Вот я сейчас даже у вас на сайте, наверное, на стандарт."
    },
    {
      "start": 289.37,
      "end": 290.53,
      "speaker": null,
      "text": "А к чём отличие?"
    },
    {
      "start": 291.31,
      "end": 291.95,
      "speaker": null,
      "text": "Он прямой."
    },
    {
      "start": 292.09,
      "end": 294.17,
      "speaker": null,
      "text": "Это прям один прямой, другой полукруглый."
    },
    {
      "start": 296.26,
      "end": 300.06,
      "speaker": null,
      "text": "Там разжище конструкции самих, то есть именно производство"
    },
    {
      "start": 300.58,
      "end": 300.86,
      "speaker": null,
      "text": "конструкций."
    },
    {
      "start": 301.5,
      "end": 307.56,
      "speaker": null,
      "text": "То есть если классик, он более такой… ну, то есть производство"
    },
    {
      "start": 307.56,
      "end": 308.32,
      "speaker": null,
      "text": "просто другое."
    },
    {
      "start": 308.7,
      "end": 313.36,
      "speaker": null,
      "text": "И то, что производство другое, у них цена материалов"
    },
    {
      "start": 313.36,
      "end": 316.0,
      "speaker": null,
      "text": "выше и поэтому стоимость самого поп-апа выше выходит."
    },
    {
      "start": 316.0,
      "end": 320.22,
      "speaker": null,
      "text": "Но в целом мы обычно как бы и стандарт рассматриваем."
    },
    {
      "start": 321.16,
      "end": 323.96,
      "speaker": null,
      "text": "Ну, смотрите, у меня вроде бы по ним ничего такого"
    },
    {
      "start": 323.96,
      "end": 325.08,
      "speaker": null,
      "text": "не написано."
    },
    {
      "start": 326.16,
      "end": 330.38,
      "speaker": null,
      "text": "Так, брендирование, стенд… ну, даже здесь написано"
    },
    {
      "start": 330.38,
      "end": 330.9,
      "speaker": null,
      "text": "классик."
    },
    {
      "start": 332.74,
      "end": 336.0,
      "speaker": null,
      "text": "То есть то, что я им дал, была ваша же позиция."
    },
    {
      "start": 336.0,
      "end": 340.49,
      "speaker": null,
      "text": "Они в реальности, то есть в жизни они никак не отличаются."
    },
    {
      "start": 340.71,
      "end": 343.21,
      "speaker": null,
      "text": "То есть вряд ли вы сможете верить какие-то различия"
    },
    {
      "start": 343.21,
      "end": 344.71,
      "speaker": null,
      "text": "между стандартом и классиком."
    },
    {
      "start": 345.67,
      "end": 347.23,
      "speaker": null,
      "text": "Просто производство разное."
    },
    {
      "start": 347.55,
      "end": 351.31,
      "speaker": null,
      "text": "А в остальном, получается у нас…"
    },
    {
      "start": 351.87,
      "end": 354.15,
      "speaker": null,
      "text": "Какое у вас бюджет, просто чтобы я понимала?"
    },
    {
      "start": 357.42,
      "end": 358.7,
      "speaker": null,
      "text": "Ну, у нас стоит…"
    },
    {
      "start": 358.7,
      "end": 363.11,
      "speaker": null,
      "text": "У нас стоит двадцатка вообще."
    },
    {
      "start": 364.07,
      "end": 366.65,
      "speaker": null,
      "text": "Но я сейчас буду как раз обсуждать увеличение,"
    },
    {
      "start": 366.65,
      "end": 370.57,
      "speaker": null,
      "text": "если мы остаёмся на ценах интернета."
    },
    {
      "start": 371.45,
      "end": 373.07,
      "speaker": null,
      "text": "Естественно, я сейчас не буду разговаривать,"
    },
    {
      "start": 373.11,
      "end": 375.17,
      "speaker": null,
      "text": "чтобы мы увеличивали их, ну, бюджет."
    },
    {
      "start": 376.09,
      "end": 376.31,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 376.91,
      "end": 379.85,
      "speaker": null,
      "text": "А стоит двадцать тысяч в начале на три сентябра?"
    },
    {
      "start": 381.12,
      "end": 381.76,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 382.27,
      "end": 385.83,
      "speaker": null,
      "text": "Двадцать только на поп-апы, на единицу."
    },
    {
      "start": 387.8,
      "end": 388.82,
      "speaker": null,
      "text": "Так, и…"
    },
    {
      "start": 390.45,
      "end": 393.49,
      "speaker": null,
      "text": "Ну, и семнадцать они пока хотят за…"
    },
    {
      "start": 401.25,
      "end": 403.17,
      "speaker": null,
      "text": "Ну, смотрите, как в любом случае, да,"
    },
    {
      "start": 403.27,
      "end": 404.63,
      "speaker": null,
      "text": "придётся увеличивать бюджет."
    },
    {
      "start": 405.49,
      "end": 409.25,
      "speaker": null,
      "text": "Потому что даже если мы там брусовой стенд просто отдельно берём,"
    },
    {
      "start": 409.35,
      "end": 411.55,
      "speaker": null,
      "text": "там восемнадцать тысяч только сам брусовой стенд,"
    },
    {
      "start": 411.65,
      "end": 413.77,
      "speaker": null,
      "text": "но там ещё работу монтажником мы также оплатим."
    },
    {
      "start": 413.87,
      "end": 416.95,
      "speaker": null,
      "text": "Вы назовите мне сумму, я сейчас приду с ними обсуждать."
    },
    {
      "start": 417.94,
      "end": 418.54,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 418.78,
      "end": 421.22,
      "speaker": null,
      "text": "Или могу вам на почту просто прописать,"
    },
    {
      "start": 421.28,
      "end": 422.56,
      "speaker": null,
      "text": "чтобы у вас закрепено было всё."
    },
    {
      "start": 424.6,
      "end": 426.96,
      "speaker": null,
      "text": "Можете продиктовать, чтобы я быстрее с ним попросил"
    },
    {
      "start": 426.96,
      "end": 428.82,
      "speaker": null,
      "text": "и скинуть ещё на почту."
    },
    {
      "start": 428.82,
      "end": 429.74,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 429.96,
      "end": 433.34,
      "speaker": null,
      "text": "Смотрите, пресс-вол из бруса как раз таки три на два"
    },
    {
      "start": 433.34,
      "end": 435.36,
      "speaker": null,
      "text": "уже с печати восемнадцать тысяч рублей."
    },
    {
      "start": 435.5,
      "end": 437.22,
      "speaker": null,
      "text": "Это уже с печати 20 стенд."
    },
    {
      "start": 437.44,
      "end": 438.44,
      "speaker": null,
      "text": "А монтаж?"
    },
    {
      "start": 439.27,
      "end": 441.25,
      "speaker": null,
      "text": "Монтаж секундочку сейчас скажу вам."
    },
    {
      "start": 441.79,
      "end": 442.31,
      "speaker": null,
      "text": "Секунду."
    },
    {
      "start": 449.94,
      "end": 452.2,
      "speaker": null,
      "text": "Монтаж стенда шесть тысяч рублей."
    },
    {
      "start": 453.55,
      "end": 454.95,
      "speaker": null,
      "text": "Так это вот двадцать четыре, да?"
    },
    {
      "start": 455.33,
      "end": 456.55,
      "speaker": null,
      "text": "Да-да-да, всё верно."
    },
    {
      "start": 457.81,
      "end": 462.57,
      "speaker": null,
      "text": "И мы сможем успеть к 19-му, правильно я понимаю?"
    },
    {
      "start": 462.57,
      "end": 463.89,
      "speaker": null,
      "text": "Да-да, сможем."
    },
    {
      "start": 464.29,
      "end": 464.83,
      "speaker": null,
      "text": "Сможем, конечно."
    },
    {
      "start": 465.29,
      "end": 468.19,
      "speaker": null,
      "text": "Только сразу предупреждай нам нужно будет уже"
    },
    {
      "start": 468.19,
      "end": 471.57,
      "speaker": null,
      "text": "по сути согласовывать с монтажником дату"
    },
    {
      "start": 473.32,
      "end": 474.4,
      "speaker": null,
      "text": "монтажа и время."
    },
    {
      "start": 475.84,
      "end": 478.9,
      "speaker": null,
      "text": "То есть в целом у вас получится согласовать с клиентами."
    },
    {
      "start": 480.2,
      "end": 484.3,
      "speaker": null,
      "text": "А до какого часа вы работаете, чтобы я понимаю успею я сегодня или нет?"
    },
    {
      "start": 484.54,
      "end": 485.76,
      "speaker": null,
      "text": "До шести работаем."
    },
    {
      "start": 488.44,
      "end": 490.64,
      "speaker": null,
      "text": "Вероятно, но я очень сильно постараюсь."
    },
    {
      "start": 490.64,
      "end": 491.16,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 491.72,
      "end": 494.8,
      "speaker": null,
      "text": "И по поводу Купа, в общем-то смотрим на цены стандарта."
    },
    {
      "start": 496.36,
      "end": 498.94,
      "speaker": null,
      "text": "Сорок три сто – это две на три секции,"
    },
    {
      "start": 499.02,
      "end": 501.36,
      "speaker": null,
      "text": "пятьдесят один девятьсот – это три на три секция."
    },
    {
      "start": 501.84,
      "end": 503.22,
      "speaker": null,
      "text": "Давайте как с вами поступим?"
    },
    {
      "start": 503.42,
      "end": 505.76,
      "speaker": null,
      "text": "Вы же как рекламное агентство, я правильно понимаю?"
    },
    {
      "start": 506.62,
      "end": 506.94,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 506.94,
      "end": 510.09,
      "speaker": null,
      "text": "Вы могли бы, например, мне направить…"
    },
    {
      "start": 510.09,
      "end": 512.47,
      "speaker": null,
      "text": "Ну я вам на почту продублирую всю информацию."
    },
    {
      "start": 513.09,
      "end": 517.25,
      "speaker": null,
      "text": "А вы могли бы мне направить в ответ карточку вашей компании,"
    },
    {
      "start": 517.41,
      "end": 519.11,
      "speaker": null,
      "text": "с которой вы производите оплату,"
    },
    {
      "start": 519.19,
      "end": 521.91,
      "speaker": null,
      "text": "чтобы я смогла с руководством согласовать для вас скидку?"
    },
    {
      "start": 523.08,
      "end": 523.96,
      "speaker": null,
      "text": "Да, давайте."
    },
    {
      "start": 524.3,
      "end": 526.54,
      "speaker": null,
      "text": "Можно еще раз продублировать?"
    },
    {
      "start": 527.58,
      "end": 528.64,
      "speaker": null,
      "text": "Папа-папа меня пропустил,"
    },
    {
      "start": 529.38,
      "end": 530.14,
      "speaker": null,
      "text": "как вы уже сказали."
    },
    {
      "start": 530.9,
      "end": 532.42,
      "speaker": null,
      "text": "Сорок три и сколько ещё?"
    },
    {
      "start": 532.42,
      "end": 534.81,
      "speaker": null,
      "text": "Ну секунду, что я скажу вам."
    },
    {
      "start": 535.47,
      "end": 535.87,
      "speaker": null,
      "text": "Секунду."
    },
    {
      "start": 537.69,
      "end": 540.59,
      "speaker": null,
      "text": "Две на три секции – это сорок три сто."
    },
    {
      "start": 541.83,
      "end": 544.35,
      "speaker": null,
      "text": "Две на три секции – это пятьдесят один девятьсот."
    },
    {
      "start": 547.32,
      "end": 549.92,
      "speaker": null,
      "text": "Хорошо, напишите тогда на почту, пожалуйста, я вам скину."
    },
    {
      "start": 550.59,
      "end": 552.89,
      "speaker": null,
      "text": "Да, конечно, конечно, я напишу."
    },
    {
      "start": 553.11,
      "end": 555.25,
      "speaker": null,
      "text": "У нас получается почта, которая у меня есть,"
    },
    {
      "start": 557.11,
      "end": 559.29,
      "speaker": null,
      "text": "«Кумаковский собака-буха-буха»."
    },
    {
      "start": 559.52,
      "end": 560.46,
      "speaker": null,
      "text": "Все верно?"
    },
    {
      "start": 560.84,
      "end": 562.24,
      "speaker": null,
      "text": "Все супер, тогда договорились,"
    },
    {
      "start": 562.34,
      "end": 565.52,
      "speaker": null,
      "text": "что все продублирую вам и тогда будем на связи."
    },
    {
      "start": 566.0,
      "end": 567.48,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 567.6,
      "end": 568.96,
      "speaker": null,
      "text": "Да, да, всего доброго."
    },
    {
      "start": 569.4,
      "end": 570.24,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}