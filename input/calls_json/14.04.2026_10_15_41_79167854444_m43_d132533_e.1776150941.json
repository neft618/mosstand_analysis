{
  "file": "14.04.2026_10_15_41_79167854444_m43_d132533_e.1776150941.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 194.3,
  "segments": [
    {
      "start": 2.86,
      "end": 13.42,
      "speaker": null,
      "text": "Алло, Сергей. Доброе утро! Это Дмитрий и компания «Мостэнк». Подскажите, пожалуйста, вчера вам пресс-слов рассчитывал. Скажите, запрос актуален?"
    },
    {
      "start": 14.76,
      "end": 21.08,
      "speaker": null,
      "text": "Я отправил людям, просто мне некогда самому это делать, я поэтому думал, у вас могут сделать."
    },
    {
      "start": 22.03,
      "end": 23.61,
      "speaker": null,
      "text": "Так, ну мы можем сделать."
    },
    {
      "start": 24.85,
      "end": 26.43,
      "speaker": null,
      "text": "Дима, перезвонили вам, раденько тогда?"
    },
    {
      "start": 27.49,
      "end": 28.11,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 28.11,
      "end": 33.43,
      "speaker": null,
      "text": "А, Дим, а вы мне можете ещё две стоимости дать, если можно по телефону?"
    },
    {
      "start": 35.32,
      "end": 36.44,
      "speaker": null,
      "text": "Какие стоимости?"
    },
    {
      "start": 37.49,
      "end": 38.63,
      "speaker": null,
      "text": "Ну, на продукцию."
    },
    {
      "start": 39.41,
      "end": 40.79,
      "speaker": null,
      "text": "Ну, скажите какую, конечно."
    },
    {
      "start": 42.36,
      "end": 43.22,
      "speaker": null,
      "text": "Поп-ап."
    },
    {
      "start": 47.6,
      "end": 48.52,
      "speaker": null,
      "text": "Так, какой?"
    },
    {
      "start": 49.59,
      "end": 52.13,
      "speaker": null,
      "text": "Вот, значит, такой закруглённый, 4х3."
    },
    {
      "start": 56.14,
      "end": 56.7,
      "speaker": null,
      "text": "5х4..."
    },
    {
      "start": 56.7,
      "end": 57.78,
      "speaker": null,
      "text": "Сейчас, подождите."
    },
    {
      "start": 58.18,
      "end": 59.66,
      "speaker": null,
      "text": "4х3 секции, правильно?"
    },
    {
      "start": 59.96,
      "end": 60.5,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 61.56,
      "end": 62.38,
      "speaker": null,
      "text": "Так, 4х3."
    },
    {
      "start": 63.27,
      "end": 64.39,
      "speaker": null,
      "text": "С печатью."
    },
    {
      "start": 64.94,
      "end": 65.94,
      "speaker": null,
      "text": "4х3..."
    },
    {
      "start": 66.58,
      "end": 66.96,
      "speaker": null,
      "text": "64 800."
    },
    {
      "start": 67.63,
      "end": 68.05,
      "speaker": null,
      "text": "Как?"
    },
    {
      "start": 68.41,
      "end": 68.91,
      "speaker": null,
      "text": "64?"
    },
    {
      "start": 69.19,
      "end": 70.47,
      "speaker": null,
      "text": "64 800."
    },
    {
      "start": 70.99,
      "end": 73.71,
      "speaker": null,
      "text": "5х3, 78 300."
    },
    {
      "start": 75.82,
      "end": 76.2,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 76.86,
      "end": 78.92,
      "speaker": null,
      "text": "6х3, 93 800."
    },
    {
      "start": 79.89,
      "end": 81.15,
      "speaker": null,
      "text": "93 800."
    },
    {
      "start": 81.39,
      "end": 83.75,
      "speaker": null,
      "text": "Скажите, а вот в комплект что входит?"
    },
    {
      "start": 83.75,
      "end": 85.15,
      "speaker": null,
      "text": "Тумба туда входит?"
    },
    {
      "start": 85.35,
      "end": 85.85,
      "speaker": null,
      "text": "Тумба туда входит, пластиковая?"
    },
    {
      "start": 86.03,
      "end": 88.53,
      "speaker": null,
      "text": "Конструкция входит и печать фотопанели."
    },
    {
      "start": 88.63,
      "end": 90.25,
      "speaker": null,
      "text": "Тумба приобретается отдельно."
    },
    {
      "start": 90.87,
      "end": 92.75,
      "speaker": null,
      "text": "Кому-то она нужна, кому-то нет."
    },
    {
      "start": 92.97,
      "end": 98.81,
      "speaker": null,
      "text": "Всегда сумки, ну, сумки на колёсах, бокс-трибуны – это всё отдельно приобретается."
    },
    {
      "start": 99.88,
      "end": 101.88,
      "speaker": null,
      "text": "Бокс-трибуна нужна?"
    },
    {
      "start": 102.39,
      "end": 103.53,
      "speaker": null,
      "text": "Сказайте стоимость."
    },
    {
      "start": 103.53,
      "end": 105.37,
      "speaker": null,
      "text": "Ну, скажите бокс-трибуна."
    },
    {
      "start": 105.43,
      "end": 106.79,
      "speaker": null,
      "text": "А какой там размер бокс-трибуны?"
    },
    {
      "start": 107.8,
      "end": 109.56,
      "speaker": null,
      "text": "60, 95, 40."
    },
    {
      "start": 113.84,
      "end": 114.4,
      "speaker": null,
      "text": "65..."
    },
    {
      "start": 114.4,
      "end": 115.62,
      "speaker": null,
      "text": "На 40 см."
    },
    {
      "start": 116.69,
      "end": 119.31,
      "speaker": null,
      "text": "А 60 – это что такое у нас? 60 – это длина?"
    },
    {
      "start": 120.22,
      "end": 125.72,
      "speaker": null,
      "text": "60 – это длина, 40 – глубина, 95 – высота."
    },
    {
      "start": 127.06,
      "end": 129.06,
      "speaker": null,
      "text": "Так, сколько она такая трибуна стоит?"
    },
    {
      "start": 129.72,
      "end": 134.24,
      "speaker": null,
      "text": "Если голая, ну то есть без столешницы и фотопанели – 24 000."
    },
    {
      "start": 134.98,
      "end": 136.4,
      "speaker": null,
      "text": "Столешница – 6 000."
    },
    {
      "start": 136.64,
      "end": 138.74,
      "speaker": null,
      "text": "И печать фотопанели на неё – 4 500."
    },
    {
      "start": 139.73,
      "end": 140.85,
      "speaker": null,
      "text": "3-4 500."
    },
    {
      "start": 142.85,
      "end": 144.47,
      "speaker": null,
      "text": "Что буду на каком случае иметь ввиду?"
    },
    {
      "start": 145.67,
      "end": 148.75,
      "speaker": null,
      "text": "По срокам 2-3 рабочего дня с момента оплаты."
    },
    {
      "start": 148.83,
      "end": 150.39,
      "speaker": null,
      "text": "И не согласование макета."
    },
    {
      "start": 151.22,
      "end": 152.74,
      "speaker": null,
      "text": "А поп-ап тоже два преднят?"
    },
    {
      "start": 154.03,
      "end": 155.69,
      "speaker": null,
      "text": "Ну, поп-ап – да."
    },
    {
      "start": 155.69,
      "end": 157.43,
      "speaker": null,
      "text": "Ну, лучше три-четыре."
    },
    {
      "start": 158.44,
      "end": 159.24,
      "speaker": null,
      "text": "Три-четыре?"
    },
    {
      "start": 159.84,
      "end": 161.66,
      "speaker": null,
      "text": "Три-четыре дня на рабочих."
    },
    {
      "start": 162.22,
      "end": 163.06,
      "speaker": null,
      "text": "Спасибо, Дим."
    },
    {
      "start": 163.16,
      "end": 167.88,
      "speaker": null,
      "text": "Сейчас все пока что-то узнают, узнают, а до работы пока не заходит."
    },
    {
      "start": 168.28,
      "end": 170.4,
      "speaker": null,
      "text": "У всех одинаковая ситуация."
    },
    {
      "start": 171.08,
      "end": 171.68,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 172.2,
      "end": 172.72,
      "speaker": null,
      "text": "Жопа."
    },
    {
      "start": 178.97,
      "end": 180.51,
      "speaker": null,
      "text": "Называем своими словами."
    },
    {
      "start": 180.81,
      "end": 183.51,
      "speaker": null,
      "text": "Хорошо, что хоть по-русски не сказали, не по-латыни."
    },
    {
      "start": 185.59,
      "end": 186.71,
      "speaker": null,
      "text": "Ладно, всё."
    },
    {
      "start": 186.71,
      "end": 187.95,
      "speaker": null,
      "text": "Хорошего дня вам."
    },
    {
      "start": 188.41,
      "end": 190.91,
      "speaker": null,
      "text": "Спасибо вам за внимание, вам тоже хорошего дня."
    },
    {
      "start": 191.27,
      "end": 192.79,
      "speaker": null,
      "text": "Да, взаимно. До свидания."
    },
    {
      "start": 192.99,
      "end": 193.57,
      "speaker": null,
      "text": "Всего доброго."
    }
  ]
}