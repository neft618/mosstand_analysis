    {
      "start": 267.85,
      "end": 269.51,
      "speaker": null,
      "text": "А доставка и монтажом?"
    },
    {
      "start": 270.69,
      "end": 272.87,
      "speaker": null,
      "text": "Зависит от адреса и времени монтажа."
