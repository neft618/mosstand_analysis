  "segments": [
    {
      "start": 2.21,
      "end": 10.95,
      "speaker": null,
      "text": "Мария, здравствуйте. Меня зовут Ксения, компания Мастент. Вы оставили обратный звонок у нас на сайте. Подскажите, чем я могу вам помочь? Что вас заинтересовало?"
    },
    {
      "start": 12.44,
      "end": 15.46,
      "speaker": null,
      "text": "Здравствуйте. А можно контакт, чтобы я прислала ТЗС?"
    },
    {
      "start": 16.62,
      "end": 23.38,
      "speaker": null,
      "text": "Да, конечно. Если на этом номере у вас есть телеграмм, я могу вас найти. Вы можете мне выслать полную ТЗС."
    },
    {
      "start": 24.67,
      "end": 27.59,
      "speaker": null,
      "text": "Да, давайте. Телеграмм есть."
    },
    {
      "start": 27.72,
      "end": 41.57,
      "speaker": null,
      "text": "Да, сейчас секундочку я у вас найду. Так, так, так. Так, а я вас не могу найти в телеграмме? Может, вы тогда запишите мой номер?"
    },
    {
      "start": 43.96,
      "end": 44.9,
      "speaker": null,
      "text": "Давайте его."
    },
    {
      "start": 45.84,
      "end": 48.2,
      "speaker": null,
      "text": "Так, готовы записать?"
    },
    {
      "start": 49.96,
      "end": 50.32,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 51.22,
      "end": 53.02,
      "speaker": null,
      "text": "Плюс семь девятьсот тридцать один."
    },
    {
      "start": 55.05,
      "end": 55.35,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 56.16,
      "end": 57.08,
      "speaker": null,
      "text": "Сто одиннадцать."
    },
    {
      "start": 58.79,
      "end": 59.65,
      "speaker": null,
      "text": "Сто одиннадцать."
    },
    {
      "start": 60.37,
      "end": 61.73,
      "speaker": null,
      "text": "Сорок два пятнадцать."
    },
    {
      "start": 63.79,
      "end": 64.49,
      "speaker": null,
      "text": "Угу, хорошо."
    },
    {
      "start": 64.49,
      "end": 65.29,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 65.29,
      "end": 65.41,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 65.81,
      "end": 69.83,
      "speaker": null,
      "text": "Тогда можете направлять мне на телеграмм, там я буду записана как синему стенд."
    },
    {
      "start": 70.09,
      "end": 72.55,
      "speaker": null,
      "text": "А у вас там, я предполагаю, большое ТЗ, правильно?"
    },
    {
      "start": 74.62,
      "end": 77.86,
      "speaker": null,
      "text": "Ну, сама бумажка выглядит небольшой."
    },
    {
      "start": 78.48,
      "end": 78.96,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 78.96,
      "end": 81.54,
      "speaker": null,
      "text": "Мы уточняем по ориентировочной стоимости."
    },
    {
      "start": 83.02,
      "end": 83.3,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 83.46,
      "end": 83.86,
      "speaker": null,
      "text": "Поняла."
    },
    {
      "start": 84.02,
      "end": 84.62,
      "speaker": null,
      "text": "Есть ли какие-то строки?"
    },
    {
      "start": 84.62,
      "end": 85.96,
      "speaker": null,
      "text": "По опыту."
    },
    {
      "start": 87.9,
      "end": 90.46,
      "speaker": null,
      "text": "Ну, смотри, это где-то..."
    },
    {
      "start": 90.46,
      "end": 92.52,
      "speaker": null,
      "text": "Вот у нас конференция будет двадцатого июня."
    },
    {
      "start": 92.52,
      "end": 93.6,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 93.92,
      "end": 94.84,
      "speaker": null,
      "text": "Двадцатого июня?"
    },
    {
      "start": 96.38,
      "end": 96.68,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 97.2,
      "end": 97.56,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 97.84,
      "end": 98.94,
      "speaker": null,
      "text": "Так, поняла вас."
    },
    {
      "start": 99.69,
      "end": 100.25,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 100.83,
      "end": 102.01,
      "speaker": null,
      "text": "Сразу по срокам."
    },
    {
      "start": 103.66,
      "end": 103.94,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 104.92,
      "end": 109.72,
      "speaker": null,
      "text": "Значит получить вам надо ну примерно где-то восемнадцатого,"
    },
    {
      "start": 109.82,
      "end": 110.04,
      "speaker": null,
      "text": "правильно?"
    },
    {
      "start": 111.57,
      "end": 111.93,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 112.27,
      "end": 113.21,
      "speaker": null,
      "text": "Примерно так."
    },
    {
      "start": 113.7,
      "end": 114.28,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 114.8,
      "end": 115.04,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 115.3,
      "end": 115.68,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 115.9,
      "end": 117.2,
      "speaker": null,
      "text": "Получить восемнадцатый."
    },
    {
      "start": 117.48,
      "end": 118.2,
      "speaker": null,
      "text": "Всё отлично."
    },
    {
      "start": 118.3,
      "end": 119.36,
      "speaker": null,
      "text": "Давайте тогда высылайте."
    },
    {
      "start": 119.44,
      "end": 122.64,
      "speaker": null,
      "text": "Я посмотрю что из этого мы делаем."
    },
    {
      "start": 122.64,
      "end": 125.68,
      "speaker": null,
      "text": "предложу вам несколько альтернатив, если это потребуется"
    },
    {
      "start": 126.16,
      "end": 127.66,
      "speaker": null,
      "text": "в данном ТЗ."
    },
    {
      "start": 128.68,
      "end": 132.22,
      "speaker": null,
      "text": "И тогда вам ну как вы вышлете я сразу посмотрю, дам"
    },
    {
      "start": 132.22,
      "end": 135.92,
      "speaker": null,
      "text": "вам отливку что я забрала на расчет и тогда вам сегодня"
    },
    {
      "start": 136.22,
      "end": 136.98,
      "speaker": null,
      "text": "всё вышло."
    },
    {
      "start": 138.02,
      "end": 140.82,
      "speaker": null,
      "text": "Там сегодня-завтра зависимости от того что там."
    },
    {
      "start": 141.0,
      "end": 141.58,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 141.58,
      "end": 141.78,
      "speaker": null,
      "text": "Всё да."
    },
    {
      "start": 142.0,
      "end": 143.46,
      "speaker": null,
      "text": "Тогда ожидаю сегодня, правильно?"
    },
    {
      "start": 145.03,
