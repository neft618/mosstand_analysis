    {
      "start": 3.94,
      "end": 10.34,
      "speaker": null,
      "text": "Добрый день. Скажите, пожалуйста, я не знаю, вы как говорили с моей коллегой по поводу стенда?"
    },
    {
      "start": 11.64,
      "end": 14.56,
      "speaker": null,
      "text": "А как зовут вашу коллегу и какой у вас был вопрос?"
    },
    {
      "start": 14.84,
      "end": 21.66,
      "speaker": null,
      "text": "С возможностью сделать стенд 2 на 3, поп-ап с кармашками."
    },
    {
      "start": 22.58,
      "end": 25.78,
      "speaker": null,
      "text": "Да, вы общались с моим коллегой Владиславом."
    },
    {
      "start": 25.78,
      "end": 36.94,
      "speaker": null,
      "text": "Владислав, да. И возможно на него меня переключить, чтобы уточнить конкретную информацию по возможности сделать от кармашки."
    },
    {
      "start": 37.48,
      "end": 43.3,
      "speaker": null,
      "text": "Давайте буквально 2 минуты, я передам информацию, он перезвонит, просто она, к сожалению, в бизнес-центре интернет пропала,"
    },
    {
      "start": 43.9,
      "end": 49.34,
      "speaker": null,
      "text": "встреча проблема, поэтому переключить не совсем получится, но он вам сейчас перезвонит со своего рабочего телефона."
    },
    {
      "start": 49.96,
      "end": 51.68,
      "speaker": null,
      "text": "Хорошо, номер медико."
    },
    {
      "start": 51.8,
      "end": 52.6,
      "speaker": null,
      "text": "А как вас зовут?"
    },
    {
      "start": 53.28,
      "end": 53.92,
      "speaker": null,
      "text": "Саша."
    },
    {
      "start": 54.8,
      "end": 56.22,
      "speaker": null,
      "text": "Александр, очень приятно."
    },
    {
      "start": 60.21,
      "end": 61.35,
      "speaker": null,
      "text": "8-93."
    },
    {
      "start": 61.73,
      "end": 62.73,
      "speaker": null,
      "text": "Да, да, да, да."
    },
    {
      "start": 63.19,
      "end": 64.07,
      "speaker": null,
      "text": "Сейчас он вам перезвонит."
    },
    {
      "start": 64.45,
      "end": 65.75,
