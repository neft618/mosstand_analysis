{
  "file": "27.05.2026_16_15_35_74997024142_m21_d137687_2.1779887735.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 114.6,
  "segments": [
    {
      "start": 0.84,
      "end": 9.6,
      "speaker": null,
      "text": "Вы позвонили в компанию Лортекс ЭК. Если вы знаете внутренний номер нужного вам специалиста, наберите его в тоновом режиме или дождитесь ответа секретаря."
    },
    {
      "start": 38.13,
      "end": 39.27,
      "speaker": null,
      "text": "Лортекс ЭКО, здравствуйте."
    },
    {
      "start": 40.07,
      "end": 41.95,
      "speaker": null,
      "text": "А, Елена, здравствуйте. Торчем на стенд?"
    },
    {
      "start": 43.42,
      "end": 43.94,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 44.54,
      "end": 52.4,
      "speaker": null,
      "text": "А я же вот, вы мне направили письмо, на которое я вам уже ответил, прям точь-в-точь, то же самое направили, я вам на него уже ответил."
    },
    {
      "start": 52.52,
      "end": 55.32,
      "speaker": null,
      "text": "Ну там попросил директор размеры, он не понял."
    },
    {
      "start": 56.68,
      "end": 57.48,
      "speaker": null,
      "text": "Ну, смотрите..."
    },
    {
      "start": 57.48,
      "end": 60.3,
      "speaker": null,
      "text": "Я вам в зелёном там написала, да, размеры-то он не понял."
    },
    {
      "start": 60.3,
      "end": 64.48,
      "speaker": null,
      "text": "Да, я на ниже ответил, просто смотрю и на такое же письмо вы ответили."
    },
    {
      "start": 64.62,
      "end": 65.9,
      "speaker": null,
      "text": "Просто его кому-то ещё раз..."
    },
    {
      "start": 65.9,
      "end": 68.34,
      "speaker": null,
      "text": "Ага, да? А, тогда простите, простите."
    },
    {
      "start": 68.74,
      "end": 69.64,
      "speaker": null,
      "text": "Вы его просто..."
    },
    {
      "start": 69.64,
      "end": 75.46,
      "speaker": null,
      "text": "Да, но просто смотрите, я как вот писал Лорт, ну, вот он изначально два метра."
    },
    {
      "start": 76.0,
      "end": 78.86,
      "speaker": null,
      "text": "Его вообще лучше меньше делать по высоте, поверьте."
    },
    {
      "start": 79.4,
      "end": 80.38,
      "speaker": null,
      "text": "Потому что, смотрите..."
    },
    {
      "start": 80.38,
      "end": 81.78,
      "speaker": null,
      "text": "На высокие, он говорит."
    },
    {
      "start": 82.64,
      "end": 83.88,
      "speaker": null,
      "text": "Так это стандарт."
    },
    {
      "start": 83.88,
      "end": 87.06,
      "speaker": null,
      "text": "На каждой, на каждой выставке рулап стандарт два метра."
    },
    {
      "start": 87.06,
      "end": 87.12,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 87.42,
      "end": 90.56,
      "speaker": null,
      "text": "Скажу тогда, скажу, да-да-да, я сейчас просто информацию собираю."
    },
    {
      "start": 91.16,
      "end": 91.38,
      "speaker": null,
      "text": "Просто..."
    },
    {
      "start": 91.38,
      "end": 93.14,
      "speaker": null,
      "text": "Вы поймите правильно, вот так вот, вот смотрите."
    },
    {
      "start": 93.48,
      "end": 95.86,
      "speaker": null,
      "text": "Вот допустим мы вам сделали рулап по высотеем меньше."
    },
    {
      "start": 95.86,
      "end": 98.28,
      "speaker": null,
      "text": "То есть вот стангу мы вам подпилили."
    },
    {
      "start": 98.78,
      "end": 99.24,
      "speaker": null,
      "text": "Окей."
    },
    {
      "start": 99.42,
      "end": 102.28,
      "speaker": null,
      "text": "А вы на следующем мероприятии просите новый баннер напечатать,"
    },
    {
      "start": 102.64,
      "end": 104.04,
      "speaker": null,
      "text": "и он уже будет по высоте больше."
    },
    {
      "start": 104.46,
      "end": 105.54,
      "speaker": null,
      "text": "А у вас консульт..."
    },
    {
      "start": 105.54,
      "end": 106.4,
      "speaker": null,
      "text": "Ну, у меня вот сейчас..."
    },
    {
      "start": 106.4,
      "end": 108.68,
      "speaker": null,
      "text": "Артём, извините, у меня вторая линия."
    },
    {
      "start": 108.8,
      "end": 111.14,
      "speaker": null,
      "text": "Я вам тогда перезвоню или напишу."
    },
    {
      "start": 111.2,
      "end": 111.66,
      "speaker": null,
      "text": "Хорошо?"
    },
    {
      "start": 111.66,
      "end": 112.42,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 113.06,
      "end": 113.38,
      "speaker": null,
      "text": "Давай."
    },
    {
      "start": 113.94,
      "end": 114.56,
      "speaker": null,
      "text": "Да, а у вас."
    }
  ]
}