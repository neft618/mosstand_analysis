{
  "file": "22.04.2026_09_39_43_79214028957_m21_d133865_b.1776839984.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 142.0,
  "segments": [
    {
      "start": 1.34,
      "end": 3.84,
      "speaker": null,
      "text": "Компания «Алмазпром», Артём, как мы к вам обращаемся?"
    },
    {
      "start": 4.68,
      "end": 24.74,
      "speaker": null,
      "text": "Да, здравствуйте. Меня зовут Дина, компания «Алмазпром». Мы хотим участвовать в грузовских пропусах и нам нужен стенд, ну, грубо говоря, 20 слова из бруса, но нужно это всё построить, согласовать с организаторами и сделать электрику, то есть свет и розетки."
    },
    {
      "start": 25.22,
      "end": 28.5,
      "speaker": null,
      "text": "Так, подождите, а вы какую-то площадь уже закупили определённую, скажите?"
    },
    {
      "start": 28.5,
      "end": 31.4,
      "speaker": null,
      "text": "Да, конечно. 16 квадратных метров."
    },
    {
      "start": 31.56,
      "end": 34.16,
      "speaker": null,
      "text": "Так, мы это так на 16 квадратных метров закупили."
    },
    {
      "start": 35.36,
      "end": 36.36,
      "speaker": null,
      "text": "Так, а вы покупали?"
    },
    {
      "start": 36.4,
      "end": 42.7,
      "speaker": null,
      "text": "Мы хотим участвовать технические требования, которые мне обслуживало, вроде как они такие."
    },
    {
      "start": 43.32,
      "end": 47.6,
      "speaker": null,
      "text": "Я имею в виду помимо площади электричной какой-то закупали ещё?"
    },
    {
      "start": 48.22,
      "end": 50.44,
      "speaker": null,
      "text": "Конечно, у нас 10 киловатт подключено."
    },
    {
      "start": 50.76,
      "end": 52.02,
      "speaker": null,
      "text": "10 киловатт подключено, хорошо."
    },
    {
      "start": 52.6,
      "end": 57.18,
      "speaker": null,
      "text": "А стенды, вы берёте из бруса, то есть вам на один раз необходимо, не на несколько раз?"
    },
    {
      "start": 57.18,
      "end": 57.28,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 58.41,
      "end": 60.23,
      "speaker": null,
      "text": "Ну, насколько я понимаю…"
    },
    {
      "start": 60.23,
      "end": 61.81,
      "speaker": null,
      "text": "Ну, видите, в чём вопрос?"
    },
    {
      "start": 62.09,
      "end": 62.45,
      "speaker": null,
      "text": "Мы…"
    },
    {
      "start": 62.45,
      "end": 71.49,
      "speaker": null,
      "text": "Да, нам нужно на один раз, потому что мы каждый раз берём новые площади, поэтому, к сожалению, не угодно на постоянку."
    },
    {
      "start": 72.37,
      "end": 73.37,
      "speaker": null,
      "text": "Поэтому, да."
    },
    {
      "start": 74.42,
      "end": 77.5,
      "speaker": null,
      "text": "Просто, смотрите, у вас там даже аккредитация будет?"
    },
    {
      "start": 77.66,
      "end": 78.72,
      "speaker": null,
      "text": "Конечно, правильно я же понимаю?"
    },
    {
      "start": 79.56,
      "end": 79.9,
      "speaker": null,
      "text": "Конечно."
    },
    {
      "start": 80.3,
      "end": 81.28,
      "speaker": null,
      "text": "Вот я по этому вопросу."
    },
    {
      "start": 81.52,
      "end": 82.06,
      "speaker": null,
      "text": "Да, смотрите."
    },
    {
      "start": 82.68,
      "end": 89.72,
      "speaker": null,
      "text": "Просто как раз по аккредитации больше поделут ли мне брус от камеры стенды, на которых можно просто вам в дальнейшем менять печать."
    },
    {
      "start": 91.01,
      "end": 91.93,
      "speaker": null,
      "text": "Не, не в этом дело."
    },
    {
      "start": 92.09,
      "end": 95.59,
      "speaker": null,
      "text": "У меня проблема в том, что мне на стену нужно взвешивать инструменты."
    },
    {
      "start": 95.79,
      "end": 95.95,
      "speaker": null,
      "text": "Это диски…"
    },
    {
      "start": 97.42,
      "end": 98.68,
      "speaker": null,
      "text": "А, вот и расписано."
    },
    {
      "start": 98.84,
      "end": 98.96,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 98.96,
      "end": 99.06,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 99.6,
      "end": 102.88,
      "speaker": null,
      "text": "А, вот и расписано это всё по весу или нет?"
    },
    {
      "start": 102.88,
      "end": 103.18,
      "speaker": null,
      "text": "Конечно."
    },
    {
      "start": 104.02,
      "end": 104.48,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 104.68,
      "end": 107.1,
      "speaker": null,
      "text": "Так, в самом начале помехи были…"
    },
    {
      "start": 108.0,
      "end": 109.08,
      "speaker": null,
      "text": "Как вас зовут?"
    },
    {
      "start": 110.18,
      "end": 110.82,
      "speaker": null,
      "text": "Дина."
    },
    {
      "start": 110.82,
      "end": 111.78,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 111.96,
      "end": 115.82,
      "speaker": null,
      "text": "Давайте я пришлю вам тоже, вы посмотрите и уже…"
    },
    {
      "start": 116.58,
      "end": 119.36,
      "speaker": null,
      "text": "А номер телефона в каком у нас сейчас привязывается?"
    },
    {
      "start": 120.42,
      "end": 121.16,
      "speaker": null,
      "text": "Телеграмм Макс?"
    },
    {
      "start": 122.66,
      "end": 124.82,
      "speaker": null,
      "text": "Да, можно Максом конечно же."
    },
    {
      "start": 125.24,
      "end": 127.86,
      "speaker": null,
      "text": "Хорошо, давайте я напишу и потом дальнейшем получат вас связать."
    },
    {
      "start": 128.68,
      "end": 130.7,
      "speaker": null,
      "text": "А даты какие-то известны уже у вас?"
    },
    {
      "start": 131.69,
      "end": 133.77,
      "speaker": null,
      "text": "Давайте я вам всё пришлю, там всё есть."
    },
    {
      "start": 134.63,
      "end": 135.51,
      "speaker": null,
      "text": "Я всё написала."
    },
    {
      "start": 136.07,
      "end": 136.65,
      "speaker": null,
      "text": "Давай, да."
    },
    {
      "start": 137.85,
      "end": 139.21,
      "speaker": null,
      "text": "Да, спасибо большое."
    },
    {
      "start": 139.39,
      "end": 140.43,
      "speaker": null,
      "text": "Всё тогда на связи."
    },
    {
      "start": 140.59,
      "end": 141.23,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}