    {
      "start": 81.94,
      "end": 82.34,
      "speaker": null,
      "text": "Куда?"
    },
    {
      "start": 82.5,
      "end": 83.36,
      "speaker": null,
      "text": "Скажите, пожалуйста."
    },
    {
      "start": 83.7,
      "end": 83.84,
      "speaker": null,
      "text": "Куда?"
    },
    {
      "start": 85.1,
      "end": 87.9,
      "speaker": null,
      "text": "Морква-сиси, башня Ока, Crystal Ballroom."
