    {
      "start": 140.08,
      "end": 142.4,
      "speaker": null,
      "text": "А забрать потом это все дело?"
    },
    {
      "start": 142.62,
      "end": 143.58,
      "speaker": null,
      "text": "Сколько будет стоить?"
