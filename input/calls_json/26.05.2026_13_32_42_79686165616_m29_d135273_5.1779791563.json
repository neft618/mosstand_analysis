  "segments": [
    {
      "start": 1.22,
      "end": 1.66,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 2.1,
      "end": 4.34,
      "speaker": null,
      "text": "Дарья, здравствуйте ещё раз. Меня слышно?"
    },
    {
      "start": 4.94,
      "end": 5.88,
      "speaker": null,
      "text": "Да, слышно."
    },
    {
      "start": 6.24,
      "end": 14.04,
      "speaker": null,
      "text": "Всё, отлично. Это Ксения из мостенды. Я видела от вас пропущенную, просто тоже на звонках была, вот сразу вам перезвонила, как освободилась."
    },
    {
      "start": 14.22,
      "end": 22.62,
      "speaker": null,
      "text": "Я увидела ваш макет, он у дизайнера на проверке. Единственное, чуть она дольше будет отвечать, потому что, ну, в связи с загрузкой."
    },
    {
      "start": 23.14,
      "end": 26.48,
      "speaker": null,
      "text": "Так что так мы, ну, всё посмотрели, я вам сразу же вышла на проверку."
    },
    {
      "start": 27.73,
      "end": 32.09,
      "speaker": null,
      "text": "Я поняла, Ксения. Вы как понимаете, что мы не успеваем до 29-го числа?"
    },
    {
      "start": 34.42,
      "end": 35.22,
      "speaker": null,
      "text": "Успеваем, успеваем."
    },
    {
      "start": 35.74,
      "end": 36.6,
      "speaker": null,
      "text": "А, успеваем, да?"
    },
    {
      "start": 36.9,
      "end": 43.04,
      "speaker": null,
      "text": "Да, да, да. Я поэтому вам вчера и напомнила, что, ну, как бы либо в понедельник, либо максимум вторник нужно макетить."
    },
    {
      "start": 43.36,
      "end": 50.68,
      "speaker": null,
      "text": "Так что вы сегодня вышлили, выслали точнее это всё на проверке, я вам сразу перешлю, и можно будет уже изготавливать."
    },
    {
      "start": 51.5,
      "end": 53.12,
      "speaker": null,
      "text": "Ну, ещё всегда. А когда ещё будет?"
    },
    {
      "start": 53.12,
      "end": 57.2,
      "speaker": null,
      "text": "А, так, а вы мне, по-моему, не высылали реквизиты?"
    },
    {
      "start": 57.94,
      "end": 58.28,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 59.14,
      "end": 60.24,
      "speaker": null,
      "text": "Вот, тогда пришли."
    },
    {
      "start": 61.58,
      "end": 66.02,
      "speaker": null,
      "text": "Да, пришлите тогда, пожалуйста, реквизиты, я сразу всё тогда выставлю тоже."
    },
    {
      "start": 66.4,
      "end": 67.62,
      "speaker": null,
      "text": "Макеты пришли вам."
    },
    {
      "start": 68.26,
      "end": 68.62,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 69.38,
      "end": 70.46,
      "speaker": null,
      "text": "Да, супер, жду."
    },
    {
      "start": 70.46,
      "end": 71.89,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 72.09,
      "end": 73.25,
      "speaker": null,
      "text": "Угу, до свидания."
    },
    {
      "start": 73.63,
      "end": 73.67,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 73.69,
      "end": 73.71,
      "speaker": null,
      "text": "Тайний, грамм."
    },
    {
      "start": 73.77,
      "end": 73.81,
      "speaker": null,
      "text": "Поверято."
    }
  ]
}