  "segments": [
    {
      "start": 0.91,
      "end": 3.39,
      "speaker": null,
      "text": "Компания «Олстенд», Артём, кому к вам обращаться?"
    },
    {
      "start": 4.33,
      "end": 5.73,
      "speaker": null,
      "text": "Добрый день, Егор меня зовут."
    },
    {
      "start": 6.63,
      "end": 7.65,
      "speaker": null,
      "text": "Егор, какой вопрос у вас?"
    },
    {
      "start": 8.56,
      "end": 14.4,
      "speaker": null,
      "text": "Артём, а вот знамя хотим заказать хотя бы, узнать сколько будет стоить, как куда-то пилить там."
    },
    {
      "start": 15.12,
      "end": 18.3,
      "speaker": null,
      "text": "Так, вы имеете в виду флаг необходимый сделать? Вымпел или что именно?"
    },
    {
      "start": 19.3,
      "end": 20.6,
      "speaker": null,
      "text": "Нет, мы не знаем."
    },
    {
      "start": 21.98,
      "end": 25.86,
      "speaker": null,
      "text": "Так, каких размеров ткань необходимо, какую дату?"
    },
    {
      "start": 27.28,
      "end": 31.34,
      "speaker": null,
      "text": "Так, сейчас я скажу вам, сейчас его читать сразу."
    },
    {
      "start": 32.64,
      "end": 33.2,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 33.2,
      "end": 39.28,
      "speaker": null,
      "text": "Так, вот, ширина полотна 110, длина 130."
    },
    {
      "start": 40.33,
      "end": 40.57,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 40.73,
      "end": 45.83,
      "speaker": null,
      "text": "С запасом из ткани темно-крашного цвета для крепления к дереву."
    },
    {
      "start": 46.55,
      "end": 46.89,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 47.41,
      "end": 48.05,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 48.27,
      "end": 50.57,
      "speaker": null,
      "text": "Так, на какую дату и какой тираж?"
    },
    {
      "start": 51.81,
      "end": 52.79,
      "speaker": null,
      "text": "Ну, одно."
    },
    {
      "start": 53.19,
      "end": 54.65,
      "speaker": null,
      "text": "Там сумышка какая нам надо."
    },
    {
      "start": 54.75,
      "end": 56.21,
      "speaker": null,
      "text": "Куда скинуть эту информацию?"
    },
    {
      "start": 56.41,
      "end": 59.13,
      "speaker": null,
      "text": "А у вас номер телефона, скажите Егор, привязан к Телеграмму?"
    },
    {
      "start": 60.1,
      "end": 61.38,
      "speaker": null,
      "text": "Да, да, напишите мне."
    },
    {
      "start": 61.68,
      "end": 61.98,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 62.18,
      "end": 62.36,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 62.36,
      "end": 63.82,
      "speaker": null,
      "text": "Так, а дату?"
    },
    {
      "start": 64.1,
      "end": 66.78,
      "speaker": null,
      "text": "На какую дату необходимо, чтобы понимать дальнейшим по срокам?"
    },
    {
      "start": 66.78,
      "end": 67.42,
      "speaker": null,
      "text": "Потому что..."
    },
    {
      "start": 67.42,
      "end": 70.36,
      "speaker": null,
      "text": "Нам нужно знать ценник, какой будет для начала."
    },
    {
      "start": 71.4,
      "end": 71.68,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 72.24,
      "end": 72.48,
      "speaker": null,
      "text": "Хорошо, да."
    },
    {
      "start": 72.9,
      "end": 74.56,
      "speaker": null,
      "text": "Как получать у нас макеты есть все."
    },
    {
      "start": 74.98,
      "end": 76.5,
      "speaker": null,
      "text": "А какую сумму рассчитываете?"
    },
    {
      "start": 77.18,
      "end": 78.52,
      "speaker": null,
      "text": "Какой, то есть, ну, какой билет?"
    },
    {
      "start": 78.56,
      "end": 82.74,
      "speaker": null,
      "text": "Да вы скажите свою там, что будет, потом будем думать."
    },
    {
      "start": 83.16,
      "end": 83.94,
      "speaker": null,
      "text": "Ну, хорошо."
    },
    {
      "start": 84.48,
      "end": 84.54,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 84.54,
      "end": 86.0,
      "speaker": null,
      "text": "Я понимаю, вы ищите его."
    },
    {
      "start": 86.2,
      "end": 86.42,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 87.04,
      "end": 89.58,
      "speaker": null,
      "text": "Так, давайте сейчас пару минут запишусь вам туда и буду ждать"
    },
    {
      "start": 89.58,
      "end": 90.1,
      "speaker": null,
      "text": "у вас макеты."
    },
    {
      "start": 90.2,
      "end": 91.6,
      "speaker": null,
      "text": "Дальше мы сделаем расчет тогда."
    },
    {
      "start": 92.87,
      "end": 93.53,
      "speaker": null,
      "text": "Да, давайте."
    },
    {
      "start": 93.69,
      "end": 93.83,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 93.83,
      "end": 94.13,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 94.27,
      "end": 95.35,
      "speaker": null,
      "text": "Да, конечно, безусловно."
    },
    {
      "start": 95.85,
      "end": 96.37,
      "speaker": null,
      "text": "Угу."
    }
  ]
