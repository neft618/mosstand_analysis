{
  "file": "02.06.2026_16_27_16_79647841606_m31_d135407_d.1780406837.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 68.9,
  "segments": [
    {
      "start": 0.21,
      "end": 1.85,
      "speaker": null,
      "text": "Полина, здравствуйте ещё раз."
    },
    {
      "start": 1.91,
      "end": 6.81,
      "speaker": null,
      "text": "Да, прошу прощения, телефон в другой комнате был, я коробку разбирала."
    },
    {
      "start": 7.09,
      "end": 16.4,
      "speaker": null,
      "text": "Да, у нас такой вопрос возника, вот вы нам прислали с сайта взять логотип «Обилимпикс», а это разве не название выставки?"
    },
    {
      "start": 18.94,
      "end": 23.14,
      "speaker": null,
      "text": "Это одновременно и название, и…"
    },
    {
      "start": 23.23,
      "end": 25.87,
      "speaker": null,
      "text": "И он, этот логотип, он должен быть…"
    },
    {
      "start": 25.87,
      "end": 26.45,
      "speaker": null,
      "text": "И организатор."
    },
    {
      "start": 28.19,
      "end": 30.41,
      "speaker": null,
      "text": "И он должен быть у вас в дизайн-проекте?"
    },
    {
      "start": 31.74,
      "end": 32.7,
      "speaker": null,
      "text": "Да, желательно."
    },
    {
      "start": 33.3,
      "end": 34.8,
      "speaker": null,
      "text": "Всё, хорошо, тогда поняли."
    },
    {
      "start": 35.7,
      "end": 41.76,
      "speaker": null,
      "text": "Всё, а то просто мы подумали, что это название выставки и думаем, а нужно ли вообще туда этот логотип?"
    },
    {
      "start": 43.32,
      "end": 48.42,
      "speaker": null,
      "text": "Это организатор всё-таки предупредит на площадку, и они обилимпиксы мероприятия."
    },
    {
      "start": 48.42,
      "end": 50.22,
      "speaker": null,
      "text": "А, и они вот должны…"
    },
    {
      "start": 50.22,
      "end": 50.36,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 50.36,
      "end": 56.5,
      "speaker": null,
      "text": "И то есть, получается, компании, которые заходят на площадку, должны включить в свои дизайны этот логотип, да?"
    },
    {
      "start": 56.8,
      "end": 59.34,
      "speaker": null,
      "text": "Ну, мы думаем, так как мы партнёры, да."
    },
    {
      "start": 59.76,
      "end": 60.54,
      "speaker": null,
      "text": "Угу, угу."
    },
    {
      "start": 60.74,
      "end": 62.64,
      "speaker": null,
      "text": "Всё, поняла, хорошо, услышала."
    },
    {
      "start": 62.94,
      "end": 64.14,
      "speaker": null,
      "text": "Тогда да, всего доброго."
    },
    {
      "start": 64.28,
      "end": 64.86,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 65.58,
      "end": 66.38,
      "speaker": null,
      "text": "Да, спасибо вам."
    },
    {
      "start": 66.44,
      "end": 66.88,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}