{
  "file": "14.04.2026_16_28_31_79958917019_m49_d131717_d.1776173312.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 374.1,
  "segments": [
    {
      "start": 0.78,
      "end": 2.02,
      "speaker": null,
      "text": "Дарья, здравствуйте."
    },
    {
      "start": 2.77,
      "end": 3.45,
      "speaker": null,
      "text": "Здравствуйте."
    },
    {
      "start": 4.07,
      "end": 14.11,
      "speaker": null,
      "text": "Скажите, пожалуйста, вот у меня вопрос по промостойке ресепшену нашему МС-4. Скажите, пожалуйста, два промостола стыкаются вместе или это невозможно?"
    },
    {
      "start": 16.26,
      "end": 18.0,
      "speaker": null,
      "text": "Нет, они не стыкуются, Дарья."
    },
    {
      "start": 18.6,
      "end": 25.82,
      "speaker": null,
      "text": "А есть ли такой стол, но большой? Вот у вас есть, например, Фон Бэд официальный партнёр, он такой длинный прямо здесь."
    },
    {
      "start": 26.36,
      "end": 29.64,
      "speaker": null,
      "text": "Секундочку, я посмотрю, что вы видите в примерах."
    },
    {
      "start": 29.64,
      "end": 56.6,
      "speaker": null,
      "text": "Я вот в примерах работ, но почему-то у меня только пять фотографий загружается и последняя Гастром."
    },
    {
      "start": 57.02,
      "end": 59.92,
      "speaker": null,
      "text": "А вы где в примерах работ увидели Фон Бэд?"
    },
    {
      "start": 59.92,
      "end": 65.0,
      "speaker": null,
      "text": "У нас вообще нету Гастрома, у нас промостойкий пример работ, который мы производим."
    },
    {
      "start": 65.9,
      "end": 73.82,
      "speaker": null,
      "text": "Вы тогда, наверное, это разные браузеры. Сейчас секунду попробую с телефона зайти, секунду посмотрю другого браузера."
    },
    {
      "start": 73.82,
      "end": 75.98,
      "speaker": null,
      "text": "Из компьютера тоже."
    },
    {
      "start": 77.08,
      "end": 77.92,
      "speaker": null,
      "text": "Из компьютера?"
    },
    {
      "start": 78.4,
      "end": 78.74,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 80.71,
      "end": 84.51,
      "speaker": null,
      "text": "Промостойка МС-4 или МС-4 текстиль?"
    },
    {
      "start": 84.89,
      "end": 85.61,
      "speaker": null,
      "text": "Текстиль."
    },
    {
      "start": 85.61,
      "end": 87.51,
      "speaker": null,
      "text": "А, текстиль, секунду."
    },
    {
      "start": 88.47,
      "end": 88.63,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 94.88,
      "end": 101.66,
      "speaker": null,
      "text": "Фон Бэд – это вы просто выбираете трёх… ну, её можно же сделать, она состоится в секции."
    },
    {
      "start": 101.66,
      "end": 104.66,
      "speaker": null,
      "text": "Её можно такую длинную сделать, да, конечно."
    },
    {
      "start": 105.74,
      "end": 109.74,
      "speaker": null,
      "text": "Так, а то получается можно единую сделать из двух секций, правильно?"
    },
    {
      "start": 112.29,
      "end": 117.95,
      "speaker": null,
      "text": "Одна секция – это вот как рядом химат, да? Вот эта одна секция…"
    },
    {
      "start": 118.75,
      "end": 119.71,
      "speaker": null,
      "text": "Получается их…"
    },
    {
      "start": 119.71,
      "end": 120.45,
      "speaker": null,
      "text": "А, то есть это четыре?"
    },
    {
      "start": 120.47,
      "end": 121.35,
      "speaker": null,
      "text": "Она 60."
    },
    {
      "start": 121.59,
      "end": 123.45,
      "speaker": null,
      "text": "Она либо три, либо четыре секции."
    },
    {
      "start": 123.55,
      "end": 124.43,
      "speaker": null,
      "text": "Да, четыре, да."
    },
    {
      "start": 124.77,
      "end": 125.05,
      "speaker": null,
      "text": "Вы правы."
    },
    {
      "start": 125.21,
      "end": 127.01,
      "speaker": null,
      "text": "Она четыре секции."
    },
    {
      "start": 127.27,
      "end": 127.39,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 127.39,
      "end": 131.47,
      "speaker": null,
      "text": "То есть вот вторая стойка, второй визуал – это две секции?"
    },
    {
      "start": 131.97,
      "end": 132.51,
      "speaker": null,
      "text": "Там где без…"
    },
    {
      "start": 132.51,
      "end": 132.99,
      "speaker": null,
      "text": "Травмон."
    },
    {
      "start": 133.33,
      "end": 136.31,
      "speaker": null,
      "text": "Травмон, спорт, норма жизни – да, это две секции."
    },
    {
      "start": 136.61,
      "end": 136.69,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 138.0,
      "end": 138.38,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 138.72,
      "end": 141.86,
      "speaker": null,
      "text": "А подскажите, пожалуйста, эти стойки вообще неустойчивые?"
    },
    {
      "start": 143.56,
      "end": 144.08,
      "speaker": null,
      "text": "Ветроустойчивые?"
    },
    {
      "start": 144.08,
      "end": 145.64,
      "speaker": null,
      "text": "Как они вообще…"
    },
    {
      "start": 145.64,
      "end": 147.04,
      "speaker": null,
      "text": "Вы хотите их на улице?"
    },
    {
      "start": 147.46,
      "end": 147.76,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 148.94,
      "end": 152.98,
      "speaker": null,
      "text": "Ну, вообще всё мобильное оборудование, оно особо не предназначено для"
    },
    {
      "start": 152.98,
      "end": 153.48,
      "speaker": null,
      "text": "улицы."
    },
    {
      "start": 153.98,
      "end": 160.28,
      "speaker": null,
      "text": "Но если там ровный пол и, например, вы сможете внутрь"
    },
    {
      "start": 160.28,
      "end": 165.92,
      "speaker": null,
      "text": "положить какие-то утяжелители, ну, например, да, то почему"
    },
    {
      "start": 165.92,
      "end": 166.2,
      "speaker": null,
      "text": "нет?"
    },
    {
      "start": 166.38,
      "end": 169.56,
      "speaker": null,
      "text": "То есть вполне себе… Просто ни одно мобильное оборудование,"
    },
    {
      "start": 169.58,
      "end": 171.44,
      "speaker": null,
      "text": "оно особо для улицы не предназначено."
    },
    {
      "start": 171.44,
      "end": 175.54,
      "speaker": null,
      "text": "Там уже когда приспосабливается, внутрь можно положить какие-то"
    },
    {
      "start": 175.54,
      "end": 176.04,
      "speaker": null,
      "text": "утяжелители."
    },
    {
      "start": 176.18,
      "end": 180.16,
      "speaker": null,
      "text": "То есть там есть полка внутри, можно чем-то утяжелить."
    },
    {
      "start": 181.51,
      "end": 181.83,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 183.52,
      "end": 184.42,
      "speaker": null,
      "text": "Я поняла."
    },
    {
      "start": 184.84,
      "end": 192.94,
      "speaker": null,
      "text": "А подскажите, пожалуйста, какие-нибудь есть у вас такие"
    },
    {
      "start": 192.94,
      "end": 195.38,
      "speaker": null,
      "text": "ресершн, которые всё-таки можно использовать на улице"
    },
    {
      "start": 195.38,
      "end": 197.98,
      "speaker": null,
      "text": "с минимизированными рисками?"
    },
    {
      "start": 199.96,
      "end": 203.18,
      "speaker": null,
      "text": "Если вам нужен сборно-разборный…"
    },
    {
      "start": 203.18,
      "end": 203.48,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 203.48,
      "end": 208.58,
      "speaker": null,
      "text": "То таких вариантов… Ну, они все одинаковые."
    },
    {
      "start": 209.26,
      "end": 211.56,
      "speaker": null,
      "text": "Они все плюс-минус одинаковые."
    },
    {
      "start": 211.6,
      "end": 217.5,
      "speaker": null,
      "text": "То есть это либо зонтичного типа, либо это какие-то пластиковые"
    },
    {
      "start": 217.5,
      "end": 218.52,
      "speaker": null,
      "text": "разборные промостойки."
    },
    {
      "start": 219.16,
      "end": 220.82,
      "speaker": null,
      "text": "Но это всё плюс-минус одинаковое."
    },
    {
      "start": 221.02,
      "end": 223.32,
      "speaker": null,
      "text": "То есть нет такого, что вот эта стойка, допустим,"
    },
    {
      "start": 223.42,
      "end": 224.28,
      "speaker": null,
      "text": "она уличная."
    },
    {
      "start": 224.62,
      "end": 224.7,
      "speaker": null,
      "text": "Да?"
    },
    {
      "start": 224.7,
      "end": 225.46,
      "speaker": null,
      "text": "Такого нет."
    },
    {
      "start": 225.62,
      "end": 225.9,
      "speaker": null,
      "text": "Ну, да."
    },
    {
      "start": 226.4,
      "end": 227.92,
      "speaker": null,
      "text": "Но она срочная?"
    },
    {
      "start": 229.32,
      "end": 229.78,
      "speaker": null,
      "text": "Ну, да."
    },
    {
      "start": 230.32,
      "end": 230.42,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 230.74,
      "end": 231.62,
      "speaker": null,
      "text": "Ну, это алюминий."
    },
    {
      "start": 231.94,
      "end": 233.22,
      "speaker": null,
      "text": "Каркас из алюминия."
    },
    {
      "start": 235.24,
      "end": 239.16,
      "speaker": null,
      "text": "Это не как поп-ап, он не складывается при…"
    },
    {
      "start": 239.16,
      "end": 241.02,
      "speaker": null,
      "text": "Ну, потому что вот у нас, например, поп-ап сел на"
    },
    {
      "start": 241.02,
      "end": 242.56,
      "speaker": null,
      "text": "улице и он просто складывается."
    },
    {
      "start": 242.56,
      "end": 244.52,
      "speaker": null,
      "text": "Ну, а смотрите, почему…"
    },
    {
      "start": 244.52,
      "end": 245.4,
      "speaker": null,
      "text": "Это зонтичный тип."
    },
    {
      "start": 245.74,
      "end": 249.56,
      "speaker": null,
      "text": "Вот в примерах фотографии есть каркас."
    },
    {
      "start": 249.56,
      "end": 250.82,
      "speaker": null,
      "text": "Да, вижу."
    },
    {
      "start": 251.14,
      "end": 255.92,
      "speaker": null,
      "text": "Ну, по фотографии не всегда понятно, какой у него конструктив"
    },
    {
      "start": 255.92,
      "end": 257.22,
      "speaker": null,
      "text": "и насколько он хлипкий."
    },
    {
      "start": 259.38,
      "end": 263.52,
      "speaker": null,
      "text": "Ну, просто вы говорите, некоторые и поп-апы ставят на улице,"
    },
    {
      "start": 263.78,
      "end": 264.26,
      "speaker": null,
      "text": "понимаете?"
    },
    {
      "start": 264.36,
      "end": 267.58,
      "speaker": null,
      "text": "Поэтому тут вот я не очень могу понять, какой у вас"
    },
    {
      "start": 267.58,
      "end": 268.18,
      "speaker": null,
      "text": "был поп-ап."
    },
    {
      "start": 268.36,
      "end": 272.04,
      "speaker": null,
      "text": "Ну, по идее это… Я не могу сказать, что она выдержит"
    },
    {
      "start": 272.04,
      "end": 273.72,
      "speaker": null,
      "text": "какой-то ураган."
    },
    {
      "start": 274.16,
      "end": 275.5,
      "speaker": null,
      "text": "Никто не выдержит урагана."
    },
    {
      "start": 275.6,
      "end": 277.3,
      "speaker": null,
      "text": "Ну, конечно, мне не говорили про это, нет."
    },
    {
      "start": 277.3,
      "end": 278.1,
      "speaker": null,
      "text": "Да, но если…"
    },
    {
      "start": 278.1,
      "end": 279.94,
      "speaker": null,
      "text": "Ну, как бы вопрос стойкости."
    },
    {
      "start": 281.12,
      "end": 283.64,
      "speaker": null,
      "text": "На ровной поверхности все станет хорошо."
    },
    {
      "start": 283.98,
      "end": 287.68,
      "speaker": null,
      "text": "То есть она приспособлена для ровной поверхности."
    },
    {
      "start": 288.48,
      "end": 291.5,
      "speaker": null,
      "text": "А какой вес она может выдержать?"
    },
    {
      "start": 291.6,
      "end": 293.26,
      "speaker": null,
      "text": "Ну, вот просто у нее там есть полка."
    },
    {
      "start": 293.54,
      "end": 295.4,
      "speaker": null,
      "text": "Вот полки рассчитаны на какой вес?"
    },
    {
      "start": 295.95,
      "end": 298.33,
      "speaker": null,
      "text": "Я думаю, что 15-20 кг точно."
    },
    {
      "start": 299.42,
      "end": 302.34,
      "speaker": null,
      "text": "А если не так, как вы думаете, а точно?"
    },
    {
      "start": 305.23,
      "end": 310.03,
      "speaker": null,
      "text": "Ну, она выдержит менее 15 кг, может быть даже больше."
    },
    {
      "start": 310.43,
      "end": 312.83,
      "speaker": null,
      "text": "15-20 кг точно она выдержит."
    },
    {
      "start": 316.61,
      "end": 317.75,
      "speaker": null,
      "text": "Это минимум."
    },
    {
      "start": 318.9,
      "end": 320.1,
      "speaker": null,
      "text": "Я поняла."
    },
    {
      "start": 321.04,
      "end": 324.2,
      "speaker": null,
      "text": "Ну, то есть они вот выдерживают, не сгибаются и плотно стоят"
    },
    {
      "start": 324.2,
      "end": 325.14,
      "speaker": null,
      "text": "при таком весе?"
    },
    {
      "start": 325.68,
      "end": 326.02,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 327.18,
      "end": 327.82,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 327.96,
      "end": 328.42,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 329.24,
      "end": 332.06,
      "speaker": null,
      "text": "И, соответственно, можно произвести вот такие 4 секции"
    },
    {
      "start": 332.06,
      "end": 334.32,
      "speaker": null,
      "text": "и сделать на него вот такой же стильный чехол."
    },
    {
      "start": 334.64,
      "end": 337.4,
      "speaker": null,
      "text": "А вы можете подсказать, сколько это будет стоить?"
    },
    {
      "start": 340.5,
      "end": 344.98,
      "speaker": null,
      "text": "Это получается двойная стойка макси."
    },
    {
      "start": 345.06,
      "end": 346.62,
      "speaker": null,
      "text": "82 400."
    },
    {
      "start": 357.85,
      "end": 359.31,
      "speaker": null,
      "text": "Ага, да, все, я поняла."
    },
    {
      "start": 359.51,
      "end": 359.91,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 361.1,
      "end": 361.92,
      "speaker": null,
      "text": "Благодарю."
    },
    {
      "start": 362.1,
      "end": 363.6,
      "speaker": null,
      "text": "А какие сроки производства?"
    },
    {
      "start": 365.34,
      "end": 367.12,
      "speaker": null,
      "text": "4-5 рабочих дней."
    },
    {
      "start": 369.0,
      "end": 370.39,
      "speaker": null,
      "text": "Поняла, спасибо."
    },
    {
      "start": 370.87,
      "end": 371.83,
      "speaker": null,
      "text": "Да, Дарья, конечно."
    },
    {
      "start": 372.29,
      "end": 372.69,
      "speaker": null,
      "text": "Благодарю."
    },
    {
      "start": 372.75,
      "end": 372.89,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 372.89,
      "end": 372.99,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 373.21,
      "end": 373.39,
      "speaker": null,
      "text": "Ага."
    }
  ]
}