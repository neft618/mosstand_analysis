  "segments": [
    {
      "start": 0.4,
      "end": 1.4,
      "speaker": null,
      "text": "Алло, добрый день."
    },
    {
      "start": 1.94,
      "end": 6.9,
      "speaker": null,
      "text": "Александр, здравствуйте, Артём из компании Мосстенд. С вами разговаривает Луда Флагов в Габардине."
    },
    {
      "start": 7.58,
      "end": 12.16,
      "speaker": null,
      "text": "Вам в Телеграмме никак не написать, у вас доступ закрыт, если там..."
    },
    {
      "start": 12.51,
      "end": 14.37,
      "speaker": null,
      "text": "А вы на какой номер?"
    },
    {
      "start": 15.67,
      "end": 17.77,
      "speaker": null,
      "text": "С которого сейчас звонили, 2755."
    },
    {
      "start": 20.19,
      "end": 22.91,
      "speaker": null,
      "text": "Ну, 927-5725, да?"
    },
    {
      "start": 24.26,
      "end": 29.08,
      "speaker": null,
      "text": "У нас только один номер, если не засвечен, 525-507-2755."
    },
    {
      "start": 29.08,
      "end": 32.85,
      "speaker": null,
      "text": "Да, там есть Телеграмм. Странно, что он недоступен."
    },
    {
      "start": 33.35,
      "end": 35.07,
      "speaker": null,
      "text": "У вас, скорее всего, доступ закрыт."
    },
    {
      "start": 35.27,
      "end": 36.17,
      "speaker": null,
      "text": "А есть почта?"
    },
    {
      "start": 37.25,
      "end": 39.01,
      "speaker": null,
      "text": "Да, запишите мою почту."
    },
    {
      "start": 40.19,
      "end": 41.39,
      "speaker": null,
      "text": "Давайте я запишу..."
    },
    {
      "start": 42.23,
      "end": 43.17,
      "speaker": null,
      "text": "Английские буквы?"
    },
    {
      "start": 43.47,
      "end": 43.53,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 58.77,
      "end": 59.71,
      "speaker": null,
      "text": "Какая-то английская?"
    },
    {
      "start": 60.27,
      "end": 65.79,
      "speaker": null,
      "text": "Да, английскими буквами первая А, ну, первая буква это А, и последняя буква З, АЗ."
    },
    {
      "start": 68.68,
      "end": 69.8,
      "speaker": null,
      "text": "Собакамостэн.ру"
    },
    {
      "start": 71.0,
      "end": 72.64,
      "speaker": null,
      "text": "Мостэн две буквы S, как доллар."
    },
    {
      "start": 76.44,
      "end": 77.56,
      "speaker": null,
      "text": "Мостэн точка ру"
    },
    {
      "start": 77.56,
      "end": 78.42,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 78.86,
      "end": 80.58,
      "speaker": null,
      "text": "Мостэн н д точка ру"
    },
    {
      "start": 80.58,
      "end": 82.56,
      "speaker": null,
      "text": "Да-да-да, так и написал."
    },
    {
      "start": 83.32,
      "end": 84.98,
      "speaker": null,
      "text": "Напишите, я потом все напоминаю..."
    },
    {
      "start": 84.98,
      "end": 87.3,
      "speaker": null,
      "text": "Как пишет язык, как пишет язык, я запишу на сцене из тебя."
    },
    {
      "start": 87.8,
      "end": 88.74,
      "speaker": null,
      "text": "Хорошо, давайте."
    },
    {
      "start": 89.5,
      "end": 90.14,
      "speaker": null,
      "text": "Ага, спасибо."
    },
    {
      "start": 90.34,
      "end": 90.62,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
