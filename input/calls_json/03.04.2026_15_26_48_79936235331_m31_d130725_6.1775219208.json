  "segments": [
    {
      "start": 0.27,
      "end": 5.93,
      "speaker": null,
      "text": "Здравствуйте, Анастасия. Это Валерий Мастенд. Мы с вами общались по почте по поводу флагштоков."
    },
    {
      "start": 7.43,
      "end": 8.53,
      "speaker": null,
      "text": "Да, добрый день."
    },
    {
      "start": 10.74,
      "end": 17.04,
      "speaker": null,
      "text": "Да, вот хотелось бы просто уточнить, я направляла к СП и хотела узнать, вообще проходим ли мы по бюджету."
    },
    {
      "start": 18.19,
      "end": 22.25,
      "speaker": null,
      "text": "Сейчас я посмотрю минутку, естественно, потому что не помню."
    },
    {
      "start": 25.83,
      "end": 29.39,
      "speaker": null,
      "text": "Ну, по-моему нет, по-моему нет."
    },
    {
      "start": 37.04,
      "end": 42.44,
      "speaker": null,
      "text": "Нет, у вас очень, прям очень высокая цена, нам в три раза дешевле даёт."
    },
    {
      "start": 43.6,
      "end": 48.42,
      "speaker": null,
      "text": "То есть вам за, ну, около там получается там 20-30?"
    },
    {
      "start": 48.82,
      "end": 50.18,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 51.22,
      "end": 54.04,
      "speaker": null,
      "text": "Всё, я вас услышала и так же вместе с выставкой, правильно?"
    },
    {
      "start": 54.48,
      "end": 55.06,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 56.43,
      "end": 58.17,
      "speaker": null,
      "text": "Хорошо, тогда я вас поняла."
    },
    {
      "start": 59.71,
      "end": 60.89,
      "speaker": null,
      "text": "Спасибо вам большое, Мария."
    },
    {
      "start": 60.89,
      "end": 62.69,
      "speaker": null,
      "text": "Всего доброго, до свидания."
    }
  ]
}