{
  "file": "13.05.2026_10_51_52_74953665566_m49_d135933_2.1778658712.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 238.6,
  "segments": [
    {
      "start": 2.19,
      "end": 4.45,
      "speaker": null,
      "text": "Елена, здравствуйте. Компания МОТЭНК."
    },
    {
      "start": 5.96,
      "end": 16.58,
      "speaker": null,
      "text": "Елена, здравствуйте. Меня зовут Светлана. Я представляю компанию АОНПП Пульсар. Мы бы хотели заказать у вас один пресс-вол с баннером и мне нужна консультация."
    },
    {
      "start": 17.26,
      "end": 27.82,
      "speaker": null,
      "text": "Если рассматривать пресс-вол типа М, там же можно баннер натянуть за конструкцию, чтобы не было видно элементов? Или он не предполагает такое?"
    },
    {
      "start": 29.26,
      "end": 33.24,
      "speaker": null,
      "text": "Это тогда вам нужно рассматривать пресс-вол тип Л."
    },
    {
      "start": 34.18,
      "end": 35.03,
      "speaker": null,
      "text": "То есть, вот..."
    },
    {
      "start": 36.36,
      "end": 46.9,
      "speaker": null,
      "text": "Смотрю работ, и вот в типе М я увидела то, что там как будто был натянут чуть назад и скрывает слайд."
    },
    {
      "start": 47.35,
      "end": 50.71,
      "speaker": null,
      "text": "Секундочку, сейчас посмотрю, что вы имеете в виду."
    },
    {
      "start": 50.71,
      "end": 55.81,
      "speaker": null,
      "text": "Тип М вообще, может быть какая-то фотография некорректно попала."
    },
    {
      "start": 56.41,
      "end": 59.65,
      "speaker": null,
      "text": "Но тип М это открытый..."
    },
    {
      "start": 59.65,
      "end": 66.01,
      "speaker": null,
      "text": "То есть, это пресс-вол и баннер с открытой конструкцией."
    },
    {
      "start": 66.63,
      "end": 68.91,
      "speaker": null,
      "text": "Сейчас я смотрю, какую фотографию не могли видеть."
    },
    {
      "start": 69.07,
      "end": 70.71,
      "speaker": null,
      "text": "А как называется? Скажите."
    },
    {
      "start": 70.71,
      "end": 76.88,
      "speaker": null,
      "text": "Ну вот первое, что присоединяется в глаза, Московский государственный университет."
    },
    {
      "start": 77.06,
      "end": 79.02,
      "speaker": null,
      "text": "Вот немножко баннер заходит назад."
    },
    {
      "start": 80.19,
      "end": 82.59,
      "speaker": null,
      "text": "Потом далее Тундра Фёдорова."
    },
    {
      "start": 82.75,
      "end": 86.65,
      "speaker": null,
      "text": "А, ну здесь, да, здесь все получаются работы."
    },
    {
      "start": 87.15,
      "end": 90.15,
      "speaker": null,
      "text": "Фёдорова это тип Л закрытый."
    },
    {
      "start": 90.95,
      "end": 92.27,
      "speaker": null,
      "text": "Рядом это..."
    },
    {
      "start": 92.27,
      "end": 92.69,
      "speaker": null,
      "text": "А-а-а, здесь на фото."
    },
    {
      "start": 93.39,
      "end": 93.95,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 94.35,
      "end": 95.19,
      "speaker": null,
      "text": "Здесь не только."
    },
    {
      "start": 95.47,
      "end": 96.41,
      "speaker": null,
      "text": "День рождения."
    },
    {
      "start": 96.69,
      "end": 97.87,
      "speaker": null,
      "text": "Это все тип Л."
    },
    {
      "start": 98.09,
      "end": 99.75,
      "speaker": null,
      "text": "М это открытый."
    },
    {
      "start": 100.01,
      "end": 102.11,
      "speaker": null,
      "text": "То есть, если вам нужен закрытый просвол,"
    },
    {
      "start": 102.51,
      "end": 104.07,
      "speaker": null,
      "text": "то это тогда тип Л."
    },
    {
      "start": 105.26,
      "end": 111.38,
      "speaker": null,
      "text": "Там будет двойная труба и баннер сочетается в большем размере специально."
    },
    {
      "start": 112.0,
      "end": 114.66,
      "speaker": null,
      "text": "А что происходит разработка макета?"
    },
    {
      "start": 114.66,
      "end": 119.63,
      "speaker": null,
      "text": "Ну, зависимости от сложности в районе двух-трех тысяч."
    },
    {
      "start": 120.09,
      "end": 123.61,
      "speaker": null,
      "text": "Но точно смогу сказать после того, как получим у тебя материалы."
    },
    {
      "start": 123.87,
      "end": 127.17,
      "speaker": null,
      "text": "То есть, вектора, тексты, картинки."
    },
    {
      "start": 127.57,
      "end": 131.71,
      "speaker": null,
      "text": "У нас, да, у нас есть своего рода наброски."
    },
    {
      "start": 132.45,
      "end": 137.23,
      "speaker": null,
      "text": "Давайте тогда я вам пришлю на почту, чтобы вы сделали расчет."
    },
    {
      "start": 137.39,
      "end": 142.17,
      "speaker": null,
      "text": "И еще меня интересует, если просто мы приедем и заберем сами."
    },
    {
      "start": 142.17,
      "end": 144.11,
      "speaker": null,
      "text": "И тут уже наши рабочие сами его соберут."
    },
    {
      "start": 144.29,
      "end": 146.81,
      "speaker": null,
      "text": "То есть, монтаж, доставка не потребуется."
    },
    {
      "start": 147.11,
      "end": 147.77,
      "speaker": null,
      "text": "Так можно сделать?"
    },
    {
      "start": 148.37,
      "end": 151.89,
      "speaker": null,
      "text": "Можно, если вы уверены в ваших работниках."
    },
    {
      "start": 152.07,
      "end": 152.47,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 154.79,
      "end": 159.01,
      "speaker": null,
      "text": "Хорошо, я тогда на почту напишу сейчас."
    },
    {
      "start": 159.79,
      "end": 164.75,
      "speaker": null,
      "text": "Прикреплю файл, в котором можно понять наш дизайн своего рода."
    },
    {
      "start": 164.95,
      "end": 166.81,
      "speaker": null,
      "text": "И буду ждать этого с расчетом. Хорошо?"
    },
    {
      "start": 166.81,
      "end": 168.97,
      "speaker": null,
      "text": "Светлана, а когда вам нужен?"
    },
    {
      "start": 169.94,
      "end": 171.28,
      "speaker": null,
      "text": "А, к 9 июня."
    },
    {
      "start": 172.6,
      "end": 173.52,
      "speaker": null,
      "text": "Время есть."
    },
    {
      "start": 173.72,
      "end": 174.02,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 174.44,
      "end": 182.16,
      "speaker": null,
      "text": "Вам нужен только пресс-вол или у вас мероприятие, на которое потребуется какая-то еще достаточная продукция полиграфия с ленирком?"
    },
    {
      "start": 182.92,
      "end": 186.2,
      "speaker": null,
      "text": "Нет, у нас своя типография есть."
    },
    {
      "start": 186.2,
      "end": 190.16,
      "speaker": null,
      "text": "Ну, вот что касается там разрешенных материалов, это мы сами можем."
    },
    {
      "start": 190.46,
      "end": 193.46,
      "speaker": null,
      "text": "А вот эта конструкция тоже нам приходится обращаться, конечно."
    },
    {
      "start": 193.7,
      "end": 194.18,
      "speaker": null,
      "text": "Поняла."
    },
    {
      "start": 195.2,
      "end": 197.2,
      "speaker": null,
      "text": "Светлана, моя почта прямая..."
    },
    {
      "start": 199.56,
      "end": 200.84,
      "speaker": null,
      "text": "Ой, вы прерваетесь."
    },
    {
      "start": 200.84,
      "end": 201.18,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 201.58,
      "end": 203.84,
      "speaker": null,
      "text": "Моя почта прямая..."
    },
    {
      "start": 204.7,
      "end": 206.04,
      "speaker": null,
      "text": "Ничего не в Польше."
    },
    {
      "start": 206.4,
      "end": 206.78,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 207.96,
      "end": 208.32,
      "speaker": null,
      "text": "Светлана?"
    },
    {
      "start": 209.74,
      "end": 210.88,
      "speaker": null,
      "text": "А сейчас?"
    },
    {
      "start": 212.44,
      "end": 214.3,
      "speaker": null,
      "text": "Вроде бы получше, непонятно."
    },
    {
      "start": 214.44,
      "end": 219.62,
      "speaker": null,
      "text": "Моя почта прямая, в разделе контакты, менеджер Елена."
    },
    {
      "start": 219.62,
      "end": 219.68,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 219.8,
      "end": 222.68,
      "speaker": null,
      "text": "Можете написать на почту..."
    },
    {
      "start": 225.03,
      "end": 226.69,
      "speaker": null,
      "text": "Сейчас я найду..."
    },
    {
      "start": 227.98,
      "end": 228.48,
      "speaker": null,
      "text": "РЕ, да?"
    },
    {
      "start": 228.6,
      "end": 229.76,
      "speaker": null,
      "text": "Собака Мостанта Шпру?"
    },
    {
      "start": 229.94,
      "end": 230.16,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 230.78,
      "end": 231.34,
      "speaker": null,
      "text": "Правильно."
    },
    {
      "start": 231.5,
      "end": 231.82,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 233.06,
      "end": 233.32,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 236.34,
      "end": 236.98,
      "speaker": null,
      "text": "Благодарю."
    }
  ]
}