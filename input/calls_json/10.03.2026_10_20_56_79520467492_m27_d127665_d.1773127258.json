    {
      "start": 81.71,
      "end": 82.43,
      "speaker": null,
      "text": "Мы её также производим."
    },
    {
      "start": 83.5,
      "end": 86.26,
      "speaker": null,
      "text": "А, нет, спасибо большое, это ничего не нужно."
    },
    {
      "start": 87.32,
      "end": 87.66,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 87.92,
      "end": 88.92,
      "speaker": null,
      "text": "Хорошо, я вас понял."
