    {
      "start": 63.84,
      "end": 64.24,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 64.54,
      "end": 65.04,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 65.48,
      "end": 68.1,
      "speaker": null,
      "text": "А у вас будет какое-то мероприятие?"
    },
    {
      "start": 68.1,
      "end": 69.12,
      "speaker": null,
      "text": "Да."
