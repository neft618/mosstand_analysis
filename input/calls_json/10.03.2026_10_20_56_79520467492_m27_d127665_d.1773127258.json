  "segments": [
    {
      "start": 0.56,
      "end": 3.46,
      "speaker": null,
      "text": "Добрый день, меня зовут Валентин, компания Масоныча, я могу вам помочь."
    },
    {
      "start": 4.12,
      "end": 8.34,
      "speaker": null,
      "text": "Здравствуйте! Скажите, пожалуйста, а сколько стоит роллап 100 на 200?"
    },
    {
      "start": 9.68,
      "end": 11.42,
      "speaker": null,
      "text": "А когда вам он будет необходим?"
    },
    {
      "start": 12.93,
      "end": 14.47,
      "speaker": null,
      "text": "Чтобы в пятницу уже был."
    },
    {
      "start": 16.04,
      "end": 18.1,
      "speaker": null,
      "text": "Вам необходим классический или каплевидный?"
    },
    {
      "start": 19.09,
      "end": 19.69,
      "speaker": null,
      "text": "Каплевидный."
    },
    {
      "start": 20.52,
      "end": 21.12,
      "speaker": null,
      "text": "Каплевидный."
    },
    {
      "start": 22.52,
      "end": 23.92,
      "speaker": null,
      "text": "А у вас макет готов уже?"
    },
    {
      "start": 24.44,
      "end": 25.7,
      "speaker": null,
      "text": "Да, всё готово."
    },
    {
      "start": 27.33,
      "end": 28.25,
      "speaker": null,
      "text": "Камила, верно?"
    },
    {
      "start": 29.61,
      "end": 32.11,
      "speaker": null,
      "text": "Да. А я вам уже обращалась к вам, да?"
    },
    {
      "start": 33.64,
      "end": 34.82,
      "speaker": null,
      "text": "Предполагаю, что ранее."
    },
    {
      "start": 34.82,
      "end": 35.6,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 38.76,
      "end": 40.46,
      "speaker": null,
      "text": "Так, скажите, пожалуйста..."
    },
    {
      "start": 40.94,
      "end": 43.3,
      "speaker": null,
      "text": "А может я вот услышал?"
    },
    {
      "start": 45.36,
      "end": 46.56,
      "speaker": null,
      "text": "Плохо вас услышал?"
    },
    {
      "start": 47.02,
      "end": 49.36,
      "speaker": null,
      "text": "Да, а молодой человек Ефим работает у вас?"
    },
    {
      "start": 50.3,
      "end": 51.44,
      "speaker": null,
      "text": "Нет, не работает."
    },
    {
      "start": 52.04,
      "end": 53.22,
      "speaker": null,
      "text": "А, всё, что-то ещё."
