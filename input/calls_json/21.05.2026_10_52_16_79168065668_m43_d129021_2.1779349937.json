{
  "file": "21.05.2026_10_52_16_79168065668_m43_d129021_2.1779349937.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 110.5,
  "segments": [
    {
      "start": 0.37,
      "end": 2.11,
      "speaker": null,
      "text": "Да, Георгий."
    },
    {
      "start": 2.52,
      "end": 8.22,
      "speaker": null,
      "text": "Дмитрий, приняли на приглашение, так что ждите…"
    },
    {
      "start": 8.22,
      "end": 10.26,
      "speaker": null,
      "text": "Так, сейчас я обновлю, секунду."
    },
    {
      "start": 17.74,
      "end": 21.16,
      "speaker": null,
      "text": "Необходимо завершить настройку «ДО» для отправки документов."
    },
    {
      "start": 21.26,
      "end": 26.22,
      "speaker": null,
      "text": "Для подписания отправки документа исполнения поставщик должен быть зарегистрирован КАУ «Гастрал»."
    },
    {
      "start": 26.22,
      "end": 28.12,
      "speaker": null,
      "text": "Уместе установлена связь с заказчиком."
    },
    {
      "start": 29.38,
      "end": 31.74,
      "speaker": null,
      "text": "Ну подождите, часть идет."
    },
    {
      "start": 33.33,
      "end": 40.41,
      "speaker": null,
      "text": "Ну просто я звонил на портал поставщиков, мне сказали, что необязательно регистрироваться на КАУ «Гастрале»."
    },
    {
      "start": 42.58,
      "end": 43.16,
      "speaker": null,
      "text": "Необязательно."
    },
    {
      "start": 44.63,
      "end": 46.49,
      "speaker": null,
      "text": "Но вам не нужно этого делать."
    },
    {
      "start": 46.87,
      "end": 47.95,
      "speaker": null,
      "text": "Ну никто этого не делает."
    },
    {
      "start": 48.49,
      "end": 54.11,
      "speaker": null,
      "text": "При установке связи у вас, условно, когда первый раз вы регистрируетесь автоматически на КАУ «Гастрал»."
    },
    {
      "start": 56.05,
      "end": 57.91,
      "speaker": null,
      "text": "Ну через портал, так скажем."
    },
    {
      "start": 58.37,
      "end": 62.37,
      "speaker": null,
      "text": "Ну просто мы вчера это нажимали, ну по крайней мере Дарья нажимала как раз."
    },
    {
      "start": 62.37,
      "end": 63.55,
      "speaker": null,
      "text": "Да, да, я видел."
    },
    {
      "start": 64.23,
      "end": 66.39,
      "speaker": null,
      "text": "Ну а, то что с моей целью было?"
    },
    {
      "start": 67.53,
      "end": 68.09,
      "speaker": null,
      "text": "Ну не знаю."
    },
    {
      "start": 68.59,
      "end": 70.41,
      "speaker": null,
      "text": "Кто-то что-то где-то купит."
    },
    {
      "start": 70.83,
      "end": 71.55,
      "speaker": null,
      "text": "Бывает такое."
    },
    {
      "start": 72.19,
      "end": 72.61,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 73.01,
      "end": 75.01,
      "speaker": null,
      "text": "Ну у нас завтра уже край, да, день?"
    },
    {
      "start": 78.42,
      "end": 81.04,
      "speaker": null,
      "text": "12-й у вас там был срок поставки?"
    },
    {
      "start": 82.22,
      "end": 83.92,
      "speaker": null,
      "text": "Срок поставки 12-го, да."
    },
    {
      "start": 84.2,
      "end": 88.18,
      "speaker": null,
      "text": "Раз, два, три, четыре, пять, шесть, семь, восемь."
    },
    {
      "start": 88.26,
      "end": 90.38,
      "speaker": null,
      "text": "Нет, 26-й будет крайний день."
    },
    {
      "start": 90.78,
      "end": 92.58,
      "speaker": null,
      "text": "А, ну хорошо, ладно."
    },
    {
      "start": 92.58,
      "end": 95.21,
      "speaker": null,
      "text": "Все, тогда ладно."
    },
    {
      "start": 95.45,
      "end": 96.47,
      "speaker": null,
      "text": "Будем подождать."
    },
    {
      "start": 97.11,
      "end": 97.85,
      "speaker": null,
      "text": "Да, да, хорошо."
    },
    {
      "start": 98.59,
      "end": 105.68,
      "speaker": null,
      "text": "Ну подтвердили 10 минут назад только это, может не дошла еще интеграция обратно."
    },
    {
      "start": 105.8,
      "end": 107.14,
      "speaker": null,
      "text": "Хорошо, ладно, спасибо."
    },
    {
      "start": 107.14,
      "end": 107.42,
      "speaker": null,
      "text": "Спасибо вам."
    },
    {
      "start": 107.98,
      "end": 108.7,
      "speaker": null,
      "text": "Угу, давайте."
    }
  ]
}