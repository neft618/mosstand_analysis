    {
      "start": 2.07,
      "end": 5.45,
      "speaker": null,
      "text": "Алло, здравствуйте. Это Иван из Мостенда, пропущенный от вас."
    },
    {
      "start": 6.36,
      "end": 9.58,
      "speaker": null,
      "text": "Да, здравствуйте, мы уже нашли всё, спасибо большое, уже не нужно."
    },
    {
      "start": 10.34,
      "end": 11.26,
      "speaker": null,
      "text": "А что искали?"
    },
    {
      "start": 12.08,
      "end": 16.6,
      "speaker": null,
      "text": "Нам нужно было сдать роллап по готовому макету до завтра."
    },
    {
      "start": 17.68,
      "end": 20.38,
      "speaker": null,
      "text": "А вы уже запустились? Потому что после чего мы можем успеть."
    },
    {
      "start": 21.86,
      "end": 23.3,
      "speaker": null,
      "text": "Сколько у вас будет стоимость?"
    },
    {
      "start": 23.96,
      "end": 25.26,
      "speaker": null,
      "text": "А какого размера?"
    },
    {
      "start": 27.26,
      "end": 31.16,
      "speaker": null,
      "text": "990 на 2070."
    },
    {
      "start": 32.09,
      "end": 35.59,
      "speaker": null,
      "text": "А, я понял, да, сейчас секундочку."
    },
    {
      "start": 38.88,
      "end": 40.34,
      "speaker": null,
      "text": "Так, сейчас, сейчас, сейчас, сейчас."
    },
    {
      "start": 47.04,
      "end": 53.44,
      "speaker": null,
      "text": "4000 рублей конструкция и 1900 печать, 5900 под ключ, то есть вместе с сумкой, с конструкцией, с печатью."
    },
    {
      "start": 55.53,
      "end": 59.79,
      "speaker": null,
      "text": "Так, там вроде бы уже напечатали, сейчас уточню, хорошо."
    },
    {
      "start": 60.17,
      "end": 62.21,
      "speaker": null,
      "text": "Иван тогда там знает, спасибо большое."
    },
    {
      "start": 62.71,
      "end": 64.03,
      "speaker": null,
      "text": "Всё, да, хорошо, тогда звоните."
    },
    {
      "start": 64.47,
      "end": 65.19,
      "speaker": null,
      "text": "До свидания."
    }
