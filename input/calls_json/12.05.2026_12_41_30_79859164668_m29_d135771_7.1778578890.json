  "segments": [
    {
      "start": 1.15,
      "end": 4.59,
      "speaker": null,
      "text": "Добрый день, я живу Ксения. Компания «Мастерендка», я могу к вам обращаться."
    },
    {
      "start": 5.56,
      "end": 24.16,
      "speaker": null,
      "text": "Здравствуйте. Я бы хотела заказать фотостену на мероприятии. У меня есть логотип, который нужен, потому что нужно добавить надпись, разработать полностью дизайн и выбрать размеры, чтобы вы мне подобрали. Вот мы это с вами детективами можем сделать?"
    },
    {
      "start": 25.64,
      "end": 30.08,
      "speaker": null,
      "text": "Подскажите, а как мы для вас размеры подберём, что именно?"
    },
    {
      "start": 32.18,
      "end": 35.02,
      "speaker": null,
      "text": "На макете или самого стенда?"
    },
    {
      "start": 38.03,
      "end": 39.19,
      "speaker": null,
      "text": "И макет где-то."
    },
    {
      "start": 41.88,
      "end": 42.7,
      "speaker": null,
      "text": "Какие дети?"
    },
    {
      "start": 43.79,
      "end": 45.41,
      "speaker": null,
      "text": "Вас очень плохо слышно."
    },
    {
      "start": 47.38,
      "end": 48.22,
      "speaker": null,
      "text": "Алло, алло."
    },
    {
      "start": 49.12,
      "end": 57.1,
      "speaker": null,
      "text": "Я не говорю, девушка телеграм-канал, ой, телеграм, чтобы переписываться, согласоваться."
    },
    {
      "start": 57.12,
      "end": 64.42,
      "speaker": null,
      "text": "Есть по моему номеру телефона, там он открыт, сможете записать, у меня не высвечился ваш номер."
    },
    {
      "start": 64.94,
      "end": 67.64,
      "speaker": null,
      "text": "Ну, я либо вышла номер в предикторе, и я сразу вас найду."
    },
    {
      "start": 73.08,
      "end": 74.68,
      "speaker": null,
      "text": "Вас очень плохо слышно."
    },
    {
      "start": 75.54,
      "end": 75.78,
      "speaker": null,
      "text": "Ватсап."
    },
    {
      "start": 75.84,
      "end": 76.9,
      "speaker": null,
      "text": "Придёпная связь."
    },
    {
      "start": 77.08,
      "end": 77.56,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 78.22,
      "end": 78.82,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 78.88,
      "end": 79.44,
      "speaker": null,
      "text": "А ватсап?"
    },
    {
      "start": 79.58,
      "end": 81.46,
      "speaker": null,
      "text": "А ватсап у вас есть, скажите, пожалуйста?"
    },
    {
      "start": 81.76,
      "end": 84.9,
      "speaker": null,
      "text": "Ватсап не работает нормально в России."
    },
    {
      "start": 85.46,
      "end": 85.54,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 86.28,
      "end": 86.7,
      "speaker": null,
      "text": "Ну да, классно."
    },
    {
      "start": 86.7,
      "end": 87.48,
      "speaker": null,
      "text": "Да, у нас плохо."
    },
    {
      "start": 88.4,
      "end": 90.4,
      "speaker": null,
      "text": "Можно либо макет, либо телеграм."
    },
    {
      "start": 92.12,
      "end": 92.66,
      "speaker": null,
      "text": "Как вам?"
    },
    {
      "start": 92.86,
      "end": 93.82,
      "speaker": null,
      "text": "Давайте в марсе."
    },
    {
      "start": 93.92,
      "end": 95.2,
      "speaker": null,
      "text": "Можем в марсе списаться?"
    },
    {
      "start": 95.3,
      "end": 96.44,
      "speaker": null,
      "text": "Да, конечно, конечно."
    },
    {
      "start": 97.32,
      "end": 99.16,
      "speaker": null,
      "text": "Вы так можете прописывать номер свой?"
    },
    {
      "start": 99.39,
      "end": 100.47,
      "speaker": null,
      "text": "Ватсап."
    },
    {
      "start": 100.47,
      "end": 101.73,
      "speaker": null,
      "text": "Да, спасибо огромное."
    },
    {
      "start": 132.51,
      "end": 133.91,
      "speaker": null,
      "text": "Ватсап."
    },
    {
      "start": 133.91,
      "end": 134.05,
      "speaker": null,
      "text": "Ватсап."
    },
    {
      "start": 134.33,
      "end": 134.89,
      "speaker": null,
      "text": "Ватсап."
    },
    {
      "start": 135.49,
      "end": 136.95,
      "speaker": null,
      "text": "Так, да."
    },
    {
      "start": 137.19,
      "end": 137.99,
      "speaker": null,
      "text": "Нашла вас."
    },
    {
      "start": 139.06,
      "end": 139.82,
      "speaker": null,
      "text": "Полина."
    },
    {
      "start": 139.82,
