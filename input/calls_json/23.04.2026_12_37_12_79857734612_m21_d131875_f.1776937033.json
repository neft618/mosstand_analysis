{
  "file": "23.04.2026_12_37_12_79857734612_m21_d131875_f.1776937033.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 339.5,
  "segments": [
    {
      "start": 1.52,
      "end": 2.74,
      "speaker": null,
      "text": "Наталья, добрый день."
    },
    {
      "start": 3.22,
      "end": 8.16,
      "speaker": null,
      "text": "Да, Артём, добрый день. Я вас всегда предлагаю мучить."
    },
    {
      "start": 8.62,
      "end": 9.38,
      "speaker": null,
      "text": "Нормально."
    },
    {
      "start": 10.34,
      "end": 16.02,
      "speaker": null,
      "text": "У меня выбора нет, простите ради Бога, я не по своей воле."
    },
    {
      "start": 16.81,
      "end": 22.41,
      "speaker": null,
      "text": "Смотрите, у вас на сайте есть такая ерунда как пресс-вол тип М."
    },
    {
      "start": 24.92,
      "end": 28.74,
      "speaker": null,
      "text": "Там тоже эти решёточки, трубы, лесенки."
    },
    {
      "start": 29.48,
      "end": 36.48,
      "speaker": null,
      "text": "Но здесь, я понимаю, баннер крепится с двух... можно крепить с двух сторон, но вот эти верёвочки как они любят, да?"
    },
    {
      "start": 37.2,
      "end": 42.4,
      "speaker": null,
      "text": "На стяжке, да. То есть баннер будет крепиться, можно закрепить, как вчера он направлялся."
    },
    {
      "start": 42.96,
      "end": 44.24,
      "speaker": null,
      "text": "Это был пресс-вол тип М."
    },
    {
      "start": 45.06,
      "end": 48.08,
      "speaker": null,
      "text": "То есть здесь две трубы по бокам."
    },
    {
      "start": 48.79,
      "end": 52.15,
      "speaker": null,
      "text": "Ради можно закрепить за первую и сбоку, соответственно."
    },
    {
      "start": 53.07,
      "end": 55.15,
      "speaker": null,
      "text": "Будет видно, соответственно, что между ними всё."
    },
    {
      "start": 55.45,
      "end": 57.49,
      "speaker": null,
      "text": "Что между ними? Между ними будет щелочка."
    },
    {
      "start": 57.61,
      "end": 61.09,
      "speaker": null,
      "text": "Такое можно сделать, как они хотят на этих... на верёвочках?"
    },
    {
      "start": 61.81,
      "end": 62.23,
      "speaker": null,
      "text": "Не вопрос."
    },
    {
      "start": 62.35,
      "end": 62.97,
      "speaker": null,
      "text": "На верёвочке?"
    },
    {
      "start": 63.01,
      "end": 63.51,
      "speaker": null,
      "text": "Не понял."
    },
    {
      "start": 63.53,
      "end": 66.37,
      "speaker": null,
      "text": "Ну вот верёвочки, вот эти растяжки, эти хому-хомучки."
    },
    {
      "start": 67.01,
      "end": 68.93,
      "speaker": null,
      "text": "На хомутах это всё и крепится, да."
    },
    {
      "start": 69.61,
      "end": 70.09,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 70.23,
      "end": 72.99,
      "speaker": null,
      "text": "Вот я их верёвочкой называю, хомучки."
    },
    {
      "start": 73.05,
      "end": 76.17,
      "speaker": null,
      "text": "Там всё крепится на стяжке, хомуты вот эти всё."
    },
    {
      "start": 76.35,
      "end": 76.45,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 77.2,
      "end": 80.28,
      "speaker": null,
      "text": "То есть тут возможно с двух сторон натянуть эту херню?"
    },
    {
      "start": 80.88,
      "end": 81.8,
      "speaker": null,
      "text": "Ну да, ну..."
    },
    {
      "start": 83.37,
      "end": 85.55,
      "speaker": null,
      "text": "Понимаете, дело о вкусах."
    },
    {
      "start": 85.63,
      "end": 87.67,
      "speaker": null,
      "text": "О вкусах мы уже здесь даже не спорим."
    },
    {
      "start": 88.41,
      "end": 88.97,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 89.65,
      "end": 91.39,
      "speaker": null,
      "text": "Просто я уже как бы устала."
    },
    {
      "start": 91.51,
      "end": 95.95,
      "speaker": null,
      "text": "Я просто им готова поставить эти конструкции и пускай они делать мне ничего хотят."
    },
    {
      "start": 96.45,
      "end": 100.73,
      "speaker": null,
      "text": "Ну пусть, Саня, вот и можно с нашей стороны конструкции или баннеры сделать."
    },
    {
      "start": 100.85,
      "end": 102.91,
      "speaker": null,
      "text": "Пусть это сами собирают, понимают какого это."
    },
    {
      "start": 103.95,
      "end": 104.47,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 104.65,
      "end": 105.83,
      "speaker": null,
      "text": "Как они это видят?"
    },
    {
      "start": 106.11,
      "end": 107.03,
      "speaker": null,
      "text": "Ну, да не вопрос."
    },
    {
      "start": 107.71,
      "end": 110.67,
      "speaker": null,
      "text": "Я даже как бы им предложила бы просто конструкция."
    },
    {
      "start": 111.66,
      "end": 112.0,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 112.98,
      "end": 114.12,
      "speaker": null,
      "text": "Вот, смотрите."
    },
    {
      "start": 114.72,
      "end": 120.9,
      "speaker": null,
      "text": "Тут есть у вас написано 3 на 2, 4 на 2, 2 на 2."
    },
    {
      "start": 121.28,
      "end": 123.48,
      "speaker": null,
      "text": "Можно сделать 3 на 2 с половиной?"
    },
    {
      "start": 123.64,
      "end": 124.9,
      "speaker": null,
      "text": "Сколько это будет стоить?"
    },
    {
      "start": 124.9,
      "end": 126.14,
      "speaker": null,
      "text": "Посчитать, да."
    },
    {
      "start": 127.22,
      "end": 131.4,
      "speaker": null,
      "text": "А считать конструкцию с баннером или как?"
    },
    {
      "start": 131.74,
      "end": 134.52,
      "speaker": null,
      "text": "Вы можете мне посчитать конструкцию?"
    },
    {
      "start": 135.19,
      "end": 135.81,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 135.81,
      "end": 136.59,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 136.59,
      "end": 140.11,
      "speaker": null,
      "text": "Можете посчитать с баннером, который пишет в 1440?"
    },
    {
      "start": 141.18,
      "end": 141.5,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 141.74,
      "end": 145.2,
      "speaker": null,
      "text": "Потому что у меня идет по-моему по ТЗС 720."
    },
    {
      "start": 145.68,
      "end": 147.1,
      "speaker": null,
      "text": "Но мы будем считать 1440."
    },
    {
      "start": 148.22,
      "end": 148.44,
      "speaker": null,
      "text": "Да, вот такой."
    },
    {
      "start": 148.44,
      "end": 149.44,
      "speaker": null,
      "text": "Там идёт литой баннер."
    },
    {
      "start": 149.52,
      "end": 149.82,
      "speaker": null,
      "text": "Правильно?"
    },
    {
      "start": 149.94,
      "end": 150.58,
      "speaker": null,
      "text": "С ливерсами?"
    },
    {
      "start": 151.08,
      "end": 152.7,
      "speaker": null,
      "text": "Да, литой баннер с ливерсами."
    },
    {
      "start": 153.08,
      "end": 153.52,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 153.82,
      "end": 156.28,
      "speaker": null,
      "text": "Пожалуйста, вот эту опцию просто отдельно."
    },
    {
      "start": 157.38,
      "end": 158.08,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 158.2,
      "end": 158.82,
      "speaker": null,
      "text": "Просто отдельно."
    },
    {
      "start": 159.0,
      "end": 159.32,
      "speaker": null,
      "text": "Хорошо?"
    },
    {
      "start": 159.66,
      "end": 160.66,
      "speaker": null,
      "text": "Да, давайте."
    },
    {
      "start": 160.66,
      "end": 161.06,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 161.46,
      "end": 164.76,
      "speaker": null,
      "text": "Да, прям вот очень жду, чтобы я им отправила предложение"
    },
    {
      "start": 164.76,
      "end": 168.08,
      "speaker": null,
      "text": "и уже как бы переключилась на как бы другую работу."
    },
    {
      "start": 168.32,
      "end": 169.1,
      "speaker": null,
      "text": "Потому что третья..."
    },
    {
      "start": 169.1,
      "end": 169.8,
      "speaker": null,
      "text": "Понял, понял, да."
    },
    {
      "start": 169.96,
      "end": 170.38,
      "speaker": null,
      "text": "Понимаю."
    },
    {
      "start": 170.5,
      "end": 170.58,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 173.3,
      "end": 174.14,
      "speaker": null,
      "text": "Ну разберёмся."
    },
    {
      "start": 175.0,
      "end": 176.86,
      "speaker": null,
      "text": "Смотрите, ещё такая штука."
    },
    {
      "start": 177.88,
      "end": 181.44,
      "speaker": null,
      "text": "Если вдруг, я не говорю, что у меня там по всей стране"
    },
    {
      "start": 181.44,
      "end": 184.3,
      "speaker": null,
      "text": "они будут стоять эти стенды, как они хотят."
    },
    {
      "start": 184.88,
      "end": 186.72,
      "speaker": null,
      "text": "Вот я не знаю, как они их будут доставлять"
    },
    {
      "start": 186.72,
      "end": 189.9,
      "speaker": null,
      "text": "и я готова им отгрузить вот сюда как бы выход"
    },
    {
      "start": 189.9,
      "end": 191.86,
      "speaker": null,
      "text": "и пускай распределяют как угодно."
    },
    {
      "start": 192.74,
      "end": 193.16,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 194.47,
      "end": 196.09,
      "speaker": null,
      "text": "Значит, если будет Москва."
    },
    {
      "start": 196.37,
      "end": 198.57,
      "speaker": null,
      "text": "Я могу поставить вас на монтаж..."
    },
    {
      "start": 199.0,
      "end": 200.23,
      "speaker": null,
      "text": "Ваш монтаж сделать?"
    },
    {
      "start": 201.03,
      "end": 201.55,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 203.36,
      "end": 203.73,
      "speaker": null,
      "text": "Но..."
    },
    {
      "start": 203.73,
      "end": 206.11,
      "speaker": null,
      "text": "Одно но нужно заранее это знать."
    },
    {
      "start": 206.63,
      "end": 209.45,
      "speaker": null,
      "text": "И у нас монтаж в этой неделе сниверситет."
    },
    {
      "start": 209.69,
      "end": 213.19,
      "speaker": null,
      "text": "Не, возможно я найду как бы своего монтажника."
    },
    {
      "start": 213.41,
      "end": 216.89,
      "speaker": null,
      "text": "У меня тоже как бы был наёмный монтажник."
    },
    {
      "start": 217.31,
      "end": 219.21,
      "speaker": null,
      "text": "Вот не знаю, просто я давно не обращалась."
    },
    {
      "start": 219.21,
      "end": 220.01,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 220.13,
      "end": 222.81,
      "speaker": null,
      "text": "Потому что и ГУМ монтировали, ещё такое, да?"
    },
    {
      "start": 222.95,
      "end": 226.07,
      "speaker": null,
      "text": "Ну просто я сейчас немножечко как бы это дело отпустила."
    },
    {
      "start": 226.55,
      "end": 226.87,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 226.95,
      "end": 230.51,
      "speaker": null,
      "text": "У них как бы свои конструкции они сами монтировали."
    },
    {
      "start": 231.58,
      "end": 231.96,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 232.16,
      "end": 235.28,
      "speaker": null,
      "text": "Просто у них стоит сейчас в ТЗ монтаж."
    },
    {
      "start": 235.52,
      "end": 238.44,
      "speaker": null,
      "text": "И я должна как бы его обозначить хотя бы на Москву."
    },
    {
      "start": 238.52,
      "end": 241.7,
      "speaker": null,
      "text": "Я же вас не буду посылать в Амурскую область монтировать этот стенд."
    },
    {
      "start": 241.7,
      "end": 243.62,
      "speaker": null,
      "text": "Ну да, это вы слишком долго."
    },
    {
      "start": 243.64,
      "end": 244.4,
      "speaker": null,
      "text": "Да, это..."
    },
    {
      "start": 245.39,
      "end": 246.4,
      "speaker": null,
      "text": "Сами слетаем."
    },
    {
      "start": 247.37,
      "end": 248.92,
      "speaker": null,
      "text": "Четыре монтажа прикручу."
    },
    {
      "start": 249.56,
      "end": 249.72,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 250.46,
      "end": 251.08,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 251.78,
      "end": 256.82,
      "speaker": null,
      "text": "Вот, если билеты купятся и слетаем с монтируем, не тот вопрос."
    },
    {
      "start": 257.54,
      "end": 259.02,
      "speaker": null,
      "text": "Вот, просто на Москву."
    },
    {
      "start": 259.22,
      "end": 261.96,
      "speaker": null,
      "text": "Я поставлю вот эти 6 тысяч рублей, да?"
    },
    {
      "start": 262.7,
      "end": 263.22,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 263.74,
      "end": 264.14,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 264.14,
      "end": 264.24,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 264.5,
      "end": 264.8,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 265.06,
      "end": 265.8,
      "speaker": null,
      "text": "В Москве, да."
    },
    {
      "start": 265.88,
      "end": 267.24,
      "speaker": null,
      "text": "Но это, смотрите, будний..."
    },
    {
      "start": 268.64,
      "end": 269.9,
      "speaker": null,
      "text": "Будний рабочий день."
    },
    {
      "start": 270.56,
      "end": 272.6,
      "speaker": null,
      "text": "Это понятно, что будний..."
    },
    {
      "start": 272.6,
      "end": 272.8,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 272.98,
      "end": 276.8,
      "speaker": null,
      "text": "Это понятно, что будний рабочий день, они точно так же работают"
    },
    {
      "start": 276.8,
      "end": 279.12,
      "speaker": null,
      "text": "как бы по будням, по рабочим дням."
    },
    {
      "start": 279.2,
      "end": 284.16,
      "speaker": null,
      "text": "Причём, насколько я понимаю, там тоже строк с 9 до 6."
    },
    {
      "start": 284.16,
      "end": 284.64,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 284.96,
      "end": 285.48,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 286.44,
      "end": 286.96,
      "speaker": null,
      "text": "Поэтому..."
    },
    {
      "start": 286.96,
      "end": 289.98,
      "speaker": null,
      "text": "Этот центр, ну как бы я просто не знаю, где будет проходить"
    },
    {
      "start": 289.98,
      "end": 293.46,
      "speaker": null,
      "text": "мероприятие, вот, но во всяком случае..."
    },
    {
      "start": 293.59,
      "end": 293.79,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 293.87,
      "end": 297.35,
      "speaker": null,
      "text": "Если будет требоваться наш монтаж, то должна будет парковка"
    },
    {
      "start": 297.35,
      "end": 298.49,
      "speaker": null,
      "text": "со стороны клиента."
    },
    {
      "start": 298.83,
      "end": 302.59,
      "speaker": null,
      "text": "Это там, это понятно, слушайте, внутри метра вот эту"
    },
    {
      "start": 302.59,
      "end": 304.63,
      "speaker": null,
      "text": "ширину вести, понятно, что там парковка."
    },
    {
      "start": 304.73,
      "end": 308.25,
      "speaker": null,
      "text": "Да, он не будет бегать искать парковку на Типове и потом"
    },
    {
      "start": 308.25,
      "end": 308.87,
      "speaker": null,
      "text": "бегать на площадке."
    },
    {
      "start": 308.89,
      "end": 309.81,
      "speaker": null,
      "text": "Нет-нет-нет."
    },
    {
      "start": 309.81,
      "end": 314.09,
      "speaker": null,
      "text": "А у вашего монтажника будет машина, в которой можно 3 метра"
    },
    {
      "start": 314.59,
      "end": 314.87,
      "speaker": null,
      "text": "довезти?"
    },
    {
      "start": 315.05,
      "end": 316.57,
      "speaker": null,
      "text": "Или ставить ещё какой-нибудь доказатель?"
    },
    {
      "start": 317.05,
      "end": 319.19,
      "speaker": null,
      "text": "Нет-нет, у неё в машине будет, да."
    },
    {
      "start": 319.81,
      "end": 320.43,
      "speaker": null,
      "text": "Всё, нет."
    },
    {
      "start": 320.53,
      "end": 323.07,
      "speaker": null,
      "text": "Эту парковку-то мы организуем, это не тот вопрос."
    },
    {
      "start": 323.95,
