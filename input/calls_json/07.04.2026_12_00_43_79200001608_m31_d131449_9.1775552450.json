{
  "file": "07.04.2026_12_00_43_79200001608_m31_d131449_9.1775552450.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 183.8,
  "segments": [
    {
      "start": 2.29,
      "end": 5.53,
      "speaker": null,
      "text": "Добрый день, это Екатерина, компания МОСАНДР. Чего могу помочь?"
    },
    {
      "start": 5.59,
      "end": 9.65,
      "speaker": null,
      "text": "Да, здравствуйте. Почту отправлял вам в ТЛС-ку вчера."
    },
    {
      "start": 10.19,
      "end": 10.45,
      "speaker": null,
      "text": "Здравствуйте."
    },
    {
      "start": 10.53,
      "end": 11.97,
      "speaker": null,
      "text": "Можете, пожалуйста, найти неё, да."
    },
    {
      "start": 12.93,
      "end": 15.53,
      "speaker": null,
      "text": "Брагар.метрик почта была. Приходите, пожалуйста."
    },
    {
      "start": 16.64,
      "end": 19.09,
      "speaker": null,
      "text": "Да, слушаю. Нашла?"
    },
    {
      "start": 20.04,
      "end": 20.7,
      "speaker": null,
      "text": "Нашли, да?"
    },
    {
      "start": 21.32,
      "end": 21.52,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 22.43,
      "end": 25.25,
      "speaker": null,
      "text": "А можете посчитать, пожалуйста, сколько это стоит быть там со свидетелями?"
    },
    {
      "start": 25.25,
      "end": 26.81,
      "speaker": null,
      "text": "Я вам ответила уже сегодня утром?"
    },
    {
      "start": 27.72,
      "end": 31.58,
      "speaker": null,
      "text": "950-20, отправила, да. Сообщение просчитано у меня, отвечено."
    },
    {
      "start": 32.3,
      "end": 33.8,
      "speaker": null,
      "text": "135, вы прочитали его."
    },
    {
      "start": 33.96,
      "end": 35.0,
      "speaker": null,
      "text": "А какая у вас почта?"
    },
    {
      "start": 36.75,
      "end": 37.63,
      "speaker": null,
      "text": "eosobakamostent.ru"
    },
    {
      "start": 37.63,
      "end": 40.87,
      "speaker": null,
      "text": "А, вот всё увидела, у меня случайно прочиталось."
    },
    {
      "start": 42.96,
      "end": 43.38,
      "speaker": null,
      "text": "Так..."
    },
    {
      "start": 43.38,
      "end": 44.76,
      "speaker": null,
      "text": "Да, ЕГЭ вам уже ответила там."
    },
    {
      "start": 44.88,
      "end": 45.78,
      "speaker": null,
      "text": "Всё указало."
    },
    {
      "start": 46.18,
      "end": 48.18,
      "speaker": null,
      "text": "Нет, да, трибуна."
    },
    {
      "start": 48.36,
      "end": 49.78,
      "speaker": null,
      "text": "А, светильники у вас включаются?"
    },
    {
      "start": 50.88,
      "end": 53.62,
      "speaker": null,
      "text": "Нет, светильники не считала, светильники тоже нужно почитать."
    },
    {
      "start": 53.88,
      "end": 56.94,
      "speaker": null,
      "text": "Просто эта картинка нарисована, это как бы референс, если вам..."
    },
    {
      "start": 56.94,
      "end": 58.66,
      "speaker": null,
      "text": "Да, я понимаю, да, светильники так надо."
    },
    {
      "start": 59.78,
      "end": 60.22,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 60.68,
      "end": 63.62,
      "speaker": null,
      "text": "Так, а по размеру стендов я правильно вам указала?"
    },
    {
      "start": 63.62,
      "end": 65.84,
      "speaker": null,
      "text": "Просто на картинке, опять же, он указан маленький."
    },
    {
      "start": 66.0,
      "end": 67.86,
      "speaker": null,
      "text": "Может быть, вам побольше нужен или подойдёт?"
    },
    {
      "start": 68.73,
      "end": 70.87,
      "speaker": null,
      "text": "Да, в целом подходит, да, для этих..."
    },
    {
      "start": 70.87,
      "end": 72.15,
      "speaker": null,
      "text": "1,95, да?"
    },
    {
      "start": 73.68,
      "end": 74.12,
      "speaker": null,
      "text": "Ширину?"
    },
    {
      "start": 74.6,
      "end": 74.96,
      "speaker": null,
      "text": "Почти диаметрия?"
    },
    {
      "start": 75.04,
      "end": 75.64,
      "speaker": null,
      "text": "Ну, да-да-да."
    },
    {
      "start": 75.82,
      "end": 76.22,
      "speaker": null,
      "text": "Нормально."
    },
    {
      "start": 76.5,
      "end": 77.52,
      "speaker": null,
      "text": "А, ну..."
    },
    {
      "start": 77.75,
      "end": 78.69,
      "speaker": null,
      "text": "Хорошо, да."
    },
    {
      "start": 78.87,
      "end": 79.81,
      "speaker": null,
      "text": "С этим я пересчитаю."
    },
    {
      "start": 79.85,
      "end": 80.49,
      "speaker": null,
      "text": "А какие вам нужны?"
    },
    {
      "start": 80.51,
      "end": 81.59,
      "speaker": null,
      "text": "Диодные или галогеновые?"
    },
    {
      "start": 82.13,
      "end": 84.19,
      "speaker": null,
      "text": "Светлые, ну точнее, жёлтые либо белые?"
    },
    {
      "start": 85.01,
      "end": 85.23,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 88.19,
      "end": 89.11,
      "speaker": null,
      "text": "Светлые, белые."
    },
    {
      "start": 90.68,
      "end": 91.12,
      "speaker": null,
      "text": "Белые."
    },
    {
      "start": 91.12,
      "end": 93.14,
      "speaker": null,
      "text": "Просто диодные, они дороже, чем галогеновые."
    },
    {
      "start": 93.22,
      "end": 97.16,
      "speaker": null,
      "text": "Галогеновые такой тёплый цвет, жёлтенький немножко, а диодные"
    },
    {
      "start": 97.16,
      "end": 97.7,
      "speaker": null,
      "text": "они белые."
    },
    {
      "start": 98.38,
      "end": 99.5,
      "speaker": null,
      "text": "Я думаю, белые, да."
    },
    {
      "start": 99.68,
      "end": 100.7,
      "speaker": null,
      "text": "Ну, такой холодный цвет."
    },
    {
      "start": 101.24,
      "end": 102.3,
      "speaker": null,
      "text": "Хорошо, посчитаю?"
    },
    {
      "start": 102.3,
      "end": 105.34,
      "speaker": null,
      "text": "Ещё что-нибудь, может быть, помимо попапа бокс-трибуны нужно?"
    },
    {
      "start": 105.64,
      "end": 107.4,
      "speaker": null,
      "text": "Что у вас вообще за мероприятие планируется?"
    },
    {
      "start": 107.84,
      "end": 108.24,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 108.58,
      "end": 109.02,
      "speaker": null,
      "text": "Полиграфия?"
    },
    {
      "start": 109.22,
      "end": 109.98,
      "speaker": null,
      "text": "Может быть, сервиска?"
    },
    {
      "start": 110.88,
      "end": 112.6,
      "speaker": null,
      "text": "Не-не-не-не, это не надо."
    },
    {
      "start": 112.74,
      "end": 115.02,
      "speaker": null,
      "text": "А вот эти вот всё в печати включено, да?"
    },
    {
      "start": 115.52,
      "end": 118.56,
      "speaker": null,
      "text": "Да-да, нет, всё рассчитано в печати, конечно, я указала"
    },
    {
      "start": 118.56,
      "end": 118.78,
      "speaker": null,
      "text": "это."
    },
    {
      "start": 118.9,
      "end": 120.56,
      "speaker": null,
      "text": "Попап конструкция плюс печати насторонние."
    },
    {
      "start": 122.06,
      "end": 124.3,
      "speaker": null,
      "text": "А бокс-трибуна – это печать и столешница."
    },
    {
      "start": 125.87,
      "end": 126.65,
      "speaker": null,
      "text": "Всё, хорошо."
    },
    {
      "start": 126.83,
      "end": 129.09,
      "speaker": null,
      "text": "Тогда жду со светильниками, спасибо."
    },
    {
      "start": 129.73,
      "end": 130.61,
      "speaker": null,
      "text": "Хорошо, да."
    },
    {
      "start": 130.73,
      "end": 133.49,
      "speaker": null,
      "text": "А вы мне подскажете, когда планируется дата мероприятия?"
    },
    {
      "start": 133.73,
      "end": 133.77,
      "speaker": null,
      "text": "Есть?"
    },
    {
      "start": 135.47,
      "end": 138.79,
      "speaker": null,
      "text": "В апреле она планировалась, а возможно его перенесутся."
    },
    {
      "start": 139.06,
      "end": 141.22,
      "speaker": null,
      "text": "Я пока не знаю, в апреле не считаю."
    },
    {
      "start": 142.02,
      "end": 142.88,
      "speaker": null,
      "text": "Всё, поняла."
    },
    {
      "start": 143.16,
      "end": 145.56,
      "speaker": null,
      "text": "Хорошо, стоимость направлена вам тогда по светильникам?"
    },
    {
      "start": 145.76,
      "end": 148.74,
      "speaker": null,
      "text": "А когда примерно получится дать обратную часть на счёт"
    },
    {
      "start": 148.74,
      "end": 149.26,
      "speaker": null,
      "text": "заказа?"
    },
    {
      "start": 149.34,
      "end": 150.3,
      "speaker": null,
      "text": "Устраивает, не устраивает?"
    },
    {
      "start": 150.38,
      "end": 154.72,
      "speaker": null,
      "text": "Я обычно руководство отдаю, они сами уже по подрядчикам"
    },
    {
      "start": 155.06,
      "end": 156.26,
      "speaker": null,
      "text": "всё заведуют, что когда им надо."
    },
    {
      "start": 157.28,
      "end": 158.02,
      "speaker": null,
      "text": "Ну, хорошо."
    },
    {
      "start": 158.52,
      "end": 159.96,
      "speaker": null,
      "text": "Дмитрий, давайте так тогда поступим."
    },
    {
      "start": 160.02,
      "end": 161.74,
      "speaker": null,
      "text": "Я вам сейчас отправлю цены по светильникам."
    },
    {
      "start": 161.82,
      "end": 163.04,
      "speaker": null,
      "text": "Вы мои контакты передаете, пожалуйста."
    },
    {
      "start": 163.28,
      "end": 164.2,
      "speaker": null,
      "text": "В почте всё указывать?"
    },
    {
      "start": 164.22,
      "end": 164.68,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 164.76,
      "end": 169.08,
      "speaker": null,
      "text": "Если устроят наши условия, они прямо могли с ними связаться."
    },
    {
      "start": 169.42,
      "end": 169.78,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 169.92,
      "end": 170.22,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 170.54,
      "end": 170.9,
      "speaker": null,
      "text": "Договорились."
    },
    {
      "start": 171.04,
      "end": 171.12,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 171.12,
      "end": 173.18,
      "speaker": null,
      "text": "Ну там итоговую также вот то, как вы расписали,"
    },
    {
      "start": 173.26,
      "end": 175.3,
      "speaker": null,
      "text": "и плюс светильники, чтобы она была с итоговой."
    },
    {
      "start": 175.42,
      "end": 177.48,
      "speaker": null,
      "text": "Так проще будет просто ориентироваться, не работать."
    },
    {
      "start": 178.39,
      "end": 178.75,
      "speaker": null,
      "text": "Окей."
    },
    {
      "start": 179.01,
      "end": 179.79,
      "speaker": null,
      "text": "Неспублина, правда, да?"
    },
    {
      "start": 180.65,
      "end": 180.93,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 181.05,
      "end": 181.25,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 181.25,
      "end": 182.37,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 183.2,
      "end": 183.32,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
