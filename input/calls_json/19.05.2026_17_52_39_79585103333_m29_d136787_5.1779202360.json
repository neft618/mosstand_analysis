{
  "file": "19.05.2026_17_52_39_79585103333_m29_d136787_5.1779202360.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 409.3,
  "segments": [
    {
      "start": 1.17,
      "end": 4.65,
      "speaker": null,
      "text": "Добрый день. Меня зовут Ксения, компания Музитант. Как же могу к вам обращаться?"
    },
    {
      "start": 5.17,
      "end": 9.43,
      "speaker": null,
      "text": "Ксения, здравствуйте. Я бы хотела заказать у вас стенд с брусом."
    },
    {
      "start": 10.11,
      "end": 10.79,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 11.61,
      "end": 12.77,
      "speaker": null,
      "text": "200 на 200."
    },
    {
      "start": 13.37,
      "end": 14.91,
      "speaker": null,
      "text": "Да, 200 на 200."
    },
    {
      "start": 17.79,
      "end": 21.01,
      "speaker": null,
      "text": "По глубине у вас есть определенные критерии?"
    },
    {
      "start": 21.77,
      "end": 24.97,
      "speaker": null,
      "text": "Нет, нету. Чем меньше, тем лучше."
    },
    {
      "start": 26.39,
      "end": 30.15,
      "speaker": null,
      "text": "Так, а вам нужен обработанный или обычный?"
    },
    {
      "start": 31.11,
      "end": 35.87,
      "speaker": null,
      "text": "Ну, с противопожарной пропиской или обычный?"
    },
    {
      "start": 36.31,
      "end": 37.59,
      "speaker": null,
      "text": "Нет, обычный можно."
    },
    {
      "start": 38.19,
      "end": 38.33,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 39.21,
      "end": 47.76,
      "speaker": null,
      "text": "У нас есть определенные сроки, когда это нужно вам получить, когда монтаж, демонтаж потребуется?"
    },
    {
      "start": 48.22,
      "end": 55.56,
      "speaker": null,
      "text": "Да, мне нужно, чтобы 31 числа днём уже привезли и поставили его на площадку."
    },
    {
      "start": 55.65,
      "end": 59.35,
      "speaker": null,
      "text": "Угу. А адрес площадки у вас есть?"
    },
    {
      "start": 60.08,
      "end": 61.54,
      "speaker": null,
      "text": "Это замкадом."
    },
    {
      "start": 62.14,
      "end": 63.04,
      "speaker": null,
      "text": "Так, замкадом."
    },
    {
      "start": 65.94,
      "end": 66.3,
      "speaker": null,
      "text": "Сумки."
    },
    {
      "start": 68.46,
      "end": 74.28,
      "speaker": null,
      "text": "А там определенная какая-нибудь площадка? Это будет на улице или в помещении?"
    },
    {
      "start": 74.46,
      "end": 77.02,
      "speaker": null,
      "text": "Это в помещении в шатре улицы."
    },
    {
      "start": 78.08,
      "end": 80.25,
      "speaker": null,
      "text": "Так, личный шатре."
    },
    {
      "start": 81.44,
      "end": 81.74,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 83.43,
      "end": 83.79,
      "speaker": null,
      "text": "Интересно."
    },
    {
      "start": 84.03,
      "end": 85.99,
      "speaker": null,
      "text": "Интересный запросик у вас."
    },
    {
      "start": 86.43,
      "end": 87.29,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 87.53,
      "end": 89.67,
      "speaker": null,
      "text": "По демонтажу вы как планируете?"
    },
    {
      "start": 89.69,
      "end": 91.97,
      "speaker": null,
      "text": "Просто поставить стенд и всё."
    },
    {
      "start": 92.05,
      "end": 94.71,
      "speaker": null,
      "text": "И он там должен определенное количество времени простоять."
    },
    {
      "start": 94.93,
      "end": 97.97,
      "speaker": null,
      "text": "Сами потом будете его демонтировать или потребуется демонтаж?"
    },
    {
      "start": 98.49,
      "end": 102.61,
      "speaker": null,
      "text": "Но по времени сможем позже договориться, как после потребности?"
    },
    {
      "start": 102.61,
      "end": 108.23,
      "speaker": null,
      "text": "Да, наверное, нужно будет его привезти, собрать, поставить и на следующий день его забрать вечером."
    },
    {
      "start": 108.97,
      "end": 110.05,
      "speaker": null,
      "text": "А, на следующий день."
    },
    {
      "start": 110.31,
      "end": 111.67,
      "speaker": null,
      "text": "Так, поняла."
    },
    {
      "start": 116.6,
      "end": 119.38,
      "speaker": null,
      "text": "Принято. Два на два, поменьше."
    },
    {
      "start": 119.92,
      "end": 126.3,
      "speaker": null,
      "text": "А макеты у вас готовы или там в течение недели следующей сможете подготовить?"
    },
    {
      "start": 126.92,
      "end": 130.44,
      "speaker": null,
      "text": "Нет, я бы хотела, чтобы ваша сотрудница могла его сделать."
    },
    {
      "start": 130.82,
      "end": 132.88,
      "speaker": null,
      "text": "У нас есть логотип из кривых."
    },
    {
      "start": 133.04,
      "end": 136.9,
      "speaker": null,
      "text": "Это один логотип для одного бренда будет, поэтому..."
    },
    {
      "start": 137.83,
      "end": 142.85,
      "speaker": null,
      "text": "А, то есть вы хотите, чтобы просто, получается, стоял брус и на макете ушло..."
    },
    {
      "start": 142.85,
      "end": 145.67,
      "speaker": null,
      "text": "Ну, к примеру, представим, белый фон и просто логотипы, да?"
    },
    {
      "start": 147.01,
      "end": 148.87,
      "speaker": null,
      "text": "Не белый, черный."
    },
    {
      "start": 149.03,
      "end": 151.23,
      "speaker": null,
      "text": "На черном фоне логотип."
    },
    {
      "start": 151.23,
      "end": 152.57,
      "speaker": null,
      "text": "Логотип, да."
    },
    {
      "start": 153.73,
      "end": 155.21,
      "speaker": null,
      "text": "Ага, так, поняла."
    },
    {
      "start": 155.41,
      "end": 156.67,
      "speaker": null,
      "text": "Поняла по макету."
    },
    {
      "start": 157.99,
      "end": 162.26,
      "speaker": null,
      "text": "Так, в целом запрос я приняла."
    },
    {
      "start": 164.34,
      "end": 164.64,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 165.8,
      "end": 166.78,
      "speaker": null,
      "text": "Это все понятно."
    },
    {
      "start": 166.94,
      "end": 168.34,
      "speaker": null,
      "text": "Дополнительно что-то потребуется?"
    },
    {
      "start": 168.52,
      "end": 170.88,
      "speaker": null,
      "text": "Фотография, семейная продукция там может быть?"
    },
    {
      "start": 171.1,
      "end": 171.52,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 172.54,
      "end": 177.66,
      "speaker": null,
      "text": "Уточните, пожалуйста, стоимость со всем вот этим пакетом, что я уточнила."
    },
    {
      "start": 177.66,
      "end": 181.66,
      "speaker": null,
      "text": "По монтажу-демонтажу это мне нужно уточнять у монтажника,"
    },
    {
      "start": 182.58,
      "end": 186.04,
      "speaker": null,
      "text": "потому что это нужно будет, ну, именно до Ахимов доезжать."
    },
    {
      "start": 186.14,
      "end": 187.54,
      "speaker": null,
      "text": "В общем, эти моменты я уточню."
    },
    {
      "start": 187.74,
      "end": 190.32,
      "speaker": null,
      "text": "По самому стенду могу вам сразу сказать,"
    },
    {
      "start": 190.42,
      "end": 193.14,
      "speaker": null,
      "text": "если размер 2 на 2 и он будет без запропостки,"
    },
    {
      "start": 193.2,
      "end": 194.98,
      "speaker": null,
      "text": "то это стандартный у нас брендбол."
    },
    {
      "start": 195.64,
      "end": 199.54,
      "speaker": null,
      "text": "Вот. И по стоимости сама конструкция плюс печать на баннере"
    },
    {
      "start": 199.54,
      "end": 202.56,
      "speaker": null,
      "text": "Вам же нужен односторонний или чтобы с двух сторон баннер был?"
    },
    {
      "start": 203.12,
      "end": 204.54,
      "speaker": null,
      "text": "Одна сторона нужна."
    },
    {
      "start": 204.54,
      "end": 208.4,
      "speaker": null,
      "text": "Если односторонний, то это 13 тысяч рублей, это под ключ."
    },
    {
      "start": 208.54,
      "end": 211.94,
      "speaker": null,
      "text": "Это конструкция с печатью уже, то есть полностью все готово."
    },
    {
      "start": 212.56,
      "end": 216.42,
      "speaker": null,
      "text": "Вот. По монтажу доставки, да, это мне нужно будет уточнить,"
    },
    {
      "start": 216.58,
      "end": 218.72,
      "speaker": null,
      "text": "потому что у меня именно монтажник сам выезжает."
    },
    {
      "start": 218.76,
      "end": 220.76,
      "speaker": null,
      "text": "У меня такой вопрос появился."
    },
    {
      "start": 221.9,
      "end": 226.54,
      "speaker": null,
      "text": "Эта конструкция, она предназначена для повторного использования?"
    },
    {
      "start": 227.14,
      "end": 228.26,
      "speaker": null,
      "text": "То есть не надо?"
    },
    {
      "start": 228.36,
      "end": 229.4,
      "speaker": null,
      "text": "Ну, никогда вообще нет."
    },
    {
      "start": 229.42,
      "end": 234.4,
      "speaker": null,
      "text": "Если разбирается брусовая конструкция, она не используется повторно."
    },
    {
      "start": 234.54,
      "end": 237.62,
      "speaker": null,
      "text": "Ну, потому что и баннер будет плохо начанут,"
    },
    {
      "start": 237.76,
      "end": 240.4,
      "speaker": null,
      "text": "так как это, ну, это в прямом смысле дерево."
    },
    {
      "start": 240.82,
      "end": 244.58,
      "speaker": null,
      "text": "Вот. И плюс если еще это на улице, там вдруг дождь,"
    },
    {
      "start": 244.64,
      "end": 246.88,
      "speaker": null,
      "text": "кто-то что-то может быть прольет еще что-то."
    },
    {
      "start": 246.88,
      "end": 251.74,
      "speaker": null,
      "text": "Нет, это под крышей шатре. Я поняла. Хорошо."
    },
    {
      "start": 251.74,
      "end": 255.9,
      "speaker": null,
      "text": "Да, но если нужна сборная-разборная, то это лучше тогда другой станет посмотреть,"
    },
    {
      "start": 256.6,
      "end": 260.06,
      "speaker": null,
      "text": "если потом использовать, чтобы тоже там на тот же монтаж,"
    },
    {
      "start": 260.16,
      "end": 261.7,
      "speaker": null,
      "text": "где монтаж, к примеру, не тратится,"
    },
    {
      "start": 262.0,
      "end": 264.24,
      "speaker": null,
      "text": "а чтоб я просто вам его привезла курьером,"
    },
    {
      "start": 264.46,
      "end": 266.6,
      "speaker": null,
      "text": "и вы там действительно могли собрать."
    },
    {
      "start": 267.1,
      "end": 268.68,
      "speaker": null,
      "text": "Это нам не подходит."
    },
    {
      "start": 269.1,
      "end": 271.84,
      "speaker": null,
      "text": "Они выглядят очень просто, очень дешево."
    },
    {
      "start": 271.84,
      "end": 275.66,
      "speaker": null,
      "text": "Вот. А там, тем более, видно вот эти вот стойки."
    },
    {
      "start": 276.1,
      "end": 277.9,
      "speaker": null,
      "text": "Я уже разные видела просто в моменте."
    },
    {
      "start": 277.94,
      "end": 279.2,
      "speaker": null,
      "text": "Да, вы уже посмотрели все."
    },
    {
      "start": 279.28,
      "end": 281.18,
      "speaker": null,
      "text": "Да, тут конкретно он будет стоять,"
    },
    {
      "start": 281.38,
      "end": 284.04,
      "speaker": null,
      "text": "а вся, например, никаких дополнительных деталей не будет."
    },
    {
      "start": 284.26,
      "end": 285.9,
      "speaker": null,
      "text": "Все здесь будет выглядеть хорошо."
    },
    {
      "start": 286.66,
      "end": 289.58,
      "speaker": null,
      "text": "Ну, кстати, если про детали, то что вам не нравится,"
    },
    {
      "start": 289.78,
      "end": 293.64,
      "speaker": null,
      "text": "что ножки будут видны там или еще где-то конструкция будет видна."
    },
    {
      "start": 293.96,
      "end": 296.2,
      "speaker": null,
      "text": "По типу бруса, но многоразовая история,"
    },
    {
      "start": 296.34,
      "end": 297.56,
      "speaker": null,
      "text": "это тканевый стенд Лика."
    },
    {
      "start": 297.76,
      "end": 299.32,
      "speaker": null,
      "text": "Вот он примерно так же выглядит,"
    },
    {
      "start": 299.32,
      "end": 302.3,
      "speaker": null,
      "text": "только этот тканевый стенд он полностью весь закрывает,"
    },
    {
      "start": 302.6,
      "end": 304.76,
      "speaker": null,
      "text": "то есть там не будет как в брендволе."
    },
    {
      "start": 304.86,
      "end": 305.96,
      "speaker": null,
      "text": "Тут, например, смотрите,"
    },
    {
      "start": 306.58,
      "end": 308.22,
      "speaker": null,
      "text": "у нас просто в примерах,"
    },
    {
      "start": 309.54,
      "end": 311.36,
      "speaker": null,
      "text": "конструкция закрыта спереди,"
    },
    {
      "start": 311.54,
      "end": 313.04,
      "speaker": null,
      "text": "а сзади ее будет видно,"
    },
    {
      "start": 313.14,
      "end": 315.32,
      "speaker": null,
      "text": "то есть вот эти ножки от дерева"
    },
    {
      "start": 315.92,
      "end": 316.9,
      "speaker": null,
      "text": "будут видны сзади."
    },
    {
      "start": 317.08,
      "end": 319.46,
      "speaker": null,
      "text": "Потому что если вам нужны именно односторонние,"
    },
    {
      "start": 319.52,
      "end": 320.34,
      "speaker": null,
      "text": "если с двух сторон,"
    },
    {
      "start": 320.52,
      "end": 322.18,
      "speaker": null,
      "text": "то с двух сторон баннером оттянем,"
    },
    {
      "start": 322.32,
      "end": 323.56,
      "speaker": null,
      "text": "и конструкция не будет видна,"
    },
    {
      "start": 323.6,
      "end": 325.24,
      "speaker": null,
      "text": "она будет как вот..."
    },
    {
      "start": 325.24,
      "end": 329.5,
      "speaker": null,
      "text": "У нас он будет стоять к стене."
    },
    {
      "start": 329.5,
      "end": 331.24,
      "speaker": null,
      "text": "А, если к стене, ага."
    },
    {
      "start": 331.3,
      "end": 333.98,
      "speaker": null,
      "text": "Да, нам не нужно с обратной стороны"
    },
    {
      "start": 333.98,
      "end": 336.44,
      "speaker": null,
      "text": "ничем его затягивать и обтягивать, да."
    },
    {
      "start": 337.66,
      "end": 340.36,
      "speaker": null,
      "text": "Ну, в любом случае, если сборная-разборная,"
    },
    {
      "start": 341.24,
      "end": 343.38,
      "speaker": null,
      "text": "тогда можно сделать просто одностороннюю печать,"
    },
    {
      "start": 343.44,
      "end": 344.32,
      "speaker": null,
      "text": "если над камерой."
    },
    {
      "start": 344.32,
      "end": 346.9,
      "speaker": null,
      "text": "Если все-таки планируете смотреть брут,"
    },
    {
      "start": 347.08,
      "end": 350.0,
      "speaker": null,
      "text": "то да, это вот на один раз либо просто поставить"
    },
    {
      "start": 350.0,
      "end": 351.84,
      "speaker": null,
      "text": "и там в зависимости от того,"
    },
    {
      "start": 351.92,
      "end": 353.8,
      "speaker": null,
      "text": "когда у вас еще будет мероприятие."
    },
    {
      "start": 354.3,
      "end": 355.36,
      "speaker": null,
      "text": "В целом, если вы..."
    },
    {
      "start": 355.36,
      "end": 356.5,
      "speaker": null,
      "text": "Я прошу, девушка."
    },
    {
      "start": 357.0,
      "end": 358.78,
      "speaker": null,
      "text": "Сейчас секундочку, у меня вторая линия."
    },
    {
      "start": 359.04,
      "end": 359.82,
      "speaker": null,
      "text": "Подождите, пожалуйста."
    },
    {
      "start": 361.05,
      "end": 362.78,
      "speaker": null,
      "text": "Пожалуйста, оставайтесь на линии."
    },
    {
      "start": 362.96,
      "end": 364.32,
      "speaker": null,
      "text": "Через некоторое время"
    },
    {
      "start": 364.32,
      "end": 366.28,
      "speaker": null,
      "text": "вы сможете продолжить разговор."
    },
    {
      "start": 366.28,
      "end": 368.32,
      "speaker": null,
      "text": "Продолжение следует..."
    },
    {
      "start": 368.32,
      "end": 370.26,
      "speaker": null,
      "text": "Продолжение следует..."
    },
    {
      "start": 370.26,
      "end": 371.44,
      "speaker": null,
      "text": "Продолжение следует..."
    },
    {
      "start": 371.44,
      "end": 371.7,
      "speaker": null,
      "text": "Продолжение следует..."
    }
  ]
}