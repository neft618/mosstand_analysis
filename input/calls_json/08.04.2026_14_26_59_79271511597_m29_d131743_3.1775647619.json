{
  "file": "08.04.2026_14_26_59_79271511597_m29_d131743_3.1775647619.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 200.2,
  "segments": [
    {
      "start": 1.01,
      "end": 4.39,
      "speaker": null,
      "text": "Добрый день, меня зовут Ксения, компания «Мистент». Как я могу к вам обращаться?"
    },
    {
      "start": 5.69,
      "end": 10.43,
      "speaker": null,
      "text": "Здравствуйте, меня зовут тоже Ксения. Я представляю компанию «Сиалко Экспресс»."
    },
    {
      "start": 10.46,
      "end": 26.08,
      "speaker": null,
      "text": "Ксения, скажите, пожалуйста, отправляла 3 часа назад примерно запрос на расчёт стендов вместе с конструкциями. Хотела бы вот точнить, дошло ли сообщение или может быть спам улетело?"
    },
    {
      "start": 26.82,
      "end": 34.7,
      "speaker": null,
      "text": "Я сейчас посмотрю по базе. Сейчас я вам сказать не могу, потому что точно это не на меня попало. Вам ещё никто не ответил?"
    },
    {
      "start": 35.4,
      "end": 37.46,
      "speaker": null,
      "text": "Нет, вот не ответили, поэтому звоню."
    },
    {
      "start": 39.01,
      "end": 42.51,
      "speaker": null,
      "text": "Так, а вы куда отправляли запрос? На почту?"
    },
    {
      "start": 43.05,
      "end": 47.47,
      "speaker": null,
      "text": "Так, я отправляла на почту, да, на info.sobachka.ru"
    },
    {
      "start": 47.47,
      "end": 51.11,
      "speaker": null,
      "text": "Сейчас смотрю."
    },
    {
      "start": 52.56,
      "end": 69.45,
      "speaker": null,
      "text": "А вы с какой почтой присылали? Ну, какая ваша?"
    },
    {
      "start": 69.45,
      "end": 72.59,
      "speaker": null,
      "text": "Я поняла. Диктую, да?"
    },
    {
      "start": 74.22,
      "end": 74.74,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 76.3,
      "end": 80.34,
      "speaker": null,
      "text": "Как подарки на английском через «г»."
    },
    {
      "start": 81.35,
      "end": 88.58,
      "speaker": null,
      "text": "Что так по слову этому?"
    },
    {
      "start": 89.06,
      "end": 90.36,
      "speaker": null,
      "text": "Или полностью вам диктовать хочется?"
    },
    {
      "start": 90.56,
      "end": 91.3,
      "speaker": null,
      "text": "Загружается."
    },
    {
      "start": 92.33,
      "end": 130.6,
      "speaker": null,
      "text": "Так, а какой там домен у вас после собаки?"
    },
    {
      "start": 131.46,
      "end": 133.12,
      "speaker": null,
      "text": "Афиалко Экспресс?"
    },
    {
      "start": 133.28,
      "end": 140.66,
      "speaker": null,
      "text": "После собачки, да. Там есть собачка, дальше фиалко, как пишут, так пишут в перескей."
    },
    {
      "start": 142.7,
      "end": 142.98,
      "speaker": null,
      "text": "Сейчас."
    },
    {
      "start": 151.45,
      "end": 154.31,
      "speaker": null,
      "text": "Нет, мы ничего не можем. Вы точно нам отправляли?"
    },
    {
      "start": 155.2,
      "end": 155.76,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 156.62,
      "end": 157.44,
      "speaker": null,
      "text": "Вот на info."
    },
    {
      "start": 158.14,
      "end": 160.2,
      "speaker": null,
      "text": "Не знаю, вот давайте я продублирую тогда."
    },
    {
      "start": 161.38,
      "end": 165.58,
      "speaker": null,
      "text": "Да, и подскажите, ранее вы обращались в нашу компанию?"
    },
    {
      "start": 165.8,
      "end": 167.96,
      "speaker": null,
      "text": "Уже вели дело с нашими менеджерами?"
    },
    {
      "start": 167.98,
      "end": 169.62,
      "speaker": null,
      "text": "Нет, ранее мы не сотрудничали."
    },
    {
      "start": 171.4,
      "end": 172.66,
      "speaker": null,
      "text": "Так, поняла вас."
    },
    {
      "start": 174.94,
      "end": 177.18,
      "speaker": null,
      "text": "Ну да, найти я вообще никак не могу вас..."
    },
    {
      "start": 177.18,
      "end": 178.68,
      "speaker": null,
      "text": "Попробуйте продублировать, пожалуйста."
    },
    {
      "start": 179.34,
      "end": 181.26,
      "speaker": null,
      "text": "Угу, хорошо, спасибо."
    },
    {
      "start": 181.84,
      "end": 184.8,
      "speaker": null,
      "text": "Угу, да, сейчас у вас еще попробую найти, ну..."
    },
    {
      "start": 184.8,
      "end": 187.74,
      "speaker": null,
      "text": "Ага, хорошо, спасибо."
    },
    {
      "start": 187.98,
      "end": 188.94,
      "speaker": null,
      "text": "Так, продублировала."
    },
    {
      "start": 191.33,
      "end": 192.53,
      "speaker": null,
      "text": "Ты очень злой ответа."
    },
    {
      "start": 193.01,
      "end": 195.13,
      "speaker": null,
      "text": "Да, хорошо, я сейчас посмотрю."
    },
    {
      "start": 195.72,
      "end": 197.82,
      "speaker": null,
      "text": "Угу, да, угу, да, на связи."
    }
  ]
}