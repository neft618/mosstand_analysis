{
  "file": "29.05.2026_13_00_31_79898269020_m21_d138145_b.1780048832.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 115.6,
  "segments": [
    {
      "start": 0.37,
      "end": 3.71,
      "speaker": null,
      "text": "Компания «Лаптест», Артём, как мне к вам здесь всё?"
    },
    {
      "start": 4.15,
      "end": 12.25,
      "speaker": null,
      "text": "Да, здравствуйте, Артём. Меня зовут Варвара, компания «Лаптест». Мы ранее с вами сотрудничали по баннерам, роллапам и так далее."
    },
    {
      "start": 12.91,
      "end": 26.27,
      "speaker": null,
      "text": "Нас вёл менеджер Иван, как мне передал руководство. Мы бы хотели перетянуть у вас уже имеющийся у нас баннер, то есть конструкция-то есть, надо перетянуть, видимо, с новым макетом."
    },
    {
      "start": 26.27,
      "end": 30.07,
      "speaker": null,
      "text": "Вот, я в WhatsApp писала по этому номеру, мне никто не ответил."
    },
    {
      "start": 30.23,
      "end": 32.67,
      "speaker": null,
      "text": "А WhatsApp у нас не работает, извините, Варвара."
    },
    {
      "start": 32.69,
      "end": 36.39,
      "speaker": null,
      "text": "А, не работает. Да, меня интересует..."
    },
    {
      "start": 36.39,
      "end": 38.61,
      "speaker": null,
      "text": "Ещё раз, извините, как компания «Лаптест»?"
    },
    {
      "start": 39.69,
      "end": 40.29,
      "speaker": null,
      "text": "«Лаптест»."
    },
    {
      "start": 45.95,
      "end": 53.52,
      "speaker": null,
      "text": "По такому причинам-то не находят «Лаптест»."
    },
    {
      "start": 53.52,
      "end": 55.56,
      "speaker": null,
      "text": "А какой баннер на каком сайте вот?"
    },
    {
      "start": 57.02,
      "end": 59.92,
      "speaker": null,
      "text": "210 на 200, он был размером."
    },
    {
      "start": 61.16,
      "end": 62.28,
      "speaker": null,
      "text": "210 на?"
    },
    {
      "start": 62.94,
      "end": 63.76,
      "speaker": null,
      "text": "На 200."
    },
    {
      "start": 65.2,
      "end": 65.56,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 69.67,
      "end": 71.79,
      "speaker": null,
      "text": "Это был просто баннер или какая-то другая конструкция?"
    },
    {
      "start": 72.03,
      "end": 74.69,
      "speaker": null,
      "text": "Там, айтек, может быть, какой-то текстильный стенд или поп-ап?"
    },
    {
      "start": 74.97,
      "end": 75.69,
      "speaker": null,
      "text": "Или просто баннер?"
    },
    {
      "start": 75.95,
      "end": 76.07,
      "speaker": null,
      "text": "Что-что?"
    },
    {
      "start": 76.85,
      "end": 78.51,
      "speaker": null,
      "text": "У вас был просто баннер?"
    },
    {
      "start": 78.65,
      "end": 79.51,
      "speaker": null,
      "text": "Правильно я понимаю, да?"
    },
    {
      "start": 80.17,
      "end": 82.07,
      "speaker": null,
      "text": "Ну, у нас, видимо, да, был баннер."
    },
    {
      "start": 82.25,
      "end": 82.99,
      "speaker": null,
      "text": "Он был..."
    },
    {
      "start": 82.99,
      "end": 86.65,
      "speaker": null,
      "text": "Ну, как бы у нас на складе он висит уже с полотном лежит."
    },
    {
      "start": 86.65,
      "end": 90.29,
      "speaker": null,
      "text": "Он такой раздвижной, получается, вверх надвигается."
    },
    {
      "start": 90.93,
      "end": 91.25,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 91.49,
      "end": 95.45,
      "speaker": null,
      "text": "И, короче, надо перетянуть полотно на другой макет."
    },
    {
      "start": 96.63,
      "end": 96.99,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 97.17,
      "end": 100.85,
      "speaker": null,
      "text": "Хорошо, давайте попробуем перенаправить Ивану всю информацию, чтобы он с вами связался."
    },
    {
      "start": 100.99,
      "end": 101.13,
      "speaker": null,
      "text": "Хорошо?"
    },
    {
      "start": 101.13,
      "end": 101.85,
      "speaker": null,
      "text": "Это контакт."
    },
    {
      "start": 101.87,
      "end": 102.41,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 102.81,
      "end": 104.25,
      "speaker": null,
      "text": "Вот по этому номеру."
    },
    {
      "start": 104.43,
      "end": 110.73,
      "speaker": null,
      "text": "Там, может, можете с СМС-кой или, ну, найти меня в том же ВАЦАДе, но лучше позвоните или СМС-кой."
    },
    {
      "start": 110.73,
      "end": 111.53,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 111.79,
      "end": 112.29,
      "speaker": null,
      "text": "Ну, хорошо."
    },
    {
      "start": 112.75,
      "end": 113.81,
      "speaker": null,
      "text": "Все, благодарю вас."
    },
    {
      "start": 114.03,
      "end": 114.23,
      "speaker": null,
      "text": "Угу."
    }
  ]
}