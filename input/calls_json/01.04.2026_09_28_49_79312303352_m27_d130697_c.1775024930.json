{
  "file": "01.04.2026_09_28_49_79312303352_m27_d130697_c.1775024930.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 196.0,
  "segments": [
    {
      "start": 0.3,
      "end": 3.66,
      "speaker": null,
      "text": "Доброе утро, меня зовут Валентин, компания «Мостон», чем я могу вам помочь?"
    },
    {
      "start": 4.02,
      "end": 10.37,
      "speaker": null,
      "text": "Здравствуйте, Валентин. Нужна печать восьми роллап в Москве до пятницы 100 на 200."
    },
    {
      "start": 11.37,
      "end": 13.23,
      "speaker": null,
      "text": "Скажите, пожалуйста, как я могу к вам обращаться?"
    },
    {
      "start": 13.81,
      "end": 14.27,
      "speaker": null,
      "text": "Всего вот."
    },
    {
      "start": 14.79,
      "end": 19.23,
      "speaker": null,
      "text": "Всего вот. А роллапы вам необходимы с конструкцией или просто печать?"
    },
    {
      "start": 19.59,
      "end": 20.35,
      "speaker": null,
      "text": "Да, с конструкцией."
    },
    {
      "start": 20.51,
      "end": 22.27,
      "speaker": null,
      "text": "С конструкцией, секунда."
    },
    {
      "start": 31.21,
      "end": 33.61,
      "speaker": null,
      "text": "100 на 200, классик или капля?"
    },
    {
      "start": 34.79,
      "end": 35.43,
      "speaker": null,
      "text": "Классик."
    },
    {
      "start": 36.65,
      "end": 37.31,
      "speaker": null,
      "text": "Классик."
    },
    {
      "start": 39.06,
      "end": 40.94,
      "speaker": null,
      "text": "К пятнице. А макета у вас уже готова?"
    },
    {
      "start": 41.22,
      "end": 43.3,
      "speaker": null,
      "text": "Да, у нас пресски собраны."
    },
    {
      "start": 44.41,
      "end": 44.81,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 46.99,
      "end": 50.51,
      "speaker": null,
      "text": "100 на 200, рулап стоит 5900 рублей."
    },
    {
      "start": 51.09,
      "end": 54.95,
      "speaker": null,
      "text": "Стоимость выходит конструкция, печать на баннере, сумка для переноса и хранения в подарок."
    },
    {
      "start": 55.29,
      "end": 55.95,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 56.41,
      "end": 58.25,
      "speaker": null,
      "text": "Доставка у вас есть?"
    },
    {
      "start": 58.61,
      "end": 61.57,
      "speaker": null,
      "text": "Да, доставка в пределах МКАД у нас 500 рублей."
    },
    {
      "start": 62.29,
      "end": 66.44,
      "speaker": null,
      "text": "Мы немножко выше МКАДа, там буквально 500 метров или..."
    },
    {
      "start": 67.77,
      "end": 69.93,
      "speaker": null,
      "text": "В таком случае необходимо будет посчитать?"
    },
    {
      "start": 70.43,
      "end": 72.47,
      "speaker": null,
      "text": "Потому что там в любом случае своя тарификация."
    },
    {
      "start": 72.73,
      "end": 76.67,
      "speaker": null,
      "text": "Да, я корою адрес скину, так вам переслать можно."
    },
    {
      "start": 76.93,
      "end": 79.67,
      "speaker": null,
      "text": "Я с вами сижусь по этому номеру телефона в Телеграм можно?"
    },
    {
      "start": 80.47,
      "end": 80.75,
      "speaker": null,
      "text": "А, да."
    },
    {
      "start": 81.53,
      "end": 81.83,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 82.33,
      "end": 86.15,
      "speaker": null,
      "text": "А по мероприятию скажите, пожалуйста, оно у вас в каком формате будет проходить?"
    },
    {
      "start": 86.23,
      "end": 87.49,
      "speaker": null,
      "text": "Это выставка или..."
    },
    {
      "start": 89.27,
      "end": 90.27,
      "speaker": null,
      "text": "Это выставка."
    },
    {
      "start": 90.47,
      "end": 90.75,
      "speaker": null,
      "text": "Верно."
    },
    {
      "start": 91.53,
      "end": 91.89,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 92.86,
      "end": 94.26,
      "speaker": null,
      "text": "А чем занимается ваша компания?"
    },
    {
      "start": 95.22,
      "end": 98.54,
      "speaker": null,
      "text": "У нас образование, мы ЛНКОшка."
    },
    {
      "start": 99.72,
      "end": 100.8,
      "speaker": null,
      "text": "Я вас понял."
    },
    {
      "start": 101.2,
      "end": 104.48,
      "speaker": null,
      "text": "А на выставку вам может потребоваться полиграфия, может сувенирная продукция?"
    },
    {
      "start": 104.56,
      "end": 105.42,
      "speaker": null,
      "text": "Мы ее также производим."
    },
    {
      "start": 105.58,
      "end": 107.14,
      "speaker": null,
      "text": "Вы бейджи печатаете?"
    },
    {
      "start": 107.38,
      "end": 108.4,
      "speaker": null,
      "text": "Да, бейджи печатаем."
    },
    {
      "start": 108.4,
      "end": 109.38,
      "speaker": null,
      "text": "Супер."
    },
    {
      "start": 109.54,
      "end": 111.12,
      "speaker": null,
      "text": "Тогда подскажите по цене."
    },
    {
      "start": 111.5,
      "end": 114.18,
      "speaker": null,
      "text": "И тоже бейджи нужны уже завтра."
    },
    {
      "start": 115.53,
      "end": 121.97,
      "speaker": null,
      "text": "По бейджам необходимо будет посчитать, потому что зависит от плотности, на которой необходимо, от размера бейджи непосредственно."
    },
    {
      "start": 122.15,
      "end": 125.61,
      "speaker": null,
      "text": "Тут дешевле и проще."
    },
    {
      "start": 126.01,
      "end": 128.31,
      "speaker": null,
      "text": "Это просто формальность у нас не пускают без них."
    },
    {
      "start": 128.59,
      "end": 130.55,
      "speaker": null,
      "text": "Нам надо участникам раздать ее массово."
    },
    {
      "start": 131.29,
      "end": 132.45,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 132.79,
      "end": 136.05,
      "speaker": null,
      "text": "А необходимы с креплением или просто с вырезом для того чтобы..."
    },
    {
      "start": 136.05,
      "end": 148.67,
      "speaker": null,
      "text": "Нет, нам просто у нас участнику навесили табличку, что он проще и лучше, чем..."
    },
    {
      "start": 149.73,
      "end": 151.07,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 152.53,
      "end": 155.27,
      "speaker": null,
      "text": "Получается бейджи с креплениями будут необходимы сразу?"
    },
    {
      "start": 155.51,
      "end": 156.29,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 156.93,
      "end": 160.15,
      "speaker": null,
      "text": "Хорошо, бейджи мне необходимо посчитать, это буквально..."
    },
    {
      "start": 160.15,
      "end": 162.75,
      "speaker": null,
      "text": "Да, я тогда все макеты и реквизиты все скину."
    },
    {
      "start": 163.39,
      "end": 164.97,
      "speaker": null,
      "text": "Все хорошо, благодарю вас."
    },
    {
      "start": 165.51,
      "end": 165.59,
      "speaker": null,
      "text": "Отлично, спасибо."
    },
    {
      "start": 167.95,
      "end": 169.59,
      "speaker": null,
      "text": "И последнее по полиграфии."
    },
    {
      "start": 169.59,
      "end": 172.71,
      "speaker": null,
      "text": "Вы, у вас блокноты тоже делаете или нет?"
    },
    {
      "start": 173.07,
      "end": 174.87,
      "speaker": null,
      "text": "Да, блокноты также делаем."
    },
    {
      "start": 174.95,
      "end": 176.75,
      "speaker": null,
      "text": "Вам с нанесением необходимо или..."
    },
    {
      "start": 176.75,
      "end": 177.63,
      "speaker": null,
      "text": "С нанесением."
    },
    {
      "start": 178.15,
      "end": 180.59,
      "speaker": null,
      "text": "Раздатка сверху на кольцах опять."
    },
    {
      "start": 182.51,
      "end": 183.85,
      "speaker": null,
      "text": "Хорошо, я вам тогда предложу."
    },
    {
      "start": 184.47,
      "end": 185.89,
      "speaker": null,
      "text": "Напишите тогда в Телеграме."
    },
    {
      "start": 186.41,
      "end": 188.71,
      "speaker": null,
      "text": "Вот сейчас я все макеты просто закину потом..."
    },
    {
      "start": 189.55,
      "end": 190.27,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 191.57,
      "end": 192.13,
      "speaker": null,
      "text": "Всего доброго."
    },
    {
      "start": 192.13,
      "end": 194.17,
      "speaker": null,
      "text": "Вам спасибо за ответственность."
    },
    {
      "start": 194.41,
      "end": 195.09,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}