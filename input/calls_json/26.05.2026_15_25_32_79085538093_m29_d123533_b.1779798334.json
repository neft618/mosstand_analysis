{
  "file": "26.05.2026_15_25_32_79085538093_m29_d123533_b.1779798334.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 230.3,
  "segments": [
    {
      "start": 0.78,
      "end": 4.26,
      "speaker": null,
      "text": "Добрый день, меня зовут Ксения, компания на стенд. Как могу к вам обращаться?"
    },
    {
      "start": 4.94,
      "end": 6.86,
      "speaker": null,
      "text": "Ксения, здравствуйте! Меня Арина зовут."
    },
    {
      "start": 7.7,
      "end": 9.82,
      "speaker": null,
      "text": "Арина, очень приятно. Чем могу вам помочь?"
    },
    {
      "start": 10.5,
      "end": 15.2,
      "speaker": null,
      "text": "Да, Ксения, смотрите, мы с вами созванивались приблизительно, наверное, где-то в феврале."
    },
    {
      "start": 15.88,
      "end": 24.44,
      "speaker": null,
      "text": "У нас была заявка, я потом её убрала, потому что шёл долгий процесс согласования по изготовлению вот этих вот всех стендов и так далее."
    },
    {
      "start": 24.56,
      "end": 29.4,
      "speaker": null,
      "text": "Они нам или не нужны. Ну вот, по итогу мы приняли решение, что они нам нужны."
    },
    {
      "start": 29.4,
      "end": 34.26,
      "speaker": null,
      "text": "И сейчас руководство запрашивает стоимость."
    },
    {
      "start": 35.64,
      "end": 37.76,
      "speaker": null,
      "text": "Угу, а каких из?"
    },
    {
      "start": 38.64,
      "end": 45.5,
      "speaker": null,
      "text": "А, смотрите, у меня вот здесь вот есть документ с техническим заданием для изготовления макетов."
    },
    {
      "start": 45.5,
      "end": 52.92,
      "speaker": null,
      "text": "Вот, нам нужен получается один roll-up, один pop-up, табличка пластиковая."
    },
    {
      "start": 53.96,
      "end": 61.6,
      "speaker": null,
      "text": "Вот, как сказать… Ну вот условно, как на дверь вешают вот такое вот обозначение, что вот, например, здесь та или иная."
    },
    {
      "start": 62.06,
      "end": 62.62,
      "speaker": null,
      "text": "Указатель, да?"
    },
    {
      "start": 62.62,
      "end": 63.18,
      "speaker": null,
      "text": "Организация."
    },
    {
      "start": 63.3,
      "end": 64.24,
      "speaker": null,
      "text": "Да, типа указатель."
    },
    {
      "start": 64.34,
      "end": 64.58,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 64.76,
      "end": 65.02,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 65.22,
      "end": 68.88,
      "speaker": null,
      "text": "И информационный стенд, там их 44 штуки нам нужно."
    },
    {
      "start": 69.0,
      "end": 69.58,
      "speaker": null,
      "text": "Ну, поняли, да?"
    },
    {
      "start": 69.68,
      "end": 71.78,
      "speaker": null,
      "text": "Информационный стенд, который с этими вкладышами."
    },
    {
      "start": 71.78,
      "end": 77.63,
      "speaker": null,
      "text": "У вас же дела такие, да, установки?"
    },
    {
      "start": 77.73,
      "end": 77.87,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 78.07,
      "end": 79.01,
      "speaker": null,
      "text": "Это все мы делаем."
    },
    {
      "start": 79.19,
      "end": 82.35,
      "speaker": null,
      "text": "Единственное, мне нужно точно понимать по всем размерам."
    },
    {
      "start": 82.89,
      "end": 84.19,
      "speaker": null,
      "text": "Да, размеры есть."
    },
    {
      "start": 84.81,
      "end": 85.29,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 86.13,
      "end": 86.89,
      "speaker": null,
      "text": "Размеры есть."
    },
    {
      "start": 87.11,
      "end": 87.97,
      "speaker": null,
      "text": "Количество есть."
    },
    {
      "start": 88.29,
      "end": 88.59,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 88.65,
      "end": 93.47,
      "speaker": null,
      "text": "Ссылку на печать, условно, их материалы, чтобы на них внешне посмотреть, что там нужно печатать, тоже есть."
    },
    {
      "start": 93.47,
      "end": 94.15,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 94.33,
      "end": 94.65,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 94.93,
      "end": 100.29,
      "speaker": null,
      "text": "А я бы хотела, может быть, вам направить это на почту, чтобы вы сделали, может быть, предварительный расчет."
    },
    {
      "start": 100.86,
      "end": 102.7,
      "speaker": null,
      "text": "А как вам будет предложение?"
    },
    {
      "start": 102.94,
      "end": 105.9,
      "speaker": null,
      "text": "Если у вас моя почта сохранена, можно не ее сразу."
    },
    {
      "start": 106.1,
      "end": 108.76,
      "speaker": null,
      "text": "Если почта не сохранена, могу ее продиктовать."
    },
    {
      "start": 108.9,
      "end": 112.22,
      "speaker": null,
      "text": "Ибо вам в МАКС направить это."
    },
    {
      "start": 113.0,
      "end": 113.36,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 114.04,
      "end": 114.48,
      "speaker": null,
      "text": "Давайте…"
    },
    {
      "start": 114.48,
      "end": 115.62,
      "speaker": null,
      "text": "Нет, какой продиктуете."
    },
    {
      "start": 115.82,
      "end": 118.12,
      "speaker": null,
      "text": "Ну нет, вам лучше отправить, чтоб без ошибок было."
    },
    {
      "start": 118.12,
      "end": 119.86,
      "speaker": null,
      "text": "А, в МАКСе есть."
    },
    {
      "start": 120.32,
      "end": 120.44,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 120.54,
      "end": 123.88,
      "speaker": null,
      "text": "В программе там просто по никнейму, поэтому, наверное, лучше МАКСе по номеру телефона."
    },
    {
      "start": 124.48,
      "end": 124.86,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 125.22,
      "end": 126.6,
      "speaker": null,
      "text": "Сейчас посмотрю."
    },
    {
      "start": 126.98,
      "end": 128.76,
      "speaker": null,
      "text": "Посмотрите, отобрали их куда или нет?"
    },
    {
      "start": 129.61,
      "end": 130.89,
      "speaker": null,
      "text": "Вообще должно быть."
    },
    {
      "start": 131.03,
      "end": 134.03,
      "speaker": null,
      "text": "МАКС как раз не закрытая история."
    },
    {
      "start": 134.75,
      "end": 135.29,
      "speaker": null,
      "text": "Секунду."
    },
    {
      "start": 139.61,
      "end": 141.41,
      "speaker": null,
      "text": "Я вроде тоже не закрывала."
    },
    {
      "start": 141.93,
      "end": 142.21,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 142.43,
      "end": 146.05,
      "speaker": null,
      "text": "Нет, у вас почему-то не нужно найти точно, поэтому можно подключить."
    },
    {
      "start": 146.07,
      "end": 146.57,
      "speaker": null,
      "text": "Ага, секунду."
    },
    {
      "start": 146.67,
      "end": 146.83,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 146.95,
      "end": 147.83,
      "speaker": null,
      "text": "Могут все."
    },
    {
      "start": 147.99,
      "end": 150.85,
      "speaker": null,
      "text": "Я сейчас просто настройки приватности изменила."
    },
    {
      "start": 151.19,
      "end": 151.63,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 151.63,
      "end": 151.71,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 152.17,
      "end": 154.0,
      "speaker": null,
      "text": "Сейчас еще раз попробую."
    },
    {
      "start": 158.29,
      "end": 159.39,
      "speaker": null,
      "text": "Все, да, можно."
    },
    {
      "start": 159.67,
      "end": 159.79,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 159.97,
      "end": 161.63,
      "speaker": null,
      "text": "Так, сейчас я вам там…"
    },
    {
      "start": 162.17,
      "end": 166.23,
      "speaker": null,
      "text": "Так, МАКС направила и сейчас свою почту вам направлю, чтобы"
    },
    {
      "start": 166.23,
      "end": 168.93,
      "speaker": null,
      "text": "вам это сразу полностью что-то за меня скинуть."
    },
    {
      "start": 169.21,
      "end": 169.47,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 169.67,
      "end": 172.35,
      "speaker": null,
      "text": "Я уже так смогу, конечно, корректно посчитать."
    },
    {
      "start": 173.11,
      "end": 173.39,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 173.51,
      "end": 173.87,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 174.87,
      "end": 175.21,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 175.57,
      "end": 175.99,
      "speaker": null,
      "text": "Все, все."
    },
    {
      "start": 176.07,
      "end": 176.27,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 177.97,
      "end": 179.15,
      "speaker": null,
      "text": "Все, отлично."
    },
    {
      "start": 179.27,
      "end": 181.15,
      "speaker": null,
      "text": "Сейчас я вам тогда скидываю техническое задание."
    },
    {
      "start": 181.41,
      "end": 182.13,
      "speaker": null,
      "text": "Все, супер."
    },
    {
      "start": 182.21,
      "end": 182.77,
      "speaker": null,
      "text": "Тогда жду."
    },
    {
      "start": 182.77,
      "end": 184.07,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 184.07,
      "end": 188.23,
      "speaker": null,
      "text": "Ну, я смогу единственный момент до завтра это все предоставить."
    },
    {
      "start": 188.37,
      "end": 189.81,
      "speaker": null,
      "text": "Даже если поздно вечером."
    },
    {
      "start": 190.82,
      "end": 193.14,
      "speaker": null,
      "text": "Ну, просто у нас сейчас загружка большая."
    },
    {
      "start": 193.22,
      "end": 196.1,
      "speaker": null,
      "text": "Не могу вам утверждать, что я через час вам сразу"
    },
    {
      "start": 196.1,
      "end": 196.66,
      "speaker": null,
      "text": "все скину."
    },
    {
      "start": 196.66,
      "end": 198.36,
      "speaker": null,
      "text": "Если так, нормально по стокам."
    },
    {
      "start": 199.12,
      "end": 199.46,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 200.06,
      "end": 201.02,
      "speaker": null,
      "text": "Давайте тогда…"
    },
    {
      "start": 201.66,
      "end": 201.9,
      "speaker": null,
      "text": "Завтра…"
    },
    {
      "start": 201.9,
      "end": 202.9,
      "speaker": null,
      "text": "Завтра до какого?"
    },
    {
      "start": 203.46,
      "end": 208.76,
      "speaker": null,
      "text": "Ну, сегодня через завтра, я думаю, вечером я буду доделывать"
    },
    {
      "start": 208.76,
      "end": 209.04,
      "speaker": null,
      "text": "дела."
    },
    {
      "start": 209.3,
      "end": 209.46,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 209.62,
      "end": 212.44,
      "speaker": null,
      "text": "И либо поздно вечером вам вышлю, либо рано-рано утром."
    },
    {
      "start": 212.72,
      "end": 213.14,
      "speaker": null,
      "text": "Там часов вечера."
    },
    {
      "start": 213.18,
      "end": 213.7,
      "speaker": null,
      "text": "Завтра, да?"
    },
    {
      "start": 213.76,
      "end": 214.78,
      "speaker": null,
      "text": "Рано-рано утром, если что?"
    },
    {
      "start": 214.86,
      "end": 215.0,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 215.66,
      "end": 215.98,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 216.18,
      "end": 216.3,
      "speaker": null,
      "text": "Все."
    },
    {
      "start": 216.44,
      "end": 216.7,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 216.92,
      "end": 217.04,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 217.04,
      "end": 217.48,
      "speaker": null,
      "text": "Я вас помню."
    },
    {
      "start": 217.48,
      "end": 217.62,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 217.82,
      "end": 218.08,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 219.36,
      "end": 221.0,
      "speaker": null,
      "text": "Ну, в любом случае все вышло."
    },
    {
      "start": 221.16,
      "end": 222.14,
      "speaker": null,
      "text": "Так что не передавайте."
    },
    {
      "start": 222.78,
      "end": 223.44,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 223.44,
      "end": 223.54,
      "speaker": null,
      "text": "Все."
    },
    {
      "start": 223.64,
      "end": 225.64,
      "speaker": null,
      "text": "Теперь тогда ожидаю все полное ТВ."
    },
    {
      "start": 226.42,
      "end": 226.6,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 226.8,
      "end": 227.16,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 227.62,
      "end": 227.8,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 227.92,
      "end": 228.48,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}