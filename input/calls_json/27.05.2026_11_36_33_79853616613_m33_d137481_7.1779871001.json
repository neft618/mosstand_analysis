  "segments": [
    {
      "start": 0.08,
      "end": 1.32,
      "speaker": null,
      "text": "Да, я вас слушаю."
    },
    {
      "start": 1.7,
      "end": 10.38,
      "speaker": null,
      "text": "Да, здравствуйте. Это Иван из мостенда Наталья. Просто утром звонили с номера 495. Это не вы случайно? Может ваши коллеги?"
    },
    {
      "start": 10.46,
      "end": 13.98,
      "speaker": null,
      "text": "Нет, нет, нет, Иван. Вы знаете, я уже не в Инвар работаю."
    },
    {
      "start": 15.44,
      "end": 16.58,
      "speaker": null,
      "text": "А, даже так?"
    },
    {
      "start": 17.39,
      "end": 18.51,
      "speaker": null,
      "text": "Да-да, даже так."
    },
    {
      "start": 19.48,
      "end": 24.88,
      "speaker": null,
      "text": "Я понял, хорошо. Ну может быть в новой компании, если стенды понадобятся, вы звоните, пишите."
    },
    {
      "start": 24.88,
      "end": 30.96,
      "speaker": null,
      "text": "Да, вы знаете, нам понадобятся. Может быть не только стенды и сумки вы нам прекрасные делали."
    },
    {
      "start": 31.44,
      "end": 39.08,
      "speaker": null,
      "text": "Да-да, ну я так, в общем. Брендирование, полиграфия, да. Всё что нужно, вы звоните, пишите. Я на связи."
    },
    {
      "start": 40.0,
      "end": 46.48,
      "speaker": null,
      "text": "Да, знаете, я вас хотела бы попросить выслать контакты. Я не все контакты сохранила, когда меняла работу."
    },
    {
      "start": 47.42,
      "end": 53.44,
      "speaker": null,
      "text": "А, хорошо. Так, секундочку. А у вас к этому номеру Телеграм или Макс? Или куда вам написать?"
    },
    {
      "start": 53.44,
      "end": 56.0,
      "speaker": null,
      "text": "У меня Ватсап, Телеграм и Има."
    },
    {
      "start": 56.54,
      "end": 57.76,
      "speaker": null,
      "text": "Ага, вот по этому номеру, да?"
    },
    {
      "start": 58.64,
      "end": 58.86,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 59.4,
      "end": 59.98,
      "speaker": null,
      "text": "Всё, давай."
    },
    {
      "start": 60.14,
      "end": 60.36,
      "speaker": null,
      "text": "У меня есть телефон."
    },
    {
      "start": 60.84,
      "end": 62.6,
      "speaker": null,
      "text": "Понял, понял. Давай сейчас там тогда напишу."
    },
    {
      "start": 63.18,
      "end": 63.94,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 64.56,
      "end": 65.38,
      "speaker": null,
      "text": "Всё, до свидания."
    },
    {
      "start": 65.74,
      "end": 66.06,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}