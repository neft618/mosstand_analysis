{
  "file": "30.03.2026_14_58_42_79259056665_m27_d130427_a.1774871922.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 88.5,
  "segments": [
    {
      "start": 2.09,
      "end": 7.53,
      "speaker": null,
      "text": "Добрый день, Глеб. Меня зовут Валентин, компания Мосстенд. Оставили заявку на обратную зону. Чем я вам помогу?"
    },
    {
      "start": 8.11,
      "end": 12.02,
      "speaker": null,
      "text": "Скажите, пожалуйста, номер 1 штучка. 85 на 200."
    },
    {
      "start": 13.51,
      "end": 15.27,
      "speaker": null,
      "text": "Когда он будет вам необходим?"
    },
    {
      "start": 15.77,
      "end": 18.81,
      "speaker": null,
      "text": "Когда вы можете сделать, то есть как начнем с какой час?"
    },
    {
      "start": 19.25,
      "end": 24.19,
      "speaker": null,
      "text": "Срок изготовления 1-2 рабочего дня после согласования макета и оплаты счёта. У вас макет уже готов?"
    },
    {
      "start": 24.79,
      "end": 28.75,
      "speaker": null,
      "text": "Макет готов, найдёмся сейчас по МВД, чуть попозже, где замерки приведёт."
    },
    {
      "start": 28.85,
      "end": 32.07,
      "speaker": null,
      "text": "Угу. Хорошо. А вам потребуется доставка?"
    },
    {
      "start": 32.79,
      "end": 37.95,
      "speaker": null,
      "text": "Давайте попробуем посчитать, а то мне сейчас 6-6 рублей за доставку посчитали уже и мы посчитали."
    },
    {
      "start": 38.63,
      "end": 39.57,
      "speaker": null,
      "text": "А куда они сходят?"
    },
    {
      "start": 40.11,
      "end": 42.05,
      "speaker": null,
      "text": "Московская область, город Дедовск."
    },
    {
      "start": 44.2,
      "end": 45.22,
      "speaker": null,
      "text": "Город ещё раз как?"
    },
    {
      "start": 45.7,
      "end": 46.38,
      "speaker": null,
      "text": "Дедовск."
    },
    {
      "start": 46.9,
      "end": 47.58,
      "speaker": null,
      "text": "Дедовск."
    },
    {
      "start": 48.1,
      "end": 48.3,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 49.85,
      "end": 52.43,
      "speaker": null,
      "text": "Смотрите просто, на какое мероприятие вам необходим коллап?"
    },
    {
      "start": 53.6,
      "end": 54.64,
      "speaker": null,
      "text": "На открытие."
    },
    {
      "start": 55.71,
      "end": 56.39,
      "speaker": null,
      "text": "Мещение."
    },
    {
      "start": 57.2,
      "end": 57.5,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 57.88,
      "end": 60.88,
      "speaker": null,
      "text": "А на сколько сейчас вы планируете его использовать? Перемещать, собирать?"
    },
    {
      "start": 60.88,
      "end": 61.78,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 62.0,
      "end": 62.58,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 64.38,
      "end": 65.34,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 65.62,
      "end": 69.8,
      "speaker": null,
      "text": "Перемещать на баннере и больше можно ничего не делать."
    },
    {
      "start": 70.46,
      "end": 70.84,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 71.0,
      "end": 72.06,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 72.95,
      "end": 77.07,
      "speaker": null,
      "text": "Так, по доставке мне сейчас необходимо будет время, чтобы её рассчитать для вас."
    },
    {
      "start": 78.17,
      "end": 80.61,
      "speaker": null,
      "text": "А вы не можете информацию или в Тагиле бумагу скинуть?"
    },
    {
      "start": 80.77,
      "end": 81.67,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 81.85,
      "end": 82.65,
      "speaker": null,
      "text": "Поэтому номер телефона?"
    },
    {
      "start": 82.71,
      "end": 82.87,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 83.09,
      "end": 83.55,
      "speaker": null,
      "text": "По этому номеру."
    },
    {
      "start": 85.63,
      "end": 86.51,
      "speaker": null,
      "text": "Всего доброго."
    },
    {
      "start": 86.67,
      "end": 86.89,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}