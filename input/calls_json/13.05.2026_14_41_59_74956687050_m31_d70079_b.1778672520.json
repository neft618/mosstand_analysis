{
  "file": "13.05.2026_14_41_59_74956687050_m31_d70079_b.1778672520.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 161.8,
  "segments": [
    {
      "start": 1.17,
      "end": 3.75,
      "speaker": null,
      "text": "Здравствуйте, меня зовут Валерия из компании МОВСТЕНД."
    },
    {
      "start": 4.21,
      "end": 16.73,
      "speaker": null,
      "text": "Да, Валерия, здравствуйте, это вас Юля беспокоит? Мы с вами переписываемся по поводу баннера. Я хотела уточнить, так вы в работу берёте или нет? Я вам прислала блога и вот опять от вас тишина."
    },
    {
      "start": 17.87,
      "end": 20.73,
      "speaker": null,
      "text": "Так, ещё раз, а уточните, пожалуйста, где вы мне направляли?"
    },
    {
      "start": 21.67,
      "end": 23.25,
      "speaker": null,
      "text": "На почту на вашу."
    },
    {
      "start": 24.1,
      "end": 26.56,
      "speaker": null,
      "text": "А мы с какой с вами почтой общаемся?"
    },
    {
      "start": 27.7,
      "end": 29.0,
      "speaker": null,
      "text": "Я с какой почтой?"
    },
    {
      "start": 29.12,
      "end": 34.38,
      "speaker": null,
      "text": "А, так, мы с вами уже урлап, который 150, да?"
    },
    {
      "start": 35.28,
      "end": 36.58,
      "speaker": null,
      "text": "Да, да, да, да."
    },
    {
      "start": 36.72,
      "end": 37.94,
      "speaker": null,
      "text": "Ага, да, вот."
    },
    {
      "start": 38.46,
      "end": 42.14,
      "speaker": null,
      "text": "Потому что вы, наверное, звоните через другого номера и я вышла только смешно."
    },
    {
      "start": 43.89,
      "end": 47.11,
      "speaker": null,
      "text": "А я вот вам даже сегодня писала по поводу макетов."
    },
    {
      "start": 47.23,
      "end": 48.75,
      "speaker": null,
      "text": "Я вам вчера тоже отвечала."
    },
    {
      "start": 50.06,
      "end": 55.26,
      "speaker": null,
      "text": "Как вы сказали, что если устроится, то есть какой ответ в итоге."
    },
    {
      "start": 56.0,
      "end": 59.32,
      "speaker": null,
      "text": "Почему-то я просто не получила ответа, не вижу букву."
    },
    {
      "start": 59.4,
      "end": 62.42,
      "speaker": null,
      "text": "Я вам написала вот лога какое имеется."
    },
    {
      "start": 62.6,
      "end": 67.44,
      "speaker": null,
      "text": "Вы его возьмёте в работу, чтобы использовать для макеты или нет?"
    },
    {
      "start": 67.68,
      "end": 69.66,
      "speaker": null,
      "text": "И опять от вас была тишина."
    },
    {
      "start": 69.84,
      "end": 71.08,
      "speaker": null,
      "text": "Я поэтому вам набираю."
    },
    {
      "start": 71.8,
      "end": 73.88,
      "speaker": null,
      "text": "И предоплата требуется или нет."
    },
    {
      "start": 74.04,
      "end": 76.64,
      "speaker": null,
      "text": "На это я тоже от вас ответа не получила."
    },
    {
      "start": 79.71,
      "end": 81.23,
      "speaker": null,
      "text": "Бля, у меня нет ваших писем."
    },
    {
      "start": 81.81,
      "end": 82.37,
      "speaker": null,
      "text": "Вот этих вот."
    },
    {
      "start": 82.37,
      "end": 84.05,
      "speaker": null,
      "text": "Вот сегодня я писала."
    },
    {
      "start": 84.25,
      "end": 85.49,
      "speaker": null,
      "text": "Не получила."
    },
    {
      "start": 85.73,
      "end": 86.25,
      "speaker": null,
      "text": "13.15."
    },
    {
      "start": 88.04,
      "end": 91.36,
      "speaker": null,
      "text": "Давайте я ещё раз перенаправлю, давайте."
    },
    {
      "start": 93.76,
      "end": 103.73,
      "speaker": null,
      "text": "А, ну у меня почему-то ваша почта почему-то спам попала."
    },
    {
      "start": 104.62,
      "end": 105.32,
      "speaker": null,
      "text": "Ну бывает."
    },
    {
      "start": 106.07,
      "end": 109.09,
      "speaker": null,
      "text": "Всё, вот теперь я вижу, потому что я тогда как раз не видела."
    },
    {
      "start": 110.21,
      "end": 111.83,
      "speaker": null,
      "text": "У меня просто есть только в таком виде."
    },
    {
      "start": 111.89,
      "end": 113.41,
      "speaker": null,
      "text": "У меня нет кривости, понимаете."
    },
    {
      "start": 113.73,
      "end": 116.15,
      "speaker": null,
      "text": "Поэтому если берётесь, то да."
    },
    {
      "start": 116.47,
      "end": 117.61,
      "speaker": null,
      "text": "И нужна ли предоплата?"
    },
    {
      "start": 117.67,
      "end": 118.69,
      "speaker": null,
      "text": "Если да, говорите."
    },
    {
      "start": 118.87,
      "end": 124.82,
      "speaker": null,
      "text": "И мне надо всё-таки успеть, чтобы в следующий четверг у меня уже был стенд."
    },
    {
      "start": 124.95,
      "end": 126.41,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 126.59,
      "end": 126.81,
      "speaker": null,
      "text": "Конечно."
    },
    {
      "start": 127.19,
      "end": 127.33,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 127.43,
      "end": 128.65,
      "speaker": null,
      "text": "Я увидела ваше письмо."
    },
    {
      "start": 128.75,
      "end": 130.37,
      "speaker": null,
      "text": "Не знаю почему он у меня упал."
    },
    {
      "start": 130.53,
      "end": 131.29,
      "speaker": null,
      "text": "Ну я поняла."
    },
    {
      "start": 131.63,
      "end": 132.73,
      "speaker": null,
      "text": "Так дайте ответы."
    },
    {
      "start": 132.91,
      "end": 133.43,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 133.67,
      "end": 133.91,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 134.11,
      "end": 134.53,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 135.13,
      "end": 136.25,
      "speaker": null,
      "text": "Да, не волнуйтесь."
    },
    {
      "start": 136.79,
      "end": 137.79,
      "speaker": null,
      "text": "Да, беру работу."
    },
    {
      "start": 138.67,
      "end": 140.57,
      "speaker": null,
      "text": "Как раз вот сегодня я спрашивала."
    },
    {
      "start": 141.03,
      "end": 142.97,
      "speaker": null,
      "text": "Да, необходимо будет предоплата."
    },
    {
      "start": 143.19,
      "end": 146.23,
      "speaker": null,
      "text": "Именно макетом мы можем отдельно просто макет сначала оплатить."
    },
    {
      "start": 146.29,
      "end": 147.13,
      "speaker": null,
      "text": "Либо сразу всё."
    },
    {
      "start": 147.35,
      "end": 149.81,
      "speaker": null,
      "text": "Давайте макет оплатим."
    },
    {
      "start": 149.89,
      "end": 152.63,
      "speaker": null,
      "text": "Вы пришлите пожалуйста ссылку, чтобы как от физического лица."
    },
    {
      "start": 152.63,
      "end": 154.55,
      "speaker": null,
      "text": "А давайте хорошо, так сказать."
    },
    {
      "start": 154.83,
      "end": 156.35,
      "speaker": null,
      "text": "Тогда мы отправим сейчас секундочку."
    },
    {
      "start": 156.55,
      "end": 156.93,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 157.27,
      "end": 157.63,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 157.91,
      "end": 158.65,
      "speaker": null,
      "text": "Всего доброго."
    },
    {
      "start": 158.79,
      "end": 158.91,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 159.07,
      "end": 159.77,
      "speaker": null,
      "text": "Сейчас направлю."
    }
  ]
