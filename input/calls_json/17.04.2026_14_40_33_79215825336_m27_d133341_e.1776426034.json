{
  "file": "17.04.2026_14_40_33_79215825336_m27_d133341_e.1776426034.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 125.2,
  "segments": [
    {
      "start": 0.11,
      "end": 3.25,
      "speaker": null,
      "text": "Добрый день, я Валентин, компания Мостенченко. Могу вам помочь?"
    },
    {
      "start": 3.95,
      "end": 18.11,
      "speaker": null,
      "text": "Алло, здравствуйте! Мы хотим заказать у вас буклеты евростандарта с двумя вгибами. Выбираем сейчас между тиражом 200 и 300, вы можете, пожалуйста, сориентироваться по цене, примерно чтобы к понедельнику было готово, с 20 апреля."
    },
    {
      "start": 18.57,
      "end": 21.23,
      "speaker": null,
      "text": "А скажите, пожалуйста, как я могу к вам обращаться?"
    },
    {
      "start": 21.85,
      "end": 22.25,
      "speaker": null,
      "text": "Ксения."
    },
    {
      "start": 22.73,
      "end": 23.29,
      "speaker": null,
      "text": "Ксения."
    },
    {
      "start": 24.83,
      "end": 26.33,
      "speaker": null,
      "text": "А у вас макета уже готова?"
    },
    {
      "start": 27.09,
      "end": 27.39,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 27.74,
      "end": 33.6,
      "speaker": null,
      "text": "Угу. А по плотности бумаги есть информация у вас, какая необходима?"
    },
    {
      "start": 33.96,
      "end": 38.57,
      "speaker": null,
      "text": "В целом без разницы, там 120 грамм, 130 подойдёт."
    },
    {
      "start": 39.68,
      "end": 45.14,
      "speaker": null,
      "text": "Угу. Так, евробуклет с двумя сложениями."
    },
    {
      "start": 45.66,
      "end": 45.92,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 51.31,
      "end": 53.89,
      "speaker": null,
      "text": "А вы с каким-то менеджером уже общаетесь?"
    },
    {
      "start": 55.2,
      "end": 55.92,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 56.4,
      "end": 62.29,
      "speaker": null,
      "text": "Нет? Хорошо. А вам биги будут необходимы на евробуклете?"
    },
    {
      "start": 63.14,
      "end": 63.7,
      "speaker": null,
      "text": "Что ещё?"
    },
    {
      "start": 63.7,
      "end": 64.56,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 66.84,
      "end": 71.64,
      "speaker": null,
      "text": "А вам необходимы будут биги на буклете? Это дополнительные каёмки для сложения?"
    },
    {
      "start": 72.18,
      "end": 74.66,
      "speaker": null,
      "text": "Да, если можно."
    },
    {
      "start": 76.15,
      "end": 81.21,
      "speaker": null,
      "text": "Угу. Хорошо. Тираж вы говорите либо 200, либо 300 штук?"
    },
    {
      "start": 81.66,
      "end": 82.1,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 83.4,
      "end": 88.9,
      "speaker": null,
      "text": "Угу. Мне необходимо будет посчитать буквально 5-10 минут."
    },
    {
      "start": 89.64,
      "end": 90.04,
      "speaker": null,
      "text": "Угу. Конечно."
    },
    {
      "start": 90.04,
      "end": 93.76,
      "speaker": null,
      "text": "Скажите, а вы с вами можно связаться в мессенджер Телеграм Макс?"
    },
    {
      "start": 94.48,
      "end": 95.72,
      "speaker": null,
      "text": "Да. В Телеграме можно."
    },
    {
      "start": 96.37,
      "end": 98.21,
      "speaker": null,
      "text": "В Телеграме. Угу."
    },
    {
      "start": 99.29,
      "end": 103.41,
      "speaker": null,
      "text": "Все. Хорошо. А у вас мероприятие какое-то планируется? Это выставка?"
    },
    {
      "start": 103.41,
      "end": 104.45,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 104.65,
      "end": 105.33,
      "speaker": null,
      "text": "Да, мероприятие."
    },
    {
      "start": 106.64,
      "end": 111.72,
      "speaker": null,
      "text": "Я хочу уточнить в каком формате, потому что может вам потребуется выставка на байлдовине стенды?"
    },
    {
      "start": 111.75,
      "end": 113.79,
      "speaker": null,
      "text": "А, нет. Почему? Уже все есть."
    },
    {
      "start": 114.35,
      "end": 121.17,
      "speaker": null,
      "text": "Угу. Хорошо. Я вас понял. Тогда я сейчас вам напишу и сообщу стоимость."
    },
    {
      "start": 121.17,
      "end": 123.79,
      "speaker": null,
      "text": "Все. Благодарю вас очень большое. До свидания."
    },
    {
      "start": 124.07,
      "end": 124.57,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}