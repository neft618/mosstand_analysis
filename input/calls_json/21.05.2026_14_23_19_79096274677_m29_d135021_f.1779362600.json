{
  "file": "21.05.2026_14_23_19_79096274677_m29_d135021_f.1779362600.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 184.3,
  "segments": [
    {
      "start": 2.17,
      "end": 3.43,
      "speaker": null,
      "text": "Алексей, да, здравствуйте."
    },
    {
      "start": 4.17,
      "end": 6.89,
      "speaker": null,
      "text": "Ксения, здравствуйте, не отвлекаю вас, есть у вас две минуты?"
    },
    {
      "start": 7.13,
      "end": 8.01,
      "speaker": null,
      "text": "Нет, не отвлекаетесь, всё хорошо."
    },
    {
      "start": 8.39,
      "end": 9.03,
      "speaker": null,
      "text": "Ой, как хорошо."
    },
    {
      "start": 10.31,
      "end": 13.33,
      "speaker": null,
      "text": "Ксюша, скажите, пожалуйста, по заказу работа идёт, да?"
    },
    {
      "start": 13.77,
      "end": 14.95,
      "speaker": null,
      "text": "Конечно, конечно."
    },
    {
      "start": 15.57,
      "end": 15.83,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 16.55,
      "end": 21.77,
      "speaker": null,
      "text": "Вы знаете, да, у нас в понедельник уже будет доставка. Скажите, пожалуйста, время какое-то фиксирование?"
    },
    {
      "start": 22.23,
      "end": 23.93,
      "speaker": null,
      "text": "Фиксированное, я помню, мы здесь с 13, да?"
    },
    {
      "start": 23.93,
      "end": 38.92,
      "speaker": null,
      "text": "А мы с вами фиксировали, но не в договоре, а с, сейчас скажу, монтаж-монтаж, Крокус-экспо. Вы просили с часу до трёх, но не указывать это в договоре. Так и остаётся, без изменений?"
    },
    {
      "start": 39.04,
      "end": 44.68,
      "speaker": null,
      "text": "Вы знаете, с 9 до 12 у нас новая установка, с 9 до 12 мы можем скорректировать время?"
    },
    {
      "start": 45.86,
      "end": 52.72,
      "speaker": null,
      "text": "Я сейчас уточню у монтажника, просто мы время уже определённое взяли, я тогда сейчас перезвоню ему."
    },
    {
      "start": 54.52,
      "end": 55.6,
      "speaker": null,
      "text": "Перезвоните тогда мне, ладно?"
    },
    {
      "start": 56.14,
      "end": 56.92,
      "speaker": null,
      "text": "Угу, хорошо."
    },
    {
      "start": 57.76,
      "end": 61.04,
      "speaker": null,
      "text": "У нас там без сборки у нас только доставка, верно? Мы сборку отменили."
    },
    {
      "start": 63.39,
      "end": 65.93,
      "speaker": null,
      "text": "Так у вас же остался... Так, сейчас, секунду."
    },
    {
      "start": 66.59,
      "end": 67.87,
      "speaker": null,
      "text": "Да, мы убирали её."
    },
    {
      "start": 68.54,
      "end": 71.4,
      "speaker": null,
      "text": "А, вы убрали. Всё, я поняла."
    },
    {
      "start": 71.42,
      "end": 72.26,
      "speaker": null,
      "text": "У нас только доставка."
    },
    {
      "start": 72.98,
      "end": 73.58,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 73.82,
      "end": 80.77,
      "speaker": null,
      "text": "Чёс, вы знаете, в чём дело? Просто там с 9 до 12 нам организатор поставил завести."
    },
    {
      "start": 80.77,
      "end": 83.65,
      "speaker": null,
      "text": "Тогда да, завод спокойно можно будет."
    },
    {
      "start": 83.93,
      "end": 84.13,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 84.13,
      "end": 86.45,
      "speaker": null,
      "text": "Я приношу извинения, поставила монтаж."
    },
    {
      "start": 86.61,
      "end": 89.29,
      "speaker": null,
      "text": "Да, тогда хорошо мы с вами созвонились, отменю его."
    },
    {
      "start": 89.65,
      "end": 92.81,
      "speaker": null,
      "text": "Да-да-да, вот видите, полезная, как говорится, корректировка."
    },
    {
      "start": 93.27,
      "end": 95.91,
      "speaker": null,
      "text": "Слушайте, смотрите, по поводу инструментов вы не подскажете?"
    },
    {
      "start": 95.91,
      "end": 99.09,
      "speaker": null,
      "text": "Что там надо? Как она крепится? Вот наша штора самая большая."
    },
    {
      "start": 99.19,
      "end": 102.35,
      "speaker": null,
      "text": "А там, что сразу в заказе будет предсказано."
    },
    {
      "start": 102.57,
      "end": 107.89,
      "speaker": null,
      "text": "Да, если что, я могу вышлать видео, как это собирается у нас на сайте."
    },
    {
      "start": 108.91,
      "end": 109.31,
      "speaker": null,
      "text": "Буду признать, да?"
    },
    {
      "start": 109.31,
      "end": 111.75,
      "speaker": null,
      "text": "У нас где-то было видео по сборке, да."
    },
    {
      "start": 112.86,
      "end": 115.12,
      "speaker": null,
      "text": "Отлично. Значит, инструменты никакие не нужны."
    },
    {
      "start": 115.78,
      "end": 117.0,
      "speaker": null,
      "text": "Доставка с 9 до 12."
    },
    {
      "start": 118.86,
      "end": 119.3,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 119.88,
      "end": 123.88,
      "speaker": null,
      "text": "Скажите, Чуша, вот эти вот штанги, они разборные или они монолит?"
    },
    {
      "start": 124.18,
      "end": 127.24,
      "speaker": null,
      "text": "Две палки по 3 метра и две палки по 2 метра."
    },
    {
      "start": 127.26,
      "end": 128.88,
      "speaker": null,
      "text": "Да, они именно неразборные."
    },
    {
      "start": 129.3,
      "end": 129.74,
      "speaker": null,
      "text": "Понял."
    },
    {
      "start": 129.74,
      "end": 130.08,
      "speaker": null,
      "text": "Понял."
    },
    {
      "start": 131.58,
      "end": 132.46,
      "speaker": null,
      "text": "Понял, понял."
    },
    {
      "start": 133.1,
      "end": 135.82,
      "speaker": null,
      "text": "Хорошо, Сеня, тогда видео приветствую."
    },
    {
      "start": 136.12,
      "end": 137.68,
      "speaker": null,
      "text": "Если будет, то будет вообще замечательно."
    },
    {
      "start": 138.12,
      "end": 141.14,
      "speaker": null,
      "text": "По поводу доставки с 9 до 12 так доставим."
    },
    {
      "start": 141.44,
      "end": 144.28,
      "speaker": null,
      "text": "У нас машина будет ждать, которая туда уже заезжает,"
    },
    {
      "start": 144.34,
      "end": 146.26,
      "speaker": null,
      "text": "чтобы второй пропуск, там есть все платные,"
    },
    {
      "start": 146.38,
      "end": 148.9,
      "speaker": null,
      "text": "чтобы не платить за две машины, хотим за одну."
    },
    {
      "start": 149.26,
      "end": 151.26,
      "speaker": null,
      "text": "И вот с 9 до 12 было бы оптимально."
    },
    {
      "start": 152.02,
      "end": 152.26,
      "speaker": null,
      "text": "Хорошо, хорошо."
    },
    {
      "start": 152.26,
      "end": 154.8,
      "speaker": null,
      "text": "Даже, наверное, с 9 до 11 вот так вот."
    },
    {
      "start": 155.62,
      "end": 156.56,
      "speaker": null,
      "text": "Спасибо, Сеня."
    },
    {
      "start": 156.56,
      "end": 160.02,
      "speaker": null,
      "text": "С 10, поэтому тут..."
    },
    {
      "start": 160.46,
      "end": 161.99,
      "speaker": null,
      "text": "А, с 10 только отгрузка."
    },
    {
      "start": 162.07,
      "end": 164.29,
      "speaker": null,
      "text": "Соответственно, где-то до 12 они подъедут."
    },
    {
      "start": 164.61,
      "end": 165.83,
      "speaker": null,
      "text": "До 12, да."
    },
    {
      "start": 167.3,
      "end": 168.48,
      "speaker": null,
      "text": "Так, остается адрес."
    },
    {
      "start": 168.62,
      "end": 169.84,
      "speaker": null,
      "text": "Крокуси Текспо, правильно?"
    },
    {
      "start": 170.72,
      "end": 171.74,
      "speaker": null,
      "text": "Абсолютно верно."
    },
    {
      "start": 172.16,
      "end": 174.42,
      "speaker": null,
      "text": "Мой телефон всегда включен."
    },
    {
      "start": 175.48,
      "end": 176.42,
      "speaker": null,
      "text": "Держим связь."
    },
    {
      "start": 177.12,
      "end": 178.52,
      "speaker": null,
      "text": "Хорошо, да, без проблем."
    },
    {
      "start": 179.26,
      "end": 180.72,
      "speaker": null,
      "text": "Спасибо, Чуша, хорошего дня."
    },
    {
      "start": 181.22,
      "end": 182.18,
      "speaker": null,
      "text": "Всего доброго."
    },
    {
      "start": 182.94,
      "end": 183.2,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}