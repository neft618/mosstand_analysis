    {
      "start": 276.17,
      "end": 286.25,
      "speaker": null,
      "text": "А вы можете..."
    },
    {
      "start": 286.25,
      "end": 289.77,
      "speaker": null,
      "text": "А, вы можете сразу же и ссылку для технических вот этих вот?"
    },
    {
      "start": 290.26,
      "end": 290.78,
      "speaker": null,
      "text": "Да."
