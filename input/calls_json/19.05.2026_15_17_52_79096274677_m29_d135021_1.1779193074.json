{
  "file": "19.05.2026_15_17_52_79096274677_m29_d135021_1.1779193074.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 61.3,
  "segments": [
    {
      "start": 1.39,
      "end": 3.03,
      "speaker": null,
      "text": "Алексей, да, я здесь."
    },
    {
      "start": 4.14,
      "end": 6.76,
      "speaker": null,
      "text": "Ксюша, извините, что я вас дёргаю, но вынуждена."
    },
    {
      "start": 6.86,
      "end": 8.72,
      "speaker": null,
      "text": "Я прекрасно сама тоже понимаю."
    },
    {
      "start": 9.06,
      "end": 9.56,
      "speaker": null,
      "text": "Да, пакет."
    },
    {
      "start": 10.14,
      "end": 11.48,
      "speaker": null,
      "text": "Пакет ждём, как там дела?"
    },
    {
      "start": 12.16,
      "end": 18.42,
      "speaker": null,
      "text": "Так, ещё жду от неё ответ."
    },
    {
      "start": 19.52,
      "end": 20.84,
      "speaker": null,
      "text": "Ксюша, я тоже от вас жду, были на связи."
    },
    {
      "start": 20.84,
      "end": 27.74,
      "speaker": null,
      "text": "Просто сегодня я это всё держу в руках, не переживайте, а то я сама начну переживать."
    },
    {
      "start": 29.04,
      "end": 34.1,
      "speaker": null,
      "text": "Вы знаете, очень тревожно, если честно, потому что буксуем."
    },
    {
      "start": 35.4,
      "end": 37.38,
      "speaker": null,
      "text": "Давайте сделаем, как говорится, как следует."
    },
    {
      "start": 37.44,
      "end": 42.8,
      "speaker": null,
      "text": "А то я там уже рассказал, как мы хорошо общались и сейчас какие-то буксовки, они, конечно, к сожалению."
    },
    {
      "start": 42.92,
      "end": 48.48,
      "speaker": null,
      "text": "Я могу, давайте так, сразу вам все отправить и сразу, как пакет она уже доделает до конца,"
    },
    {
      "start": 48.64,
      "end": 50.96,
      "speaker": null,
      "text": "я ей пакет сразу докину, уже после."
    },
    {
      "start": 51.1,
      "end": 54.82,
      "speaker": null,
      "text": "Сейчас все макеты, чтобы точно понимали, что работа идёт, всё в порядке."
    },
    {
      "start": 55.04,
      "end": 56.8,
      "speaker": null,
      "text": "Хорошо, буду признательно."
    },
    {
      "start": 57.28,
      "end": 58.92,
      "speaker": null,
      "text": "Спасибо, Ксюша, жду, жду."
    },
    {
      "start": 59.12,
      "end": 59.56,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 60.58,
      "end": 61.0,
      "speaker": null,
      "text": "Да, пожалуйста."
    }
  ]
}