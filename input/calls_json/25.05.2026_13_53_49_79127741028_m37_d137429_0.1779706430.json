  "segments": [
    {
      "start": 2.26,
      "end": 5.34,
      "speaker": null,
      "text": "Добрый день. Это Екатерина, компания МОСРЕНТ. Как могу к вам обращаться?"
    },
    {
      "start": 6.0,
      "end": 8.02,
      "speaker": null,
      "text": "Екатерина, здравствуйте! Меня зовут Мария."
    },
    {
      "start": 9.02,
      "end": 19.02,
      "speaker": null,
      "text": "Екатерина, у меня вот такой вопрос. У меня есть промостойка похожая на вашу, заказывала два года назад в компании, но я не могу её найти, она закрылась видимо."
    },
    {
      "start": 19.62,
      "end": 26.81,
      "speaker": null,
      "text": "А мне надо переклеить композицию. Могу ли я к вам обратиться?"
    },
    {
      "start": 27.39,
      "end": 32.49,
      "speaker": null,
      "text": "Ну, мне нужно, чтобы вы прислали фотографии в стойке, чтобы я поняла о какой стойке речи и так далее."
    },
    {
      "start": 33.13,
      "end": 33.99,
      "speaker": null,
      "text": "Можем помочь или нет?"
    },
    {
      "start": 34.19,
      "end": 34.89,
      "speaker": null,
      "text": "Да, давай."
    },
    {
      "start": 35.13,
      "end": 36.29,
      "speaker": null,
      "text": "Тогда куда прислать?"
    },
    {
      "start": 36.51,
      "end": 36.93,
      "speaker": null,
      "text": "Куда?"
    },
    {
      "start": 37.07,
      "end": 40.17,
      "speaker": null,
      "text": "А у вас по этому номеру что-то есть? Телеграмм, Макс?"
    },
    {
      "start": 40.45,
      "end": 41.91,
      "speaker": null,
      "text": "Телеграмм, Макс, всё есть."
    },
    {
      "start": 43.1,
      "end": 43.9,
      "speaker": null,
      "text": "Посмотрю секунду."
    },
    {
      "start": 44.6,
      "end": 44.98,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 45.68,
      "end": 46.74,
      "speaker": null,
      "text": "Откроется или нет?"
    },
    {
      "start": 47.46,
      "end": 49.34,
      "speaker": null,
      "text": "Да, не всегда открывается."
    },
    {
      "start": 52.68,
      "end": 53.64,
      "speaker": null,
      "text": "Телефон открыт."
    },
    {
      "start": 65.2,
      "end": 65.68,
      "speaker": null,
      "text": "Нашла."
    },
    {
      "start": 69.88,
      "end": 71.98,
      "speaker": null,
      "text": "Сейчас я вам маякну в телеграмме."
    },
    {
      "start": 72.5,
      "end": 72.74,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 72.86,
      "end": 74.66,
      "speaker": null,
      "text": "Мне пришлите тогда, ну..."
    },
    {
      "start": 74.79,
      "end": 78.85,
      "speaker": null,
      "text": "Да, я пришлю тогда."
    },
    {
      "start": 79.71,
      "end": 80.29,
      "speaker": null,
      "text": "О-о-о."
    },
    {
      "start": 81.22,
      "end": 83.78,
      "speaker": null,
      "text": "Давайте прислать фотографии, посмотрите, да?"
    },
    {
      "start": 83.78,
      "end": 84.68,
      "speaker": null,
      "text": "Или просто фото?"
    },
    {
      "start": 84.76,
      "end": 85.4,
      "speaker": null,
      "text": "Фото можно."
    },
    {
      "start": 85.9,
      "end": 87.94,
      "speaker": null,
      "text": "Ну, фото и размеры, конечно, да."
    },
    {
      "start": 88.52,
      "end": 89.46,
      "speaker": null,
      "text": "Естественно надо понимать."
    },
    {
      "start": 89.48,
      "end": 92.05,
      "speaker": null,
      "text": "Так, тогда пошла снимать размеры."
    },
    {
      "start": 93.16,
      "end": 93.42,
      "speaker": null,
      "text": "Давай."
    },
    {
      "start": 93.82,
      "end": 97.6,
      "speaker": null,
      "text": "Ну, изначально хотя бы фотографию у меня набрать, а потом может уже..."
    },
    {
      "start": 97.6,
      "end": 97.88,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 98.22,
      "end": 100.08,
      "speaker": null,
      "text": "Может так понятно будет."
    },
    {
      "start": 100.32,
      "end": 100.7,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 100.9,
      "end": 103.78,
      "speaker": null,
      "text": "Дизайн все тоже как бы сделаю, не вопрос."
    },
    {
      "start": 104.54,
      "end": 104.8,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 104.8,
      "end": 105.14,
      "speaker": null,
      "text": "Хорошо?"
    },
    {
      "start": 105.84,
