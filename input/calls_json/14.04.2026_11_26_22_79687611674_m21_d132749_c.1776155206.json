    {
      "start": 54.09,
      "end": 54.75,
      "speaker": null,
      "text": "Альбомный вариант."
    },
    {
      "start": 55.52,
      "end": 58.24,
      "speaker": null,
      "text": "Ага, всё, высота 190 у нас значит."
