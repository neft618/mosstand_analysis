      "speaker": null,
      "text": "9400."
    },
    {
      "start": 74.18,
      "end": 74.5,
      "speaker": null,
      "text": "Суммарно?"
    },
    {
      "start": 75.18,
      "end": 77.54,
      "speaker": null,
      "text": "Да, да, тема за конструкцию, вот этот роллап."
    },
    {
      "start": 77.72,
      "end": 80.46,
      "speaker": null,
      "text": "Баннер, который напечатан, отправлен уже будет и сумка вместе."
