      "start": 69.34,
      "end": 70.42,
      "speaker": null,
      "text": "Конструкция от баннера заправлена."
    },
    {
      "start": 70.42,
      "end": 71.0,
      "speaker": null,
      "text": "Сколько ещё раз стоит?"
