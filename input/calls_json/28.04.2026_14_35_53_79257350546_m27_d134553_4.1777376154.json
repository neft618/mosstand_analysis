{
  "file": "28.04.2026_14_35_53_79257350546_m27_d134553_4.1777376154.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 140.8,
  "segments": [
    {
      "start": 0.3,
      "end": 3.38,
      "speaker": null,
      "text": "Добрый день. Меня зовут Валентин, компания Масонченко. Я могу вам помочь?"
    },
    {
      "start": 4.44,
      "end": 16.95,
      "speaker": null,
      "text": "Валентина, здравствуйте. Скажите, пожалуйста, вот интересует печать на плотной сетке баннера размером 95 метров на 12. Вы такие изготавливаете?"
    },
    {
      "start": 17.81,
      "end": 21.23,
      "speaker": null,
      "text": "Да, но необходимо уточнить вам это на улице. Я правильно понимаю?"
    },
    {
      "start": 21.99,
      "end": 25.37,
      "speaker": null,
      "text": "Это для улицы, для покрытия генельных валов."
    },
    {
      "start": 26.62,
      "end": 29.28,
      "speaker": null,
      "text": "А скажите, пожалуйста, как я могу к вам обращаться?"
    },
    {
      "start": 29.28,
      "end": 30.4,
      "speaker": null,
      "text": "Светлана."
    },
    {
      "start": 31.3,
      "end": 31.94,
      "speaker": null,
      "text": "Светлана."
    },
    {
      "start": 34.48,
      "end": 37.22,
      "speaker": null,
      "text": "А скажите, пожалуйста, ещё раз размер, который необходим?"
    },
    {
      "start": 38.4,
      "end": 41.26,
      "speaker": null,
      "text": "95 метров на 12."
    },
    {
      "start": 41.74,
      "end": 44.84,
      "speaker": null,
      "text": "На 12 метров. А по срокам вам когда необходимо будет?"
    },
    {
      "start": 46.09,
      "end": 52.86,
      "speaker": null,
      "text": "Слушайте, по сроку меня не сориентировали, но в чем какого времени вообще вы изготавливаете?"
    },
    {
      "start": 54.01,
      "end": 62.19,
      "speaker": null,
      "text": "Мне необходимо будет обговориться с технологом, потому что размер достаточно большой и я думаю в районе 7-8 рабочих дней после согласования макета и оплаты."
    },
    {
      "start": 63.68,
      "end": 73.2,
      "speaker": null,
      "text": "А скажите, я могу вам вот отправить макет, размеры и чтобы вы мне просчитали и прописали какой материал, какие размеры и какая стоимость и сроки?"
    },
    {
      "start": 73.2,
      "end": 78.18,
      "speaker": null,
      "text": "Да, конечно. А скажите, пожалуйста, вам про варка «Люзерс» и что-то будет необходимо?"
    },
    {
      "start": 80.4,
      "end": 83.12,
      "speaker": null,
      "text": "Слушайте, ну если это для покрытия, скорее всего нет."
    },
    {
      "start": 84.14,
      "end": 88.2,
      "speaker": null,
      "text": "Угу. То есть просто только полотно, верно?"
    },
    {
      "start": 88.5,
      "end": 89.7,
      "speaker": null,
      "text": "Да, да, полотно."
    },
    {
      "start": 90.34,
      "end": 97.98,
      "speaker": null,
      "text": "Угу. Хорошо. Я посчитаю всё с технологом. Светлана, скажите, пожалуйста, я могу с вами как-то в дальнейшем связаться?"
    },
    {
      "start": 98.46,
      "end": 101.94,
      "speaker": null,
      "text": "Мои контакты будут указаны в электронной почте."
    },
    {
      "start": 102.5,
      "end": 105.54,
      "speaker": null,
      "text": "Угу. А могли бы вы тогда мне на почту написать?"
    },
    {
      "start": 105.54,
      "end": 108.5,
      "speaker": null,
      "text": "Так, а вы мне тогда её продиктуете сейчас."
    },
    {
      "start": 110.05,
      "end": 111.23,
      "speaker": null,
      "text": "Угу. Продиктуете как?"
    },
    {
      "start": 111.25,
      "end": 113.55,
      "speaker": null,
      "text": "А «С» как русская «С»."
    },
    {
      "start": 114.32,
      "end": 116.08,
      "speaker": null,
      "text": "«В» как галочка."
    },
    {
      "start": 116.7,
      "end": 116.88,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 117.2,
      "end": 117.78,
      "speaker": null,
      "text": "Собачка."
    },
    {
      "start": 118.86,
      "end": 119.1,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 120.98,
      "end": 121.56,
      "speaker": null,
      "text": "«Мосстант»."
    },
    {
      "start": 124.95,
      "end": 126.11,
      "speaker": null,
      "text": "«Точка ру», да?"
    },
    {
      "start": 126.35,
      "end": 127.79,
      "speaker": null,
      "text": "Да, точка ру. Всё верно."
    },
    {
      "start": 128.29,
      "end": 131.43,
      "speaker": null,
      "text": "Так, «С» «В» собакамосстант точка ру."
    },
    {
      "start": 131.83,
      "end": 132.87,
      "speaker": null,
      "text": "Угу. Да, всё верно."
    },
    {
      "start": 132.87,
      "end": 135.54,
      "speaker": null,
      "text": "И вообще всё правду вам тогда."
    },
    {
      "start": 136.04,
      "end": 137.68,
      "speaker": null,
      "text": "Всё, Светлана, благодарю, ожидаю."
    },
    {
      "start": 137.92,
      "end": 138.2,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 138.36,
      "end": 139.28,
      "speaker": null,
      "text": "Спасибо. До свидания."
    },
    {
      "start": 139.42,
      "end": 139.92,
      "speaker": null,
      "text": "До свидания."
    }
  ]
