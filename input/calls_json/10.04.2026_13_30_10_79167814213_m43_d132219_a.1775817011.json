      "start": 475.74,
      "end": 479.56,
      "speaker": null,
      "text": "Если без обработки, пожалуйста, нам еще легче и проще."
    },
    {
      "start": 480.36,
      "end": 480.76,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 481.22,
      "end": 481.6,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 481.78,
      "end": 484.96,
      "speaker": null,
      "text": "Ну теперь осталось продумать, как сбыть с этим телевизором."
    },
    {
      "start": 486.02,
      "end": 488.84,
      "speaker": null,
      "text": "Ну да, если есть какие-то варианты, можете мы их написать все-таки."
    },
    {
      "start": 489.22,
      "end": 495.17,
      "speaker": null,
      "text": "Да, давайте я дождусь от монтажника и тогда сразу вам."
    },
    {
      "start": 495.17,
      "end": 495.47,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 495.77,
      "end": 496.17,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 497.9,
      "end": 498.74,
      "speaker": null,
      "text": "Хорошо, спасибо."
    },
    {
      "start": 499.02,
      "end": 499.54,
      "speaker": null,
      "text": "Отпишусь."
    },
    {
      "start": 499.68,
      "end": 500.4,
      "speaker": null,
      "text": "Да, пожалуйста."
    },
    {
      "start": 500.9,
      "end": 501.5,
      "speaker": null,
      "text": "Так, ответ."
    },
    {
      "start": 501.74,
      "end": 502.46,
      "speaker": null,
      "text": "Ну когда нужно?"
    },
    {
      "start": 502.54,
      "end": 504.0,
      "speaker": null,
      "text": "А вообще есть какой-то бюджет?"
    },
    {
      "start": 505.42,
      "end": 508.54,
      "speaker": null,
      "text": "Ну нам надо понять, как это сделать и можем ли мы это сделать."
    },
    {
      "start": 508.62,
      "end": 509.58,
      "speaker": null,
      "text": "Вот это главная облачка."
    },
    {
      "start": 512.05,
      "end": 513.25,
      "speaker": null,
      "text": "Сделать всегда можно."
    },
    {
      "start": 514.79,
      "end": 517.35,
      "speaker": null,
      "text": "Главное – понять сколько денег на это надо потратить."
    },
    {
      "start": 520.74,
      "end": 523.62,
      "speaker": null,
      "text": "Все меньше, чем полноценный застройок стендов."
    },
    {
      "start": 531.04,
      "end": 531.66,
      "speaker": null,
      "text": "Дмитрий?"
    },
    {
      "start": 532.58,
      "end": 536.52,
      "speaker": null,
      "text": "Я просто думаю, что можно еще придумать помимо этого."
    },
    {
      "start": 537.85,
      "end": 538.19,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 538.71,
      "end": 544.78,
      "speaker": null,
      "text": "Можно сделать прикольно из секпро лайтбоксов."
    },
    {
      "start": 544.9,
      "end": 546.22,
      "speaker": null,
      "text": "Но это будет очень дорого."
    },
    {
      "start": 546.4,
      "end": 547.08,
      "speaker": null,
      "text": "Очень дорого."
    },
    {
      "start": 548.05,
      "end": 549.07,
      "speaker": null,
      "text": "Ну это понятно."
    },
    {
      "start": 549.49,
      "end": 551.55,
      "speaker": null,
      "text": "Ляма полтора, наверное, даже больше."
    },
    {
      "start": 552.67,
      "end": 553.07,
      "speaker": null,
      "text": "Обалдеть."
    },
    {
      "start": 553.23,
      "end": 558.69,
      "speaker": null,
      "text": "Ну там двухсторонние лайтбоксы с подсветкой, они сейчас популярны."
    },
    {
      "start": 559.41,
      "end": 561.05,
      "speaker": null,
      "text": "Арки можно было добавить."
    },
    {
      "start": 562.71,
      "end": 562.95,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 563.09,
      "end": 564.17,
      "speaker": null,
      "text": "Так, а промостройка что?"
    },
    {
      "start": 565.96,
      "end": 566.76,
      "speaker": null,
      "text": "А что с ней?"
    },
    {
      "start": 567.61,
      "end": 569.71,
      "speaker": null,
      "text": "Ну вот эта изогнута неинтересно."
    },
    {
      "start": 569.83,
      "end": 570.67,
      "speaker": null,
      "text": "Она порядка…"
    },
    {
      "start": 570.67,
      "end": 571.47,
      "speaker": null,
      "text": "Нет, точно."
    },
    {
      "start": 571.69,
      "end": 574.21,
      "speaker": null,
      "text": "Это просто было мне любопытно."
    },
    {
      "start": 574.79,
      "end": 575.55,
      "speaker": null,
      "text": "Ага, вам будет."
    },
    {
      "start": 575.79,
      "end": 576.39,
      "speaker": null,
      "text": "Ну понял."
    },
    {
      "start": 576.57,
      "end": 577.79,
      "speaker": null,
      "text": "Но так она очень классная."
    },
    {
      "start": 578.03,
      "end": 579.31,
      "speaker": null,
      "text": "Как бы клиент брал вот…"
    },
    {
      "start": 579.31,
      "end": 580.63,
      "speaker": null,
      "text": "Я вот просто вот гадал."
    },
    {
      "start": 581.09,
      "end": 582.35,
      "speaker": null,
      "text": "Она офигенная."
    },
    {
      "start": 582.47,
      "end": 585.37,
      "speaker": null,
      "text": "Там с дверями она, столешница сверху,"
    },
    {
      "start": 585.37,
      "end": 586.33,
      "speaker": null,
      "text": "внутри полочки."
    },
    {
      "start": 586.79,
      "end": 589.47,
      "speaker": null,
      "text": "И видео на ней идет."
    },
    {
      "start": 590.41,
      "end": 592.53,
      "speaker": null,
      "text": "Если интересно, потом пришли видео."
    },
    {
      "start": 592.81,
      "end": 594.87,
      "speaker": null,
      "text": "Ну не так просто."
    },
    {
      "start": 595.03,
      "end": 595.83,
      "speaker": null,
      "text": "Было любопытно."
    },
    {
      "start": 595.85,
      "end": 597.29,
      "speaker": null,
      "text": "Это у вас конструкция или не у вас?"
    },
    {
      "start": 597.39,
      "end": 598.97,
      "speaker": null,
      "text": "Прямо удобно сделать и…"
    },
    {
      "start": 598.97,
      "end": 600.67,
      "speaker": null,
      "text": "Нет, это стандартная."
    },
    {
      "start": 600.69,
      "end": 601.89,
      "speaker": null,
      "text": "Она только арендная идет."
    },
    {
      "start": 602.13,
      "end": 607.26,
      "speaker": null,
      "text": "И мы привозим и его сами подключаем."
    },
    {
      "start": 607.86,
      "end": 608.32,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 608.5,
      "end": 609.76,
      "speaker": null,
      "text": "Все, ладно тогда сейчас…"
    },
    {
      "start": 609.76,
      "end": 610.74,
      "speaker": null,
      "text": "Да, все, спасибо большое."
    },
    {
      "start": 611.38,
      "end": 612.44,
      "speaker": null,
      "text": "Да, да, спасибо."
    },
    {
      "start": 613.14,
      "end": 614.62,
      "speaker": null,
      "text": "А размеры не подскажете?"
    }
  ]
}