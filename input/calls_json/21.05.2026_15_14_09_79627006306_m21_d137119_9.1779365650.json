{
  "file": "21.05.2026_15_14_09_79627006306_m21_d137119_9.1779365650.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 202.2,
  "segments": [
    {
      "start": 1.26,
      "end": 2.54,
      "speaker": null,
      "text": "Да, Максим, добрый день."
    },
    {
      "start": 2.96,
      "end": 11.3,
      "speaker": null,
      "text": "Да, добрый. Хотел точиться по заказу в моготипном этом ежедневнике, то что писал блокноты."
    },
    {
      "start": 12.52,
      "end": 15.28,
      "speaker": null,
      "text": "Так, сколько, что делаем тогда по итогу?"
    },
    {
      "start": 16.12,
      "end": 26.64,
      "speaker": null,
      "text": "Так, а значит смотри, мне нужна будет ленты, то что мы с тобой говорили, тегов 50 штук, УК «Энерго Ремонт» 25."
    },
    {
      "start": 27.53,
      "end": 29.59,
      "speaker": null,
      "text": "Так, 25 штук, чего ещё раз 25 штук?"
    },
    {
      "start": 29.59,
      "end": 36.21,
      "speaker": null,
      "text": "А это вот ещё одна из наших компаний, УК «Энерго Ремонт». Я не знаю, скидывал я тебе брендбук или нет."
    },
    {
      "start": 36.91,
      "end": 38.49,
      "speaker": null,
      "text": "Лучше пусть будет, лучше пусть будет."
    },
    {
      "start": 38.63,
      "end": 38.79,
      "speaker": null,
      "text": "Давай."
    },
    {
      "start": 39.29,
      "end": 40.21,
      "speaker": null,
      "text": "Это тоже ленты, да?"
    },
    {
      "start": 40.71,
      "end": 41.65,
      "speaker": null,
      "text": "Да, надо будет."
    },
    {
      "start": 42.11,
      "end": 42.31,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 42.93,
      "end": 45.81,
      "speaker": null,
      "text": "Так, блокноты А5-й формат."
    },
    {
      "start": 46.41,
      "end": 47.65,
      "speaker": null,
      "text": "А5-й блокнот."
    },
    {
      "start": 47.91,
      "end": 48.87,
      "speaker": null,
      "text": "Делали которые, да?"
    },
    {
      "start": 49.37,
      "end": 49.65,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 59.59,
      "end": 62.05,
      "speaker": null,
      "text": "Делали там с такими синими полосками ещё было."
    },
    {
      "start": 62.59,
      "end": 63.93,
      "speaker": null,
      "text": "А5-й, сколько их?"
    },
    {
      "start": 64.43,
      "end": 65.79,
      "speaker": null,
      "text": "40 штук."
    },
    {
      "start": 66.35,
      "end": 67.87,
      "speaker": null,
      "text": "40 штук два кната."
    },
    {
      "start": 68.91,
      "end": 75.09,
      "speaker": null,
      "text": "Ежедневник А5-го формата 20 штук."
    },
    {
      "start": 75.09,
      "end": 75.99,
      "speaker": null,
      "text": "20 штук."
    },
    {
      "start": 76.79,
      "end": 77.17,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 77.63,
      "end": 81.49,
      "speaker": null,
      "text": "Так, а подскажи, пожалуйста, ещё, есть возможность подготовить"
    },
    {
      "start": 82.03,
      "end": 82.41,
      "speaker": null,
      "text": "шеврон?"
    },
    {
      "start": 84.55,
      "end": 88.11,
      "speaker": null,
      "text": "Это вот эти накладные, которые как патчи?"
    },
    {
      "start": 88.4,
      "end": 89.38,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 89.68,
      "end": 90.44,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 90.66,
      "end": 91.14,
      "speaker": null,
      "text": "На один раз."
    },
    {
      "start": 91.6,
      "end": 93.94,
      "speaker": null,
      "text": "Как типа Stone Island обычно делаются, да?"
    },
    {
      "start": 94.2,
      "end": 94.4,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 95.34,
      "end": 96.52,
      "speaker": null,
      "text": "Вроде можно, да."
    },
    {
      "start": 98.86,
      "end": 100.5,
      "speaker": null,
      "text": "Размер только необходимый."
    },
    {
      "start": 101.35,
      "end": 102.27,
      "speaker": null,
      "text": "Так, размер."
    },
    {
      "start": 102.65,
      "end": 103.83,
      "speaker": null,
      "text": "Всё принято."
    },
    {
      "start": 104.69,
      "end": 106.77,
      "speaker": null,
      "text": "Где-то, наверное, около 200 штук."
    },
    {
      "start": 106.87,
      "end": 108.67,
      "speaker": null,
      "text": "Я тогда попросу ТЗ-ку."
    },
    {
      "start": 110.28,
      "end": 111.6,
      "speaker": null,
      "text": "Шеврон 200."
    },
    {
      "start": 112.88,
      "end": 113.24,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 113.24,
      "end": 115.42,
      "speaker": null,
      "text": "Так, шеврон 200."
    },
    {
      "start": 115.64,
      "end": 116.32,
      "speaker": null,
      "text": "Ленты 50."
    },
    {
      "start": 116.64,
      "end": 117.26,
      "speaker": null,
      "text": "Техмос Энерго."
    },
    {
      "start": 117.38,
      "end": 118.68,
      "speaker": null,
      "text": "25 штук другой компании."
    },
    {
      "start": 119.02,
      "end": 120.24,
      "speaker": null,
      "text": "Глокноты А5-40."
    },
    {
      "start": 120.46,
      "end": 121.6,
      "speaker": null,
      "text": "Ежедневника 20 штук."
    },
    {
      "start": 121.98,
      "end": 122.22,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 124.3,
      "end": 124.6,
      "speaker": null,
      "text": "Плюс."
    },
    {
      "start": 125.98,
      "end": 126.7,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 127.04,
      "end": 128.02,
      "speaker": null,
      "text": "Сроки есть какие-то, кстати?"
    },
    {
      "start": 128.98,
      "end": 132.66,
      "speaker": null,
      "text": "Ну смотри, шевроны нам нужно где-то месяца через полтора."
    },
    {
      "start": 132.86,
      "end": 133.84,
      "speaker": null,
      "text": "Поэтому всё нормально."
    },
    {
      "start": 134.04,
      "end": 136.84,
      "speaker": null,
      "text": "А эти давай по мере изготовления."
    },
    {
      "start": 137.36,
      "end": 139.64,
      "speaker": null,
      "text": "Но вот ленты мне нужны в первую очередь."
    },
    {
      "start": 139.9,
      "end": 142.62,
      "speaker": null,
      "text": "Я бы скорее всего одним заказом всё отдал, попробовал."
    },
    {
      "start": 142.7,
      "end": 142.96,
      "speaker": null,
      "text": "Один?"
    },
    {
      "start": 143.66,
      "end": 144.14,
      "speaker": null,
      "text": "Без, без."
    },
    {
      "start": 144.22,
      "end": 144.84,
      "speaker": null,
      "text": "Потому что да."
    },
    {
      "start": 145.66,
      "end": 150.32,
      "speaker": null,
      "text": "По поводу того, что одинаковые, считай, почти логотипы везде"
    },
    {
      "start": 150.32,
      "end": 151.4,
      "speaker": null,
      "text": "Вашей компании."
    },
    {
      "start": 151.68,
      "end": 153.58,
      "speaker": null,
      "text": "Их просят или одним заказом всё направить."
    },
    {
      "start": 153.64,
      "end": 154.76,
      "speaker": null,
      "text": "Даже есть разная продукция."
    },
    {
      "start": 155.08,
      "end": 155.56,
      "speaker": null,
      "text": "Ага, ага."
    },
    {
      "start": 155.64,
      "end": 157.08,
      "speaker": null,
      "text": "Хорошо, хорошо договорились."
    },
    {
      "start": 158.45,
      "end": 160.95,
      "speaker": null,
      "text": "Я пришёл со своей стороны макеты."
    },
    {
      "start": 162.11,
      "end": 163.91,
      "speaker": null,
      "text": "Ну то есть пойму, что мы делали."
    },
    {
      "start": 164.39,
      "end": 165.93,
      "speaker": null,
      "text": "А ленты какие-то другие?"
    },
    {
      "start": 166.67,
      "end": 171.05,
      "speaker": null,
      "text": "А ленты, которые мы в последний раз делали с тобой просто..."
    },
    {
      "start": 171.05,
      "end": 172.21,
      "speaker": null,
      "text": "Ой, мы делали..."
    },
    {
      "start": 172.21,
      "end": 172.63,
      "speaker": null,
      "text": "Я понял."
    },
    {
      "start": 173.67,
      "end": 175.61,
      "speaker": null,
      "text": "А вот без рулетки."
    },
    {
      "start": 175.79,
      "end": 177.45,
      "speaker": null,
      "text": "Просто с карабином."
    },
    {
      "start": 178.29,
      "end": 178.63,
      "speaker": null,
      "text": "Понял."
    },
    {
      "start": 178.63,
      "end": 180.77,
      "speaker": null,
      "text": "Я отправлю фотографии карабин, который есть."
    },
    {
      "start": 180.89,
      "end": 181.23,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 181.59,
      "end": 183.71,
      "speaker": null,
      "text": "Белая лента, как с размерами."
    },
    {
      "start": 183.99,
      "end": 185.07,
      "speaker": null,
      "text": "Нужно время, я направлю."
    },
    {
      "start": 185.21,
      "end": 186.27,
      "speaker": null,
      "text": "Постараюсь сегодня..."
    },
    {
      "start": 186.85,
      "end": 187.31,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 187.55,
      "end": 188.01,
      "speaker": null,
      "text": "Надеюсь."
    },
    {
      "start": 188.31,
      "end": 189.39,
      "speaker": null,
      "text": "Всё, даже на связи."
    },
    {
      "start": 189.49,
      "end": 189.75,
      "speaker": null,
      "text": "Есть ещё?"
    },
    {
      "start": 189.83,
      "end": 191.21,
      "speaker": null,
      "text": "Можешь проиграть завтра там попробовать."
    },
    {
      "start": 191.31,
      "end": 191.51,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 191.93,
      "end": 192.25,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 192.49,
      "end": 196.25,
      "speaker": null,
      "text": "А я тогда направлю брендбук и по шевронным информациям."
    },
    {
      "start": 196.25,
      "end": 197.25,
      "speaker": null,
      "text": "Да, всё супер хорошо."
    },
    {
      "start": 197.73,
      "end": 198.19,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 198.65,
      "end": 199.13,
      "speaker": null,
      "text": "На связи туда."
    }
  ]
}