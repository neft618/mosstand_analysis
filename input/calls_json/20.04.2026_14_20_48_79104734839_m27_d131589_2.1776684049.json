{
  "file": "20.04.2026_14_20_48_79104734839_m27_d131589_2.1776684049.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 255.1,
  "segments": [
    {
      "start": 0.0,
      "end": 2.0,
      "speaker": null,
      "text": "Добрый день, Валентин. Компания «Москенд»."
    },
    {
      "start": 2.86,
      "end": 10.76,
      "speaker": null,
      "text": "Добрый день, Валентин. Мы сообщили на прошлой неделе по поводу задика баннера на стене в Госфонде."
    },
    {
      "start": 11.2,
      "end": 11.94,
      "speaker": null,
      "text": "Да, Олег."
    },
    {
      "start": 13.75,
      "end": 21.61,
      "speaker": null,
      "text": "Хотел бы объяснить, можем ли мы на месте встретиться, чтобы посмотреть, как его вешат, какие варианты будут?"
    },
    {
      "start": 23.75,
      "end": 39.01,
      "speaker": null,
      "text": "Да, конечно. Смотрите, по замерам в целом я могу вам отправить человека, мне необходим будет ваш адрес, время, в которое можно отправить человека."
    },
    {
      "start": 40.7,
      "end": 52.17,
      "speaker": null,
      "text": "Выезд мне необходимо будет посчитать отдельно, стоимость выезда. И он замерит и вашу площадку, и посмотрит, какие варианты возможно вообще вам установить."
    },
    {
      "start": 52.17,
      "end": 60.11,
      "speaker": null,
      "text": "Да, вот просто вариант это, как его крепить, чтобы он был, скажем так, возможно сменой, то есть два баннера использовать."
    },
    {
      "start": 60.51,
      "end": 63.29,
      "speaker": null,
      "text": "Один с одним фоном, другой с другим."
    },
    {
      "start": 64.13,
      "end": 74.57,
      "speaker": null,
      "text": "Чтобы не было вот этих морщин, складок, чтобы он был максимально натянут и в то же время не вседал пространство от стены."
    },
    {
      "start": 77.58,
      "end": 94.32,
      "speaker": null,
      "text": "Хорошо. У нас были уже способы исполнения с роллерным, как будто выдвижной фон для конференций использовали также. Он, как знаете, полотно для проектора был?"
    },
    {
      "start": 94.32,
      "end": 97.9,
      "speaker": null,
      "text": "Да. Но длина 5,5 метров это реально?"
    },
    {
      "start": 99.26,
      "end": 111.08,
      "speaker": null,
      "text": "Вот с технологом общаюсь по этому поводу, потому что вы ранее называли. Жду вот ответ от него по возможности вообще такого исполнения в 5,5 метров."
    },
    {
      "start": 112.98,
      "end": 116.52,
      "speaker": null,
      "text": "Ну это вот когда можно будет информацию после возможного невозможного?"
    },
    {
      "start": 118.13,
      "end": 124.35,
      "speaker": null,
      "text": "Вот более точно я смогу завтра утром вам сообщить, возможно сегодня в течение дня жду ответ."
    },
    {
      "start": 124.35,
      "end": 129.47,
      "speaker": null,
      "text": "Так, ну адрес наш Сенферопольский бульвар, дом 13."
    },
    {
      "start": 130.33,
      "end": 132.09,
      "speaker": null,
      "text": "Угу. Так, записываю."
    },
    {
      "start": 133.0,
      "end": 136.54,
      "speaker": null,
      "text": "Визит если делать, то желательно где-то в интервале с 9 до 10."
    },
    {
      "start": 138.9,
      "end": 141.73,
      "speaker": null,
      "text": "Угу. Так."
    },
    {
      "start": 141.83,
      "end": 143.57,
      "speaker": null,
      "text": "Ну а день, любой рабочий день."
    },
    {
      "start": 144.38,
      "end": 151.75,
      "speaker": null,
      "text": "Так. Сенферопольский бульвар, дом 13."
    },
    {
      "start": 151.75,
      "end": 153.17,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 178.14,
      "end": 179.54,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 182.03,
      "end": 183.29,
      "speaker": null,
      "text": "Там заезд?"
    },
    {
      "start": 183.29,
      "end": 185.29,
      "speaker": null,
      "text": "А контактным лицом будете вы, да?"
    },
    {
      "start": 185.95,
      "end": 186.41,
      "speaker": null,
      "text": "При..."
    },
    {
      "start": 187.75,
      "end": 187.77,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 187.77,
      "end": 188.17,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 193.03,
      "end": 196.27,
      "speaker": null,
      "text": "Все, я все данные передам человеку в стоимость."
    },
    {
      "start": 196.27,
      "end": 196.37,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 196.49,
      "end": 199.91,
      "speaker": null,
      "text": "Я могу с вами как-то по почте связаться?"
    },
    {
      "start": 200.01,
      "end": 200.61,
      "speaker": null,
      "text": "У вас есть почта?"
    },
    {
      "start": 201.96,
      "end": 203.34,
      "speaker": null,
      "text": "Так, мы с вами не списывались."
    },
    {
      "start": 203.42,
      "end": 203.66,
      "speaker": null,
      "text": "Ну да."
    },
    {
      "start": 204.7,
      "end": 208.4,
      "speaker": null,
      "text": "Могу прогетовать в ходе на неслово, могу с кем-нибудь там где-то мессенджером."
    },
    {
      "start": 209.0,
      "end": 209.96,
      "speaker": null,
      "text": "Давайте я записываю."
    },
    {
      "start": 210.08,
      "end": 211.08,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 211.08,
      "end": 211.96,
      "speaker": null,
      "text": "О.Денидов?"
    },
    {
      "start": 212.31,
      "end": 213.39,
      "speaker": null,
      "text": "О.Денидов."
    },
    {
      "start": 214.71,
      "end": 216.81,
      "speaker": null,
      "text": "Да, ну как слышишь, как в принципе пишут."
    },
    {
      "start": 216.95,
      "end": 217.11,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 217.69,
      "end": 219.17,
      "speaker": null,
      "text": "На конце видит, кто-то девочкам."
    },
    {
      "start": 220.15,
      "end": 220.51,
      "speaker": null,
      "text": "Собака"
    },
    {
      "start": 220.51,
      "end": 221.81,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 223.09,
      "end": 223.81,
      "speaker": null,
      "text": "Газафонд"
    },
    {
      "start": 223.81,
      "end": 225.57,
      "speaker": null,
      "text": "G-A-Z-Z-R"
    },
    {
      "start": 226.49,
      "end": 227.21,
      "speaker": null,
      "text": "Газафонд"
    },
    {
      "start": 227.21,
      "end": 227.99,
      "speaker": null,
      "text": "точка ру"
    },
    {
      "start": 229.46,
      "end": 230.58,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 231.26,
      "end": 231.86,
      "speaker": null,
      "text": "Точка ру"
    },
    {
      "start": 231.86,
      "end": 233.53,
      "speaker": null,
      "text": "Все хорошо."
    },
    {
      "start": 235.04,
      "end": 237.7,
      "speaker": null,
      "text": "Я тогда вам всю информацию туда отправлю"
    },
    {
      "start": 237.7,
      "end": 243.38,
      "speaker": null,
      "text": "и по возможности исполнения именно рулонного варианта такого навесного,"
    },
    {
      "start": 243.82,
      "end": 246.02,
      "speaker": null,
      "text": "и по замерам."
    },
    {
      "start": 247.52,
      "end": 248.32,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 249.2,
      "end": 250.34,
      "speaker": null,
      "text": "Все, Олег, благодарю вас."
    },
    {
      "start": 251.02,
      "end": 251.48,
      "speaker": null,
      "text": "Да, спасибо."
    },
    {
      "start": 252.08,
      "end": 252.78,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 253.54,
      "end": 253.96,
      "speaker": null,
      "text": "До свидания."
    }
  ]
