      "speaker": null,
      "text": "Потому что у нас вроде как мы заказываем"
    },
    {
      "start": 369.26,
      "end": 370.7,
      "speaker": null,
      "text": "на всякую сувенивку и так далее."
    },
    {
      "start": 370.88,
      "end": 371.96,
      "speaker": null,
      "text": "Ну может у вас все тоже есть."
    },
    {
      "start": 372.28,
      "end": 372.6,
      "speaker": null,
      "text": "Тоже хорошо."
    },
    {
      "start": 372.78,
      "end": 373.28,
      "speaker": null,
      "text": "Уже в Москве, да?"
    },
    {
      "start": 373.28,
      "end": 373.66,
      "speaker": null,
      "text": "Уже в Москве, да?"
    },
    {
      "start": 374.18,
      "end": 374.42,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 375.18,
      "end": 375.78,
      "speaker": null,
      "text": "Ну отлично."
    },
    {
      "start": 376.87,
      "end": 377.11,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 377.65,
      "end": 379.15,
      "speaker": null,
      "text": "Все, составляю вам письмо."
    },
    {
      "start": 379.47,
      "end": 381.79,
      "speaker": null,
      "text": "Отправляю, чтобы вам сохранили все мои контакты"
    },
    {
      "start": 381.79,
      "end": 383.31,
      "speaker": null,
      "text": "и буду ждать информацию."
    },
    {
      "start": 384.15,
      "end": 384.63,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 384.63,
      "end": 385.29,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 385.77,
      "end": 385.95,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 386.61,
      "end": 386.99,
      "speaker": null,
      "text": "На связи."
    },
    {
      "start": 387.07,
      "end": 389.45,
      "speaker": null,
      "text": "У нас получается, они в принципе вот что стандарт,"
    },
    {
      "start": 389.57,
      "end": 390.51,
      "speaker": null,
      "text": "что классика просто не помню."
    },
    {
      "start": 390.67,
      "end": 392.07,
      "speaker": null,
      "text": "А в чем вообще отличаются?"
    },
    {
      "start": 392.23,
      "end": 392.99,
      "speaker": null,
      "text": "Ну никакого отличаются."
    },
    {
      "start": 393.05,
      "end": 395.15,
      "speaker": null,
      "text": "Ну они отличаются как бы производителем."
    },
    {
      "start": 395.77,
      "end": 396.21,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 396.57,
      "end": 399.15,
      "speaker": null,
      "text": "Ну брендом производителя."
    },
    {
      "start": 400.21,
      "end": 402.59,
      "speaker": null,
      "text": "Но ничем большим они не отличаются."
    },
    {
      "start": 402.89,
      "end": 404.47,
      "speaker": null,
      "text": "То есть по качеству они вообще одинаковые?"
    },
    {
      "start": 405.13,
      "end": 405.45,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 406.59,
      "end": 408.55,
      "speaker": null,
      "text": "Просто думал, что там качество какой-то пленки или"
    },
    {
      "start": 408.55,
      "end": 409.37,
      "speaker": null,
      "text": "еще что-то такое?"
    },
    {
      "start": 409.61,
      "end": 410.35,
      "speaker": null,
      "text": "Нет, абсолютно."
    },
    {
      "start": 410.35,
      "end": 412.95,
      "speaker": null,
      "text": "Потому что нам, в принципе, не принципиально, там"
    },
    {
      "start": 412.95,
      "end": 413.83,
      "speaker": null,
      "text": "есть большие это деньги."
    },
    {
      "start": 414.01,
      "end": 415.91,
      "speaker": null,
      "text": "Мы можем кто-то другой заказать просто и вопрос"
    },
    {
      "start": 415.91,
      "end": 417.87,
      "speaker": null,
      "text": "что удобнее, что лучше."
    },
    {
      "start": 418.11,
      "end": 418.37,
      "speaker": null,
      "text": "Понял?"
    },
    {
      "start": 418.55,
      "end": 419.67,
      "speaker": null,
      "text": "Ну я одинаковый."
    },
    {
      "start": 419.91,
      "end": 420.07,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 420.33,
      "end": 420.47,
      "speaker": null,
      "text": "Понял."
    },
    {
      "start": 420.61,
      "end": 421.33,
      "speaker": null,
      "text": "Хорошо, ясно."
    },
    {
      "start": 421.33,
      "end": 421.57,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 421.93,
      "end": 422.87,
      "speaker": null,
      "text": "Все тогда там..."
    },
    {
      "start": 422.87,
      "end": 424.17,
      "speaker": null,
      "text": "Да, составляю письмо."
    },
    {
      "start": 424.53,
      "end": 424.97,
      "speaker": null,
      "text": "Ловите."
    },
    {
      "start": 425.29,
      "end": 425.91,
      "speaker": null,
      "text": "На связи."
    },
    {
      "start": 426.17,
      "end": 426.43,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 426.43,
      "end": 427.27,
      "speaker": null,
      "text": "Хорошо, спасибо большое."
    },
    {
      "start": 427.57,
      "end": 427.63,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 427.97,
      "end": 427.99,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 428.45,
      "end": 428.99,
      "speaker": null,
      "text": "А еще..."
    }
  ]
}