      "speaker": null,
      "text": "2423"
    },
    {
      "start": 81.43,
      "end": 81.89,
      "speaker": null,
      "text": "Аликсей, так?"
    },
    {
      "start": 82.53,
      "end": 83.01,
      "speaker": null,
      "text": "Аликсей."
    },
    {
      "start": 83.53,
      "end": 85.67,
      "speaker": null,
      "text": "Скажите, вот Роман на Авазова."
    },
    {
      "start": 86.11,
      "end": 87.27,
      "speaker": null,
      "text": "Авазов – Роман."
    },
    {
      "start": 87.63,
      "end": 89.69,
      "speaker": null,
      "text": "Скажите ему по поводу промостойки."
    },
    {
      "start": 89.79,
      "end": 91.89,
      "speaker": null,
      "text": "Либо просто у него телега есть, поэтому номер пришлёте."
    },
    {
      "start": 92.67,
      "end": 93.81,
      "speaker": null,
      "text": "Промостойка вот именно эти."
    },
    {
      "start": 94.33,
      "end": 95.19,
      "speaker": null,
      "text": "Одна штука нужна."
    },
    {
      "start": 95.97,
      "end": 97.61,
      "speaker": null,
      "text": "Да, и ту, и ту, да?"
    },
    {
      "start": 97.77,
