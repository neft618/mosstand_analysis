{
  "file": "12.05.2026_10_14_45_79052440680_m31_d135691_5.1778570088.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 418.0,
  "segments": [
    {
      "start": 0.56,
      "end": 2.78,
      "speaker": null,
      "text": "Запись разговоров активирована."
    },
    {
      "start": 2.94,
      "end": 5.84,
      "speaker": null,
      "text": "Алло, Ангелина, здравствуйте. Это Валерия?"
    },
    {
      "start": 6.48,
      "end": 7.74,
      "speaker": null,
      "text": "Да, вот мы с вами открылись."
    },
    {
      "start": 8.4,
      "end": 16.56,
      "speaker": null,
      "text": "Смотрите, да, мы можем сегодня делать, но у нас до 16 часов сегодня можем сделать к 16. Так устроено?"
    },
    {
      "start": 16.6,
      "end": 17.3,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 17.64,
      "end": 18.72,
      "speaker": null,
      "text": "Да, 20 тысяч, да?"
    },
    {
      "start": 19.16,
      "end": 19.86,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 20.46,
      "end": 21.32,
      "speaker": null,
      "text": "Всё, всё хорошо."
    },
    {
      "start": 21.92,
      "end": 25.52,
      "speaker": null,
      "text": "Давайте тогда макет мне направите. Где вам удобнее?"
    },
    {
      "start": 25.54,
      "end": 25.78,
      "speaker": null,
      "text": "Куда?"
    },
    {
      "start": 26.0,
      "end": 28.94,
      "speaker": null,
      "text": "Например, в Максе, можно на почте. Как вам удобнее?"
    },
    {
      "start": 28.94,
      "end": 32.91,
      "speaker": null,
      "text": "Вот давайте я вам прямо сейчас в Максе направлю, прежде всего."
    },
    {
      "start": 33.21,
      "end": 37.13,
      "speaker": null,
      "text": "А давайте я вам напишу, а вы сейчас не пишите просто на общую почву, наверное?"
    },
    {
      "start": 37.41,
      "end": 42.64,
      "speaker": null,
      "text": "Либо если вы по номеру телефона, с которым я имею, то да, вы напишите уже мне."
    },
    {
      "start": 43.91,
      "end": 49.07,
      "speaker": null,
      "text": "Давайте по номеру телефона, у меня просто Макс на компьютере, на мой номер телефона."
    },
    {
      "start": 49.07,
      "end": 49.15,
      "speaker": null,
      "text": "Конечно."
    },
    {
      "start": 49.59,
      "end": 51.23,
      "speaker": null,
      "text": "Тогда дайте секунду подождите."
    },
    {
      "start": 52.35,
      "end": 56.29,
      "speaker": null,
      "text": "Один, один, два, девять, восемьдесят."
    },
    {
      "start": 57.49,
      "end": 57.73,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 58.45,
      "end": 59.45,
      "speaker": null,
      "text": "Так, Валерия?"
    },
    {
      "start": 59.91,
      "end": 60.59,
      "speaker": null,
      "text": "Да, это да."
    },
    {
      "start": 61.29,
      "end": 61.55,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 63.07,
      "end": 63.87,
      "speaker": null,
      "text": "Так, написала."
    },
    {
      "start": 64.31,
      "end": 68.01,
      "speaker": null,
      "text": "Сейчас подождите, макет 2 на 2 он нам нужен."
    },
    {
      "start": 68.01,
      "end": 69.07,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 69.23,
      "end": 72.97,
      "speaker": null,
      "text": "Так, разбросим его тут."
    },
    {
      "start": 74.52,
      "end": 75.24,
      "speaker": null,
      "text": "Отправить."
    },
    {
      "start": 76.4,
      "end": 77.34,
      "speaker": null,
      "text": "Так, супер."
    },
    {
      "start": 77.54,
      "end": 79.48,
      "speaker": null,
      "text": "А подождите, у вас он отправился картинкой?"
    },
    {
      "start": 81.14,
      "end": 82.0,
      "speaker": null,
      "text": "Так, да."
    },
    {
      "start": 82.28,
      "end": 82.4,
      "speaker": null,
      "text": "Наверное."
    },
    {
      "start": 82.5,
      "end": 83.4,
      "speaker": null,
      "text": "Попробую подождите."
    },
    {
      "start": 83.56,
      "end": 83.78,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 83.92,
      "end": 86.16,
      "speaker": null,
      "text": "Потому что у меня сейчас скачался он картинкой."
    },
    {
      "start": 86.46,
      "end": 88.38,
      "speaker": null,
      "text": "А у вас же TIFF формат, да?"
    },
    {
      "start": 88.98,
      "end": 92.14,
      "speaker": null,
      "text": "Нет, у меня JPEG в формате."
    },
    {
      "start": 93.3,
      "end": 93.68,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 93.84,
      "end": 96.58,
      "speaker": null,
      "text": "Хорошо, смотрите, я сразу нас предупреждаю, я конечно"
    },
    {
      "start": 96.58,
      "end": 101.18,
      "speaker": null,
      "text": "сейчас отправлю на проверку, но нам нужны форматы файлов"
    },
    {
      "start": 101.18,
      "end": 105.88,
      "speaker": null,
      "text": "там TIFF, PDF например, AI тоже подойдёт."
    },
    {
      "start": 106.02,
      "end": 106.22,
      "speaker": null,
      "text": "Почему?"
    },
    {
      "start": 106.22,
      "end": 111.01,
      "speaker": null,
      "text": "Потому что JPEG или PNG это картинки, то есть они если"
    },
    {
      "start": 111.01,
      "end": 114.39,
      "speaker": null,
      "text": "будут печататься в огромном таком размере, то есть"
    },
    {
      "start": 114.39,
      "end": 116.19,
      "speaker": null,
      "text": "2 на 2 метра достаточно большой."
    },
    {
      "start": 116.99,
      "end": 122.02,
      "speaker": null,
      "text": "Он просто будет печатать очень сильно, когда мы уже"
    },
    {
      "start": 122.02,
      "end": 122.34,
      "speaker": null,
      "text": "будем печатать."
    },
    {
      "start": 122.36,
      "end": 125.3,
      "speaker": null,
      "text": "У меня есть PDF, но он не того размера, видите?"
    },
    {
      "start": 125.52,
      "end": 127.32,
      "speaker": null,
      "text": "Могу он не того размера делать, мне нужно сделать"
    },
    {
      "start": 127.32,
      "end": 128.44,
      "speaker": null,
      "text": "всё равно 2 на 2."
    },
    {
      "start": 129.0,
      "end": 129.32,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 129.78,
      "end": 131.92,
      "speaker": null,
      "text": "А у вас PDF уже в реакторном формате?"
    },
    {
      "start": 135.65,
      "end": 138.41,
      "speaker": null,
      "text": "Блин, ну скорее всего да, мне этот типограф я делала."
    },
    {
      "start": 139.14,
      "end": 141.18,
      "speaker": null,
      "text": "И у меня есть, смотрите, второй вариант."
    },
    {
      "start": 141.6,
      "end": 142.72,
      "speaker": null,
      "text": "У меня есть как бы два варианта."
    },
    {
      "start": 142.84,
      "end": 144.4,
      "speaker": null,
      "text": "Я могу отправить всё, что у меня есть."
    },
    {
      "start": 145.14,
      "end": 148.51,
      "speaker": null,
      "text": "Есть в формате 2 на 1, там нужно убирать номер зала."
    },
    {
      "start": 148.51,
      "end": 150.83,
      "speaker": null,
      "text": "Ага, подождите секундочку."
    },
    {
      "start": 151.56,
      "end": 152.5,
      "speaker": null,
      "text": "Блин, нет."
    },
    {
      "start": 152.74,
      "end": 153.82,
      "speaker": null,
      "text": "Блин, есть нету."
    },
    {
      "start": 154.76,
      "end": 158.18,
      "speaker": null,
      "text": "Так, есть вот такой у меня, но тут нужно убирать в серединке"
    },
    {
      "start": 158.18,
      "end": 160.36,
      "speaker": null,
      "text": "плашку номер зала."
    },
    {
      "start": 160.36,
      "end": 163.18,
      "speaker": null,
      "text": "А есть баннер."
    },
    {
      "start": 163.68,
      "end": 166.42,
      "speaker": null,
      "text": "Баннер 3 на 2, да."
    },
    {
      "start": 166.7,
      "end": 168.72,
      "speaker": null,
      "text": "Вот здесь баннер 3 на 2 и тут."
    },
    {
      "start": 171.09,
      "end": 172.59,
      "speaker": null,
      "text": "Это вот который вы сейчас отправили?"
    },
    {
      "start": 173.29,
      "end": 173.43,
      "speaker": null,
      "text": "Да, да?"
    },
    {
      "start": 174.4,
      "end": 175.28,
      "speaker": null,
      "text": "Да, вот."
    },
    {
      "start": 175.58,
      "end": 178.76,
      "speaker": null,
      "text": "Есть такой вот, но он 3 на 2 и его нужно будет, получается,"
    },
    {
      "start": 179.26,
      "end": 179.72,
      "speaker": null,
      "text": "сужать."
    },
    {
      "start": 182.2,
      "end": 184.1,
      "speaker": null,
      "text": "Вот сейчас я смотрю, он узкий."
    },
    {
      "start": 186.69,
      "end": 188.17,
      "speaker": null,
      "text": "Он узкий нам тоже есть."
    },
    {
      "start": 188.17,
      "end": 188.43,
      "speaker": null,
      "text": "Есть."
    },
    {
      "start": 188.9,
      "end": 189.32,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 189.54,
      "end": 192.12,
      "speaker": null,
      "text": "Да, вот можно убирать номер зала."
    },
    {
      "start": 192.44,
      "end": 195.58,
      "speaker": null,
      "text": "Либо же вот есть побольше размером, я вам скинула"
    },
    {
      "start": 195.58,
      "end": 196.58,
      "speaker": null,
      "text": "ниже его там."
    },
    {
      "start": 197.46,
      "end": 198.26,
      "speaker": null,
      "text": "Давайте языкак."
    },
    {
      "start": 198.34,
      "end": 202.05,
      "speaker": null,
      "text": "Я сейчас отправлю дизайнеру всё, что у нас есть, чтобы"
    },
    {
      "start": 202.05,
      "end": 204.21,
      "speaker": null,
      "text": "она уже посмотрела, какой будет лучше."
    },
    {
      "start": 206.93,
      "end": 207.37,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 207.67,
      "end": 207.99,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 208.23,
      "end": 210.79,
      "speaker": null,
      "text": "И тогда сейчас я отправляю сразу на проверку."
    },
    {
      "start": 210.89,
      "end": 213.39,
      "speaker": null,
      "text": "Подскажите, у вас оплата как по счёту от Юлиса"
    },
    {
      "start": 213.39,
      "end": 215.43,
      "speaker": null,
      "text": "будет или от Физиса по ссылке?"
    },
    {
      "start": 215.43,
      "end": 216.47,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 217.36,
      "end": 218.54,
      "speaker": null,
      "text": "Блин, ну как вам удобнее?"
    },
    {
      "start": 218.78,
      "end": 220.36,
      "speaker": null,
      "text": "Слушайте, на каком удобнее?"
    },
    {
      "start": 220.64,
      "end": 221.24,
      "speaker": null,
      "text": "Потому что…"
    },
    {
      "start": 221.24,
      "end": 221.44,
      "speaker": null,
      "text": "Веки быстрее."
    },
    {
      "start": 222.0,
      "end": 226.48,
      "speaker": null,
      "text": "Просто веки быстрее – это оплата от Юлиса."
    },
    {
      "start": 226.78,
      "end": 229.58,
      "speaker": null,
      "text": "Потому что обычно по счёту он не дольше оплачивает,"
    },
    {
      "start": 229.7,
      "end": 232.74,
      "speaker": null,
      "text": "потому что через бухгалтера это просто в целом дольше"
    },
    {
      "start": 232.74,
      "end": 233.4,
      "speaker": null,
      "text": "получается."
    },
    {
      "start": 234.04,
      "end": 234.34,
      "speaker": null,
      "text": "Посмотрите."
    },
    {
      "start": 234.34,
      "end": 234.78,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 234.94,
      "end": 235.38,
      "speaker": null,
      "text": "Смотрите."
    },
    {
      "start": 235.8,
      "end": 236.2,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 236.42,
      "end": 241.7,
      "speaker": null,
      "text": "Только у нас дело в том, что он примерно через час"
    },
    {
      "start": 241.7,
      "end": 244.32,
      "speaker": null,
      "text": "проснётся, он просто в другом часовом полисе и сейчас"
    },
    {
      "start": 244.32,
      "end": 245.04,
      "speaker": null,
      "text": "я ему…"
    },
    {
      "start": 245.04,
      "end": 245.24,
      "speaker": null,
      "text": "Конечно, конечно."
    },
    {
      "start": 245.98,
      "end": 246.1,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 246.94,
      "end": 249.24,
      "speaker": null,
      "text": "Где-то через час-полтора он будет оплачивать."
    },
    {
      "start": 249.92,
      "end": 251.24,
      "speaker": null,
      "text": "Тогда сколько можете присылать?"
    },
    {
      "start": 251.66,
      "end": 252.14,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 252.4,
      "end": 254.94,
      "speaker": null,
      "text": "Давайте тогда я сейчас разберусь сначала с макетом,"
    },
    {
      "start": 256.12,
      "end": 259.26,
      "speaker": null,
      "text": "чтобы у нас всё получилось в целом."
    },
    {
      "start": 259.32,
      "end": 261.24,
      "speaker": null,
      "text": "Потому что макет – это одна из самых важных."
    },
    {
      "start": 261.24,
      "end": 264.44,
      "speaker": null,
      "text": "И я направлю пока ссылку, там как проснётся – оплатит."
    },
    {
      "start": 266.65,
      "end": 267.01,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 267.37,
      "end": 267.65,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 267.79,
      "end": 268.01,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 268.33,
      "end": 268.51,
      "speaker": null,
      "text": "Супер."
    },
    {
      "start": 268.79,
      "end": 268.95,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 269.11,
      "end": 271.27,
      "speaker": null,
      "text": "Тогда на связи сейчас буду отправлять инфидизайнеру."
    },
    {
      "start": 271.35,
      "end": 272.85,
      "speaker": null,
      "text": "Я дам вам обратную связь обязательно."
    },
    {
      "start": 273.31,
      "end": 274.71,
      "speaker": null,
      "text": "16 будет готов примерно?"
    },
    {
      "start": 274.87,
      "end": 276.11,
      "speaker": null,
      "text": "Ну, там уже 15-17."
    },
    {
      "start": 276.75,
      "end": 276.77,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 276.81,
      "end": 278.53,
      "speaker": null,
      "text": "Ну, если по 17 – тоже нормально."
    },
    {
      "start": 280.22,
      "end": 280.74,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 281.06,
      "end": 281.44,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 281.7,
      "end": 281.96,
      "speaker": null,
      "text": "Супер."
    },
    {
      "start": 282.06,
      "end": 283.08,
      "speaker": null,
      "text": "Тогда договорились."
    },
    {
      "start": 283.2,
      "end": 285.62,
      "speaker": null,
      "text": "Ну, к 16 мы плачаем пока что крайний срок."
    },
    {
      "start": 285.8,
      "end": 287.36,
      "speaker": null,
      "text": "Сейчас мы быстро проверим макету."
    },
    {
      "start": 287.52,
      "end": 288.16,
      "speaker": null,
      "text": "Нам чтобы…"
    },
    {
      "start": 288.16,
      "end": 290.22,
      "speaker": null,
      "text": "Макетом сейчас самое важное, что без макета мы"
    },
    {
      "start": 290.22,
      "end": 291.28,
      "speaker": null,
      "text": "написать не сможем."
    },
    {
      "start": 292.03,
      "end": 292.43,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 292.89,
      "end": 293.29,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 293.79,
      "end": 293.97,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 294.17,
      "end": 295.49,
      "speaker": null,
      "text": "Слушайте, только единственное ещё момент…"
    },
    {
      "start": 296.27,
      "end": 296.37,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 296.65,
      "end": 299.29,
      "speaker": null,
      "text": "Единственное, что потом до мужчины позвонить, ну,"
    },
    {
      "start": 299.41,
      "end": 299.79,
      "speaker": null,
      "text": "выбирать."
    },
    {
      "start": 299.93,
      "end": 301.91,
      "speaker": null,
      "text": "Потому что там тоже вот в Москву вот так, ну,"
    },
    {
      "start": 302.17,
      "end": 302.95,
      "speaker": null,
      "text": "полететь получается."
    },
    {
      "start": 303.53,
      "end": 305.21,
      "speaker": null,
      "text": "Я просто не знаю, прилетел он сегодня или нет."
    },
    {
      "start": 305.31,
      "end": 307.63,
      "speaker": null,
      "text": "Вот пока если бы не прилетел наш смачал спит,"
    },
    {
      "start": 307.67,
      "end": 309.79,
      "speaker": null,
      "text": "но я не могу вообще надеяться спит в любом случае."
    },
    {
      "start": 310.39,
      "end": 314.8,
      "speaker": null,
      "text": "Но при самолёте, причём отсюда где-то в часов шесть."
    },
    {
      "start": 314.9,
      "end": 318.11,
      "speaker": null,
      "text": "Если либо я в шесть заберу его, вот."
    },
    {
      "start": 318.51,
      "end": 320.01,
      "speaker": null,
      "text": "Либо же он заберёт раньше."
    },
    {
      "start": 320.33,
      "end": 324.25,
      "speaker": null,
      "text": "Ну, если бы мужчина заберёт и побудет звонить по макету."
    },
    {
      "start": 324.25,
      "end": 325.27,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 325.86,
      "end": 327.54,
      "speaker": null,
      "text": "Смотрите, Ангелина, если что…"
    },
    {
      "start": 328.08,
      "end": 330.78,
      "speaker": null,
      "text": "Ну, тут без разницы кто именно будет забирать."
    },
    {
      "start": 330.94,
      "end": 332.6,
      "speaker": null,
      "text": "Я дам вам номер заказа."
    },
    {
      "start": 332.88,
      "end": 334.64,
      "speaker": null,
      "text": "Адрес я тоже всё продублирую."
    },
    {
      "start": 334.72,
      "end": 337.9,
      "speaker": null,
      "text": "Контакт от нас тоже постоянно пришло."
    },
    {
      "start": 337.9,
      "end": 341.02,
      "speaker": null,
      "text": "И там уже кто от вас может забрать, вот тот заберёт."
    },
    {
      "start": 341.02,
      "end": 342.52,
      "speaker": null,
      "text": "Вы можете хоть курьера вызвать."
    },
    {
      "start": 343.3,
      "end": 344.78,
      "speaker": null,
      "text": "Там, например, от Яндекса."
    },
    {
      "start": 344.92,
      "end": 345.9,
      "speaker": null,
      "text": "То есть это не проблема."
    },
    {
      "start": 346.24,
      "end": 348.22,
      "speaker": null,
      "text": "Просто главное, чтобы номер заказа был."
    },
    {
      "start": 349.76,
      "end": 351.06,
      "speaker": null,
      "text": "Единственное, что хотела сказать."
    },
    {
      "start": 351.16,
      "end": 353.28,
      "speaker": null,
      "text": "Смотрите, у нас производство будет работать до шести."
    },
    {
      "start": 353.48,
      "end": 355.54,
      "speaker": null,
      "text": "То есть оно в целом у нас до шести работает."
    },
    {
      "start": 356.0,
      "end": 358.86,
      "speaker": null,
      "text": "После шести лет отдать не смогут."
    },
    {
      "start": 358.98,
      "end": 364.01,
      "speaker": null,
      "text": "То есть можем, например, курьера вызвать с четырёх,"
    },
    {
      "start": 364.01,
      "end": 368.65,
      "speaker": null,
      "text": "чтобы он там приехал, там его куда-то увёз, например, на какую-то точку где-то оставил."
    },
    {
      "start": 368.97,
      "end": 371.13,
      "speaker": null,
      "text": "Либо может быть что-то от вас заберёт тоже."
    },
    {
      "start": 371.97,
      "end": 372.75,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 374.19,
      "end": 376.17,
      "speaker": null,
      "text": "Я думаю, что я пока буду улететь."
    },
    {
      "start": 376.33,
      "end": 377.03,
      "speaker": null,
      "text": "Они вызовут…"
    },
    {
      "start": 377.03,
      "end": 379.71,
      "speaker": null,
      "text": "Ну, у меня просто прилетают в 17.45."
    },
    {
      "start": 380.21,
      "end": 380.75,
      "speaker": null,
      "text": "У нас такое."
    },
    {
      "start": 381.37,
      "end": 384.03,
      "speaker": null,
      "text": "Понимаю, считаю, что с самолёцами такая управа."
    },
    {
      "start": 384.27,
      "end": 384.67,
      "speaker": null,
      "text": "Неизвестно."
    },
    {
      "start": 385.05,
      "end": 386.37,
      "speaker": null,
      "text": "Приведись, не приведись в это время."
    },
    {
      "start": 387.09,
      "end": 387.35,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 388.25,
      "end": 389.13,
      "speaker": null,
      "text": "Я им передам."
    },
    {
      "start": 389.15,
      "end": 390.61,
      "speaker": null,
      "text": "Если что, они закажут либо садиться."
    },
    {
      "start": 391.03,
      "end": 391.39,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 391.39,
      "end": 392.45,
      "speaker": null,
      "text": "Ну, в любом случае, да."
    },
    {
      "start": 392.57,
      "end": 395.07,
      "speaker": null,
      "text": "Я им передам всю информацию и раз вы пропишите."
    },
    {
      "start": 395.35,
      "end": 395.43,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 395.55,
      "end": 396.03,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 396.89,
      "end": 397.45,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 398.23,
      "end": 398.51,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 398.63,
      "end": 399.31,
      "speaker": null,
      "text": "Тогда договорились."
    },
    {
      "start": 399.47,
      "end": 400.65,
      "speaker": null,
      "text": "Сейчас я отправляю уже."
    },
    {
      "start": 402.48,
      "end": 403.04,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 403.26,
      "end": 403.46,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 404.22,
      "end": 405.2,
      "speaker": null,
      "text": "На связи."
    },
    {
      "start": 405.48,
      "end": 407.26,
      "speaker": null,
      "text": "Спасибо огромное за помощь вам."
    },
    {
      "start": 407.38,
      "end": 408.52,
      "speaker": null,
      "text": "Вы меня прямо выручили."
    },
    {
      "start": 409.3,
      "end": 410.86,
      "speaker": null,
      "text": "Ничего страшного сюда выручения."
    },
    {
      "start": 412.09,
      "end": 412.65,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 413.23,
      "end": 413.51,
      "speaker": null,
      "text": "Спасибо вам."
    },
    {
      "start": 413.69,
      "end": 413.81,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 414.17,
      "end": 414.79,
      "speaker": null,
      "text": "Хорошего дня."
    },
    {
      "start": 414.93,
      "end": 415.35,
      "speaker": null,
      "text": "На связи."
    },
    {
      "start": 415.55,
      "end": 416.05,
      "speaker": null,
      "text": "И вам."
    },
    {
      "start": 416.73,
      "end": 417.13,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}