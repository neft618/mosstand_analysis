    {
      "start": 135.38,
      "end": 136.3,
      "speaker": null,
      "text": "Вот так я прописала."
    },
    {
      "start": 136.94,
      "end": 139.54,
      "speaker": null,
      "text": "По монтажу, в принципе, да, супер."
