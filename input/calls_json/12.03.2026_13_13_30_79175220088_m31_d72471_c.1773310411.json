  "segments": [
    {
      "start": 0.4,
      "end": 2.14,
      "speaker": null,
      "text": "Валерия, здравствуйте, это Валерия."
    },
    {
      "start": 2.72,
      "end": 5.68,
      "speaker": null,
      "text": "Валерия, здравствуйте, это Павел. Я вам только что написал как раз?"
