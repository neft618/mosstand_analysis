  "segments": [
    {
      "start": 0.94,
      "end": 2.44,
      "speaker": null,
      "text": "Алексей, приветствую."
    },
    {
      "start": 2.8,
      "end": 3.9,
      "speaker": null,
      "text": "Здравствуйте, Владислав."
    },
    {
      "start": 4.84,
      "end": 13.54,
      "speaker": null,
      "text": "Только что отправил вам письмо с информацией о том, что выбрали, соответственно, с центров метровой ширины и ссылкой на МАКЕР."
    },
    {
      "start": 14.15,
      "end": 17.03,
      "speaker": null,
      "text": "Макетный дизайнер сделал стихо и подайся."
    },
    {
      "start": 18.24,
      "end": 22.41,
      "speaker": null,
      "text": "Так, да, выбрали центр."
    },
    {
      "start": 24.37,
      "end": 29.15,
      "speaker": null,
      "text": "Так, макет выбрал."
    },
    {
      "start": 29.37,
      "end": 30.97,
      "speaker": null,
      "text": "А у вас полотно же будет, правильно?"
    },
    {
      "start": 31.39,
      "end": 34.13,
      "speaker": null,
      "text": "Да, только полотно, без конструкции."
    },
    {
      "start": 34.32,
      "end": 39.26,
      "speaker": null,
      "text": "Хорошо, тогда сейчас вам направляю ответным письмом правильно и макеты проверяю."
    },
    {
      "start": 39.66,
      "end": 39.92,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 40.86,
      "end": 42.44,
      "speaker": null,
      "text": "Всё, отлично, да, сейчас сделаем."
    },
    {
      "start": 42.96,
      "end": 43.28,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 43.82,
      "end": 54.16,
      "speaker": null,
      "text": "А если помните нам с доставкой нужно и небольшую стыдочку вы мне давали на 2,5 метра, надеюсь, что на 3 метра она больше справится."
    },
    {
      "start": 55.56,
      "end": 59.18,
      "speaker": null,
      "text": "Да-да-да, я сейчас всю вам информацию предоставляю."
    },
    {
      "start": 59.62,
      "end": 60.24,
      "speaker": null,
      "text": "Угу, спасибо."
    },
    {
      "start": 60.8,
      "end": 61.42,
      "speaker": null,
      "text": "Да, на связи."
    },
    {
      "start": 61.54,
      "end": 62.48,
      "speaker": null,
      "text": "Всё, тогда до свидания."
    },
    {
      "start": 63.1,
      "end": 63.48,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}