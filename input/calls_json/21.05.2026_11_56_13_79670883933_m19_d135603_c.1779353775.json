{
  "file": "21.05.2026_11_56_13_79670883933_m19_d135603_c.1779353775.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 64.4,
  "segments": [
    {
      "start": 1.97,
      "end": 5.11,
      "speaker": null,
      "text": "Алло, Кристина. Здравствуйте! Это была компания МОСТЭНД."
    },
    {
      "start": 5.88,
      "end": 6.9,
      "speaker": null,
      "text": "Да, здравствуйте."
    },
    {
      "start": 7.06,
      "end": 16.06,
      "speaker": null,
      "text": "Да, мы с вами по промостоке общались в следующий четверг. Планировали связаться по поводу макета. Хотела узнать о готовности макета у вас."
    },
    {
      "start": 16.94,
      "end": 25.84,
      "speaker": null,
      "text": "Да, у нас макет готов. Мы сейчас просто выбираем цвет нужный и будем уже вам присылать."
    },
    {
      "start": 27.04,
      "end": 37.93,
      "speaker": null,
      "text": "В целом, можно пока счёт выставить на оплату. Для этого мне нужно будет вам по почте расслабить."
    },
    {
      "start": 39.14,
      "end": 39.72,
      "speaker": null,
      "text": "Репрезиты?"
    },
    {
      "start": 40.46,
      "end": 40.86,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 41.92,
      "end": 46.08,
      "speaker": null,
      "text": "Хорошо, без проблем. Тогда жду ваши репрезиты и ответы на письмо почтаю вам сейчас."
    },
    {
      "start": 47.13,
      "end": 51.25,
      "speaker": null,
      "text": "Единственное, я хотел уточнить. Напомните, пожалуйста, у нас самовоз уже будет, правильно?"
    },
    {
      "start": 52.38,
      "end": 53.8,
      "speaker": null,
      "text": "Нет, у нас с доставкой."
    },
    {
      "start": 54.4,
      "end": 56.6,
      "speaker": null,
      "text": "Доставку ставим в пределах МКАД, верно?"
    },
    {
      "start": 56.6,
      "end": 57.58,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 58.22,
      "end": 60.6,
      "speaker": null,
      "text": "Всё отлично, отлично. Тогда жду репрезиты ваши."
    },
    {
      "start": 60.88,
      "end": 61.7,
      "speaker": null,
      "text": "Ага, хорошо."
    },
    {
      "start": 62.26,
      "end": 62.76,
      "speaker": null,
      "text": "На связи."
    }
  ]
}