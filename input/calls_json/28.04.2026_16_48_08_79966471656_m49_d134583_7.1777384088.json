{
  "file": "28.04.2026_16_48_08_79966471656_m49_d134583_7.1777384088.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 142.3,
  "segments": [
    {
      "start": 2.61,
      "end": 5.05,
      "speaker": null,
      "text": "Елена, здравствуйте. Компания МОСТЕНТ."
    },
    {
      "start": 5.82,
      "end": 8.6,
      "speaker": null,
      "text": "Елена, доброго дня. Скажите, а Вы производство?"
    },
    {
      "start": 10.16,
      "end": 12.28,
      "speaker": null,
      "text": "Рекламное производство, да."
    },
    {
      "start": 13.28,
      "end": 17.18,
      "speaker": null,
      "text": "Но Вы не изготавливаете флаги и комплектующие для них?"
    },
    {
      "start": 19.17,
      "end": 20.29,
      "speaker": null,
      "text": "Комплектующие для чего?"
    },
    {
      "start": 21.06,
      "end": 22.54,
      "speaker": null,
      "text": "Для флагов виндеров."
    },
    {
      "start": 23.54,
      "end": 25.3,
      "speaker": null,
      "text": "А какие комплектующие Вам нужны?"
    },
    {
      "start": 25.64,
      "end": 30.26,
      "speaker": null,
      "text": "Меня интересует риска утяжелительная 40 на 40 с отверстием для флага."
    },
    {
      "start": 31.63,
      "end": 32.71,
      "speaker": null,
      "text": "Одна штука Вам нужна?"
    },
    {
      "start": 32.71,
      "end": 33.87,
      "speaker": null,
      "text": "Сто штук."
    },
    {
      "start": 35.54,
      "end": 37.84,
      "speaker": null,
      "text": "А, ну, мы не..."
    },
    {
      "start": 37.84,
      "end": 39.34,
      "speaker": null,
      "text": "Ну, эти отдельные основания..."
    },
    {
      "start": 39.34,
      "end": 40.34,
      "speaker": null,
      "text": "То есть нам нужны основания?"
    },
    {
      "start": 40.56,
      "end": 40.88,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 42.42,
      "end": 44.36,
      "speaker": null,
      "text": "Мне нужна плитка для оснований."
    },
    {
      "start": 44.62,
      "end": 46.02,
      "speaker": null,
      "text": "Да, плитка для оснований."
    },
    {
      "start": 46.12,
      "end": 47.22,
      "speaker": null,
      "text": "Ну да, конечно."
    },
    {
      "start": 47.84,
      "end": 51.46,
      "speaker": null,
      "text": "Меня интересует, мне нужна плитка в сто штук."
    },
    {
      "start": 53.11,
      "end": 56.49,
      "speaker": null,
      "text": "Утяжелительная плитка 40 на 40 с отверстием по центру."
    },
    {
      "start": 56.73,
      "end": 60.11,
      "speaker": null,
      "text": "Чтобы, знаете, на этот виндер одна плитка называлась."
    },
    {
      "start": 60.11,
      "end": 61.03,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 61.13,
      "end": 61.37,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 61.63,
      "end": 66.23,
      "speaker": null,
      "text": "Но, но, но мне нужна не обычная, знаете, вот как вот плитка..."
    },
    {
      "start": 66.23,
      "end": 68.35,
      "speaker": null,
      "text": "Вот есть каменная, да?"
    },
    {
      "start": 68.73,
      "end": 69.75,
      "speaker": null,
      "text": "И на с отверстием."
    },
    {
      "start": 70.45,
      "end": 73.21,
      "speaker": null,
      "text": "Такая более ударопрочная история..."
    },
    {
      "start": 73.21,
      "end": 74.17,
      "speaker": null,
      "text": "Они стандартные."
    },
    {
      "start": 74.61,
      "end": 75.05,
      "speaker": null,
      "text": "А?"
    },
    {
      "start": 75.6,
      "end": 76.96,
      "speaker": null,
      "text": "Они стандартные."
    },
    {
      "start": 77.84,
      "end": 79.06,
      "speaker": null,
      "text": "Какие они у Вас?"
    },
    {
      "start": 80.95,
      "end": 84.47,
      "speaker": null,
      "text": "Ну, какой-то материал, бетон."
    },
    {
      "start": 86.11,
      "end": 87.91,
      "speaker": null,
      "text": "Артикул на сайте подскажете?"
    },
    {
      "start": 88.39,
      "end": 89.51,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 89.89,
      "end": 91.31,
      "speaker": null,
      "text": "Они без артикула идут."
    },
    {
      "start": 91.45,
      "end": 94.39,
      "speaker": null,
      "text": "Они идут в основание, то есть они идут в разделе"
    },
    {
      "start": 94.39,
      "end": 101.19,
      "speaker": null,
      "text": "флаги и вот где вся информация для флагов расписана."
    },
    {
      "start": 101.67,
      "end": 104.69,
      "speaker": null,
      "text": "Флагшток и разные виды оснований."
    },
    {
      "start": 104.85,
      "end": 107.09,
      "speaker": null,
      "text": "Вот она есть там как плитка-утяжелитель."
    },
    {
      "start": 109.84,
      "end": 112.18,
      "speaker": null,
      "text": "Так, флагштоки, флагштоки только."
    },
    {
      "start": 114.98,
      "end": 120.8,
      "speaker": null,
      "text": "Сейчас попробуем найти основания для флагштоков в Москве."
    },
    {
      "start": 121.61,
      "end": 124.61,
      "speaker": null,
      "text": "Вот плитка-утяжелительная, вижу, да."
    },
    {
      "start": 126.14,
      "end": 128.62,
      "speaker": null,
      "text": "На Вас она идет бетонная, каменная?"
    },
    {
      "start": 129.5,
      "end": 131.96,
      "speaker": null,
      "text": "Ну да, это вот она, но других нет."
    },
    {
      "start": 133.34,
      "end": 133.6,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 135.78,
      "end": 136.94,
      "speaker": null,
      "text": "Я к Вас понял."
    },
    {
      "start": 137.4,
      "end": 138.22,
      "speaker": null,
      "text": "Ладно, спасибо."
    },
    {
      "start": 138.98,
      "end": 139.42,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 139.84,
      "end": 140.94,
      "speaker": null,
      "text": "Да, на связи."
    }
  ]
}