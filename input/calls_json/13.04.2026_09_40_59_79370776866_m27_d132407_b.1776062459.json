{
  "file": "13.04.2026_09_40_59_79370776866_m27_d132407_b.1776062459.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 185.8,
  "segments": [
    {
      "start": 0.4,
      "end": 3.44,
      "speaker": null,
      "text": "Добрый день. Меня зовут Валентин, компания Мастан. Чем я могу вам помочь?"
    },
    {
      "start": 4.34,
      "end": 10.18,
      "speaker": null,
      "text": "Здравствуйте. Скажите, а баннер 1 на 2 пораспечать сколько будет стоить у вас?"
    },
    {
      "start": 10.96,
      "end": 12.7,
      "speaker": null,
      "text": "А скажите, пожалуйста, как я могу к вам обращаться?"
    },
    {
      "start": 13.3,
      "end": 13.94,
      "speaker": null,
      "text": "Александр."
    },
    {
      "start": 14.72,
      "end": 16.6,
      "speaker": null,
      "text": "Александр. Когда вам необходим баннер?"
    },
    {
      "start": 17.5,
      "end": 18.12,
      "speaker": null,
      "text": "Сегодня."
    },
    {
      "start": 18.92,
      "end": 19.46,
      "speaker": null,
      "text": "Сегодня."
    },
    {
      "start": 21.01,
      "end": 22.19,
      "speaker": null,
      "text": "Блэкбэк или обычный?"
    },
    {
      "start": 23.29,
      "end": 23.93,
      "speaker": null,
      "text": "Обычный."
    },
    {
      "start": 24.75,
      "end": 28.53,
      "speaker": null,
      "text": "Обычный литовый баннер. Метр на два вы сказали?"
    },
    {
      "start": 29.26,
      "end": 29.56,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 32.06,
      "end": 34.94,
      "speaker": null,
      "text": "Ну, вот для рулапов только баннер сам."
    },
    {
      "start": 36.09,
      "end": 38.29,
      "speaker": null,
      "text": "А, баннер для рулапов. Хорошо."
    },
    {
      "start": 38.95,
      "end": 41.81,
      "speaker": null,
      "text": "А вам перезаправка потребуется или только баннер?"
    },
    {
      "start": 44.57,
      "end": 45.51,
      "speaker": null,
      "text": "Да, баннер только."
    },
    {
      "start": 46.65,
      "end": 47.51,
      "speaker": null,
      "text": "Только баннер."
    },
    {
      "start": 49.68,
      "end": 56.2,
      "speaker": null,
      "text": "Стоимость баннера будет 2200 рублей. Вам заправка потребуется?"
    },
    {
      "start": 59.1,
      "end": 61.26,
      "speaker": null,
      "text": "А где вы находитесь? Куда она отдаётся?"
    },
    {
      "start": 61.8,
      "end": 65.24,
      "speaker": null,
      "text": "Район Новогиреево, Мартеновская, 35А."
    },
    {
      "start": 72.8,
      "end": 74.78,
      "speaker": null,
      "text": "Да ну можно забрать съездить."
    },
    {
      "start": 76.13,
      "end": 80.51,
      "speaker": null,
      "text": "Хорошо. А скажите, пожалуйста, у вас мероприятие будет? Выставка?"
    },
    {
      "start": 82.5,
      "end": 85.96,
      "speaker": null,
      "text": "Да надо выступить ребёнку на конфиденции."
    },
    {
      "start": 88.01,
      "end": 93.41,
      "speaker": null,
      "text": "Хорошо, я вас понял. Смотрите, у нас минимальная сумма заказа 5000 рублей."
    },
    {
      "start": 93.41,
      "end": 94.75,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 96.17,
      "end": 96.45,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 96.95,
      "end": 101.81,
      "speaker": null,
      "text": "Вам может ещё что-то потребоваться? Сам рулап, полиграфия сувенирная продукция?"
    },
    {
      "start": 101.81,
      "end": 102.75,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 103.0,
      "end": 106.73,
      "speaker": null,
      "text": "А у вас сам рулап что-то написано было 2000, что ли? Примерно."
    },
    {
      "start": 107.85,
      "end": 112.17,
      "speaker": null,
      "text": "Сам рулап 100 на 200 конструкция стоит 4000 рублей."
    },
    {
      "start": 115.06,
      "end": 118.14,
      "speaker": null,
      "text": "Конструкция с печатью будет стоить 5900 рублей."
    },
    {
      "start": 118.14,
      "end": 122.56,
      "speaker": null,
      "text": "Стоимость входит конструкция, печать на баннере и сумка для переноса и хранения в подарок."
    },
    {
      "start": 129.4,
      "end": 133.86,
      "speaker": null,
      "text": "Ладно, хорошо. А это вот то есть день в день вы можете сделать?"
    },
    {
      "start": 134.44,
      "end": 137.94,
      "speaker": null,
      "text": "Да, мы можем подготовить день в день, если готовы уже макеты."
    },
    {
      "start": 139.32,
      "end": 139.8,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 142.12,
      "end": 143.46,
      "speaker": null,
      "text": "А подойдёт вам такой вариант?"
    },
    {
      "start": 145.42,
      "end": 147.04,
      "speaker": null,
      "text": "Ну, мы подумаем тогда."
    },
    {
      "start": 149.16,
      "end": 150.18,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 150.78,
      "end": 157.22,
      "speaker": null,
      "text": "Да, скажите пожалуйста, я могу с вами как-то связаться, кроме как по телефону написать, можно продублировать всю информацию?"
    },
    {
      "start": 157.6,
      "end": 158.62,
      "speaker": null,
      "text": "Да ну нет смысла."
    },
    {
      "start": 159.51,
      "end": 162.89,
      "speaker": null,
      "text": "Что у нас там одноразовый вопрос. Позвоним, если решил."
    },
    {
      "start": 164.11,
      "end": 167.75,
      "speaker": null,
      "text": "Хорошо, я вас понял. А по решению по времени это сколько может занять?"
    },
    {
      "start": 167.93,
      "end": 169.15,
      "speaker": null,
      "text": "То есть сегодня в течение дня?"
    },
    {
      "start": 169.81,
      "end": 170.01,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 171.02,
      "end": 174.2,
      "speaker": null,
      "text": "Давайте я тогда вам во второй половине дня позвоню и уточню информацию."
    },
    {
      "start": 175.64,
      "end": 176.24,
      "speaker": null,
      "text": "Ну, хорошо."
    },
    {
      "start": 177.08,
      "end": 179.27,
      "speaker": null,
      "text": "В любом случае, если я не позвоню, значит..."
    },
    {
      "start": 180.67,
      "end": 181.65,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 183.56,
      "end": 184.9,
      "speaker": null,
      "text": "Всего благодаря, до свидания Александр."
    }
  ]
}