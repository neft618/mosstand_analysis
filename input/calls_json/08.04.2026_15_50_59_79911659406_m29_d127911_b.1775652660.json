  "segments": [
    {
      "start": 1.46,
      "end": 2.6,
      "speaker": null,
      "text": "Добрый день, Виталий."
    },
    {
      "start": 3.1,
      "end": 10.06,
      "speaker": null,
      "text": "Алло, слушай, привет. Подскажи, пожалуйста, если не стал по поводу запроса, можешь приближать от твоего времени? Желательно дать ответ."
    },
    {
      "start": 11.12,
      "end": 15.86,
      "speaker": null,
      "text": "Да, сейчас мне просто очень плохо прогружается Телеграм."
    },
    {
      "start": 17.16,
      "end": 25.02,
      "speaker": null,
      "text": "Я могу озвучить ответ на твой вопрос. Ты спрашивал про размеры тираж на одну штуку 80 на 200."
    },
    {
      "start": 32.09,
      "end": 40.23,
      "speaker": null,
      "text": "А, 80 на 180, да? Ну, пускай будет на 180."
    },
    {
      "start": 41.83,
      "end": 49.01,
      "speaker": null,
      "text": "Если у нас одну штучку, то сама конструкция 2500 по стоимости, а печать на баннере 1500 рублей."
    },
    {
      "start": 49.01,
      "end": 51.31,
      "speaker": null,
      "text": "То есть суммарно..."
    },
    {
      "start": 51.5,
      "end": 52.58,
      "speaker": null,
      "text": "Четыре тысячи?"
    },
    {
      "start": 53.12,
      "end": 55.82,
      "speaker": null,
      "text": "Да, четыре тысячи рублей."
    },
    {
      "start": 56.48,
      "end": 60.62,
      "speaker": null,
      "text": "Ага, самая конструкция плюс печать с баннером с печатью."
    },
    {
      "start": 60.7,
      "end": 61.78,
      "speaker": null,
      "text": "Да, так-так-так."
    },
    {
      "start": 62.5,
      "end": 64.92,
      "speaker": null,
      "text": "Это аренда, напомни, или от продажи?"
    },
    {
      "start": 65.2,
      "end": 66.44,
      "speaker": null,
      "text": "Это под продажу."
    },
    {
      "start": 67.68,
      "end": 69.58,
      "speaker": null,
      "text": "Под продажей, так, ага."
    },
    {
      "start": 69.58,
      "end": 72.56,
      "speaker": null,
      "text": "Ну, и самовывоз там у вас что-то любит?"
    },
    {
      "start": 72.84,
      "end": 73.66,
      "speaker": null,
      "text": "Самовывоз есть."
    },
    {
      "start": 74.36,
      "end": 75.08,
      "speaker": null,
      "text": "Если там..."
    },
    {
      "start": 75.08,
      "end": 75.92,
      "speaker": null,
      "text": "Надо посмотреть, где..."
    },
    {
      "start": 75.92,
      "end": 77.94,
      "speaker": null,
      "text": "У нас просто два склада есть."
    },
    {
      "start": 78.1,
      "end": 84.72,
      "speaker": null,
      "text": "Либо на Новогиреево, либо рядом с этим..."
    },
    {
      "start": 84.72,
      "end": 85.7,
      "speaker": null,
      "text": "С Лефортово."
    },
    {
      "start": 86.22,
      "end": 87.54,
      "speaker": null,
      "text": "То есть они не знают друг от друга."
    },
    {
      "start": 88.32,
      "end": 88.38,
      "speaker": null,
      "text": "Ну, Москва это?"
    },
    {
      "start": 88.38,
      "end": 89.74,
      "speaker": null,
      "text": "Да-да-да, это Москва."
    },
    {
      "start": 90.7,
      "end": 93.54,
      "speaker": null,
      "text": "Там это ВАО как раз таки."
    },
    {
      "start": 93.84,
      "end": 94.98,
      "speaker": null,
      "text": "Ну, восточного округа."
    },
    {
      "start": 95.32,
      "end": 95.88,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 96.56,
      "end": 98.66,
      "speaker": null,
      "text": "Слушай, а в легковую это помещается вообще?"
    },
    {
      "start": 98.66,
      "end": 100.12,
      "speaker": null,
      "text": "Да, спокойно."
    },
    {
      "start": 100.62,
      "end": 101.92,
      "speaker": null,
      "text": "Там получается вот этот размер."
    },
    {
      "start": 102.06,
      "end": 103.74,
      "speaker": null,
      "text": "Единственное, если..."
    },
    {
      "start": 103.74,
      "end": 105.88,
      "speaker": null,
      "text": "Так, 180 нам нужно."
    },
    {
      "start": 106.18,
      "end": 109.18,
      "speaker": null,
      "text": "Там из-за того, что данная конструкция, она, ну, как"
    },
    {
      "start": 109.18,
      "end": 112.22,
      "speaker": null,
      "text": "X-образная такая, и она получается, ну, как бы вытянутая."
    },
    {
      "start": 112.32,
      "end": 114.96,
      "speaker": null,
      "text": "Поэтому 180 сантиметров она приблизительно и будет."
    },
    {
      "start": 115.54,
      "end": 115.8,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 115.86,
      "end": 118.04,
      "speaker": null,
      "text": "Поэтому легковую лужку в целом спокойно влезет,"
    },
    {
      "start": 118.08,
      "end": 119.7,
      "speaker": null,
      "text": "если в багажник складывать."
    },
    {
      "start": 120.0,
      "end": 123.8,
      "speaker": null,
      "text": "Ну, либо если заднее сиденье можно пододвинуть, ну,"
    },
    {
      "start": 123.88,
      "end": 125.88,
      "speaker": null,
      "text": "как бы опустить, то спокойно тоже влезать."
    },
    {
      "start": 125.88,
      "end": 128.88,
      "speaker": null,
      "text": "Ну, как бы по почвам я бы не советовала скакать очень"
    },
    {
      "start": 128.88,
      "end": 129.36,
      "speaker": null,
      "text": "сильно."
    },
    {
      "start": 129.5,
      "end": 131.56,
      "speaker": null,
      "text": "Ну, чтобы там не болтыхалась конструкция."
    },
    {
      "start": 132.2,
      "end": 133.0,
      "speaker": null,
      "text": "Угу, угу, угу."
    },
    {
      "start": 133.2,
      "end": 133.7,
      "speaker": null,
      "text": "Я понял."
    },
    {
      "start": 133.76,
      "end": 133.78,
      "speaker": null,
      "text": "Огонь."
    },
    {
      "start": 133.78,
      "end": 138.08,
      "speaker": null,
      "text": "И если нужно, чтобы прям, ну, как бы более усиленное"
    },
    {
      "start": 138.08,
      "end": 141.38,
      "speaker": null,
      "text": "было, то лучше тогда можно на рулап перевести."
    },
    {
      "start": 141.94,
      "end": 143.7,
      "speaker": null,
      "text": "Там конструкция она уже в сумке идет."
    },
    {
      "start": 143.86,
      "end": 145.7,
      "speaker": null,
      "text": "Просто для X-баннера там сумки нет."
    },
    {
      "start": 145.7,
      "end": 146.52,
      "speaker": null,
      "text": "Есть."
    },
    {
      "start": 146.82,
      "end": 146.86,
      "speaker": null,
      "text": "Есть."
    },
    {
      "start": 147.5,
      "end": 148.52,
      "speaker": null,
      "text": "Рубопы мы делаем."
    },
    {
      "start": 148.92,
      "end": 149.8,
      "speaker": null,
      "text": "Я понял, что такое."
    },
    {
      "start": 150.16,
      "end": 153.0,
      "speaker": null,
      "text": "Но конкретно закачивать хочется этого паука в конструкции."
    },
    {
      "start": 153.28,
      "end": 153.54,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 153.62,
      "end": 154.76,
      "speaker": null,
      "text": "Поэтому вы его уточняли."
    },
    {
      "start": 155.56,
      "end": 155.76,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 155.92,
      "end": 158.24,
      "speaker": null,
      "text": "Ну, вот в целом принцип тоже."
    },
    {
      "start": 158.4,
      "end": 161.62,
      "speaker": null,
      "text": "Только единственное там идет отдельно баннер скрутки"
    },
    {
      "start": 161.62,
      "end": 163.8,
      "speaker": null,
      "text": "и там ливерсет по углам."
    },
    {
      "start": 163.83,
      "end": 165.01,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 165.27,
      "end": 165.73,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 165.79,
      "end": 166.05,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 166.11,
      "end": 166.47,
      "speaker": null,
      "text": "Понял."
    },
    {
      "start": 166.47,
      "end": 168.15,
      "speaker": null,
      "text": "Так что давайте будем это предложить."
    },
    {
      "start": 168.69,
      "end": 169.29,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 169.43,
      "end": 170.23,
      "speaker": null,
      "text": "Спасибо огромное."
    },
    {
      "start": 170.55,
      "end": 171.19,
      "speaker": null,
      "text": "Угу, да."
    },
    {
      "start": 171.75,
      "end": 172.99,
      "speaker": null,
      "text": "Давай, хорошего дня."
    },
    {
      "start": 173.95,
