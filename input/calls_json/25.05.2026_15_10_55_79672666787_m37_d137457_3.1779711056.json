{
  "file": "25.05.2026_15_10_55_79672666787_m37_d137457_3.1779711056.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 125.9,
  "segments": [
    {
      "start": 2.36,
      "end": 5.82,
      "speaker": null,
      "text": "Добрый день. Это Екатерина, компания МОСЭТ. Оставили у нас заявку на сайте."
    },
    {
      "start": 7.14,
      "end": 16.98,
      "speaker": null,
      "text": "Екатерина, добрый день. Меня зовут Ольга. Хотела бы у вас спросить, нам нужно в прошлом порядке напечатать копию видный роллап 100 на 200?"
    },
    {
      "start": 17.76,
      "end": 22.6,
      "speaker": null,
      "text": "Вот, мы уже у вас печатали, сообщалась с менеджером Ксении, но не могу почему-то до неё дозвониться."
    },
    {
      "start": 25.45,
      "end": 26.01,
      "speaker": null,
      "text": "Вопрос..."
    },
    {
      "start": 26.01,
      "end": 27.73,
      "speaker": null,
      "text": "А как давно печатали у неё?"
    },
    {
      "start": 28.68,
      "end": 33.52,
      "speaker": null,
      "text": "У неё печатали, печатали..."
    },
    {
      "start": 33.52,
      "end": 34.54,
      "speaker": null,
      "text": "Блин, не помню."
    },
    {
      "start": 35.34,
      "end": 38.8,
      "speaker": null,
      "text": "Ну что-то я просто вижу, что только в 24 году от вас был заказ."
    },
    {
      "start": 39.0,
      "end": 40.94,
      "speaker": null,
      "text": "Ну по вашему номеру телефона имени."
    },
    {
      "start": 44.62,
      "end": 46.66,
      "speaker": null,
      "text": "Так, подождите, я что-то смотрю."
    },
    {
      "start": 47.96,
      "end": 50.44,
      "speaker": null,
      "text": "Не, ну в 25-м мы что-то делали точно."
    },
    {
      "start": 53.2,
      "end": 55.22,
      "speaker": null,
      "text": "В общем, в чём вопрос, собственно."
    },
    {
      "start": 55.22,
      "end": 61.5,
      "speaker": null,
      "text": "Подскажите, пожалуйста, насколько оперативно вы можете напечатать копию видный роллап?"
    },
    {
      "start": 62.04,
      "end": 65.2,
      "speaker": null,
      "text": "Ну, сколько оперативно вам нужно? Макета у вас уже готова?"
    },
    {
      "start": 66.08,
      "end": 67.18,
      "speaker": null,
      "text": "Макет в работе."
    },
    {
      "start": 67.4,
      "end": 70.32,
      "speaker": null,
      "text": "Например, если сегодня мы отдаём встречать, когда он будет готов?"
    },
    {
      "start": 70.86,
      "end": 71.34,
      "speaker": null,
      "text": "А завтра?"
    },
    {
      "start": 72.36,
      "end": 73.0,
      "speaker": null,
      "text": "Завтра."
    },
    {
      "start": 73.16,
      "end": 73.46,
      "speaker": null,
      "text": "Завтра."
    },
    {
      "start": 73.46,
      "end": 73.78,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 74.12,
      "end": 75.78,
      "speaker": null,
      "text": "И у вас доставка есть?"
    },
    {
      "start": 76.44,
      "end": 77.52,
      "speaker": null,
      "text": "Да, конечно есть."
    },
    {
      "start": 77.78,
      "end": 79.4,
      "speaker": null,
      "text": "Так ещё раз в какой же размере 100 на 200?"
    },
    {
      "start": 79.9,
      "end": 81.02,
      "speaker": null,
      "text": "100 на 200, да."
    },
    {
      "start": 81.46,
      "end": 83.2,
      "speaker": null,
      "text": "Ага, ну в наличии они как раз есть."
    },
    {
      "start": 84.14,
      "end": 87.6,
      "speaker": null,
      "text": "Да, ну в принципе сегодня, если запускаемся, завтра можно забирать."
    },
    {
      "start": 87.72,
      "end": 90.04,
      "speaker": null,
      "text": "Если доставка нужна, можем доставить..."
    },
    {
      "start": 90.58,
      "end": 93.8,
      "speaker": null,
      "text": "Доставка по Москве полторы тысячи рублей, это курьер пеший будет."
    },
    {
      "start": 94.74,
      "end": 96.24,
      "speaker": null,
      "text": "Ага, ага, я поняла."
    },
    {
      "start": 96.42,
      "end": 98.6,
      "speaker": null,
      "text": "Так, в принципе всё, что я хотела от вас узнать."
    },
    {
      "start": 98.82,
      "end": 99.44,
      "speaker": null,
      "text": "Одно рассыпано, да?"
    },
    {
      "start": 101.18,
      "end": 103.84,
      "speaker": null,
      "text": "Предварительно да, но может быть так, что и две."
    },
    {
      "start": 104.54,
      "end": 105.54,
      "speaker": null,
      "text": "Ага, хорошо."
    },
    {
      "start": 105.7,
      "end": 109.5,
      "speaker": null,
      "text": "Ольга, а когда получится дать обратную связь по поводу оформления заказа?"
    },
    {
      "start": 110.18,
      "end": 110.62,
      "speaker": null,
      "text": "Ээээ..."
    },
    {
      "start": 110.62,
      "end": 114.34,
      "speaker": null,
      "text": "Я думаю то, что где-то в течение часа."
    },
    {
      "start": 115.04,
      "end": 115.18,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 115.54,
      "end": 119.06,
      "speaker": null,
      "text": "Хорошо, мне тогда с вами самой связаться или вы перезвоните, как удобнее будет?"
    },
    {
      "start": 119.26,
      "end": 121.16,
      "speaker": null,
      "text": "Я думаю, что я перезвоню просто вам, да."
    },
    {
      "start": 121.26,
      "end": 122.54,
      "speaker": null,
      "text": "Хорошо, всё договорились."
    },
    {
      "start": 122.6,
      "end": 125.04,
      "speaker": null,
      "text": "Да, спасибо вам большое, да, всего доброго на связи."
    },
    {
      "start": 125.28,
      "end": 125.42,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}