{
  "file": "06.04.2026_11_16_31_79376362360_m21_d131291_c.1775463392.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 98.9,
  "segments": [
    {
      "start": 0.88,
      "end": 3.24,
      "speaker": null,
      "text": "Компания «Мостент», Артём, как мы про обращаться?"
    },
    {
      "start": 4.03,
      "end": 13.03,
      "speaker": null,
      "text": "Артём, добрый день. Меня Анастасия зовут. Подскажите, пожалуйста, нам нужно четыре роллапа. Можете сориентировать по сроку изготовления и цены?"
    },
    {
      "start": 14.33,
      "end": 19.09,
      "speaker": null,
      "text": "Так, срок производства 1-2 рабочих дня с момента оплаты согласования макета."
    },
    {
      "start": 20.57,
      "end": 23.27,
      "speaker": null,
      "text": "Нам нужен из конструкции метр на два."
    },
    {
      "start": 23.92,
      "end": 27.76,
      "speaker": null,
      "text": "Так, метр на два. А смотрели определенный модель какой-то у нас есть?"
    },
    {
      "start": 29.21,
      "end": 31.79,
      "speaker": null,
      "text": "Честно говоря, нам нужен просто обычный."
    },
    {
      "start": 32.25,
      "end": 34.53,
      "speaker": null,
      "text": "Ага, всё, то иначе вариантов все их считаем."
    },
    {
      "start": 34.69,
      "end": 36.83,
      "speaker": null,
      "text": "Так, у нас с вами получается метр на два."
    },
    {
      "start": 39.7,
      "end": 41.5,
      "speaker": null,
      "text": "Девять тысячи... ой, извините."
    },
    {
      "start": 43.42,
      "end": 44.24,
      "speaker": null,
      "text": "Пять девятьсот, да."
    },
    {
      "start": 44.8,
      "end": 48.1,
      "speaker": null,
      "text": "Пять девятьсот за одну конструкцию с печатью."
    },
    {
      "start": 48.46,
      "end": 50.98,
      "speaker": null,
      "text": "Баннер у вас будет включать на заправную конструкцию и ссылку в комплекте."
    },
    {
      "start": 52.22,
      "end": 56.64,
      "speaker": null,
      "text": "То есть у нас получаются четыре, это двадцать тысяч рублей."
    },
    {
      "start": 57.18,
      "end": 59.0,
      "speaker": null,
      "text": "У вас макета уже готова, скажите, Анастасия?"
    },
    {
      "start": 59.0,
      "end": 59.46,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 59.46,
      "end": 60.64,
      "speaker": null,
      "text": "И какое мероприятие будет?"
    },
    {
      "start": 61.61,
      "end": 62.91,
      "speaker": null,
      "text": "Ой, честно, я не знаю."
    },
    {
      "start": 63.13,
      "end": 65.35,
      "speaker": null,
      "text": "Вот мне надо сейчас проконсультировать."
    },
    {
      "start": 66.11,
      "end": 67.15,
      "speaker": null,
      "text": "Я тогда вам перезвоню."
    },
    {
      "start": 67.31,
      "end": 68.01,
      "speaker": null,
      "text": "Ну, я поняла."
    },
    {
      "start": 68.15,
      "end": 68.57,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 68.73,
      "end": 71.55,
      "speaker": null,
      "text": "Давайте раз можем продублироваться, чтобы сейчас ничего не потерялось."
    },
    {
      "start": 71.63,
      "end": 72.91,
      "speaker": null,
      "text": "Какой-то мессенджер или почта."
    },
    {
      "start": 73.87,
      "end": 74.53,
      "speaker": null,
      "text": "А нет, спасибо."
    },
    {
      "start": 74.69,
      "end": 75.11,
      "speaker": null,
      "text": "Я запишу."
    },
    {
      "start": 75.9,
      "end": 76.3,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 76.6,
      "end": 77.3,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 78.36,
      "end": 80.6,
      "speaker": null,
      "text": "Держите в курсе, чтобы мы с вами все это вместе сделали."
    },
    {
      "start": 81.36,
      "end": 81.88,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 82.06,
      "end": 82.98,
      "speaker": null,
      "text": "Спасибо вам огромное."
    },
    {
      "start": 83.02,
      "end": 85.8,
      "speaker": null,
      "text": "Если полиграфия сувенирная продукция потребуется, тоже имеете в виду."
    },
    {
      "start": 86.9,
      "end": 87.78,
      "speaker": null,
      "text": "Что еще раз?"
    },
    {
      "start": 88.0,
      "end": 92.0,
      "speaker": null,
      "text": "Если потребуется на мероприятия что-то из полиграфии или сувенирной продукции,"
    },
    {
      "start": 92.0,
      "end": 94.26,
      "speaker": null,
      "text": "тоже имеете в виду, то все вместе комплексно сделаем."
    },
    {
      "start": 94.72,
      "end": 95.24,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 95.46,
      "end": 96.1,
      "speaker": null,
      "text": "Спасибо вам большое."
    },
    {
      "start": 96.1,
      "end": 96.6,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 97.0,
      "end": 97.92,
      "speaker": null,
      "text": "Всего доброго."
    }
  ]
}