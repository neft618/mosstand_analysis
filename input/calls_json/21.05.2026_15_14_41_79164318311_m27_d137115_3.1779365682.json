    {
      "start": 99.09,
      "end": 100.37,
      "speaker": null,
      "text": "Нет, не в один день."
    },
    {
      "start": 100.53,
      "end": 100.83,
      "speaker": null,
      "text": "Не в один день."
    },
    {
      "start": 100.85,
      "end": 103.67,
      "speaker": null,
      "text": "Можно сначала ПВХ, потом рулапы."
