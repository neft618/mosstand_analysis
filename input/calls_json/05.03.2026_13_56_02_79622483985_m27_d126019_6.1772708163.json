  "segments": [
    {
      "start": 0.88,
      "end": 3.52,
      "speaker": null,
      "text": "Да, Игорь, я вам отправил эту шпангу."
    },
    {
      "start": 3.94,
      "end": 12.5,
      "speaker": null,
      "text": "Да, ну вот смотрите, первое, начнём, мы говорили, что мы делаем роботов, где сами роботы, там наш робот."
    },
    {
      "start": 12.82,
      "end": 18.17,
      "speaker": null,
      "text": "Так, это у нас получается, мы делаем роботов, это у вас левый верхний, верно?"
    },
    {
      "start": 18.69,
      "end": 19.99,
      "speaker": null,
      "text": "Да, левый верхний, да."
    },
    {
      "start": 20.27,
      "end": 23.25,
      "speaker": null,
      "text": "Левый верхний, мы делаем роботов."
    },
    {
      "start": 24.73,
      "end": 28.52,
      "speaker": null,
      "text": "Мы делаем роботов."
    },
    {
      "start": 39.26,
      "end": 43.06,
      "speaker": null,
      "text": "Грань, научное производство объединения, мы делаем роботов."
    },
    {
      "start": 43.14,
      "end": 46.02,
      "speaker": null,
      "text": "Потом наш робот решение под ваши задачи, БРГ-2."
    },
    {
      "start": 47.81,
      "end": 51.73,
      "speaker": null,
      "text": "Дальше, разверни инфраструктуру за 20 лет."
    },
    {
      "start": 51.73,
      "end": 54.55,
      "speaker": null,
      "text": "Там нужно добавить фотографию дома."
    },
    {
      "start": 56.65,
      "end": 57.31,
      "speaker": null,
      "text": "Вот это дома."
    },
    {
      "start": 59.13,
      "end": 60.35,
      "speaker": null,
      "text": "Модульного который, да?"
    },
    {
      "start": 60.35,
      "end": 61.65,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 65.12,
      "end": 66.0,
      "speaker": null,
      "text": "Социальные проекты?"
    },
    {
      "start": 66.08,
      "end": 68.97,
      "speaker": null,
      "text": "Ну, наверное так там всё, не знаю, не вижу тут никто."
    },
    {
      "start": 71.4,
      "end": 75.56,
      "speaker": null,
      "text": "Я вам могу позднее отправить уже по отдельности их."
    },
    {
      "start": 76.22,
      "end": 76.78,
      "speaker": null,
      "text": "А, давайте."
    },
    {
      "start": 77.22,
      "end": 81.3,
      "speaker": null,
      "text": "А вот эта система, ну на базе технологий, факты об ИИ убираем?"
    },
    {
      "start": 81.3,
      "end": 81.82,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 82.14,
      "end": 83.18,
      "speaker": null,
      "text": "Так, еще секунду."
    },
    {
      "start": 84.6,
      "end": 85.04,
      "speaker": null,
      "text": "Факты."
    },
    {
      "start": 85.81,
      "end": 88.77,
      "speaker": null,
      "text": "Факты об ИИ и МИ."
    },
    {
      "start": 88.91,
      "end": 89.21,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 89.75,
      "end": 91.15,
      "speaker": null,
      "text": "И вместо него что-то?"
    },
    {
      "start": 91.47,
      "end": 91.79,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 92.83,
      "end": 93.71,
      "speaker": null,
      "text": "Искусственные..."
    },
    {
      "start": 93.71,
      "end": 94.37,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 95.42,
      "end": 97.7,
      "speaker": null,
      "text": "И облачаем в металл."
    },
    {
      "start": 104.81,
      "end": 108.87,
      "speaker": null,
      "text": "Ну, в принципе, наверное всё."
    },
    {
      "start": 110.16,
      "end": 110.76,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 111.5,
      "end": 115.04,
      "speaker": null,
      "text": "Тогда, подытожим, у нас получается, мы делаем роботов."
    },
    {
      "start": 115.04,
      "end": 116.78,
      "speaker": null,
      "text": "Фото дома добавить."
    },
    {
      "start": 117.1,
      "end": 117.48,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 117.64,
      "end": 121.5,
      "speaker": null,
      "text": "И убрать факты об ИИ, добавить и облачаем в металл."
    },
    {
      "start": 121.5,
      "end": 122.2,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 122.44,
      "end": 123.28,
      "speaker": null,
      "text": "Ну, только давайте так."
    },
    {
      "start": 123.58,
      "end": 133.28,
      "speaker": null,
      "text": "Научно-производственное объединение и вот тогда делаем это как о... ИИ облачаем в металл."
    },
    {
      "start": 133.88,
      "end": 134.1,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 134.24,
      "end": 138.84,
      "speaker": null,
      "text": "То есть сразу под логотипом вашим убрать?"
    },
    {
      "start": 139.06,
      "end": 139.4,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 139.58,
      "end": 140.1,
      "speaker": null,
      "text": "Убираем факты."
    },
    {
      "start": 140.2,
      "end": 141.22,
      "speaker": null,
      "text": "Всё хорошо, я вас понял."
    },
    {
      "start": 141.56,
      "end": 141.68,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 142.0,
      "end": 146.92,
      "speaker": null,
      "text": "Ну, систему мониторинга на базе искусственного интеллекта мы оставляем."
    },
    {
      "start": 147.26,
      "end": 147.58,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 147.58,
      "end": 149.12,
      "speaker": null,
      "text": "А перед этим там..."
    },
    {
      "start": 149.12,
      "end": 150.88,
      "speaker": null,
      "text": "Да, перед ним я понял."
    },
    {
      "start": 151.62,
      "end": 152.0,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 152.54,
      "end": 153.06,
      "speaker": null,
      "text": "Всё тогда."
    },
    {
      "start": 153.3,
      "end": 154.28,
      "speaker": null,
      "text": "Всё хорошо, Ирис?"
    },
    {
      "start": 154.76,
      "end": 155.14,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 155.52,
      "end": 157.94,
      "speaker": null,
      "text": "А это всё сколько будем ждать-то?"
    },
    {
      "start": 158.08,
      "end": 162.24,
      "speaker": null,
      "text": "Вот честно не скажу, вот ориентироваться на около часа."
    },
    {
      "start": 162.94,
      "end": 163.44,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 165.06,
      "end": 165.92,
      "speaker": null,
      "text": "Всё, благодарю вас."
