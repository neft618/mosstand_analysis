{
  "file": "13.05.2026_11_18_57_79153354850_m43_d129021_e.1778660337.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 104.8,
  "segments": [
    {
      "start": 0.72,
      "end": 1.36,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 2.08,
      "end": 3.62,
      "speaker": null,
      "text": "Елизавета, добрый день."
    },
    {
      "start": 4.3,
      "end": 4.86,
      "speaker": null,
      "text": "Добрый."
    },
    {
      "start": 5.3,
      "end": 7.86,
      "speaker": null,
      "text": "Это Дмитрий, компания «Мастент»."
    },
    {
      "start": 8.05,
      "end": 8.45,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 9.48,
      "end": 12.28,
      "speaker": null,
      "text": "А когда у нас с вами край? Напомните, пожалуйста."
    },
    {
      "start": 12.96,
      "end": 20.1,
      "speaker": null,
      "text": "15-го числа ожидаем. Мы вот сейчас тоже подняли переписки в почте. Всё было согласовано на 15-е число и заказчиками с вами."
    },
    {
      "start": 20.52,
      "end": 28.82,
      "speaker": null,
      "text": "Да, хорошо. Если сегодня привезём, то до скольки? И если завтра, то скольки до скольки?"
    },
    {
      "start": 28.89,
      "end": 31.33,
      "speaker": null,
      "text": "С 10-ти до 6-ти, сегодня и завтра."
    },
    {
      "start": 32.36,
      "end": 36.64,
      "speaker": null,
      "text": "С 10-ти до 18-ти. Вас указывает, да?"
    },
    {
      "start": 38.38,
      "end": 42.36,
      "speaker": null,
      "text": "Я вам в почте пришлю контакт, как его указать."
    },
    {
      "start": 43.62,
      "end": 46.04,
      "speaker": null,
      "text": "Но это зависит от того, сегодня или завтра, да?"
    },
    {
      "start": 47.64,
      "end": 49.84,
      "speaker": null,
      "text": "Скорее всего, этот человек будет и на тот, и на тот день."
    },
    {
      "start": 50.42,
      "end": 54.48,
      "speaker": null,
      "text": "Ну, давайте тогда на завтра планируем доставку. Завтра всё привезём."
    },
    {
      "start": 55.25,
      "end": 56.79,
      "speaker": null,
      "text": "Так, завтра у нас включается 6-ти."
    },
    {
      "start": 57.19,
      "end": 64.38,
      "speaker": null,
      "text": "Да. А нам подгружать вот эти документы нужно завтра, да?"
    },
    {
      "start": 65.31,
      "end": 68.91,
      "speaker": null,
      "text": "Ну, всё, что касается документов, тут, к сожалению, я не смогу подсказать."
    },
    {
      "start": 68.91,
      "end": 71.15,
      "speaker": null,
      "text": "Это вот Дарья Катрушина."
    },
    {
      "start": 71.81,
      "end": 73.37,
      "speaker": null,
      "text": "Она вышла с отпуска?"
    },
    {
      "start": 75.66,
      "end": 77.56,
      "speaker": null,
      "text": "Нет, это Дарья не Гончарова."
    },
    {
      "start": 77.64,
      "end": 80.34,
      "speaker": null,
      "text": "Дарья Гончарову тоже эти вопросы не надеется."
    },
    {
      "start": 80.62,
      "end": 84.34,
      "speaker": null,
      "text": "Есть Дарья Катрушина, она у нас тоже есть в почте, в переписке."
    },
    {
      "start": 84.34,
      "end": 85.26,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 85.78,
      "end": 88.74,
      "speaker": null,
      "text": "Она сможет подсказать именно насчёт документов и информации."
    },
    {
      "start": 88.82,
      "end": 90.2,
      "speaker": null,
      "text": "Хорошо, ладно, спасибо."
    },
    {
      "start": 91.26,
      "end": 92.18,
      "speaker": null,
      "text": "Всё, да, спасибо вам."
    },
    {
      "start": 92.18,
      "end": 92.92,
      "speaker": null,
      "text": "Всё, да, хорошо."
    },
    {
      "start": 93.12,
      "end": 97.22,
      "speaker": null,
      "text": "Как фото будет готово, как стенды будут готовы, я направлю фото вам."
    },
    {
      "start": 98.08,
      "end": 100.12,
      "speaker": null,
      "text": "Всё, спасибо, я вам тоже направлю фото."
    },
    {
      "start": 100.12,
      "end": 100.68,
      "speaker": null,
      "text": "Всё, да, спасибо, прошу."
    }
  ]
}