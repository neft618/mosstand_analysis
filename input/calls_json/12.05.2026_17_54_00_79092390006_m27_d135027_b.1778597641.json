  "segments": [
    {
      "start": 0.0,
      "end": 1.04,
      "speaker": null,
      "text": "Да, Александр."
    },
    {
      "start": 2.14,
      "end": 4.3,
      "speaker": null,
      "text": "О, добрый день. Удобно?"
    },
    {
      "start": 4.68,
      "end": 5.28,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 6.67,
      "end": 18.19,
      "speaker": null,
      "text": "Подскажите, вы мне опять написали там штуки, но не всё учли. Подскажите габариты самой стеллы, вот этой перфорированной, от пола до верха."
    },
    {
      "start": 18.53,
      "end": 20.27,
      "speaker": null,
      "text": "А, от пола до верха?"
    },
    {
      "start": 20.27,
      "end": 21.67,
      "speaker": null,
      "text": "По сантиметрам, конечно."
    },
    {
      "start": 23.06,
      "end": 24.46,
      "speaker": null,
      "text": "Так, сейчас, секунду."
    },
    {
      "start": 27.94,
      "end": 29.84,
      "speaker": null,
      "text": "Соответственно, высоту и ширину её."
    },
    {
      "start": 31.12,
      "end": 36.94,
      "speaker": null,
      "text": "Ширина у неё 455 мм, если не брать сам баннер."
    },
    {
      "start": 37.58,
      "end": 38.32,
      "speaker": null,
      "text": "Да, 45 мм."
    },
    {
      "start": 38.32,
      "end": 42.82,
      "speaker": null,
      "text": "Баннер, это отдельно у меня будет прописано, я сейчас баннер сверю с вами, пока по стелле."
    },
    {
      "start": 43.42,
      "end": 45.3,
      "speaker": null,
      "text": "Высота вот ширина 45 мм."
    },
    {
      "start": 46.88,
      "end": 52.18,
      "speaker": null,
      "text": "А так, по высоте мне нужно уточнить, но вообще она идёт 1600 мм."
    },
    {
      "start": 54.88,
      "end": 56.36,
      "speaker": null,
      "text": "Ага, у меня 60 мм."
    },
    {
      "start": 56.38,
      "end": 58.74,
      "speaker": null,
      "text": "То есть на 3 см больше, чем баннер?"
    },
    {
      "start": 59.19,
      "end": 67.19,
      "speaker": null,
      "text": "Если я не ошибаюсь, я давайте сейчас у технолога уточню, но уже ответить завтра только смогу по высоте."
    },
    {
      "start": 69.68,
      "end": 72.62,
      "speaker": null,
      "text": "160 примерно, если 3 см."
    },
    {
      "start": 72.86,
      "end": 78.78,
      "speaker": null,
      "text": "Может они и есть как раз этот зазор между полом и началом конструкции, в которой крепится баннер?"
    },
    {
      "start": 78.78,
      "end": 81.58,
      "speaker": null,
      "text": "Ну, вообще там побольше расстояние идёт."
    },
    {
      "start": 81.74,
      "end": 85.3,
      "speaker": null,
      "text": "Я вам могу прям живые фото примеры прислать, которые у нас есть."
    },
    {
      "start": 85.3,
      "end": 89.47,
      "speaker": null,
      "text": "Так, ну пусть это будет тогда, ну ладно, 165."
    },
    {
      "start": 90.09,
      "end": 92.63,
      "speaker": null,
      "text": "Ну, 165-170 вот так оно где-то, да."
    },
    {
      "start": 95.22,
      "end": 95.54,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 96.24,
      "end": 98.7,
      "speaker": null,
      "text": "Так, габариты баннера у нас 157 на 40."
    },
    {
      "start": 99.28,
      "end": 99.96,
      "speaker": null,
      "text": "Правильно?"
    },
    {
      "start": 100.7,
      "end": 103.06,
      "speaker": null,
      "text": "157 на 595 он идёт."
    },
    {
      "start": 105.04,
      "end": 106.62,
      "speaker": null,
      "text": "Ага, большой взяли, да?"
    },
    {
      "start": 107.83,
      "end": 108.17,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 109.39,
      "end": 111.49,
      "speaker": null,
      "text": "59 с половиной сантиметров."
    },
    {
      "start": 111.49,
      "end": 114.75,
      "speaker": null,
      "text": "Так, основание у нас 40 на 40 сантиметров."
    },
    {
      "start": 114.95,
      "end": 115.49,
      "speaker": null,
      "text": "Правильно я понимаю?"
    },
    {
      "start": 116.13,
      "end": 117.25,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 119.34,
      "end": 119.56,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 121.99,
      "end": 122.19,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 122.43,
      "end": 123.01,
      "speaker": null,
      "text": "И фриз?"
    },
    {
      "start": 124.66,
      "end": 126.06,
      "speaker": null,
      "text": "Размер самого фриза нужен?"
    },
    {
      "start": 126.76,
      "end": 127.1,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 129.44,
      "end": 133.9,
      "speaker": null,
      "text": "А, по фризу мы его можем сделать на самом деле любого размера, который вам необходим."
    },
    {
      "start": 135.04,
      "end": 135.9,
      "speaker": null,
      "text": "А, вот."
    },
    {
      "start": 136.08,
      "end": 138.7,
      "speaker": null,
      "text": "Ну а на примерах что он идёт..."
    },
    {
      "start": 138.7,
      "end": 139.0,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 139.0,
      "end": 139.1,
      "speaker": null,
      "text": "А."
    },
    {
      "start": 139.3,
      "end": 141.24,
      "speaker": null,
      "text": "Я нашёл всю информацию, которая нужна."
    },
    {
      "start": 141.76,
      "end": 142.48,
      "speaker": null,
      "text": "Эээ..."
    },
    {
      "start": 142.69,
      "end": 145.76,
      "speaker": null,
      "text": "Основание 647 на 334 миллиметра."
    },
    {
      "start": 146.3,
      "end": 147.34,
      "speaker": null,
      "text": "А, вот так."
    },
    {
      "start": 147.54,
      "end": 149.46,
      "speaker": null,
      "text": "То есть не соответствует тому, что на сайте."
    },
    {
      "start": 149.66,
      "end": 152.44,
      "speaker": null,
      "text": "Так, 647 на..."
    },
    {
      "start": 152.47,
      "end": 153.31,
      "speaker": null,
      "text": "333?"
    },
    {
      "start": 153.67,
      "end": 153.81,
      "speaker": null,
      "text": "333."
    },
    {
      "start": 155.84,
      "end": 161.56,
      "speaker": null,
      "text": "Так, 33,4 и 67 это основание."
    },
    {
      "start": 161.72,
      "end": 161.92,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 162.5,
      "end": 164.1,
      "speaker": null,
      "text": "Высота 1625."
    },
    {
      "start": 168.62,
      "end": 170.78,
      "speaker": null,
