    {
      "start": 246.81,
      "end": 246.91,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 247.05,
      "end": 252.27,
      "speaker": null,
      "text": "Нет, ну верхушку если брендировать вот такую, как на примерах на сайте."
    },
    {
      "start": 254.37,
      "end": 257.77,
      "speaker": null,
      "text": "Ну да, 45 на 10 я думаю здесь была у нас фотография."
    },
    {
      "start": 259.4,
      "end": 259.76,
      "speaker": null,
      "text": "Есть?"
    },
    {
      "start": 259.8,
      "end": 260.68,
      "speaker": null,
      "text": "Наверно даже..."
    },
    {
      "start": 260.68,
      "end": 262.38,
      "speaker": null,
      "text": "Наверно даже на 15."
    },
    {
      "start": 263.26,
      "end": 265.08,
      "speaker": null,
      "text": "Потому что она такая объемная достаточно."
    },
    {
      "start": 266.21,
      "end": 266.57,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 266.91,
      "end": 267.41,
      "speaker": null,
      "text": "Да, 15."
    },
    {
      "start": 268.62,
      "end": 269.56,
      "speaker": null,
      "text": "Так есть."
    },
    {
      "start": 269.76,
      "end": 274.02,
      "speaker": null,
      "text": "Скажите, а фото примеры уже готовых работ именно с карманами от речи?"
