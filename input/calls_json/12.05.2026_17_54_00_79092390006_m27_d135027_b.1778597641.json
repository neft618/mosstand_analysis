    },
    {
      "start": 185.7,
      "end": 189.92,
      "speaker": null,
      "text": "А всей металлической части 486 миллиметров."
    },
    {
      "start": 191.26,
      "end": 191.62,
      "speaker": null,
      "text": "Ага."
