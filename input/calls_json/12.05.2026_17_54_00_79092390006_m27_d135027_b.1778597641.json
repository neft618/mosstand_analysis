    {
      "start": 219.12,
      "end": 221.58,
      "speaker": null,
      "text": "Баннер мы правильно с вами записали, да?"
    },
    {
      "start": 221.78,
      "end": 222.3,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 222.36,
      "end": 223.86,
      "speaker": null,
      "text": "По баннеру там идёт один размер."
    },
    {
      "start": 224.4,
      "end": 225.62,
      "speaker": null,
      "text": "Вот как раз таки."
