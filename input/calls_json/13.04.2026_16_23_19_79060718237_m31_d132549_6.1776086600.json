  "segments": [
    {
      "start": 0.27,
      "end": 1.93,
      "speaker": null,
      "text": "Здравствуйте, Валерия Матент."
    },
    {
      "start": 3.91,
      "end": 6.81,
      "speaker": null,
      "text": "Добрый день, меня зовут Илона, компания Белкина."
    },
    {
      "start": 7.8,
      "end": 15.8,
      "speaker": null,
      "text": "У меня коллега с вами связывалась, касательно согласования макета, у меня ещё вопрос по поводу оплаты."
    },
    {
      "start": 16.46,
      "end": 24.05,
      "speaker": null,
      "text": "Мы будем оплачивать по счёту, для этого нам нужно подписать договор. Подскажите, что от нас требуется, куда направить вам?"
    },
    {
      "start": 24.05,
      "end": 31.62,
      "speaker": null,
      "text": "Смотрите, у нас с вами сумма заказа 7400 получается вместе с доставкой."
    },
    {
      "start": 32.3,
      "end": 40.94,
      "speaker": null,
      "text": "У нас единственное, что мы можем вам направить счёт, но у нас по договору так не получится сделать, потому что на договор 100000 рублей сумма заказа уходит."
    },
    {
      "start": 41.42,
      "end": 42.48,
      "speaker": null,
      "text": "То есть возьмём..."
    },
    {
      "start": 42.48,
      "end": 43.97,
      "speaker": null,
      "text": "Что ещё раз?"
    },
    {
      "start": 44.47,
      "end": 45.79,
      "speaker": null,
      "text": "От какой суммы идёт?"
    },
    {
      "start": 46.11,
      "end": 49.69,
      "speaker": null,
      "text": "От 100000 рублей, да, от 100000 рублей сумма заказа."
    },
    {
      "start": 49.69,
      "end": 53.93,
      "speaker": null,
      "text": "Поэтому тут либо счёт, либо счёт-договор – это публичная оферта."
    },
    {
      "start": 54.55,
      "end": 56.57,
      "speaker": null,
      "text": "Точнее прямая, просто точнее прямая оферта."
    },
    {
      "start": 58.03,
      "end": 60.37,
      "speaker": null,
      "text": "Так, либо счёт, либо счёт-договор."
    },
    {
      "start": 64.1,
      "end": 68.98,
      "speaker": null,
      "text": "Так, хорошо, я тогда сейчас уточню и напишу вам в Телеграм. Удобно будет?"
    },
    {
      "start": 69.54,
      "end": 71.68,
      "speaker": null,
      "text": "Давайте я вам сейчас прямо напишу."
    },
    {
      "start": 71.84,
      "end": 74.04,
      "speaker": null,
      "text": "А вот Федя, пожалуйста, как вас ещё раз зовут?"
    },
    {
      "start": 74.78,
      "end": 75.3,
      "speaker": null,
      "text": "Илона."
    },
    {
      "start": 76.02,
      "end": 76.96,
      "speaker": null,
      "text": "Илона, так."
    },
    {
      "start": 77.43,
      "end": 80.63,
      "speaker": null,
      "text": "Я прямо сейчас напишу, чтобы вы уже знали, куда писать."
    },
    {
      "start": 81.05,
      "end": 85.13,
      "speaker": null,
      "text": "Да, у меня просто в Телеграме другой номер привязан."
    },
    {
      "start": 85.37,
      "end": 85.71,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 86.23,
      "end": 87.03,
      "speaker": null,
      "text": "А ну, давайте..."
    },
    {
      "start": 87.03,
      "end": 88.07,
      "speaker": null,
      "text": "Я вам уже написала."
    },
    {
      "start": 88.87,
      "end": 92.91,
      "speaker": null,
      "text": "А вы просто, наверное, написали на общий и он мне мог не попасть."
    },
    {
      "start": 93.29,
      "end": 95.74,
      "speaker": null,
      "text": "Так, 2980."
    },
    {
      "start": 97.46,
      "end": 97.94,
      "speaker": null,
      "text": "Ваш?"
    },
    {
      "start": 98.63,
      "end": 99.11,
      "speaker": null,
      "text": "Мой."
    },
    {
      "start": 99.47,
      "end": 99.81,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 100.01,
      "end": 101.25,
      "speaker": null,
      "text": "А, вижу, вижу, вижу."
    },
    {
      "start": 101.49,
      "end": 102.13,
      "speaker": null,
      "text": "Теперь вижу, да."
    },
    {
      "start": 102.29,
      "end": 102.31,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 103.57,
      "end": 103.91,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 106.66,
      "end": 107.26,
      "speaker": null,
      "text": "Всё, хорошо."
    },
    {
      "start": 107.62,
      "end": 107.96,
      "speaker": null,
      "text": "Супер."
    },
    {
      "start": 108.36,
      "end": 108.84,
      "speaker": null,
      "text": "Договорились."
    },
    {
      "start": 109.4,
      "end": 112.24,
      "speaker": null,
      "text": "Да, а можете ещё раз сказать доставка какая сумма?"
    },
    {
      "start": 113.08,
      "end": 114.58,
      "speaker": null,
      "text": "Доставка 1500 рублей."
    },
    {
      "start": 115.31,
      "end": 115.83,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 115.83,
      "end": 116.73,
