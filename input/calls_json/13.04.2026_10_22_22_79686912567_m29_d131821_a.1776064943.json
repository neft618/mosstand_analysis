  "segments": [
    {
      "start": 2.12,
      "end": 12.26,
      "speaker": null,
      "text": "Доброе утро. Ксения, подскажите, пожалуйста, когда мы утвердим с вами макеты и уже они уйдут на печать?"
    },
    {
      "start": 13.32,
      "end": 16.5,
      "speaker": null,
      "text": "Я вам уже выслала макеты на проверку."
    },
    {
      "start": 18.56,
      "end": 21.46,
      "speaker": null,
      "text": "Так, я просто пошла и пока не вижу ничего."
    },
    {
      "start": 22.08,
      "end": 26.44,
      "speaker": null,
      "text": "Да, я вам направила две листовки для Питера и для Москвы."
    },
    {
      "start": 27.14,
      "end": 31.48,
      "speaker": null,
      "text": "А, сори. Сейчас, может, у меня не подпрудились, они..."
    },
    {
      "start": 31.48,
      "end": 32.32,
      "speaker": null,
      "text": "Да, они..."
    },
    {
      "start": 32.32,
      "end": 32.98,
      "speaker": null,
      "text": "Сейчас, конечно."
    },
    {
      "start": 33.24,
      "end": 33.96,
      "speaker": null,
      "text": "Да, встречу."
    },
    {
      "start": 34.26,
      "end": 35.24,
      "speaker": null,
      "text": "Ну, мы всё успеваем."
    },
    {
      "start": 36.06,
      "end": 41.01,
      "speaker": null,
      "text": "Да, успеваем. Единственное, сможете, пожалуйста, вышить ещё ваши реквизиты?"
    },
    {
      "start": 41.15,
      "end": 45.73,
      "speaker": null,
      "text": "А то есть прошлое там затерялись, а нам нужны для договора полные данные."
    },
    {
      "start": 46.73,
      "end": 49.33,
      "speaker": null,
      "text": "Да, я у них только, наверное, договорились."
    },
    {
      "start": 49.89,
      "end": 51.55,
      "speaker": null,
      "text": "Спасибо большое, жду очень."
    },
    {
      "start": 51.65,
      "end": 53.17,
      "speaker": null,
      "text": "И согласование что-то."
    },
    {
      "start": 53.17,
      "end": 56.17,
      "speaker": null,
      "text": "Да, в текущем счёте они актуальны."
    },
    {
      "start": 56.87,
      "end": 59.05,
      "speaker": null,
      "text": "Нет, сейчас я по телефону для вас проверю."
    },
    {
      "start": 60.21,
      "end": 64.07,
      "speaker": null,
      "text": "Мой оператор, оператор с маленькой буквы был."
    },
    {
      "start": 64.37,
      "end": 67.31,
      "speaker": null,
      "text": "Если они неактуальны, нужно будет..."
    },
    {
      "start": 69.23,
      "end": 70.33,
      "speaker": null,
      "text": "Сейчас, где этот счёт?"
    },
    {
      "start": 70.53,
      "end": 71.69,
      "speaker": null,
      "text": "Где этот счёт?"
    },
    {
      "start": 72.37,
      "end": 74.67,
      "speaker": null,
      "text": "Я ещё напишу лучше, чтобы вас не держать."
    },
    {
      "start": 74.89,
      "end": 74.97,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 74.97,
      "end": 76.19,
      "speaker": null,
      "text": "Я карточку попросила."
    },
    {
      "start": 76.31,
      "end": 76.89,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 76.89,
      "end": 78.17,
      "speaker": null,
      "text": "Да-да-да, спасибо, жду."
    },
    {
      "start": 78.17,
      "end": 78.71,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 78.71,
      "end": 78.77,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 79.09,
      "end": 79.29,
      "speaker": null,
      "text": "Угу."
    }
  ]
}