{
  "file": "14.04.2026_12_03_26_79031965684_m49_d132757_2.1776157408.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 94.4,
  "segments": [
    {
      "start": 2.51,
      "end": 4.43,
      "speaker": null,
      "text": "Здравствуйте, компания МОСтент."
    },
    {
      "start": 5.19,
      "end": 8.39,
      "speaker": null,
      "text": "Здравствуйте, я плохо вас слышу. Говорите громко."
    },
    {
      "start": 9.93,
      "end": 12.17,
      "speaker": null,
      "text": "Здравствуйте, Елена, компания МОСтент."
    },
    {
      "start": 13.9,
      "end": 16.92,
      "speaker": null,
      "text": "Елена, да? Правильно я услышала?"
    },
    {
      "start": 17.32,
      "end": 17.54,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 17.88,
      "end": 30.28,
      "speaker": null,
      "text": "Елена, я не знаю, давно вы работаете в своей организации? Потому что я хочу вам напомнить, что в прошлом году мы делали стенды, посвящённые жизнедеятельности Дашковой."
    },
    {
      "start": 31.88,
      "end": 35.9,
      "speaker": null,
      "text": "Я не могу помнить каждый заказ, у нас работает много менеджеров."
    },
    {
      "start": 35.92,
      "end": 37.68,
      "speaker": null,
      "text": "Это понятно, но скажите, пожалуйста."
    },
    {
      "start": 38.26,
      "end": 43.38,
      "speaker": null,
      "text": "Если вы хотите, вам нужен менеджер, скажите, пожалуйста, на кого вас переключить, кто вам нужен? Кому перезвонить?"
    },
    {
      "start": 44.84,
      "end": 49.4,
      "speaker": null,
      "text": "Вот этого я, к сожалению, не помню. Кто был менеджер с нами?"
    },
    {
      "start": 49.6,
      "end": 53.14,
      "speaker": null,
      "text": "Номер заказа у вас сохранился? Какой-то номер заказа сохранился?"
    },
    {
      "start": 54.38,
      "end": 57.82,
      "speaker": null,
      "text": "Так, сейчас мы его будем искать. Спасибо, Елена."
    },
    {
      "start": 57.82,
      "end": 60.18,
      "speaker": null,
      "text": "Да, поднимите, пожалуйста, номер заказа."
    },
    {
      "start": 60.32,
      "end": 64.78,
      "speaker": null,
      "text": "Ещё, да, номер заказа и вы тогда найдёте кто этот менеджер, да?"
    },
    {
      "start": 64.84,
      "end": 66.42,
      "speaker": null,
      "text": "Да, найдём, найдём, угу."
    },
    {
      "start": 66.42,
      "end": 66.98,
      "speaker": null,
      "text": "А?"
    },
    {
      "start": 67.3,
      "end": 68.04,
      "speaker": null,
      "text": "Я помню."
    },
    {
      "start": 68.28,
      "end": 69.8,
      "speaker": null,
      "text": "У нас были торги."
    },
    {
      "start": 73.48,
      "end": 76.68,
      "speaker": null,
      "text": "Лена, алё, у нас были торги."
    },
    {
      "start": 77.12,
      "end": 77.68,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 80.08,
      "end": 84.52,
      "speaker": null,
      "text": "То есть тоже посмотреть номер этих торгов или что там, да, какие документы были?"
    },
    {
      "start": 84.66,
      "end": 86.78,
      "speaker": null,
      "text": "Нет, номер заказа, просто номер заказа."
    },
    {
      "start": 88.12,
      "end": 90.12,
      "speaker": null,
      "text": "Ну а торги-то был же номер заказа."
    },
    {
      "start": 90.12,
      "end": 91.4,
      "speaker": null,
      "text": "Хорошо, спасибо."
    },
    {
      "start": 91.68,
      "end": 93.16,
      "speaker": null,
      "text": "Сейчас будем искать."
    },
    {
      "start": 93.42,
      "end": 93.64,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 93.96,
      "end": 94.12,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}