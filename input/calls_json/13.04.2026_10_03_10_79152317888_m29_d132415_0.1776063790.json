{
  "file": "13.04.2026_10_03_10_79152317888_m29_d132415_0.1776063790.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 83.2,
  "segments": [
    {
      "start": 1.45,
      "end": 4.61,
      "speaker": null,
      "text": "Добрый день. Меня зовут Ксения, компания MyStand. Какие могут возвращаться?"
    },
    {
      "start": 4.71,
      "end": 10.27,
      "speaker": null,
      "text": "Добрый день. Меня зовут Вера. Скажите, пожалуйста, меня интересует стенд Roll Up в одном экземпляре."
    },
    {
      "start": 10.87,
      "end": 14.35,
      "speaker": null,
      "text": "Распечатать и монтировать стенд. Сколько будет стоить?"
    },
    {
      "start": 15.11,
      "end": 15.83,
      "speaker": null,
      "text": "Два метра."
    },
    {
      "start": 16.05,
      "end": 19.09,
      "speaker": null,
      "text": "Ну, 100 на 2. Ну, метр на два."
    },
    {
      "start": 20.23,
      "end": 21.99,
      "speaker": null,
      "text": "Так, одна штучка, правильно?"
    },
    {
      "start": 22.29,
      "end": 22.77,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 24.72,
      "end": 26.44,
      "speaker": null,
      "text": "Классический вариант вам для школы?"
    },
    {
      "start": 26.72,
      "end": 28.38,
      "speaker": null,
      "text": "Да-да, это школьная конференция."
    },
    {
      "start": 28.38,
      "end": 36.32,
      "speaker": null,
      "text": "Угу. Так, по скорости будет Roll Up метр на два классический, конструкция плюс печать на баннере 5900."
    },
    {
      "start": 36.78,
      "end": 38.4,
      "speaker": null,
      "text": "Это подключить полностью будет."
    },
    {
      "start": 38.72,
      "end": 38.86,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 39.62,
      "end": 41.1,
      "speaker": null,
      "text": "Подскажите, макеты готовы?"
    },
    {
      "start": 41.6,
      "end": 41.84,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 42.83,
      "end": 43.17,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 43.77,
      "end": 49.73,
      "speaker": null,
      "text": "Так, Вера, а будет удобнее передать макеты через почту, телеграмму?"
    },
    {
      "start": 49.73,
      "end": 50.69,
      "speaker": null,
      "text": "Да, нет."
    },
    {
      "start": 50.89,
      "end": 55.83,
      "speaker": null,
      "text": "Знаете, тогда пока, наверное, не нужно, потому что, в принципе, у меня сейчас был вариант поближе ко мне."
    },
    {
      "start": 55.83,
      "end": 58.89,
      "speaker": null,
      "text": "Я просто смотрела ваши контакты, я, наверное, поближе закажу, так что спасибо."
    },
    {
      "start": 59.09,
      "end": 61.45,
      "speaker": null,
      "text": "Я тогда буду иметь в виду, пока тогда не нужно."
    },
    {
      "start": 61.57,
      "end": 61.83,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 62.07,
      "end": 62.45,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 62.65,
      "end": 63.69,
      "speaker": null,
      "text": "Так вы же обратились."
    },
    {
      "start": 63.99,
      "end": 66.81,
      "speaker": null,
      "text": "Вас адрес только смущает?"
    },
    {
      "start": 66.97,
      "end": 67.41,
      "speaker": null,
      "text": "Можем достать?"
    },
    {
      "start": 67.41,
      "end": 71.03,
      "speaker": null,
      "text": "Ну, чуть-чуть дороже у вас, буквально на 200 рублей."
    },
    {
      "start": 71.15,
      "end": 75.83,
      "speaker": null,
      "text": "Чуть-чуть вы дальше от меня, поэтому, значит, я в другой сфографии пока захожу."
    },
    {
      "start": 76.41,
      "end": 78.67,
      "speaker": null,
      "text": "Потому что мне трудно будет ехать."
    },
    {
      "start": 79.09,
      "end": 80.37,
      "speaker": null,
      "text": "Ладно, спасибо большое тогда."
    },
    {
      "start": 80.47,
      "end": 80.83,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 80.95,
      "end": 81.83,
      "speaker": null,
      "text": "Ладно, до свидания."
    },
    {
      "start": 81.99,
      "end": 82.39,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}