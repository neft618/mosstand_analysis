{
  "file": "08.04.2026_13_01_19_79999624096_m21_d131723_4.1775642480.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 159.0,
  "segments": [
    {
      "start": 0.82,
      "end": 3.54,
      "speaker": null,
      "text": "Компания МОСЭН, Арсём, как могу к вам обращаться?"
    },
    {
      "start": 4.26,
      "end": 11.15,
      "speaker": null,
      "text": "Арсём, добрый день. У меня лифтон, директор АВСЭН. Крышные конструкции делаете?"
    },
    {
      "start": 11.47,
      "end": 13.77,
      "speaker": null,
      "text": "Что делать у вас плохо слышно?"
    },
    {
      "start": 14.35,
      "end": 15.65,
      "speaker": null,
      "text": "Крышные вывески."
    },
    {
      "start": 16.87,
      "end": 18.49,
      "speaker": null,
      "text": "Вывески на улице имеете ввиду?"
    },
    {
      "start": 19.72,
      "end": 23.76,
      "speaker": null,
      "text": "На крыше зданий, не на фасаде зданий."
    },
    {
      "start": 25.05,
      "end": 29.09,
      "speaker": null,
      "text": "Мне нужно понимать, честно говоря, что вы имеете ввиду."
    },
    {
      "start": 29.65,
      "end": 31.33,
      "speaker": null,
      "text": "Именно по такой вывеске."
    },
    {
      "start": 33.51,
      "end": 33.95,
      "speaker": null,
      "text": "Алло!"
    },
    {
      "start": 34.73,
      "end": 37.33,
      "speaker": null,
      "text": "Алло, у вас плохо слышно?"
    },
    {
      "start": 37.51,
      "end": 39.31,
      "speaker": null,
      "text": "Имя даже не расслышал. Ещё раз, как он зовут?"
    },
    {
      "start": 39.49,
      "end": 41.09,
      "speaker": null,
      "text": "Я говорю, зовут Александр."
    },
    {
      "start": 42.04,
      "end": 44.26,
      "speaker": null,
      "text": "Занимаетесь крышными конструкциями или нет?"
    },
    {
      "start": 46.02,
      "end": 48.16,
      "speaker": null,
      "text": "Просто мне надо понимать фотографию, что вы имеете ввиду."
    },
    {
      "start": 48.48,
      "end": 50.84,
      "speaker": null,
      "text": "Если вы сначала скажите вывеску..."
    },
    {
      "start": 50.84,
      "end": 53.14,
      "speaker": null,
      "text": "Ну, вывеска. Крышными вывесками я имею ввиду."
    },
    {
      "start": 53.94,
      "end": 57.0,
      "speaker": null,
      "text": "У вас есть примерный визуал, что вы имеете ввиду?"
    },
    {
      "start": 57.2,
      "end": 57.64,
      "speaker": null,
      "text": "Фотографии?"
    },
    {
      "start": 57.64,
      "end": 62.42,
      "speaker": null,
      "text": "Наша местная организация уже разработала проект."
    },
    {
      "start": 62.64,
      "end": 64.1,
      "speaker": null,
      "text": "Они реализовать это не могут."
    },
    {
      "start": 64.34,
      "end": 71.12,
      "speaker": null,
      "text": "Мы сейчас фирмам раскидываем задания, чтобы выбрать оптимальное предложение."
    },
    {
      "start": 72.14,
      "end": 75.38,
      "speaker": null,
      "text": "Нам бы понимать, что если у вас есть техническое задание раз,"
    },
    {
      "start": 75.78,
      "end": 78.04,
      "speaker": null,
      "text": "примеры два, то надо хотя бы от этого толкиваться."
    },
    {
      "start": 78.14,
      "end": 78.58,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 79.88,
      "end": 81.48,
      "speaker": null,
      "text": "Проектная организация уже разработана."
    },
    {
      "start": 82.2,
      "end": 83.3,
      "speaker": null,
      "text": "У нас есть готовый проект."
    },
    {
      "start": 83.3,
      "end": 88.04,
      "speaker": null,
      "text": "Меня интересует, в Московской области вы выполняете работу или нет?"
    },
    {
      "start": 88.88,
      "end": 89.5,
      "speaker": null,
      "text": "Можем, да."
    },
    {
      "start": 90.22,
      "end": 92.62,
      "speaker": null,
      "text": "Скажите, нам же как включить все техническое задание?"
    },
    {
      "start": 92.74,
      "end": 96.52,
      "speaker": null,
      "text": "По номеру телефона, по почте, чтобы все рассмотреть и дать полную область?"
    },
    {
      "start": 96.52,
      "end": 98.3,
      "speaker": null,
      "text": "Вот на сайте у вас написано"
    },
    {
      "start": 100.08,
      "end": 101.72,
      "speaker": null,
      "text": "Это общее, это общее."
    },
    {
      "start": 101.82,
      "end": 103.44,
      "speaker": null,
      "text": "Можете записать на мою почту?"
    },
    {
      "start": 103.74,
      "end": 106.28,
      "speaker": null,
      "text": "То, что вы сейчас кидаете запрос на общую почту,"
    },
    {
      "start": 106.28,
      "end": 108.66,
      "speaker": null,
      "text": "он может один или другой менеджер и не видит, что сразу ли придет."
    },
    {
      "start": 109.6,
      "end": 112.18,
      "speaker": null,
      "text": "Записывайте тогда английские буквы первые две."
    },
    {
      "start": 112.5,
      "end": 113.0,
      "speaker": null,
      "text": "А, З."
    },
    {
      "start": 113.82,
      "end": 114.66,
      "speaker": null,
      "text": "Как еще раз?"
    },
    {
      "start": 115.18,
      "end": 115.78,
      "speaker": null,
      "text": "А, З."
    },
    {
      "start": 115.98,
      "end": 117.24,
      "speaker": null,
      "text": "Английские две буквы."
    },
    {
      "start": 117.36,
      "end": 117.76,
      "speaker": null,
      "text": "А, З."
    },
    {
      "start": 119.04,
      "end": 120.0,
      "speaker": null,
      "text": "Собакамостэн.ру"
    },
    {
      "start": 120.68,
      "end": 121.76,
      "speaker": null,
      "text": "То есть как на сайт записано."
    },
    {
      "start": 123.29,
      "end": 125.05,
      "speaker": null,
      "text": "Также МОЗ, Людей, да?"
    },
    {
      "start": 125.13,
      "end": 126.41,
      "speaker": null,
      "text": "Да-да-да-да-да-да-да."
    },
    {
      "start": 132.71,
      "end": 133.89,
      "speaker": null,
      "text": "МОЗ.ру, да?"
    },
    {
      "start": 133.89,
      "end": 135.31,
      "speaker": null,
      "text": "Вот туда можно отправиться."
    },
    {
      "start": 135.45,
      "end": 135.67,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 135.95,
      "end": 136.89,
      "speaker": null,
      "text": "Мне надо осмотреть, Александр."
    },
    {
      "start": 136.97,
      "end": 138.15,
      "speaker": null,
      "text": "Нужно знать еще в дальнейшем,"
    },
    {
      "start": 138.63,
      "end": 142.09,
      "speaker": null,
      "text": "что вы прописали мне в письме адрес необходимый."
    },
    {
      "start": 142.33,
      "end": 143.67,
      "speaker": null,
      "text": "Сроки есть какие-то известные?"
    },
    {
      "start": 144.33,
      "end": 145.79,
      "speaker": null,
      "text": "В данном проекте будет, да."
    },
    {
      "start": 145.99,
      "end": 146.87,
      "speaker": null,
      "text": "И сроки у нас есть."
    },
    {
      "start": 149.28,
      "end": 149.84,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 150.32,
      "end": 152.78,
      "speaker": null,
      "text": "Я жду полностью ОТЗ, чтобы дать обратную связь."
    },
    {
      "start": 153.58,
      "end": 155.2,
      "speaker": null,
      "text": "Так ответы не понять конечно."
    },
    {
      "start": 155.52,
      "end": 155.74,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 155.92,
      "end": 157.8,
      "speaker": null,
      "text": "Давайте жду."
    }
  ]
}