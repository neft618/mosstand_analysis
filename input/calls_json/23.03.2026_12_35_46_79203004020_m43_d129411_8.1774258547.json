  "segments": [
    {
      "start": 1.52,
      "end": 2.96,
      "speaker": null,
      "text": "Добрый день, Дмитрий."
    },
    {
      "start": 3.8,
      "end": 8.88,
      "speaker": null,
      "text": "Здравствуйте. Наташаик, меня интересует система СЭГВОУ у вас есть."
    },
    {
      "start": 9.72,
      "end": 12.48,
      "speaker": null,
      "text": "Да, подскажите, как я могу к вам обращаться?"
    },
    {
      "start": 12.72,
      "end": 13.42,
      "speaker": null,
      "text": "Наталья."
    },
    {
      "start": 13.96,
      "end": 15.44,
      "speaker": null,
      "text": "Наталья, очень приятно."
    },
    {
      "start": 16.38,
      "end": 28.24,
      "speaker": null,
      "text": "Меня интересует размер 4х4 секция, он 298х34298, двухсторонний. На сайте у вас обозначена стоимость 139400."
    },
    {
      "start": 29.74,
      "end": 31.76,
      "speaker": null,
      "text": "Именно СЭГВОУ, правильно?"
    },
    {
      "start": 31.76,
      "end": 39.78,
      "speaker": null,
      "text": "Да. Мне нужна двухсторонняя конструкция для автомобильного салона."
    },
    {
      "start": 42.66,
      "end": 48.14,
      "speaker": null,
      "text": "Так, он высотой 298 будет и шириной 298, то есть 3х3 метра."
    },
    {
      "start": 48.72,
      "end": 49.0,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 49.68,
      "end": 50.62,
      "speaker": null,
      "text": "Когда вам нужен?"
    },
    {
      "start": 51.78,
      "end": 55.48,
      "speaker": null,
      "text": "Меня сначала интересует вот эта стоимость 139400."
    },
    {
      "start": 57.25,
      "end": 59.59,
      "speaker": null,
      "text": "Что она в себя включает?"
    },
    {
      "start": 60.46,
      "end": 62.04,
      "speaker": null,
      "text": "Конструкция плюс печать."
    },
    {
      "start": 62.04,
      "end": 65.86,
      "speaker": null,
      "text": "Это с печатью уже, да? Двухсторонней печатью, правильно?"
    },
    {
      "start": 66.54,
      "end": 66.92,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 67.98,
      "end": 68.7,
      "speaker": null,
      "text": "Так, отлично."
    },
    {
      "start": 68.7,
      "end": 69.12,
      "speaker": null,
      "text": "Верно."
    },
    {
      "start": 69.56,
      "end": 79.8,
      "speaker": null,
      "text": "Да, пожалуйста, посмотрите, потому что я тоже рекламное агентство и я тоже еще буду этот вопрос обсуждать с заказчиком, поэтому мне нужно все моменты."
    },
    {
      "start": 79.8,
      "end": 80.6,
      "speaker": null,
      "text": "Да, все верно."
    },
    {
      "start": 81.29,
      "end": 82.95,
      "speaker": null,
      "text": "Так, 139400."
    },
    {
      "start": 83.11,
      "end": 83.89,
      "speaker": null,
      "text": "Следующий момент."
    },
    {
      "start": 84.07,
      "end": 93.43,
      "speaker": null,
      "text": "Вы работаете по как бы с другими регионами, мы из другого города, город Смоленск, транспортными компаниями, отправляете?"
    },
    {
      "start": 93.43,
      "end": 94.97,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 95.19,
      "end": 98.19,
      "speaker": null,
      "text": "Отправляем, вызываем к себе на склад и отправляем."
    },
    {
      "start": 98.73,
      "end": 99.25,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 99.81,
      "end": 100.83,
      "speaker": null,
      "text": "Следующий момент."
    },
    {
      "start": 100.91,
      "end": 101.81,
      "speaker": null,
      "text": "И переходим до терминала."
    },
    {
      "start": 102.37,
      "end": 103.19,
      "speaker": null,
      "text": "Я поняла."
    },
    {
      "start": 103.53,
      "end": 104.03,
      "speaker": null,
      "text": "Ну хорошо."
    },
    {
      "start": 105.39,
      "end": 107.63,
      "speaker": null,
      "text": "Следующий момент у меня по срокам."
    },
    {
      "start": 109.24,
      "end": 116.18,
      "speaker": null,
      "text": "По срокам закладывайте 4-5 рабочих дня с момента оплаты и согласования макета."
    },
    {
      "start": 116.18,
      "end": 118.9,
      "speaker": null,
      "text": "4-5 рабочих дней."
    },
    {
      "start": 119.18,
      "end": 120.1,
      "speaker": null,
      "text": "Угу, все."
    },
    {
      "start": 120.64,
      "end": 122.06,
      "speaker": null,
      "text": "Отлично, спасибо огромное."
    },
    {
      "start": 122.12,
      "end": 123.54,
      "speaker": null,
      "text": "Поготованные фото отправляем."
    },
    {
      "start": 124.34,
      "end": 128.0,
      "speaker": null,
      "text": "Ну то есть делаем фото спереди и сзади, что все собирается и все сходит."
    },
    {
      "start": 128.56,
      "end": 130.58,
      "speaker": null,
      "text": "И это все направляем перед отгрузкой."
    },
    {
      "start": 131.7,
      "end": 132.5,
      "speaker": null,
      "text": "Все, отлично."
    },
    {
      "start": 132.8,
      "end": 133.86,
      "speaker": null,
      "text": "Спасибо огромное."
    },
    {
      "start": 134.0,
      "end": 136.26,
      "speaker": null,
      "text": "Буду согласовывать и тогда наберу, хорошо?"
    },
    {
      "start": 136.74,
      "end": 137.54,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 138.1,
      "end": 140.3,
      "speaker": null,
      "text": "Наталья, а можете записать мой рабочий?"
    },
    {
      "start": 140.66,
      "end": 141.1,
      "speaker": null,
      "text": "Пишу."
    },
    {
      "start": 141.22,
      "end": 143.12,
      "speaker": null,
      "text": "Или вы на него и звоните, не знаю я."
    },
    {
      "start": 143.12,
      "end": 145.36,
      "speaker": null,
      "text": "А вот 931."
    },
    {
      "start": 146.17,
      "end": 148.37,
      "speaker": null,
      "text": "Угу, я звоню на общий."
    },
    {
      "start": 148.69,
      "end": 149.13,
      "speaker": null,
      "text": "Так, далее?"
    },
    {
      "start": 150.79,
      "end": 152.23,
      "speaker": null,
      "text": "931 111"
    },
    {
      "start": 153.25,
      "end": 153.61,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 154.83,
