  "segments": [
    {
      "start": 1.62,
      "end": 6.28,
      "speaker": null,
      "text": "Здравствуйте, Александр. Это Валерий из Мостэнд. Вы оставляли обратную заявку у нас на сайте."
    },
    {
      "start": 7.06,
      "end": 19.44,
      "speaker": null,
      "text": "Да, все верно. Я хотел узнать, а вы делаете такие, знаете, переносные конструкции? Типа там приехал на выставку и они оттягиваются тканью, а внутри свет. Типа такой темы."
    },
    {
      "start": 19.86,
      "end": 27.32,
      "speaker": null,
      "text": "Да, мы делаем. Смотрите, давайте как-то поступим. У вас же на этом номере есть Макс, может быть?"
    },
    {
      "start": 27.82,
      "end": 28.84,
      "speaker": null,
      "text": "Нет, Макса нет."
    },
    {
      "start": 30.1,
      "end": 33.6,
      "speaker": null,
      "text": "Так, или, может быть, вы знаете же наш сайт?"
    },
    {
      "start": 35.13,
      "end": 37.89,
      "speaker": null,
      "text": "А скиньте мне его, что надо сделать будет."
    },
    {
      "start": 38.98,
      "end": 41.74,
      "speaker": null,
      "text": "Или, может быть, я на почту направлю просто смс-ка и не смотрю."
    },
    {
      "start": 41.74,
      "end": 43.62,
      "speaker": null,
      "text": "Давайте на почту он. Да, окей."
    },
    {
      "start": 44.2,
      "end": 45.06,
      "speaker": null,
      "text": "Тогда диктуруйте."
    },
    {
      "start": 45.18,
      "end": 45.32,
      "speaker": null,
      "text": "Запишите."
    },
    {
      "start": 64.85,
      "end": 67.31,
      "speaker": null,
      "text": "Должно получиться А.Прохорин."
    },
    {
      "start": 68.76,
      "end": 72.43,
      "speaker": null,
      "text": "Так. Еще раз, как должно получиться?"
    },
    {
      "start": 73.38,
      "end": 75.52,
      "speaker": null,
      "text": "А.Прохорин."
    },
    {
      "start": 75.9,
      "end": 76.32,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 76.5,
      "end": 76.98,
      "speaker": null,
      "text": "Бескей."
    },
    {
      "start": 77.42,
      "end": 77.76,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 78.64,
      "end": 78.84,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 79.26,
      "end": 79.96,
      "speaker": null,
      "text": "Мэл.ру."
    },
    {
      "start": 80.64,
      "end": 82.9,
      "speaker": null,
      "text": "Да, gmail.com."
    },
    {
      "start": 83.68,
      "end": 84.88,
      "speaker": null,
      "text": "А, gmail."
    },
    {
      "start": 85.08,
      "end": 85.36,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 85.36,
      "end": 87.06,
      "speaker": null,
      "text": "Все, хорошо."
    },
    {
      "start": 87.3,
      "end": 89.14,
      "speaker": null,
      "text": "Сейчас давайте тогда направлю вам ссылку."
    },
    {
      "start": 89.46,
      "end": 90.9,
      "speaker": null,
      "text": "Смотрите, сразу объясню."
    },
    {
      "start": 91.8,
      "end": 94.16,
      "speaker": null,
      "text": "Там будет несколько разных лайтбоксов."
    },
    {
      "start": 95.19,
      "end": 101.87,
      "speaker": null,
      "text": "Есть у нас те, которые ткань натягивается как наволочка, они в глубину даже побольше будут."
    },
    {
      "start": 102.43,
      "end": 107.55,
      "speaker": null,
      "text": "А есть те, у которых профиль такой алиниевый, он изначально идет с подсветкой."
    },
    {
      "start": 107.55,
      "end": 111.81,
      "speaker": null,
      "text": "И за счет силиконовой ленты ткань туда, вот в профиль вставляется."
    },
    {
      "start": 112.47,
      "end": 112.81,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 113.23,
      "end": 116.89,
      "speaker": null,
      "text": "Также еще есть, если что, стойки как раз-таки с таким лайтбоксом."
    },
    {
      "start": 117.07,
      "end": 117.81,
      "speaker": null,
      "text": "Ну, давайте я вам..."
    },
    {
      "start": 117.81,
      "end": 119.43,
      "speaker": null,
      "text": "Ну, мы посмотрим, да, давайте."
    },
    {
      "start": 120.35,
      "end": 122.49,
      "speaker": null,
      "text": "Да, они, соответственно, как лайтбоксы."
    },
    {
      "start": 122.73,
      "end": 124.21,
      "speaker": null,
      "text": "Где у вас производство?"
    },
    {
      "start": 125.43,
      "end": 126.73,
      "speaker": null,
      "text": "Вам адрес необходим?"
    },
    {
      "start": 127.33,
      "end": 130.33,
      "speaker": null,
      "text": "Москва или Россия или другие страны."
    },
    {
      "start": 130.49,
      "end": 131.83,
      "speaker": null,
      "text": "Нет, это область Люверсе."
    },
    {
      "start": 132.47,
      "end": 133.53,
      "speaker": null,
      "text": "А, все, все, хорошо."
    },
    {
      "start": 133.63,
      "end": 134.59,
      "speaker": null,
      "text": "Там и Рязанское шоссе."
    },
    {
      "start": 134.77,
