    {
      "start": 361.78,
      "end": 362.78,
      "speaker": null,
      "text": "Ну да, да, да."
    },
    {
      "start": 366.74,
      "end": 368.14,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 368.72,
      "end": 370.5,
      "speaker": null,
      "text": "Тогда вот говорили с вами,"
    },
    {
      "start": 370.6,
      "end": 371.94,
      "speaker": null,
      "text": "что я жду под цветопроби"
    },
    {
      "start": 372.76,
      "end": 374.34,
      "speaker": null,
      "text": "макетик просто быстренько"
    },
    {
      "start": 374.34,
      "end": 375.72,
      "speaker": null,
      "text": "вам там уклую или не уклую."
    },
    {
      "start": 376.3,
      "end": 376.42,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 376.88,
      "end": 377.84,
      "speaker": null,
      "text": "Потом заберем,"
    },
    {
      "start": 378.44,
      "end": 381.16,
      "speaker": null,
      "text": "и дальше уже будем запускаться."
    },
    {
      "start": 382.02,
      "end": 383.1,
      "speaker": null,
      "text": "Хорошо, хорошо."
    },
    {
      "start": 385.03,
      "end": 386.23,
      "speaker": null,
      "text": "В таком случае..."
    },
    {
      "start": 386.23,
      "end": 388.51,
      "speaker": null,
      "text": "Да, я сейчас буквально,"
    },
    {
      "start": 388.51,
      "end": 389.75,
      "speaker": null,
      "text": "думаю, в течение часа"
    },
    {
      "start": 389.75,
      "end": 391.07,
      "speaker": null,
      "text": "у вас будет уже"
    },
    {
      "start": 391.07,
      "end": 392.31,
      "speaker": null,
      "text": "макет цветопробы."
    },
    {
      "start": 393.01,
      "end": 394.51,
      "speaker": null,
      "text": "А по стойке"
    },
    {
      "start": 394.51,
      "end": 395.77,
      "speaker": null,
      "text": "мы сейчас посмотрим вообще..."
    },
    {
      "start": 395.77,
      "end": 396.55,
      "speaker": null,
      "text": "А у вас есть какие-то"
    },
    {
      "start": 396.55,
      "end": 397.55,
      "speaker": null,
      "text": "другие фотографии стойки"
    },
    {
      "start": 397.55,
      "end": 398.31,
      "speaker": null,
      "text": "там сбоку, например,"
    },
    {
      "start": 398.49,
      "end": 398.95,
      "speaker": null,
      "text": "в разрез,"
    },
    {
      "start": 399.03,
      "end": 399.97,
      "speaker": null,
      "text": "как она вообще выглядит,"
    },
    {
      "start": 400.13,
      "end": 400.89,
      "speaker": null,
      "text": "чтобы мы понимали"
    },
    {
      "start": 400.89,
      "end": 401.95,
      "speaker": null,
      "text": "все, можно зацепиться?"
    },
    {
      "start": 403.98,
      "end": 404.96,
      "speaker": null,
      "text": "Я сейчас поищу."
    },
    {
      "start": 405.2,
      "end": 406.42,
      "speaker": null,
      "text": "Поищу, пришло вам."
    },
    {
      "start": 407.26,
      "end": 408.84,
      "speaker": null,
      "text": "Ну или разобранный вариант."
    },
    {
      "start": 409.28,
      "end": 410.48,
      "speaker": null,
      "text": "Любое вот все, что..."
    },
    {
      "start": 410.48,
      "end": 411.58,
      "speaker": null,
      "text": "Они цельные, да."
    },
    {
      "start": 411.68,
      "end": 412.8,
      "speaker": null,
      "text": "В общем, сейчас подумаю."
    },
    {
      "start": 413.16,
      "end": 414.04,
      "speaker": null,
      "text": "Да, я сейчас подумаю,"
    },
    {
      "start": 414.2,
      "end": 414.9,
      "speaker": null,
      "text": "пришло, что есть."
    },
    {
      "start": 415.42,
      "end": 416.66,
      "speaker": null,
      "text": "Все, спасибо, Светлана."
    },
    {
      "start": 417.22,
      "end": 417.9,
      "speaker": null,
      "text": "Спасибо вам."
    },
    {
      "start": 418.08,
      "end": 418.5,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 418.64,
      "end": 419.2,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}