{
  "file": "25.05.2026_15_43_08_79647841606_m31_d135407_0.1779712990.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 93.1,
  "segments": [
    {
      "start": 0.43,
      "end": 1.39,
      "speaker": null,
      "text": "Да, Полина?"
    },
    {
      "start": 2.31,
      "end": 7.95,
      "speaker": null,
      "text": "Добрый день ещё раз. Я к вам выдвинулась только. Показывают навигатор где-то час ехать."
    },
    {
      "start": 8.31,
      "end": 14.75,
      "speaker": null,
      "text": "А, ну хорошо, там офис до шести. А у вас остались контакты Ирины? Вот вы созванивались."
    },
    {
      "start": 16.93,
      "end": 19.77,
      "speaker": null,
      "text": "Сомневаюсь, если честно. Но проверил на всякий случай."
    },
    {
      "start": 20.43,
      "end": 30.89,
      "speaker": null,
      "text": "Смотри, там просто пропуск нужен будет. И лучше, конечно, сразу Ирина, потому что она вот уже, ну именно на месте там находится."
    },
    {
      "start": 31.43,
      "end": 36.85,
      "speaker": null,
      "text": "Либо я могу вам написать на почту номер телефона её."
    },
    {
      "start": 37.74,
      "end": 41.02,
      "speaker": null,
      "text": "Ну, если ещё предупрежу, что где-то через час буду."
    },
    {
      "start": 42.05,
      "end": 42.33,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 42.77,
      "end": 44.75,
      "speaker": null,
      "text": "Потому что не далеко от этого где-то?"
    },
    {
      "start": 45.71,
      "end": 48.35,
      "speaker": null,
      "text": "Нет, совсем не далеко от этого."
    },
    {
      "start": 48.63,
      "end": 54.33,
      "speaker": null,
      "text": "От электрозаводской, если от электрозаводской смотреть, то, если пешком, то минут 15."
    },
    {
      "start": 55.46,
      "end": 55.92,
      "speaker": null,
      "text": "А, пешком?"
    },
    {
      "start": 55.92,
      "end": 57.68,
      "speaker": null,
      "text": "Если на автобусе, минут 5-10."
    },
    {
      "start": 58.14,
      "end": 61.74,
      "speaker": null,
      "text": "А так, смотрите, сейчас скажу её контакты."
    },
    {
      "start": 61.9,
      "end": 68.28,
      "speaker": null,
      "text": "Вот вы знаете мой номер там 931 111, то есть у нас разные четыре цифра."
    },
    {
      "start": 68.7,
      "end": 70.18,
      "speaker": null,
      "text": "У неё 45-40."
    },
    {
      "start": 71.22,
      "end": 73.0,
      "speaker": null,
      "text": "45-40. Прошлось запомнило."
    },
    {
      "start": 73.0,
      "end": 75.52,
      "speaker": null,
      "text": "Начало такое же, как у меня на мобильном."
    },
    {
      "start": 76.93,
      "end": 77.31,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 77.95,
      "end": 78.73,
      "speaker": null,
      "text": "Всё, супер."
    },
    {
      "start": 78.77,
      "end": 80.13,
      "speaker": null,
      "text": "Если что, она ждёт вас."
    },
    {
      "start": 80.33,
      "end": 81.25,
      "speaker": null,
      "text": "Я её предупредила."
    },
    {
      "start": 84.23,
      "end": 84.49,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 84.89,
      "end": 85.87,
      "speaker": null,
      "text": "Да, тогда..."
    },
    {
      "start": 86.19,
      "end": 87.45,
      "speaker": null,
      "text": "Хорошего вечера."
    },
    {
      "start": 87.73,
      "end": 88.43,
      "speaker": null,
      "text": "Да, до свидания."
    },
    {
      "start": 89.17,
      "end": 89.43,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 89.43,
      "end": 89.63,
      "speaker": null,
      "text": "Пока."
    }
  ]
}