  "segments": [
    {
      "start": 0.05,
      "end": 3.07,
      "speaker": null,
      "text": "Добрый день, Валентин. Компания Most Station. Могу вам помочь?"
    },
    {
      "start": 3.95,
      "end": 13.33,
      "speaker": null,
      "text": "Здравствуйте. Подскажите, у меня есть полностью готовый стенд, роллап, метр на два метра. Возможно ли заменить на нём само полотно?"
    },
    {
      "start": 14.31,
      "end": 16.93,
      "speaker": null,
      "text": "Да. А скажите, как я могу к вам пришиться?"
    },
    {
      "start": 18.42,
      "end": 19.1,
      "speaker": null,
      "text": "Елизавета."
    },
    {
      "start": 21.9,
      "end": 24.87,
      "speaker": null,
      "text": "Елизавета. Когда вам будет необходим баннер?"
    },
    {
      "start": 26.31,
      "end": 27.83,
      "speaker": null,
      "text": "Сегодня или завтра."
    },
    {
      "start": 29.4,
      "end": 36.48,
      "speaker": null,
      "text": "Угу. Получается, у вас есть конструкция роллап 100 на 200 и вам необходим баннер?"
    },
    {
      "start": 36.96,
      "end": 38.68,
      "speaker": null,
      "text": "Да. Ну и замена."
    },
    {
      "start": 38.92,
      "end": 40.44,
      "speaker": null,
      "text": "Один? Один только?"
    },
    {
      "start": 41.0,
      "end": 41.26,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 48.07,
      "end": 58.1,
      "speaker": null,
      "text": "Смотрите, стоимость баннера для роллап классик 100 на 200 будет 2200 рублей?"
    },
    {
      "start": 58.78,
      "end": 59.0,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 60.04,
      "end": 67.31,
      "speaker": null,
      "text": "Это в стоимость входит баннер и замены его. Скажите, пожалуйста, вам доставка потребуется?"
    },
    {
      "start": 68.75,
      "end": 69.23,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 69.97,
      "end": 71.31,
      "speaker": null,
      "text": "Доставка не потребуется."
    },
    {
      "start": 71.31,
      "end": 75.87,
      "speaker": null,
      "text": "У нас минимальная сумма заказа 5000 рублей."
    },
    {
      "start": 76.43,
      "end": 76.77,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 77.15,
      "end": 79.45,
      "speaker": null,
      "text": "Может вам потребуется какая-то дополнительная продукция?"
    },
    {
      "start": 79.57,
      "end": 80.71,
      "speaker": null,
      "text": "Может сам роллап?"
    },
    {
      "start": 84.91,
      "end": 87.71,
      "speaker": null,
      "text": "Мы производим полиграфию и сувенирную продукцию."
    },
    {
      "start": 88.85,
      "end": 90.01,
      "speaker": null,
      "text": "Нет, думаю нет."
    },
    {
      "start": 91.43,
      "end": 91.79,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 93.19,
      "end": 97.97,
      "speaker": null,
      "text": "Смотрите, роллап классический 100 на 200 будет стоить 5900 рублей."
    },
    {
      "start": 98.11,
      "end": 101.31,
      "speaker": null,
      "text": "Это вместе с конструкцией, баннером и сумкой для переноса и хранения."
    },
    {
      "start": 101.89,
      "end": 102.63,
      "speaker": null,
      "text": "5900, да?"
    },
    {
      "start": 103.21,
