    {
      "start": 116.66,
      "end": 117.02,
      "speaker": null,
      "text": "Что?"
    },
    {
      "start": 117.02,
      "end": 118.58,
      "speaker": null,
      "text": "Макет у вас уже готов?"
    },
    {
      "start": 119.0,
