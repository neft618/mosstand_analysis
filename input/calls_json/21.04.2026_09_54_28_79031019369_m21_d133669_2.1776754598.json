{
  "file": "21.04.2026_09_54_28_79031019369_m21_d133669_2.1776754598.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 112.4,
  "segments": [
    {
      "start": 0.98,
      "end": 7.98,
      "speaker": null,
      "text": "Компания Нос-Center. Здравствуйте, Артем. Подскажите, пожалуйста, нам нужно напечатать полотно баммера для роллапа."
    },
    {
      "start": 8.75,
      "end": 9.67,
      "speaker": null,
      "text": "Угу, так."
    },
    {
      "start": 10.21,
      "end": 11.91,
      "speaker": null,
      "text": "И просто полотно вот это вот."
    },
    {
      "start": 12.58,
      "end": 16.14,
      "speaker": null,
      "text": "А у вас же самая конструкция роллапы есть? Правильно я вас понимаю?"
    },
    {
      "start": 16.36,
      "end": 20.84,
      "speaker": null,
      "text": "У нас сама конструкция есть, нам нужно просто вот это вот полотно, сами мы её прицепим."
    },
    {
      "start": 21.2,
      "end": 22.42,
      "speaker": null,
      "text": "А какой размер у вас?"
    },
    {
      "start": 23.06,
      "end": 25.06,
      "speaker": null,
      "text": "Ну, я думаю, стандарт 2х1."
    },
    {
      "start": 26.99,
      "end": 29.95,
      "speaker": null,
      "text": "То есть метр ширина, два метра высота."
    },
    {
      "start": 30.17,
      "end": 32.03,
      "speaker": null,
      "text": "Да, вот как обычный, затирал лапы."
    },
    {
      "start": 32.75,
      "end": 33.09,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 33.29,
      "end": 38.07,
      "speaker": null,
      "text": "Вот знаете, печать одного баннера – 1900 рублей под вашу размер лапа."
    },
    {
      "start": 38.23,
      "end": 39.19,
      "speaker": null,
      "text": "У вас макет уже готов?"
    },
    {
      "start": 39.59,
      "end": 39.87,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 40.13,
      "end": 42.91,
      "speaker": null,
      "text": "Макет готов, а вот за срочность, если доплатить."
    },
    {
      "start": 43.69,
      "end": 44.45,
      "speaker": null,
      "text": "А вам сегодня необходимо?"
    },
    {
      "start": 44.87,
      "end": 45.81,
      "speaker": null,
      "text": "Нам сегодня надо."
    },
    {
      "start": 46.56,
      "end": 48.76,
      "speaker": null,
      "text": "Буду уточнять, есть ли возможность по срокам, расскажи."
    },
    {
      "start": 49.04,
      "end": 50.12,
      "speaker": null,
      "text": "Да, начните, пожалуйста."
    },
    {
      "start": 50.22,
      "end": 51.4,
      "speaker": null,
      "text": "Всё зависит ещё от макета."
    },
    {
      "start": 51.52,
      "end": 56.54,
      "speaker": null,
      "text": "Вы на сайте требования у нас брали, как необходимо делать макет?"
    },
    {
      "start": 57.68,
      "end": 58.34,
      "speaker": null,
      "text": "Вряд ли."
    },
    {
      "start": 59.92,
      "end": 60.92,
      "speaker": null,
      "text": "Лучше по ним проверили."
    },
    {
      "start": 61.08,
      "end": 65.2,
      "speaker": null,
      "text": "Потому что, смотрите, на первую часть макета управляли на проверку."
    },
    {
      "start": 65.82,
      "end": 68.58,
      "speaker": null,
      "text": "То есть, во-первых, он должен быть по всем требованиям по размеру."
    },
    {
      "start": 68.8,
      "end": 71.58,
      "speaker": null,
      "text": "То есть, если получается у вас метр ширина и два метра высота,"
    },
    {
      "start": 72.28,
      "end": 76.54,
      "speaker": null,
      "text": "в миллиметрах он должен быть 990 на 2030 миллиметров."
    },
    {
      "start": 76.66,
      "end": 79.16,
      "speaker": null,
      "text": "Все изображения должны быть хорошего качества."
    },
    {
      "start": 79.36,
      "end": 81.34,
      "speaker": null,
      "text": "Все шлифты должны переведены в кривые."
    },
    {
      "start": 81.82,
      "end": 83.58,
      "speaker": null,
      "text": "Ага, то есть я туда уточню."
    },
    {
      "start": 84.5,
      "end": 88.52,
      "speaker": null,
      "text": "Да, смотрите, на сайте у нас в разделе «Руллапы» есть требования к макету."
    },
    {
      "start": 88.92,
      "end": 90.76,
      "speaker": null,
      "text": "Можно скачать и посмотреть, проверить."
    },
    {
      "start": 91.24,
      "end": 92.0,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 93.12,
      "end": 98.88,
      "speaker": null,
      "text": "А вы тут уточните, пожалуйста, сможете ли вы в итоге распечататься за один день, а я подкаст доставляю в два дня."
    },
    {
      "start": 98.88,
      "end": 99.3,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 99.58,
      "end": 100.28,
      "speaker": null,
      "text": "Как это вот?"
    },
    {
      "start": 101.62,
      "end": 104.24,
      "speaker": null,
      "text": "А мы на телефону привязываем к какому-то макету?"
    },
    {
      "start": 105.1,
      "end": 105.64,
      "speaker": null,
      "text": "Макс."
    },
    {
      "start": 106.24,
      "end": 106.78,
      "speaker": null,
      "text": "Макс."
    },
    {
      "start": 107.04,
      "end": 109.86,
      "speaker": null,
      "text": "Хорошо, давайте я сейчас отпишу сам тогда и точнее про возможность."
    }
  ]
}