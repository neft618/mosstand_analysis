{
  "file": "03.06.2026_14_33_59_79661160055_m21_d138671_b.1780486440.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 63.8,
  "segments": [
    {
      "start": 0.72,
      "end": 9.6,
      "speaker": null,
      "text": "Да, Сергей. Я написал вам то, что наклейки какой размер был, и тираж, и буклетов тоже?"
    },
    {
      "start": 10.16,
      "end": 15.08,
      "speaker": null,
      "text": "Только я не понял, там по 200 каждого или по 100 каждого?"
    },
    {
      "start": 15.5,
      "end": 20.86,
      "speaker": null,
      "text": "Ну вот всё, что у меня было, у меня 200 наклеек было и 200 буклетов."
    },
    {
      "start": 21.12,
      "end": 26.36,
      "speaker": null,
      "text": "Ну, 200 наклеек – это общая позиция?"
    },
    {
      "start": 26.64,
      "end": 27.74,
      "speaker": null,
      "text": "Это общая."
    },
    {
      "start": 27.9,
      "end": 30.04,
      "speaker": null,
      "text": "То есть по 100 штук каждого?"
    },
    {
      "start": 30.3,
      "end": 33.02,
      "speaker": null,
      "text": "Ну да, вроде да. Вот так у меня сейчас было в расчетах смотрел."
    },
    {
      "start": 34.7,
      "end": 37.36,
      "speaker": null,
      "text": "Ну давайте так тогда. Давайте повторяться."
    },
    {
      "start": 37.84,
      "end": 40.16,
      "speaker": null,
      "text": "Хорошо, тогда макеты мне когда направят-то?"
    },
    {
      "start": 41.12,
      "end": 43.6,
      "speaker": null,
      "text": "Димка должен сбросить. Ещё не сбросил?"
    },
    {
      "start": 44.1,
      "end": 44.48,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 45.52,
      "end": 47.12,
      "speaker": null,
      "text": "Я понял, сейчас давай."
    },
    {
      "start": 48.08,
      "end": 50.94,
      "speaker": null,
      "text": "Ты мне продублируй, пожалуйста, почту, я ему скину."
    },
    {
      "start": 51.06,
      "end": 53.38,
      "speaker": null,
      "text": "Мало ли, может он там тупит тоже где-то сидит за работой."
    },
    {
      "start": 53.62,
      "end": 54.8,
      "speaker": null,
      "text": "Я сейчас за компьютером."
    },
    {
      "start": 55.58,
      "end": 58.46,
      "speaker": null,
      "text": "Либо вот мне почта всегда удобнее, на самом деле."
    },
    {
      "start": 59.1,
      "end": 60.28,
      "speaker": null,
      "text": "На почту да, давайте."
    },
    {
      "start": 60.66,
      "end": 61.72,
      "speaker": null,
      "text": "Сейчас вам пишу, давайте."
    }
  ]
}