    {
      "start": 281.89,
      "end": 283.81,
      "speaker": null,
      "text": "У вас будет 4,48."
    },
    {
      "start": 286.43,
      "end": 288.87,
      "speaker": null,
      "text": "А высота 3,01?"
    },
    {
      "start": 289.05,
      "end": 289.99,
      "speaker": null,
      "text": "3,01, да."
    },
    {
      "start": 290.27,
