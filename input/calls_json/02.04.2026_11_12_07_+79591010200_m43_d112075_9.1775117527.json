    {
      "start": 128.91,
      "end": 130.27,
      "speaker": null,
      "text": "Там будет 4,95."
    },
    {
      "start": 131.74,
      "end": 133.54,
      "speaker": null,
      "text": "Следующий размер 5,67."
    },
    {
      "start": 139.88,
      "end": 143.42,
      "speaker": null,
      "text": "Ну там тогда другой, другой размер макета будет."
    },
    {
      "start": 143.62,
      "end": 144.14,
      "speaker": null,
      "text": "Там ширина секса."
    },
    {
      "start": 144.14,
      "end": 150.12,
      "speaker": null,
      "text": "Нет какой-то такой картиночки, на которой вот этот вот изогнутый стенд нарисован."
