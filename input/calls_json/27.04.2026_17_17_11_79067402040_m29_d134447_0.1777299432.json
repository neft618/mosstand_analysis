{
  "file": "27.04.2026_17_17_11_79067402040_m29_d134447_0.1777299432.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 132.4,
  "segments": [
    {
      "start": 1.6,
      "end": 5.06,
      "speaker": null,
      "text": "Добрый день, меня зовут Ксения. Компания, выставка, как я могу к вам обращаться?"
    },
    {
      "start": 5.7,
      "end": 8.68,
      "speaker": null,
      "text": "Добрый день, меня Анастасия зовут. Подскажите, нужный размер?"
    },
    {
      "start": 10.52,
      "end": 12.78,
      "speaker": null,
      "text": "Вышел 102. Есть такой?"
    },
    {
      "start": 15.68,
      "end": 17.48,
      "speaker": null,
      "text": "180 на 200?"
    },
    {
      "start": 18.44,
      "end": 20.04,
      "speaker": null,
      "text": "180 на 200."
    },
    {
      "start": 22.19,
      "end": 24.55,
      "speaker": null,
      "text": "Это точно по рису вам необходим?"
    },
    {
      "start": 25.29,
      "end": 25.55,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 27.47,
      "end": 32.73,
      "speaker": null,
      "text": "В целом мы такое можем сделать. А 180 – это в ширину или высоту?"
    },
    {
      "start": 35.92,
      "end": 38.0,
      "speaker": null,
      "text": "180 – это в высоту."
    },
    {
      "start": 41.02,
      "end": 43.32,
      "speaker": null,
      "text": "2 на 1, 8."
    },
    {
      "start": 44.24,
      "end": 49.9,
      "speaker": null,
      "text": "Так, а вам нужен именно присвол однофекционный или с двойной трубой?"
    },
    {
      "start": 50.22,
      "end": 51.22,
      "speaker": null,
      "text": "Как вообще необходимо?"
    },
    {
      "start": 51.58,
      "end": 52.02,
      "speaker": null,
      "text": "Однофекция."
    },
    {
      "start": 56.18,
      "end": 58.42,
      "speaker": null,
      "text": "Только конструкцию или вместе с баннером?"
    },
    {
      "start": 58.62,
      "end": 59.72,
      "speaker": null,
      "text": "Только конструкцию."
    },
    {
      "start": 60.62,
      "end": 61.78,
      "speaker": null,
      "text": "Только конструкцию."
    },
    {
      "start": 64.25,
      "end": 65.91,
      "speaker": null,
      "text": "А на какую дату?"
    },
    {
      "start": 67.38,
      "end": 69.34,
      "speaker": null,
      "text": "Новую партнер, ориентируйте."
    },
    {
      "start": 75.92,
      "end": 76.6,
      "speaker": null,
      "text": "Фекционную."
    },
    {
      "start": 78.32,
      "end": 79.52,
      "speaker": null,
      "text": "Сейчас мне ее загрузится."
    },
    {
      "start": 84.69,
      "end": 87.79,
      "speaker": null,
      "text": "А баннер вы в другом месте печатаете или вы типография?"
    },
    {
      "start": 87.79,
      "end": 88.77,
      "speaker": null,
      "text": "Баннеры у вас уже есть."
    },
    {
      "start": 89.17,
      "end": 90.79,
      "speaker": null,
      "text": "А, у вас уже есть, поняла."
    },
    {
      "start": 91.13,
      "end": 99.24,
      "speaker": null,
      "text": "По стоимости только конструкции будет у нас 5000 рублей для данного размера,"
    },
    {
      "start": 99.34,
      "end": 101.78,
      "speaker": null,
      "text": "для однофекционного пресс-вола."
    },
    {
      "start": 102.7,
      "end": 103.34,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 104.0,
      "end": 105.94,
      "speaker": null,
      "text": "Так, получается баннер у вас уже есть."
    },
    {
      "start": 106.04,
      "end": 110.1,
      "speaker": null,
      "text": "А баннер вы как сделали? Размер в размер или учитывали вылеты?"
    },
    {
      "start": 112.23,
      "end": 112.87,
      "speaker": null,
      "text": "Учитывали."
    },
    {
      "start": 114.24,
      "end": 115.14,
      "speaker": null,
      "text": "Поняла, да?"
    },
    {
      "start": 115.54,
      "end": 118.82,
      "speaker": null,
      "text": "Так, и на какую дату вам необходимо конструкцию сделать?"
    },
    {
      "start": 120.09,
      "end": 122.25,
      "speaker": null,
      "text": "Ну, пока мы просто прицениваемся."
    },
    {
      "start": 122.49,
      "end": 123.89,
      "speaker": null,
      "text": "Я сейчас собираю информацию."
    },
    {
      "start": 124.81,
      "end": 125.79,
      "speaker": null,
      "text": "Дальше будем решать."
    },
    {
      "start": 126.01,
      "end": 127.97,
      "speaker": null,
      "text": "Если что, я вам перезвоню."
    },
    {
      "start": 128.11,
      "end": 129.61,
      "speaker": null,
      "text": "Спасибо большое за информацию."
    },
    {
      "start": 131.14,
      "end": 132.26,
      "speaker": null,
      "text": "А что-нибудь еще?"
    }
  ]
}