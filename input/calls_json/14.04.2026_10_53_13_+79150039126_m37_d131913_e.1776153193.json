  "segments": [
    {
      "start": 0.72,
      "end": 1.36,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 2.05,
      "end": 3.09,
      "speaker": null,
      "text": "Добрый день, Артём."
    },
    {
      "start": 4.8,
      "end": 5.4,
      "speaker": null,
      "text": "Да, здравствуйте."
    },
    {
      "start": 5.64,
      "end": 10.32,
      "speaker": null,
      "text": "Вы на компанию Мустэн доставили заявку у нас на сайте. Чем могу смочь рекламно-высключено оборудованием?"
    },
    {
      "start": 11.26,
      "end": 18.62,
      "speaker": null,
      "text": "Да, смотрите, я присылал ТЗ необходим тлаш каскадного типа."
    },
    {
      "start": 19.55,
      "end": 20.43,
      "speaker": null,
      "text": "А куда присылали?"
    },
    {
      "start": 21.31,
      "end": 22.25,
      "speaker": null,
      "text": "На почту."
    },
    {
      "start": 23.08,
      "end": 23.92,
      "speaker": null,
      "text": "На нашу почту?"
    },
    {
      "start": 25.56,
      "end": 26.16,
      "speaker": null,
      "text": "Да?"
    },
    {
      "start": 26.44,
      "end": 27.16,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 27.94,
      "end": 29.88,
      "speaker": null,
      "text": "И вам кто-то ответил или ещё нет?"
    },
    {
      "start": 30.08,
      "end": 30.82,
      "speaker": null,
      "text": "Нет, ещё нет."
    },
    {
      "start": 30.82,
      "end": 33.86,
      "speaker": null,
      "text": "Так, а подскажите почту, посмотрю запросы."
    },
    {
      "start": 34.96,
      "end": 38.5,
      "speaker": null,
      "text": "Бергер-маркет 2010 gmail.com"
    },
    {
      "start": 38.5,
      "end": 39.46,
      "speaker": null,
      "text": "Так, подождите."
    },
    {
      "start": 40.1,
      "end": 40.64,
      "speaker": null,
      "text": "Не спустите."
    },
    {
      "start": 44.02,
      "end": 49.3,
      "speaker": null,
      "text": "Так, Бергер, да?"
    },
    {
      "start": 50.02,
      "end": 50.34,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 55.56,
      "end": 57.16,
      "speaker": null,
      "text": "Так, Бергер..."
    },
    {
      "start": 59.63,
      "end": 60.33,
      "speaker": null,
      "text": "Дальше."
    },
    {
      "start": 61.96,
      "end": 64.76,
      "speaker": null,
      "text": "Бергер-маркет, маркет."
    },
    {
      "start": 66.24,
      "end": 69.31,
      "speaker": null,
      "text": "Бергер-маркет."
    },
    {
      "start": 71.9,
      "end": 75.91,
      "speaker": null,
      "text": "2010 gmail.com"
    },
    {
      "start": 76.98,
      "end": 79.58,
      "speaker": null,
      "text": "Ну я не вижу такого запроса, а вы когда направляли его?"
    },
    {
      "start": 80.38,
      "end": 81.16,
      "speaker": null,
      "text": "Да, вот вчера."
    },
    {
      "start": 83.82,
      "end": 85.88,
      "speaker": null,
      "text": "Так, а Бергер правильно?"
    },
    {
      "start": 86.06,
      "end": 87.3,
      "speaker": null,
      "text": "Ну как слышите, так и пишите."
    },
    {
      "start": 88.34,
      "end": 88.7,
      "speaker": null,
      "text": "ДРГ..."
    },
    {
      "start": 88.7,
      "end": 89.82,
      "speaker": null,
      "text": "Давайте продублирую."
    },
    {
      "start": 90.93,
      "end": 95.53,
      "speaker": null,
      "text": "Ну от того, что вы продублируете я не увижу на общей почте, у меня нет доступа к общей почте."
    },
    {
      "start": 95.61,
      "end": 97.75,
      "speaker": null,
      "text": "Я просто не вижу этого запроса."
    },
    {
      "start": 97.75,
      "end": 104.19,
      "speaker": null,
      "text": "Вы можете направить на мою почту вместо info.eo две маленькие буковки, и тогда я его увижу."
    },
    {
      "start": 104.97,
      "end": 107.63,
      "speaker": null,
      "text": "А может быть вы мне тогда напишите там WhatsApp, Telegram?"
    },
    {
      "start": 108.46,
      "end": 109.18,
      "speaker": null,
      "text": "Ну давайте."
    },
    {
      "start": 109.36,
      "end": 110.3,
      "speaker": null,
      "text": "На этот номер есть, да?"
    },
    {
      "start": 110.78,
      "end": 111.34,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 111.7,
      "end": 113.28,
      "speaker": null,
      "text": "Я тогда вам сразу скину."
    },
    {
      "start": 113.74,
      "end": 115.3,
      "speaker": null,
      "text": "Так, сейчас подождите секунду, я посмотрю."
    },
    {
      "start": 115.38,
      "end": 121.08,
      "speaker": null,
      "text": "Там у меня просто ничего не работает на самом деле касаемо Telegram, поэтому я не уверена."
    },
    {
      "start": 121.08,
      "end": 124.02,
      "speaker": null,
      "text": "Лучше, если вы перешлете на почту все-таки будет."
    },
    {
      "start": 124.26,
      "end": 125.78,
      "speaker": null,
      "text": "За 100% мы сможем все..."
    },
    {
      "start": 125.78,
      "end": 127.08,
      "speaker": null,
      "text": "Ну удобнее было бы все-таки..."
    },
    {
      "start": 130.1,
      "end": 133.2,
      "speaker": null,
      "text": "Я понимаю, но мне что сделать, если у меня не работает мессенджер?"
    },
    {
      "start": 134.06,
      "end": 137.42,
      "speaker": null,
      "text": "Давайте я другому менеджеру передам вашу заявку, он вам напишет в Telegram, хорошо?"
    },
    {
      "start": 137.42,
      "end": 138.32,
      "speaker": null,
      "text": "Давайте, да."
    },
    {
      "start": 138.7,
      "end": 139.32,
      "speaker": null,
      "text": "Угу, спасибо."
    },
    {
      "start": 139.62,
      "end": 139.9,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}