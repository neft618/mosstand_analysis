    {
      "start": 49.38,
      "end": 50.86,
      "speaker": null,
      "text": "Всё, я поняла вас."
    },
    {
      "start": 51.1,
      "end": 54.12,
      "speaker": null,
      "text": "А примерно пока не знаете насколько она в командировке?"
