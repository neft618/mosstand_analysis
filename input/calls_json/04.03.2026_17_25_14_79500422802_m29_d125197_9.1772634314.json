  "segments": [
    {
      "start": 1.44,
      "end": 6.82,
      "speaker": null,
      "text": "Здравствуйте, Алина. Я так сильно из компании МОСЦЕНТ разговаривала с вами по поводу аренды стойки."
    },
    {
      "start": 7.42,
      "end": 10.24,
      "speaker": null,
      "text": "Подскажите, пожалуйста, директор ваш..."
    },
    {
      "start": 10.46,
      "end": 13.86,
      "speaker": null,
      "text": "Ага. А почему? Что такое? Что не понравилось?"
    },
    {
      "start": 15.38,
      "end": 20.42,
      "speaker": null,
      "text": "Угу. Поняла вас. А дело было в томности или нет другой?"
    },
    {
      "start": 21.32,
      "end": 26.32,
      "speaker": null,
      "text": "Угу. Поняла вас. Хорошо. Спасибо большое."
    },
    {
      "start": 26.32,
      "end": 31.28,
      "speaker": null,
      "text": "У нас с ними... Ну, тоже вот дам информацию. Ага."
    },
    {
      "start": 33.01,
      "end": 42.25,
      "speaker": null,
      "text": "Столы... Ну, один стол, два стула под ресепшн и три стула для стола вышли там на 70 тысяч на 2 дня."
    },
    {
      "start": 42.89,
      "end": 50.56,
      "speaker": null,
      "text": "А у вас только ресепшн. Это вместе с доставкой, вместе со сборкой и вместе с дизайном."
    },
    {
      "start": 52.26,
      "end": 53.9,
      "speaker": null,
      "text": "Именно мы сами наторались."
    },
    {
      "start": 55.16,
      "end": 61.42,
      "speaker": null,
      "text": "Да, я вас поняла. Хорошо. А полиграфия сувенирная продукция? Что-то из этого потребуется?"
    },
    {
      "start": 63.04,
      "end": 65.24,
      "speaker": null,
      "text": "А сувенирка у вас своя где-то?"
    },
    {
      "start": 65.24,
      "end": 73.26,
      "speaker": null,
      "text": "Да, у нас стояло. Мы можем либо на ваших вещах..."
    },
    {
      "start": 73.26,
      "end": 77.88,
      "speaker": null,
      "text": "Нам данное мероприятие не нужно. Мы сотрудничаем с типографиями."
    },
    {
      "start": 96.21,
      "end": 96.77,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 96.77,
      "end": 97.77,
      "speaker": null,
      "text": "Если тут тиража..."
    },
    {
      "start": 99.69,
      "end": 100.29,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 101.67,
      "end": 103.33,
      "speaker": null,
      "text": "Да, хорошо. Вышлю вам."
    },
    {
      "start": 103.57,
      "end": 104.87,
      "speaker": null,
      "text": "Да, давайте. Спасибо."
    },
    {
      "start": 105.05,
      "end": 105.29,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 106.39,
      "end": 107.97,
      "speaker": null,
      "text": "Спасибо вам за обратную связь."
    },
    {
      "start": 108.11,
      "end": 108.67,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 108.67,
      "end": 108.75,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 109.05,
      "end": 109.19,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
