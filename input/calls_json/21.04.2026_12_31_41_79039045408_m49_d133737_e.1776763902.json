  "segments": [
    {
      "start": 2.67,
      "end": 4.89,
      "speaker": null,
      "text": "Елена, здравствуйте. Компания МОСЭНД."
    },
    {
      "start": 5.92,
      "end": 15.7,
      "speaker": null,
      "text": "Здравствуйте. Елена, подскажите, пожалуйста, у нас планируется мероприятие в Туле 28 апреля, следующий вторник."
    },
    {
      "start": 16.14,
      "end": 26.34,
      "speaker": null,
      "text": "И нам нужен будет пресвол стандартный 3х2 на Джокере с нашим дизайном, естественно, то есть печать, сам Джокер в аренду и монтаж-демонтаж."
    },
    {
      "start": 26.34,
      "end": 29.14,
      "speaker": null,
      "text": "То есть, чтоб нам доставка привезли его, поставили."
    },
    {
      "start": 29.38,
      "end": 29.94,
      "speaker": null,
      "text": "В Туле?"
    },
    {
      "start": 30.77,
      "end": 31.15,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 33.9,
      "end": 39.96,
      "speaker": null,
      "text": "Так, секундочку, у вас это будет стоимость... Подкрыть, как назовут?"
    },
    {
      "start": 40.59,
      "end": 41.39,
      "speaker": null,
      "text": "Анастасия."
    },
    {
      "start": 42.04,
      "end": 43.16,
      "speaker": null,
      "text": "Анастасия примерно."
    },
    {
      "start": 45.63,
      "end": 56.21,
      "speaker": null,
      "text": "Сколько километров до Тулы? Километров? Надо посмотреть, просто тут логистика выйдет золотая. Секунду, сейчас смотрю."
    },
    {
      "start": 56.21,
      "end": 58.79,
      "speaker": null,
      "text": "Подождите, а у вас вы еще не в Туле, да, находитесь?"
    },
    {
      "start": 59.13,
      "end": 59.61,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 60.13,
      "end": 60.61,
      "speaker": null,
      "text": "Москва."
    },
    {
      "start": 61.48,
      "end": 62.84,
      "speaker": null,
      "text": "А, 200 километров."
    },
    {
      "start": 63.42,
      "end": 65.54,
      "speaker": null,
      "text": "У вас доставка выйдет золотая."
    },
    {
      "start": 65.8,
      "end": 66.6,
      "speaker": null,
      "text": "Не-не-не."
    },
    {
      "start": 67.52,
      "end": 70.3,
      "speaker": null,
      "text": "Я поняла, потому что у меня почему-то вышли, что сайт в Туле."
    },
    {
      "start": 70.94,
      "end": 71.96,
      "speaker": null,
      "text": "Нет, нет, Москва."
    },
    {
      "start": 72.36,
      "end": 74.08,
      "speaker": null,
      "text": "Все, все, извиняюсь тогда."
    },
    {
      "start": 74.3,
      "end": 74.54,
      "speaker": null,
      "text": "Конечно."
    },
    {
      "start": 75.06,
      "end": 75.86,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 76.08,
      "end": 76.98,
      "speaker": null,
      "text": "Да-да-да, спасибо."
    },
    {
      "start": 76.98,
      "end": 77.14,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 77.38,
      "end": 77.52,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
