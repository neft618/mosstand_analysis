{
  "file": "22.05.2026_16_21_19_79774393699_m29_d137057_d.1779456080.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 146.2,
  "segments": [
    {
      "start": 0.4,
      "end": 15.6,
      "speaker": null,
      "text": "Алло? Елена, здравствуйте. Это Ксения из компании Мостенд. Вы с запросом вчера пришли. Здравствуйте. От тканевого рулапа. Вот. Подскажите, я в одну минуту уже уточню. Буквально минуту сейчас подойду, уточню минуту. Угу."
    },
    {
      "start": 15.6,
      "end": 20.79,
      "speaker": null,
      "text": "Юра, по обстановленному рулапу, уточню, какой там ваш взрослый отзывчик?"
    },
    {
      "start": 20.97,
      "end": 26.5,
      "speaker": null,
      "text": "А какую они по итогу выбрали?"
    },
    {
      "start": 31.36,
      "end": 35.5,
      "speaker": null,
      "text": "Будут брать. Сейчас документы на согласование Ксения, поэтому вернула."
    },
    {
      "start": 35.94,
      "end": 40.0,
      "speaker": null,
      "text": "Хорошо. Хорошо. А вы выбрили односторонний печат или с двух сторон?"
    },
    {
      "start": 40.68,
      "end": 43.02,
      "speaker": null,
      "text": "Юра, нет информации? Двусторонние, односторонние?"
    },
    {
      "start": 45.08,
      "end": 46.1,
      "speaker": null,
      "text": "Двусторонние подавали."
    },
    {
      "start": 46.1,
      "end": 48.32,
      "speaker": null,
      "text": "Угу. Хорошо, принято."
    },
    {
      "start": 48.56,
      "end": 56.3,
      "speaker": null,
      "text": "Тогда как у вас там с договором? Ну, чтобы я понимала, там не каждый день вам звонила, а на определенную дату можем связаться уже по согласованию."
    },
    {
      "start": 56.3,
      "end": 60.16,
      "speaker": null,
      "text": "А мне сейчас сложно сказать. Юра, есть у тебя понимание, когда отзовутся?"
    },
    {
      "start": 60.32,
      "end": 61.48,
      "speaker": null,
      "text": "Минутку буквально Ксения."
    },
    {
      "start": 67.64,
      "end": 76.44,
      "speaker": null,
      "text": "Да, вот менеджер говорит, что все, они сейчас в уборочном режиме, потому что у меня на выставке все куда-то за границу надо со всем этим хозяйством ехать."
    },
    {
      "start": 105.44,
      "end": 106.84,
      "speaker": null,
      "text": "Угу. Так."
    },
    {
      "start": 135.67,
      "end": 137.07,
      "speaker": null,
      "text": "Хорошо, принято."
    },
    {
      "start": 137.07,
      "end": 138.81,
      "speaker": null,
      "text": "Еще удобнее, еще быстрее."
    },
    {
      "start": 139.23,
      "end": 139.63,
      "speaker": null,
      "text": "Ну да."
    },
    {
      "start": 140.65,
      "end": 141.53,
      "speaker": null,
      "text": "Все, хорошо."
    },
    {
      "start": 141.97,
      "end": 143.44,
      "speaker": null,
      "text": "Тогда да, договорились."
    },
    {
      "start": 144.19,
      "end": 145.01,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}