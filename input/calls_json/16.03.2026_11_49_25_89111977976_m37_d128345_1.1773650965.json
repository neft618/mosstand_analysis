{
  "file": "16.03.2026_11_49_25_89111977976_m37_d128345_1.1773650965.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 351.2,
  "segments": [
    {
      "start": 0.72,
      "end": 1.32,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 2.09,
      "end": 4.31,
      "speaker": null,
      "text": "Коенбек, добрый день, ещё раз Екатерина Мостент."
    },
    {
      "start": 5.27,
      "end": 5.99,
      "speaker": null,
      "text": "Да, добрый день."
    },
    {
      "start": 6.01,
      "end": 10.65,
      "speaker": null,
      "text": "Как я хотел бы уточнить, заявку оставляли у нас в субботу? Что хотели?"
    },
    {
      "start": 12.37,
      "end": 16.01,
      "speaker": null,
      "text": "Что именно за организация? Я что-то просто не понял."
    },
    {
      "start": 16.11,
      "end": 17.97,
      "speaker": null,
      "text": "Мостент – рекламно-выставочное оборудование."
    },
    {
      "start": 18.57,
      "end": 23.89,
      "speaker": null,
      "text": "А, смотрите, мне флажки нужны, напольные флажки."
    },
    {
      "start": 24.86,
      "end": 29.8,
      "speaker": null,
      "text": "Флаги напольные. Так, хорошо. Знаете размер, какая форма, что вам нужно?"
    },
    {
      "start": 30.44,
      "end": 35.42,
      "speaker": null,
      "text": "Нет, нет. Нужно составить две штуки, но нужно составить это всё."
    },
    {
      "start": 37.82,
      "end": 39.1,
      "speaker": null,
      "text": "Составить что именно? Размер?"
    },
    {
      "start": 39.5,
      "end": 41.82,
      "speaker": null,
      "text": "Ну, макет, да, размер."
    },
    {
      "start": 42.54,
      "end": 44.48,
      "speaker": null,
      "text": "Да, макет-то мы сделаем, это не проблема."
    },
    {
      "start": 44.64,
      "end": 49.46,
      "speaker": null,
      "text": "Мне надо понимать изначально, какие флаги вам нужны, то есть какой высоты и какой ширины."
    },
    {
      "start": 49.76,
      "end": 55.5,
      "speaker": null,
      "text": "Но если напольные, они в основном в ширину 60-70 см, бывают 90 см, конечно, это прям огромные."
    },
    {
      "start": 55.5,
      "end": 60.88,
      "speaker": null,
      "text": "Вам высоту сам, ну вот флагшток и, например, флаг, какая максимальная высота нужна?"
    },
    {
      "start": 61.06,
      "end": 62.32,
      "speaker": null,
      "text": "Два-три метра."
    },
    {
      "start": 62.82,
      "end": 63.26,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 63.86,
      "end": 64.3,
      "speaker": null,
      "text": "Метр?"
    },
    {
      "start": 64.3,
      "end": 65.4,
      "speaker": null,
      "text": "Метр либо два, да."
    },
    {
      "start": 65.94,
      "end": 66.56,
      "speaker": null,
      "text": "Два-два."
    },
    {
      "start": 66.58,
      "end": 71.62,
      "speaker": null,
      "text": "Ну, если мы говорим с вами про уличные, да, вот эти напольные, то два метра в принципе нормально."
    },
    {
      "start": 72.04,
      "end": 72.78,
      "speaker": null,
      "text": "Два метра."
    },
    {
      "start": 73.02,
      "end": 73.56,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 73.9,
      "end": 76.38,
      "speaker": null,
      "text": "Форма, ну я так понимаю, наверное, самая обычная, да?"
    },
    {
      "start": 76.8,
      "end": 77.4,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 77.42,
      "end": 79.02,
      "speaker": null,
      "text": "Такой круглённый сверху и прямой."
    },
    {
      "start": 79.1,
      "end": 79.98,
      "speaker": null,
      "text": "Да-да-да-да."
    },
    {
      "start": 81.96,
      "end": 83.08,
      "speaker": null,
      "text": "Односторонний, двусторонний?"
    },
    {
      "start": 84.32,
      "end": 86.28,
      "speaker": null,
      "text": "Он, скорее всего, двухсторонний будет."
    },
    {
      "start": 87.96,
      "end": 88.24,
      "speaker": null,
      "text": "Двусторонний."
    },
    {
      "start": 88.78,
      "end": 90.92,
      "speaker": null,
      "text": "То есть печать из двух сторон, правильно, разные там картины?"
    },
    {
      "start": 91.26,
      "end": 91.3,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 92.4,
      "end": 92.58,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 93.67,
      "end": 94.39,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 94.85,
      "end": 97.15,
      "speaker": null,
      "text": "Значит, макета у вас нет, надо будет сделать."
    },
    {
      "start": 97.53,
      "end": 99.17,
      "speaker": null,
      "text": "А подскажите даты когда нужны?"
    },
    {
      "start": 101.04,
      "end": 103.1,
      "speaker": null,
      "text": "За все он без разницы."
    },
    {
      "start": 103.76,
      "end": 106.18,
      "speaker": null,
      "text": "Ну, то есть ограничений и сроков каких-то срочностей?"
    },
    {
      "start": 107.1,
      "end": 108.24,
      "speaker": null,
      "text": "Нет-нет-нет."
    },
    {
      "start": 109.01,
      "end": 110.83,
      "speaker": null,
      "text": "Так, всё, сроков нет."
    },
    {
      "start": 111.83,
      "end": 114.05,
      "speaker": null,
      "text": "Так, подскажите по поводу основания."
    },
    {
      "start": 114.13,
      "end": 115.95,
      "speaker": null,
      "text": "Вы где планируете вообще размещать флаг?"
    },
    {
      "start": 116.41,
      "end": 117.61,
      "speaker": null,
      "text": "На улице он будет стоять?"
    },
    {
      "start": 117.67,
      "end": 118.41,
      "speaker": null,
      "text": "На улице, да."
    },
    {
      "start": 118.57,
      "end": 122.21,
      "speaker": null,
      "text": "Он будет на улице стоять и единственное, я бы хотел уточнить,"
    },
    {
      "start": 122.71,
      "end": 125.91,
      "speaker": null,
      "text": "он будет ли в этом с плиткой?"
    },
    {
      "start": 126.85,
      "end": 127.73,
      "speaker": null,
      "text": "С плиткой?"
    },
    {
      "start": 128.27,
      "end": 128.77,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 129.49,
      "end": 131.85,
      "speaker": null,
      "text": "Ну вот, я как раз хотела её почему спрашивать, где"
    },
    {
      "start": 131.85,
      "end": 132.43,
      "speaker": null,
      "text": "он будет стоять."
    },
    {
      "start": 132.45,
      "end": 135.07,
      "speaker": null,
      "text": "У нас несколько видов есть оснований для улицы."
    },
    {
      "start": 135.29,
      "end": 138.05,
      "speaker": null,
      "text": "Есть такое пластиковое наливное, не знаю, может вы видели"
    },
    {
      "start": 138.05,
      "end": 139.37,
      "speaker": null,
      "text": "когда-нибудь такое белое."
    },
    {
      "start": 139.81,
      "end": 141.49,
      "speaker": null,
      "text": "Белое, туда водичка выливается."
    },
    {
      "start": 141.85,
      "end": 141.99,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 141.99,
      "end": 144.41,
      "speaker": null,
      "text": "Ну, есть вот основание такое квадратное металлическое,"
    },
    {
      "start": 144.45,
      "end": 146.19,
      "speaker": null,
      "text": "на него плита бетонная кладётся."
    },
    {
      "start": 146.29,
      "end": 146.69,
      "speaker": null,
      "text": "Вот такое, да?"
    },
    {
      "start": 146.69,
      "end": 149.29,
      "speaker": null,
      "text": "Он тоже у нас в ветре, но он не держится скорее всего"
    },
    {
      "start": 149.29,
      "end": 149.81,
      "speaker": null,
      "text": "на плитке."
    },
    {
      "start": 149.87,
      "end": 150.75,
      "speaker": null,
      "text": "На плитке нет у вас?"
    },
    {
      "start": 151.31,
      "end": 153.93,
      "speaker": null,
      "text": "Ну вот, я же говорю, у вас плита бетонная."
    },
    {
      "start": 154.25,
      "end": 155.03,
      "speaker": null,
      "text": "Бетонная плита жива?"
    },
    {
      "start": 155.03,
      "end": 155.79,
      "speaker": null,
      "text": "Да-да-да-да."
    },
    {
      "start": 156.13,
      "end": 158.67,
      "speaker": null,
      "text": "Ну вот, там просто для такого размера в принципе одной"
    },
    {
      "start": 158.67,
      "end": 159.61,
      "speaker": null,
      "text": "плиты будет достаточно."
    },
    {
      "start": 159.99,
      "end": 164.21,
      "speaker": null,
      "text": "Есть ещё основание с такой, оно крестом и там 4 плиты"
    },
    {
      "start": 164.21,
      "end": 164.81,
      "speaker": null,
      "text": "кладётся."
    },
    {
      "start": 165.45,
      "end": 168.05,
      "speaker": null,
      "text": "Но это прям мне кажется слишком много будет для"
    },
    {
      "start": 168.05,
      "end": 169.61,
      "speaker": null,
      "text": "такого размера флага."
    },
    {
      "start": 169.73,
      "end": 171.01,
      "speaker": null,
      "text": "То есть одной плиты будет достаточно."
    },
    {
      "start": 171.47,
      "end": 172.53,
      "speaker": null,
      "text": "Ну смотрите сами конечно."
    },
    {
      "start": 173.33,
      "end": 175.19,
      "speaker": null,
      "text": "А вы в Москве или в каком-нибудь другом городе?"
    },
    {
      "start": 175.19,
      "end": 176.13,
      "speaker": null,
      "text": "Да, в Москве."
    },
    {
      "start": 176.63,
      "end": 177.11,
      "speaker": null,
      "text": "Москва."
    },
    {
      "start": 177.49,
      "end": 177.79,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 178.53,
      "end": 180.27,
      "speaker": null,
      "text": "А по сумме сколько выйдет?"
    },
    {
      "start": 180.65,
      "end": 183.11,
      "speaker": null,
      "text": "Вот я это у вас узнаю всё, чтобы посчитать."
    },
    {
      "start": 183.25,
      "end": 185.09,
      "speaker": null,
      "text": "Есть какой-то бюджетный флаг, сколько хотели бы"
    },
    {
      "start": 185.09,
      "end": 186.69,
      "speaker": null,
      "text": "чтобы вышло в итоге?"
    },
    {
      "start": 186.75,
      "end": 190.09,
      "speaker": null,
      "text": "Нет, я просто даже не в курсе, что сколько стоит."
    },
    {
      "start": 190.99,
      "end": 192.19,
      "speaker": null,
      "text": "Угу, я поняла."
    },
    {
      "start": 192.93,
      "end": 195.13,
      "speaker": null,
      "text": "Просто если был бы бюджет, я вам тогда могла бы сказать"
    },
    {
      "start": 195.13,
      "end": 197.09,
      "speaker": null,
      "text": "ну смотрите, двусторонний он в любом случае дороже,"
    },
    {
      "start": 197.19,
      "end": 199.45,
      "speaker": null,
      "text": "чем односторонний, потому что там шивная ткань,"
    },
    {
      "start": 199.61,
      "end": 200.97,
      "speaker": null,
      "text": "то есть два куска ткани шиваются."
    },
    {
      "start": 200.97,
      "end": 205.59,
      "speaker": null,
      "text": "Поэтому, то есть ну как бы в таком размере ну примерно тысяч четыре"
    },
    {
      "start": 205.59,
      "end": 208.95,
      "speaker": null,
      "text": "три будет одна штука стоить около трёх."
    },
    {
      "start": 209.13,
      "end": 210.73,
      "speaker": null,
      "text": "Три-четыре тысячи вот так там флаг."
    },
    {
      "start": 211.01,
      "end": 214.27,
      "speaker": null,
      "text": "Ну в общем комплект где-то около 6-8 тысяч выйдет."
    },
    {
      "start": 214.39,
      "end": 217.81,
      "speaker": null,
      "text": "То есть это флаг, флагшток на что крепится флаг"
    },
    {
      "start": 217.81,
      "end": 218.93,
      "speaker": null,
      "text": "и основание святой."
    },
    {
      "start": 220.14,
      "end": 220.68,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 221.24,
      "end": 221.88,
      "speaker": null,
      "text": "Плюс-минус."
    },
    {
      "start": 222.3,
      "end": 223.72,
      "speaker": null,
      "text": "По строимости устроит вас?"
    },
    {
      "start": 224.37,
      "end": 225.93,
      "speaker": null,
      "text": "А сколько это будет стоить?"
    },
    {
      "start": 226.03,
      "end": 226.61,
      "speaker": null,
      "text": "Я не расслышал."
    },
    {
      "start": 226.83,
      "end": 228.49,
      "speaker": null,
      "text": "Ну я говорю примерно 6-8."
    },
    {
      "start": 228.87,
      "end": 229.49,
      "speaker": null,
      "text": "Вот так это комплект."
    },
    {
      "start": 229.51,
      "end": 230.09,
      "speaker": null,
      "text": "6-8."
    },
    {
      "start": 230.25,
      "end": 231.27,
      "speaker": null,
      "text": "Один флаг будет?"
    },
    {
      "start": 231.71,
      "end": 232.75,
      "speaker": null,
      "text": "Да, одна штука комплект."
    },
    {
      "start": 232.89,
      "end": 234.63,
      "speaker": null,
      "text": "Да, это флаг, флагшток и основание."
    },
    {
      "start": 236.0,
      "end": 236.34,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 237.22,
      "end": 237.38,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 237.74,
      "end": 239.58,
      "speaker": null,
      "text": "Ну я сейчас более точно конечно посчитаю."
    },
    {
      "start": 239.66,
      "end": 241.68,
      "speaker": null,
      "text": "Может чуть меньше получится, не могу вам точно сказать."
    },
    {
      "start": 241.76,
      "end": 243.44,
      "speaker": null,
      "text": "Да, если вы сможете."
    },
    {
      "start": 244.14,
      "end": 246.98,
      "speaker": null,
      "text": "Да, если сможете там подешевле вообще скажем так."
    },
    {
      "start": 247.22,
      "end": 248.26,
      "speaker": null,
      "text": "Давайте, предстою."
    },
    {
      "start": 248.4,
      "end": 251.46,
      "speaker": null,
      "text": "Я где-то рассчитываю на 8-10, это прям максимум, я думаю."
    },
    {
      "start": 251.94,
      "end": 253.2,
      "speaker": null,
      "text": "Это за оба флага?"
    },
    {
      "start": 253.68,
      "end": 253.9,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 255.04,
      "end": 256.66,
      "speaker": null,
      "text": "И ещё и разработка макетов, да?"
    },
    {
      "start": 256.88,
      "end": 257.6,
      "speaker": null,
      "text": "А макеты разные?"
    },
    {
      "start": 257.6,
      "end": 258.14,
      "speaker": null,
      "text": "Макет."
    },
    {
      "start": 258.14,
      "end": 262.34,
      "speaker": null,
      "text": "Макет я сам могу разработать, то есть можно без разработки"
    },
    {
      "start": 262.34,
      "end": 263.18,
      "speaker": null,
      "text": "макеты сделать."
    },
    {
      "start": 263.18,
      "end": 263.86,
      "speaker": null,
      "text": "Всё, поняла вас."
    },
    {
      "start": 263.86,
      "end": 264.52,
      "speaker": null,
      "text": "Всё, поняла вас."
    },
    {
      "start": 264.78,
      "end": 265.1,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 265.42,
      "end": 268.44,
      "speaker": null,
      "text": "Так, значит две штуки флагов 2 метра – это высота общая,"
    },
    {
      "start": 268.56,
      "end": 271.74,
      "speaker": null,
      "text": "то есть там флаг 1,8 где-то полтора может будет."
    },
    {
      "start": 272.58,
      "end": 275.3,
      "speaker": null,
      "text": "Двусторонний блок-аут я посчитаю вам, потому что это такой"
    },
    {
      "start": 275.3,
      "end": 278.42,
      "speaker": null,
      "text": "самый стандартный материал, который не будет просвечиваться,"
    },
    {
      "start": 278.48,
      "end": 280.54,
      "speaker": null,
      "text": "на котором хорошо печать будет выглядеть."
    },
    {
      "start": 280.54,
      "end": 282.92,
      "speaker": null,
      "text": "Так, макеты сделайте, если что."
    },
    {
      "start": 282.98,
      "end": 283.64,
      "speaker": null,
      "text": "Сроков нет."
    },
    {
      "start": 283.82,
      "end": 284.78,
      "speaker": null,
      "text": "Москва на улицу."
    },
    {
      "start": 285.78,
      "end": 287.22,
      "speaker": null,
      "text": "Всё, значит я уточнила."
    },
    {
      "start": 287.56,
      "end": 289.2,
      "speaker": null,
      "text": "Вам тогда, ну расчёт дела…"
    },
    {
      "start": 289.2,
      "end": 291.26,
      "speaker": null,
      "text": "Ну сроки если на самом деле…"
    },
    {
      "start": 291.26,
      "end": 294.18,
      "speaker": null,
      "text": "Да, сроки если чем быстрее тем лучше на самом деле."
    },
    {
      "start": 294.36,
      "end": 295.58,
      "speaker": null,
      "text": "Это понятно, это у всех так."
    },
    {
      "start": 295.94,
      "end": 296.58,
      "speaker": null,
      "text": "Я понимаю."
    },
    {
      "start": 296.94,
      "end": 299.2,
      "speaker": null,
      "text": "Я просто уточняю, может быть мало ли у вас там дата"
    },
    {
      "start": 299.2,
      "end": 301.24,
      "speaker": null,
      "text": "какая-то мероприятие планируется, может быть,"
    },
    {
      "start": 301.28,
      "end": 303.12,
      "speaker": null,
      "text": "ну в общем какая-то дата конкретная есть."
    },
    {
      "start": 303.4,
      "end": 304.1,
      "speaker": null,
      "text": "Это понятно."
    },
    {
      "start": 304.1,
      "end": 307.3,
      "speaker": null,
      "text": "Ну по сроку, ну где-то до 5 рабочих дней производства"
    },
    {
      "start": 307.68,
      "end": 310.38,
      "speaker": null,
      "text": "с момента голосования макетов и внесения платы."
    },
    {
      "start": 310.58,
      "end": 314.04,
      "speaker": null,
      "text": "То есть может даже быстрее получится, там уже по загрузке надо будет смотреть."
    },
    {
      "start": 314.1,
      "end": 314.94,
      "speaker": null,
      "text": "Супер, супер."
    },
    {
      "start": 315.26,
      "end": 317.86,
      "speaker": null,
      "text": "Так, помимо флагов вам может быть что-то ещё понадобится?"
    },
    {
      "start": 318.54,
      "end": 321.1,
      "speaker": null,
      "text": "Полиграфия, стандартная продукция, много чего."
    },
    {
      "start": 322.2,
      "end": 325.22,
      "speaker": null,
      "text": "Стенды всевозможные, мерч, может быть что-то ещё."
    },
    {
      "start": 326.84,
      "end": 331.28,
      "speaker": null,
      "text": "Как, ну хорошо, если вдруг понадобится, знаете, мы это тоже сделаем."
    },
    {
      "start": 332.22,
      "end": 334.92,
      "speaker": null,
      "text": "Хорошо, вопросы ко мне какие-то есть конкретные или всё понятно?"
    },
    {
      "start": 335.14,
      "end": 335.82,
      "speaker": null,
      "text": "Не-не-не, спасибо."
    },
    {
      "start": 336.1,
      "end": 336.48,
      "speaker": null,
      "text": "Всё понятно."
    },
    {
      "start": 336.94,
      "end": 340.36,
      "speaker": null,
      "text": "Значит, расчёт сделаю и в ближайшее время, ну я думаю в рамках получаса сейчас"
    },
    {
      "start": 340.36,
      "end": 341.86,
      "speaker": null,
      "text": "с вами отбежусь на этот номер."
    },
    {
      "start": 342.06,
      "end": 342.38,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 342.66,
      "end": 345.26,
      "speaker": null,
      "text": "Да, на Телеграм, да, на Телеграм."
    },
    {
      "start": 345.8,
      "end": 347.38,
      "speaker": null,
      "text": "Всё, окей, окей, договорились."
    },
    {
      "start": 347.64,
      "end": 351.22,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}