{
  "file": "08.04.2026_11_18_07_79282345805_m29_d131163_e.1775636288.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 83.3,
  "segments": [
    {
      "start": 2.51,
      "end": 7.75,
      "speaker": null,
      "text": "Леонид, здравствуйте. Это Ксения из компании Мастент. Мы с вами на этой неделе общались по поводу роллапа."
    },
    {
      "start": 8.39,
      "end": 12.05,
      "speaker": null,
      "text": "Да, я жду этот... А, ещё ждёшь в макете?"
    },
    {
      "start": 12.37,
      "end": 14.77,
      "speaker": null,
      "text": "Макет, да, жду этот, что-то человек заболел."
    },
    {
      "start": 15.51,
      "end": 16.21,
      "speaker": null,
      "text": "А, ага."
    },
    {
      "start": 17.31,
      "end": 18.69,
      "speaker": null,
      "text": "Кто мне макет должен сделать?"
    },
    {
      "start": 19.53,
      "end": 22.87,
      "speaker": null,
      "text": "Так, хорошо. А поскольку мы с вами ещё успеваем, всё в порядке?"
    },
    {
      "start": 23.05,
      "end": 23.77,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 24.37,
      "end": 24.79,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 24.95,
      "end": 27.75,
      "speaker": null,
      "text": "Мне надо к 22-му числу там."
    },
    {
      "start": 29.22,
      "end": 34.02,
      "speaker": null,
      "text": "А, ну если в 22-м, то с вами у нас ещё есть время, поэтому можно туда не переживать."
    },
    {
      "start": 34.04,
      "end": 36.32,
      "speaker": null,
      "text": "Я вам, да, перезвоню вам, да, спасибо."
    },
    {
      "start": 37.06,
      "end": 41.94,
      "speaker": null,
      "text": "Всё, хорошо, а тогда это... Ожидая до конца недели, да, макеты или когда?"
    },
    {
      "start": 42.4,
      "end": 44.24,
      "speaker": null,
      "text": "Да я говорю, он болеет, у него телефон."
    },
    {
      "start": 44.42,
      "end": 47.3,
      "speaker": null,
      "text": "Я вот сегодня хотел вам вопросы задать, и у него отключено."
    },
    {
      "start": 47.4,
      "end": 48.46,
      "speaker": null,
      "text": "Я вот сам не знаю как."
    },
    {
      "start": 49.31,
      "end": 51.09,
      "speaker": null,
      "text": "То ли мне его ждать, то ли мне оно."
    },
    {
      "start": 52.57,
      "end": 52.73,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 52.73,
      "end": 55.53,
      "speaker": null,
      "text": "Не сдать, короче, самому что-то делать."
    },
    {
      "start": 56.58,
      "end": 59.86,
      "speaker": null,
      "text": "Ну, давайте-ка досмотрите. У нас пока по времени не есть."
    },
    {
      "start": 60.02,
      "end": 63.46,
      "speaker": null,
      "text": "Если что там до вторника буду ждать туда ответы."
    },
    {
      "start": 63.64,
      "end": 67.14,
      "speaker": null,
      "text": "Если не получится, то я могу предложить услуги нашего дизайнера."
    },
    {
      "start": 67.28,
      "end": 69.08,
      "speaker": null,
      "text": "Да, да, давайте так и сделаем."
    },
    {
      "start": 69.2,
      "end": 73.06,
      "speaker": null,
      "text": "До вторника я вам ничего не пишу, там мы берёте и будем решать."
    },
    {
      "start": 73.54,
      "end": 75.06,
      "speaker": null,
      "text": "Да, хорошо, отлично всё."
    },
    {
      "start": 75.2,
      "end": 76.84,
      "speaker": null,
      "text": "Спасибо большое за обратную связь."
    },
    {
      "start": 76.92,
      "end": 77.78,
      "speaker": null,
      "text": "Хорошего вам дня."
    },
    {
      "start": 78.4,
      "end": 79.62,
      "speaker": null,
      "text": "Да, вам тоже до свидания."
    },
    {
      "start": 79.62,
      "end": 81.12,
      "speaker": null,
      "text": "Спасибо, до свидания."
    }
  ]
}