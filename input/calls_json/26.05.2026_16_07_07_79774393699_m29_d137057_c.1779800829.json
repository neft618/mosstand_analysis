  "segments": [
    {
      "start": 0.78,
      "end": 1.38,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 1.98,
      "end": 8.84,
      "speaker": null,
      "text": "Елена, здравствуйте, это Ксени из Мусленда. Хочу уточнить по актуальности всё ли в порядке по тканевому рулапу?"
    },
    {
      "start": 10.02,
      "end": 16.68,
      "speaker": null,
      "text": "Да, пока нет у нас информации по рулапу. Сейчас одну минуту не отключать всё, я уточню."
    },
    {
      "start": 17.12,
      "end": 18.12,
      "speaker": null,
      "text": "Да-да, без проблем."
    },
    {
      "start": 68.42,
      "end": 68.94,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 69.54,
      "end": 70.6,
      "speaker": null,
      "text": "Да-да-да, я здесь."
    },
    {
      "start": 70.6,
      "end": 76.1,
      "speaker": null,
      "text": "Да-да, до среды сказали дадут информацию. Сейчас всё на согласование. Завтра среда."
    },
    {
      "start": 76.14,
      "end": 79.52,
      "speaker": null,
      "text": "А, ну я помню, да, вы там уже договор согласовывали."
    },
    {
      "start": 80.06,
      "end": 82.12,
      "speaker": null,
      "text": "Да-да-да, именно это сейчас происходит."
    },
    {
      "start": 82.98,
      "end": 85.7,
      "speaker": null,
      "text": "Хорошо, получается в среду у вас будет обратная сеть?"
    },
    {
      "start": 85.92,
      "end": 86.94,
      "speaker": null,
      "text": "В целом..."
    },
    {
      "start": 86.94,
      "end": 89.14,
      "speaker": null,
      "text": "Ну, я вам тогда уже запрос беру."
    },
    {
      "start": 89.52,
      "end": 93.9,
      "speaker": null,
      "text": "Да, потому что мне уже будет, да, запрос уже конкретно на тираж."
    },
    {
      "start": 94.51,
      "end": 96.53,
      "speaker": null,
      "text": "Всё, хорошо, тогда жду."
    },
    {
      "start": 97.19,
      "end": 98.05,
      "speaker": null,
      "text": "Да, спасибо."
    },
    {
      "start": 98.35,
      "end": 99.63,
      "speaker": null,
      "text": "Да, хорошего вечера. До свидания."
    }
  ]
}