{
  "file": "24.03.2026_11_45_42_74951183122_m33_d132399_3.1774341942.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 93.0,
  "segments": [
    {
      "start": 0.0,
      "end": 6.78,
      "speaker": null,
      "text": "Здравствуйте. Спасибо за ваш звонок. Пожалуйста, наберите добавочный номер сотрудника или дождитесь ответа."
    },
    {
      "start": 27.0,
      "end": 28.1,
      "speaker": null,
      "text": "Фирма здоровья, добрый день."
    },
    {
      "start": 28.99,
      "end": 38.6,
      "speaker": null,
      "text": "Добрый день. А подскажите, пожалуйста, звонили с этого номера и вам компания МОС-стенд для утром сегодня?"
    },
    {
      "start": 40.38,
      "end": 43.08,
      "speaker": null,
      "text": "Интересно, интересно. Так, ещё раз фирма."
    },
    {
      "start": 43.26,
      "end": 47.08,
      "speaker": null,
      "text": "МОС-стенд. Выставки, вот всё это для выставки."
    },
    {
      "start": 47.66,
      "end": 50.08,
      "speaker": null,
      "text": "А, всё, я поняла. Соединяюсь с маркетологом."
    },
    {
      "start": 50.08,
      "end": 64.07,
      "speaker": null,
      "text": "Ага, спасибо. Алло, добрый день."
    },
    {
      "start": 64.83,
      "end": 68.13,
      "speaker": null,
      "text": "Здравствуйте. Иван из компании МОС-стенд. Звонили сегодня утром?"
    },
    {
      "start": 69.31,
      "end": 73.91,
      "speaker": null,
      "text": "Да, я звонила, но я уже по почте с вашей сотрудницей связалась."
    },
    {
      "start": 74.13,
      "end": 75.87,
      "speaker": null,
      "text": "А, всё, отлично."
    },
    {
      "start": 76.05,
      "end": 77.59,
      "speaker": null,
      "text": "Мы уже с ним на контакте."
    },
    {
      "start": 77.87,
      "end": 80.73,
      "speaker": null,
      "text": "Отлично, всё, договорились. А с какой вы компанией не посажите?"
    },
    {
      "start": 82.07,
      "end": 84.81,
      "speaker": null,
      "text": "Здоровья. Фирма, мы у вас заказывали Roll Up."
    },
    {
      "start": 85.25,
      "end": 88.69,
      "speaker": null,
      "text": "А, всё, понял. Ну хорошо, раз связали, значит продолжай с ней."
    },
    {
      "start": 88.69,
      "end": 90.51,
      "speaker": null,
      "text": "Всё. Да, спасибо большое."
    },
    {
      "start": 90.93,
      "end": 91.35,
      "speaker": null,
      "text": "Угу."
    }
  ]
}