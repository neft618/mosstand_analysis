{
  "file": "26.03.2026_15_15_34_79154842492_m33_d129401_b.1774527335.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 67.7,
  "segments": [
    {
      "start": 0.0,
      "end": 2.92,
      "speaker": null,
      "text": "Продолжаем дозваниваться. Оставайтесь на линии."
    },
    {
      "start": 15.67,
      "end": 17.15,
      "speaker": null,
      "text": "Алло? Алло, да."
    },
    {
      "start": 17.41,
      "end": 19.83,
      "speaker": null,
      "text": "А, Евгения, здравствуйте. Это Иван из Макета."
    },
    {
      "start": 20.17,
      "end": 21.05,
      "speaker": null,
      "text": "Добрый день. Да, Иван."
    },
    {
      "start": 21.57,
      "end": 25.17,
      "speaker": null,
      "text": "Хотела вас спросить, как у вас дела с макетами? Всё ли там хорошо?"
    },
    {
      "start": 25.31,
      "end": 31.25,
      "speaker": null,
      "text": "Ну, мы ушли согласовывать, сейчас пока ещё сделали несколько, поэтому пока согласовываем."
    },
    {
      "start": 31.63,
      "end": 35.63,
      "speaker": null,
      "text": "Ага. А когда там дедлайн может по согласованию, чтоб я тоже понимал?"
    },
    {
      "start": 37.9,
      "end": 39.96,
      "speaker": null,
      "text": "Здесь какие-то..."
    },
    {
      "start": 41.14,
      "end": 42.48,
      "speaker": null,
      "text": "На следующей неделе..."
    },
    {
      "start": 44.95,
      "end": 46.09,
      "speaker": null,
      "text": "Ой, пропадаете."
    },
    {
      "start": 48.66,
      "end": 50.18,
      "speaker": null,
      "text": "Я думаю, вы должны согласовать."
    },
    {
      "start": 50.94,
      "end": 52.22,
      "speaker": null,
      "text": "На следующей неделе, да, должны?"
    },
    {
      "start": 52.9,
      "end": 53.54,
      "speaker": null,
      "text": "Пропадали."
    }
  ]
}