      "end": 527.73,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 527.89,
      "end": 531.51,
      "speaker": null,
      "text": "Стол получается высота метр 70, метр 8..."
    },
    {
      "start": 531.51,
      "end": 535.35,
      "speaker": null,
      "text": "Вернее, 70-80, 800 в смысле."
    },
    {
      "start": 536.03,
      "end": 536.67,
      "speaker": null,
      "text": "Да, я поняла."
    },
    {
      "start": 537.91,
      "end": 538.23,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 538.41,
      "end": 540.19,
      "speaker": null,
      "text": "И ширина стола 3 метра."
    },
    {
      "start": 542.16,
      "end": 542.54,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 543.35,
      "end": 545.37,
      "speaker": null,
      "text": "Да, смотрите, давайте тогда попробуем."
    },
    {
      "start": 545.37,
      "end": 549.23,
      "speaker": null,
      "text": "А обязательно, если это высота стола должна быть 70 сантиметров?"
    },
    {
      "start": 549.47,
      "end": 550.17,
      "speaker": null,
      "text": "Потому что я сейчас..."
    },
    {
      "start": 550.17,
      "end": 550.93,
      "speaker": null,
      "text": "Нет, нет жадей."
    },
    {
      "start": 552.07,
      "end": 552.61,
      "speaker": null,
      "text": "Не обязательно."
    },
    {
      "start": 552.67,
      "end": 555.05,
      "speaker": null,
      "text": "То есть, если она там метр, высоту будет, это не страшно?"
    },
    {
      "start": 555.64,
      "end": 557.54,
      "speaker": null,
      "text": "Ну вообще даже очень хорошо."
    },
    {
      "start": 558.29,
      "end": 558.75,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 559.15,
      "end": 560.15,
      "speaker": null,
      "text": "Все, хорошо, поняла."
    },
    {
      "start": 560.21,
      "end": 562.15,
      "speaker": null,
      "text": "А какому сроку это все необходимо в целом?"
    },
    {
      "start": 562.77,
      "end": 566.68,
      "speaker": null,
      "text": "Ну, вообще желательно в течение 3-4 дней."
    },
    {
      "start": 567.84,
      "end": 568.22,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 568.22,
      "end": 568.36,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 568.96,
      "end": 569.4,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 569.84,
      "end": 572.82,
      "speaker": null,
      "text": "Смотрите, да, сейчас я тогда уточнила по поводу стойки."
    },
    {
      "start": 573.74,
      "end": 575.22,
      "speaker": null,
      "text": "Если стойка будет..."
    },
    {
      "start": 576.48,
      "end": 578.54,
      "speaker": null,
      "text": "Сейчас покажу, какой конструкции."
    },
    {
      "start": 579.7,
      "end": 581.24,
      "speaker": null,
      "text": "Прямо пока мы общаемся."
    },
    {
      "start": 581.72,
      "end": 589.45,
      "speaker": null,
      "text": "Вот такой вот."
    },
    {
      "start": 591.36,
      "end": 593.44,
      "speaker": null,
      "text": "Это зонтичного типа конструкция."
    },
    {
      "start": 595.75,
      "end": 596.55,
      "speaker": null,
      "text": "Там также ткань."
    },
    {
      "start": 596.61,
      "end": 597.71,
      "speaker": null,
      "text": "А она легко собирается?"
    },
    {
      "start": 598.37,
      "end": 599.77,
      "speaker": null,
      "text": "Да, она легко собирается."
    },
    {
      "start": 599.89,
      "end": 602.17,
      "speaker": null,
      "text": "Там просто как зонтиковая конструкция открываете."
    },
    {
      "start": 602.61,
      "end": 605.61,
      "speaker": null,
      "text": "А перекладины ставите и крепите уже ткань."
    },
    {
      "start": 605.77,
      "end": 607.85,
      "speaker": null,
      "text": "Полки вниз погрузите еще."
    },
    {
      "start": 608.49,
      "end": 609.89,
      "speaker": null,
      "text": "Ну и столешницу наверху."
    },
    {
      "start": 611.4,
      "end": 611.72,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 612.54,
      "end": 613.56,
      "speaker": null,
      "text": "Ну да, давайте с тобой."
    },
    {
      "start": 614.3,
      "end": 616.12,
      "speaker": null,
      "text": "Все, хорошо, тогда сейчас рассчитаю."
    },
    {
      "start": 616.22,
      "end": 616.94,
      "speaker": null,
      "text": "Вам как удобнее?"
    },
    {
      "start": 617.06,
      "end": 618.84,
      "speaker": null,
      "text": "Созвониться или чтобы я написала вам?"
    },
    {
      "start": 619.55,
      "end": 621.33,
      "speaker": null,
      "text": "Ну вы можете написать, а я потом уберу вам."
    },
    {
      "start": 622.01,
      "end": 623.59,
      "speaker": null,
      "text": "А, ну все, хорошо, договорились."
    },
    {
      "start": 623.69,
      "end": 625.45,
      "speaker": null,
      "text": "Тогда сейчас все быстро уточним за носком."
    },
    {
      "start": 625.91,
      "end": 626.21,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 626.69,
      "end": 626.91,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 626.91,
      "end": 627.07,
      "speaker": null,
      "text": "Продолжение следует..."
    }
  ]
