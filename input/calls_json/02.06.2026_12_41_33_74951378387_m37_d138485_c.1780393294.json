{
  "file": "02.06.2026_12_41_33_74951378387_m37_d138485_c.1780393294.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 199.4,
  "segments": [
    {
      "start": 2.19,
      "end": 5.61,
      "speaker": null,
      "text": "Добрый день. Это Екатерина, компания Mostent. Как могу к вам обращаться?"
    },
    {
      "start": 5.85,
      "end": 14.88,
      "speaker": null,
      "text": "Добрый день. Меня София зовут. У меня был вопрос по поводу печати. Мне нужно на печати 25 лапов."
    },
    {
      "start": 16.38,
      "end": 17.94,
      "speaker": null,
      "text": "На какие лапы вам нужны?"
    },
    {
      "start": 18.16,
      "end": 23.96,
      "speaker": null,
      "text": "Да, сейчас скажу. Смотрите, мне нужно 15 штук размера 100х200."
    },
    {
      "start": 25.45,
      "end": 27.53,
      "speaker": null,
      "text": "А модель или без разницы?"
    },
    {
      "start": 27.95,
      "end": 29.07,
      "speaker": null,
      "text": "А где есть варианты?"
    },
    {
      "start": 30.19,
      "end": 41.11,
      "speaker": null,
      "text": "Есть модель классическая, которая с двумя ножками внизу выдвижными, а есть каплевидная. Она в основании формы капли без ножек, то есть за счёт основания такого широкого условия."
    },
    {
      "start": 41.49,
      "end": 43.03,
      "speaker": null,
      "text": "Да, я поняла, наверное, обычные с ножками."
    },
    {
      "start": 44.06,
      "end": 44.78,
      "speaker": null,
      "text": "Классические, ага."
    },
    {
      "start": 46.26,
      "end": 46.44,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 47.06,
      "end": 48.76,
      "speaker": null,
      "text": "Две вот, как я сказала?"
    },
    {
      "start": 49.4,
      "end": 49.6,
      "speaker": null,
      "text": "15."
    },
    {
      "start": 50.24,
      "end": 51.44,
      "speaker": null,
      "text": "15 в таком размере."
    },
    {
      "start": 52.5,
      "end": 53.64,
      "speaker": null,
      "text": "8х200 на 80."
    },
    {
      "start": 55.75,
      "end": 57.19,
      "speaker": null,
      "text": "80 на 200, ага."
    },
    {
      "start": 57.19,
      "end": 57.61,
      "speaker": null,
      "text": "Ну, да."
    },
    {
      "start": 57.99,
      "end": 60.35,
      "speaker": null,
      "text": "И две стуки 150 на 200."
    },
    {
      "start": 63.17,
      "end": 65.25,
      "speaker": null,
      "text": "Сейчас, секунду, смотрю."
    },
    {
      "start": 70.23,
      "end": 73.15,
      "speaker": null,
      "text": "15 штук классических тушек есть у нас."
    },
    {
      "start": 74.53,
      "end": 75.21,
      "speaker": null,
      "text": "Значит..."
    },
    {
      "start": 75.34,
      "end": 77.9,
      "speaker": null,
      "text": "А точнее это 100 вы сказали, правильно?"
    },
    {
      "start": 78.2,
      "end": 78.5,
      "speaker": null,
      "text": "Сотые."
    },
    {
      "start": 78.76,
      "end": 79.74,
      "speaker": null,
      "text": "15 штук сотых."
    },
    {
      "start": 80.14,
      "end": 81.14,
      "speaker": null,
      "text": "Ну, 100 на 200."
    },
    {
      "start": 81.54,
      "end": 82.44,
      "speaker": null,
      "text": "100 на 200."
    },
    {
      "start": 82.44,
      "end": 84.02,
      "speaker": null,
      "text": "Так, 15 есть."
    },
    {
      "start": 84.85,
      "end": 86.71,
      "speaker": null,
      "text": "150 тоже есть."
    },
    {
      "start": 88.81,
      "end": 91.33,
      "speaker": null,
      "text": "Так, и крайний размер 80, да?"
    },
    {
      "start": 91.99,
      "end": 92.23,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 92.57,
      "end": 93.23,
      "speaker": null,
      "text": "80 тоже есть."
    },
    {
      "start": 93.33,
      "end": 93.53,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 93.91,
      "end": 95.97,
      "speaker": null,
      "text": "Так, а когда вам это нужно на свете подскажите?"
    },
    {
      "start": 95.97,
      "end": 96.51,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 96.67,
      "end": 99.27,
      "speaker": null,
      "text": "Смотрите, для начала нужно коммерческое предложение"
    },
    {
      "start": 99.27,
      "end": 101.71,
      "speaker": null,
      "text": "у нас просто юрлисты, у нас много всяких..."
    },
    {
      "start": 101.71,
      "end": 104.31,
      "speaker": null,
      "text": "Мне надо понимать по срокам есть какие-то ограничения,"
    },
    {
      "start": 104.45,
      "end": 106.57,
      "speaker": null,
      "text": "потому что если, например, срочная какая-то печать,"
    },
    {
      "start": 106.77,
      "end": 107.85,
      "speaker": null,
      "text": "это будет другая стоимость."
    },
    {
      "start": 108.07,
      "end": 110.79,
      "speaker": null,
      "text": "А если, ну, например, спандартные сроки укладываемся,"
    },
    {
      "start": 111.03,
      "end": 111.33,
      "speaker": null,
      "text": "то..."
    },
    {
      "start": 111.33,
      "end": 111.89,
      "speaker": null,
      "text": "Спандартные с какого?"
    },
    {
      "start": 112.92,
      "end": 115.98,
      "speaker": null,
      "text": "Ну, на такой тираж я думаю где-то 3-4 рабочих дня"
    },
    {
      "start": 115.98,
      "end": 116.36,
      "speaker": null,
      "text": "уйдет."
    },
    {
      "start": 116.78,
      "end": 116.8,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 116.8,
      "end": 117.58,
      "speaker": null,
      "text": "Что за стандартный?"
    },
    {
      "start": 117.72,
      "end": 118.68,
      "speaker": null,
      "text": "Я думаю все в порядке."
    },
    {
      "start": 118.68,
      "end": 118.88,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 119.0,
      "end": 121.64,
      "speaker": null,
      "text": "Стараемся, конечно, побыстрее, как обычно мы все постараемся"
    },
    {
      "start": 121.64,
      "end": 123.32,
      "speaker": null,
      "text": "побыстрее отдать, но..."
    },
    {
      "start": 123.32,
      "end": 124.44,
      "speaker": null,
      "text": "Да, я понимаю."
    },
    {
      "start": 124.72,
      "end": 126.68,
      "speaker": null,
      "text": "Смотрите, у меня уже начало, правда, коммерческое"
    },
    {
      "start": 126.68,
      "end": 127.24,
      "speaker": null,
      "text": "предложение."
    },
    {
      "start": 127.7,
      "end": 128.02,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 128.52,
      "end": 128.68,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 128.78,
      "end": 129.14,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 129.28,
      "end": 130.16,
      "speaker": null,
      "text": "Составлю без проблем."
    },
    {
      "start": 130.38,
      "end": 131.92,
      "speaker": null,
      "text": "Вам куда его будет удобно получить?"
    },
    {
      "start": 132.04,
      "end": 133.68,
      "speaker": null,
      "text": "Вы просто звоните с рабочего?"
    },
    {
      "start": 133.68,
      "end": 134.26,
      "speaker": null,
      "text": "Да, я понимаю."
    },
    {
      "start": 134.44,
      "end": 135.38,
      "speaker": null,
      "text": "На почту тоже, да."
    },
    {
      "start": 135.38,
      "end": 139.1,
      "speaker": null,
      "text": "Смотрите, если стоит, я, например, могу вам отправить"
    },
    {
      "start": 139.1,
      "end": 142.2,
      "speaker": null,
      "text": "характеристики к вам на почту, чтобы вы мне ответное"
    },
    {
      "start": 142.2,
      "end": 143.04,
      "speaker": null,
      "text": "письмо прислали."
    },
    {
      "start": 143.46,
      "end": 144.04,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 144.42,
      "end": 144.62,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 144.92,
      "end": 145.34,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 145.44,
      "end": 148.02,
      "speaker": null,
      "text": "На почту, которое указано на сайте или у вас есть"
    },
    {
      "start": 148.02,
      "end": 148.68,
      "speaker": null,
      "text": "что-то..."
    },
    {
      "start": 148.68,
      "end": 151.48,
      "speaker": null,
      "text": "Можете прямо напрямую мне, потому что это общая"
    },
    {
      "start": 151.48,
      "end": 152.84,
      "speaker": null,
      "text": "почта на сайте, которая указана."
    },
    {
      "start": 152.96,
      "end": 154.06,
      "speaker": null,
      "text": "Там будет..."
    },
    {
      "start": 154.06,
      "end": 154.82,
      "speaker": null,
      "text": "Ну, в общем, общая."
    },
    {
      "start": 155.4,
      "end": 155.92,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 156.0,
      "end": 157.0,
      "speaker": null,
      "text": "Скажите куда-то, да."
    },
    {
      "start": 157.56,
      "end": 160.08,
      "speaker": null,
      "text": "А вы на почте, ой, еще не на сайте видите"
    },
    {
      "start": 160.08,
      "end": 161.94,
      "speaker": null,
      "text": "почту инфо собакамастен.ру?"
    },
    {
      "start": 162.22,
      "end": 162.3,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 163.3,
      "end": 165.9,
      "speaker": null,
      "text": "Вот вместо инфо пишите две буковки маленькие"
    },
    {
      "start": 165.9,
      "end": 166.6,
      "speaker": null,
      "text": "ВЕ О."
    },
    {
      "start": 167.1,
      "end": 168.18,
      "speaker": null,
      "text": "Екатерина Орлова."
    },
    {
      "start": 168.44,
      "end": 168.88,
      "speaker": null,
      "text": "ВЕО."
    },
    {
      "start": 169.46,
      "end": 170.44,
      "speaker": null,
      "text": "Бесочек без всего."
    },
    {
      "start": 170.9,
      "end": 172.58,
      "speaker": null,
      "text": "А собакамастен.ру так и остается."
    },
    {
      "start": 172.84,
      "end": 173.08,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 173.4,
      "end": 175.2,
      "speaker": null,
      "text": "Вот можете мне все направить, я вам все почитаю,"
    },
    {
      "start": 175.26,
      "end": 176.12,
      "speaker": null,
      "text": "естественно, подготовлю."
    },
    {
      "start": 176.12,
      "end": 178.7,
      "speaker": null,
      "text": "И, Анастасия, если у вас есть какой-то пиджет, ну,"
    },
    {
      "start": 178.9,
      "end": 180.52,
      "speaker": null,
      "text": "который рассчитываете за штуку, например."
    },
    {
      "start": 180.7,
      "end": 182.78,
      "speaker": null,
      "text": "Можете тоже мне указать, я посмотрю, то есть, ну,"
    },
    {
      "start": 183.1,
      "end": 183.56,
      "speaker": null,
      "text": "чтоб сразу."
    },
    {
      "start": 183.84,
      "end": 187.5,
      "speaker": null,
      "text": "Я вам, конечно, посчитаю тиражи с учетом, ну, скидки"
    },
    {
      "start": 187.5,
      "end": 188.24,
      "speaker": null,
      "text": "за тиражи."
    },
    {
      "start": 188.46,
      "end": 190.7,
      "speaker": null,
      "text": "Но в любом случае, может там, если у вас есть, то я"
    },
    {
      "start": 190.7,
      "end": 191.1,
      "speaker": null,
      "text": "не зашлю."
    },
    {
      "start": 191.2,
      "end": 192.64,
      "speaker": null,
      "text": "Нет, нет, просто вот это интересно."
    },
    {
      "start": 193.0,
      "end": 193.34,
      "speaker": null,
      "text": "Понимаете?"
    },
    {
      "start": 194.1,
      "end": 195.02,
      "speaker": null,
      "text": "Все, поняла."
    },
    {
      "start": 195.3,
      "end": 195.68,
      "speaker": null,
      "text": "Ну, хорошо."
    },
    {
      "start": 196.04,
      "end": 196.24,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 197.14,
      "end": 197.5,
      "speaker": null,
      "text": "Угу."
    }
  ]
}