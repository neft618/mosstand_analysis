    },
    {
      "start": 307.39,
      "end": 308.07,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 308.07,
      "end": 308.11,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 308.11,
      "end": 310.07,
      "speaker": null,
      "text": "Ну, это как-то странно, если там не запустят."
    },
    {
      "start": 310.13,
      "end": 312.63,
      "speaker": null,
      "text": "Но бывает, конечно, что да, я понимаю, что там просто"
    },
    {
      "start": 312.63,
      "end": 316.13,
      "speaker": null,
      "text": "там сами должны без монтажей."
    },
    {
      "start": 316.25,
      "end": 319.29,
      "speaker": null,
      "text": "Вот даже вот тут, например, в Москве у нас застройки"
    },
    {
      "start": 319.29,
      "end": 322.69,
      "speaker": null,
      "text": "проходили, нормально пускали, то есть, ну, сторонних"
    },
    {
      "start": 322.69,
      "end": 325.49,
      "speaker": null,
      "text": "застройщиков, которые приезжали."
    },
    {
      "start": 326.74,
      "end": 329.7,
      "speaker": null,
      "text": "Там же в площадке больше всего важно – это пройти"
    },
    {
      "start": 329.7,
      "end": 330.54,
      "speaker": null,
      "text": "аккредитацию."
    },
    {
      "start": 330.66,
      "end": 331.7,
      "speaker": null,
      "text": "Вот честно скажу."
    },
    {
      "start": 332.4,
      "end": 334.74,
      "speaker": null,
      "text": "Аккредитация – это просто заплатить им денежку."
    },
    {
      "start": 335.36,
      "end": 335.78,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 335.78,
      "end": 335.86,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 336.28,
      "end": 339.76,
      "speaker": null,
      "text": "Это по большей части важно собой площадки, а остальное"
    },
    {
      "start": 339.76,
      "end": 342.7,
      "speaker": null,
      "text": "в целом их вот больше ничего… ну, редко что"
    },
    {
      "start": 342.7,
      "end": 343.4,
      "speaker": null,
      "text": "их волнует."
    },
    {
      "start": 345.03,
      "end": 345.37,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 345.37,
      "end": 349.33,
      "speaker": null,
      "text": "В целом сложность он, скажем так, именно с организаторов,"
    },
    {
      "start": 349.53,
      "end": 351.55,
      "speaker": null,
      "text": "потому что там участвует большое количество всяких"
    },
    {
      "start": 352.15,
      "end": 352.69,
      "speaker": null,
      "text": "фондов."
    },
    {
      "start": 352.79,
      "end": 353.03,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 353.33,
      "end": 358.33,
      "speaker": null,
      "text": "И разное количество участников, в том числе и фонд защитников"
    },
    {
      "start": 358.33,
      "end": 359.47,
      "speaker": null,
      "text": "отчасти есть эта ситуация."
    },
    {
      "start": 360.05,
      "end": 360.27,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 360.55,
      "end": 363.03,
      "speaker": null,
      "text": "Поэтому всё-всё вот прям вот очень-очень-очень"
    },
    {
      "start": 363.03,
      "end": 365.49,
      "speaker": null,
      "text": "щепетильно, и шаг лёв, шаг вправо я на всякий"
    },
    {
      "start": 365.49,
      "end": 366.77,
      "speaker": null,
      "text": "в случае, думаю, еще..."
    },
    {
      "start": 366.77,
      "end": 369.27,
      "speaker": null,
      "text": "Ну, я думаю, что... Да, я понимаю вас."
    },
    {
      "start": 369.47,
      "end": 371.45,
      "speaker": null,
      "text": "Конечно, конечно, я вас понимаю."
    },
    {
      "start": 371.53,
      "end": 373.21,
      "speaker": null,
      "text": "Но в любом случае, если что, мы"
    },
    {
      "start": 373.21,
      "end": 375.23,
      "speaker": null,
      "text": "с вами на связи же. Мы сейчас"
    },
    {
      "start": 375.23,
      "end": 377.69,
      "speaker": null,
      "text": "уже начинаем изготовление дизайн-проекта."
    },
    {
      "start": 378.23,
      "end": 379.49,
      "speaker": null,
      "text": "А как он будет готов,"
    },
    {
      "start": 379.63,
      "end": 381.23,
      "speaker": null,
      "text": "я сразу его вам направляю. То есть"
    },
    {
      "start": 381.23,
      "end": 382.51,
      "speaker": null,
      "text": "я на связи, если что."
    },
    {
      "start": 383.13,
      "end": 385.09,
      "speaker": null,
      "text": "А с организаторами, я думаю, что мы"
    },
    {
      "start": 386.69,
      "end": 387.57,
      "speaker": null,
      "text": "разберемся, пообщаемся,"
    },
    {
      "start": 387.73,
      "end": 389.23,
      "speaker": null,
      "text": "поговорим, поймем вообще, что они"
    },
    {
      "start": 389.23,
      "end": 390.63,
      "speaker": null,
      "text": "хотят точно. Потому что"
    },
    {
      "start": 390.63,
      "end": 392.61,
      "speaker": null,
      "text": "тут как-то странно выглядит."
    },
    {
      "start": 392.97,
      "end": 394.93,
      "speaker": null,
      "text": "Мне кажется, они просто хотят, что все у них"
    },
    {
      "start": 394.93,
      "end": 395.49,
      "speaker": null,
      "text": "делали."
    },
    {
      "start": 399.39,
      "end": 399.95,
      "speaker": null,
      "text": "Нам,"
    },
    {
      "start": 401.89,
      "end": 404.27,
      "speaker": null,
      "text": "организатору, это делать на безвозмездной основе."
    },
    {
      "start": 405.56,
      "end": 406.54,
      "speaker": null,
      "text": "Ну, понятное дело."
    },
    {
      "start": 406.66,
      "end": 406.94,
      "speaker": null,
      "text": "Конечно."
    },
    {
      "start": 408.14,
      "end": 409.8,
      "speaker": null,
      "text": "А безвозмездный или наоборот?"
    },
    {
      "start": 409.84,
      "end": 409.98,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 410.82,
      "end": 411.38,
      "speaker": null,
      "text": "Безвозмездный."
    },
    {
      "start": 414.2,
      "end": 414.76,
      "speaker": null,
      "text": "Интересно."
    },
    {
      "start": 415.04,
      "end": 416.6,
      "speaker": null,
      "text": "Ну вот как раз-таки, да, давайте тогда"
    },
    {
      "start": 417.28,
      "end": 419.22,
      "speaker": null,
      "text": "ближе к делу. Сейчас мы уже начали"
    },
    {
      "start": 419.22,
      "end": 421.3,
      "speaker": null,
      "text": "просто изготовление, я уже отдала в работу."
    },
    {
      "start": 422.48,
      "end": 423.32,
      "speaker": null,
      "text": "Да, поэтому"
    },
    {
      "start": 423.32,
      "end": 425.44,
      "speaker": null,
      "text": "я на сайте слушаю"
    },
    {
      "start": 425.44,
      "end": 426.7,
      "speaker": null,
      "text": "в этом плане, уточняю."
    },
    {
      "start": 426.76,
      "end": 427.68,
      "speaker": null,
      "text": "Тут даже не"
    },
    {
      "start": 427.68,
      "end": 428.52,
      "speaker": null,
      "text": "с тем, что"
    },
    {
      "start": 429.36,
      "end": 430.36,
      "speaker": null,
      "text": "пустить-не пустить,"
    },
    {
      "start": 430.48,
      "end": 431.66,
      "speaker": null,
      "text": "а вот тут такой формат."
    },
    {
      "start": 432.53,
      "end": 432.87,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 433.43,
      "end": 434.33,
      "speaker": null,
      "text": "То есть у вас..."
    },
    {
      "start": 434.33,
      "end": 434.85,
      "speaker": null,
      "text": "Когда я"
    },
    {
      "start": 434.85,
      "end": 435.55,
      "speaker": null,
      "text": "еще"
    },
    {
      "start": 436.17,
      "end": 436.73,
      "speaker": null,
      "text": "застройщиком"
    },
    {
      "start": 436.73,
      "end": 438.11,
      "speaker": null,
      "text": "организатору разговаривала,"
    },
    {
      "start": 438.41,
      "end": 439.27,
      "speaker": null,
      "text": "они не сказали, что"
    },
    {
      "start": 439.27,
      "end": 440.27,
      "speaker": null,
      "text": "то, что мы хотим,"
    },
    {
      "start": 440.31,
      "end": 440.95,
      "speaker": null,
      "text": "изготовить нельзя."
    },
    {
      "start": 441.78,
      "end": 442.96,
      "speaker": null,
      "text": "Они могут нам помочь"
    },
    {
      "start": 442.96,
      "end": 443.48,
      "speaker": null,
      "text": "предоставить"
    },
    {
      "start": 443.48,
      "end": 444.82,
      "speaker": null,
      "text": "то-то, то-то, то-то, то-то, то-то, то-то."
    },
    {
      "start": 446.08,
      "end": 446.44,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 447.82,
      "end": 449.44,
      "speaker": null,
      "text": "А как это нельзя изготовить?"
    },
    {
      "start": 449.46,
      "end": 451.24,
      "speaker": null,
      "text": "В плане того, что они не изготавливают такое?"
    },
    {
      "start": 452.64,
      "end": 453.5,
      "speaker": null,
      "text": "Ну, допустим,"
    },
    {
      "start": 453.56,
      "end": 453.76,
      "speaker": null,
      "text": "они"
    },
    {
      "start": 453.76,
      "end": 454.82,
      "speaker": null,
      "text": "не делают"
    },
    {
      "start": 454.82,
      "end": 455.48,
      "speaker": null,
      "text": "нестандартное"
    },
    {
      "start": 455.48,
      "end": 456.32,
      "speaker": null,
      "text": "возведение стен,"
    },
    {
      "start": 456.44,
      "end": 457.12,
      "speaker": null,
      "text": "они не делают"
    },
    {
      "start": 457.12,
      "end": 457.32,
      "speaker": null,
      "text": "там"
    },
    {
      "start": 457.78,
      "end": 458.5,
      "speaker": null,
      "text": "подъем пола,"
    },
    {
      "start": 458.66,
      "end": 458.76,
      "speaker": null,
      "text": "они"
    },
    {
      "start": 459.22,
      "end": 459.88,
      "speaker": null,
      "text": "не делают"
    },
    {
      "start": 459.88,
      "end": 460.36,
      "speaker": null,
      "text": "какие-то"
    },
    {
      "start": 460.36,
      "end": 460.92,
      "speaker": null,
      "text": "экспозиторы,"
    },
    {
      "start": 461.04,
      "end": 461.58,
      "speaker": null,
      "text": "которые мы"
    },
    {
      "start": 461.58,
      "end": 462.0,
      "speaker": null,
      "text": "хотим."
    },
    {
      "start": 462.0,
      "end": 463.06,
      "speaker": null,
      "text": "А, я поняла."
    },
    {
      "start": 463.08,
      "end": 463.8,
      "speaker": null,
      "text": "У нас же все-таки"
    },
    {
