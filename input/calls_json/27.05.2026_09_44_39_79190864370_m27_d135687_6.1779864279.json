{
  "file": "27.05.2026_09_44_39_79190864370_m27_d135687_6.1779864279.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 64.4,
  "segments": [
    {
      "start": 0.66,
      "end": 1.3,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 2.16,
      "end": 4.92,
      "speaker": null,
      "text": "Катерина, добрый день. Это Валентин, компания «Мосцент»."
    },
    {
      "start": 5.11,
      "end": 6.13,
      "speaker": null,
      "text": "Добрый день."
    },
    {
      "start": 6.84,
      "end": 15.88,
      "speaker": null,
      "text": "Да, мы оплату от вас сегодня получили. Я передаю их в производство. Единственное, мне необходимо от вас согласование по макету на почте."
    },
    {
      "start": 17.36,
      "end": 17.92,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 18.58,
      "end": 21.1,
      "speaker": null,
      "text": "Да, и скажите, пожалуйста, когда у вас дедлайн сдачи?"
    },
    {
      "start": 23.05,
      "end": 27.43,
      "speaker": null,
      "text": "Я не думала, что у нас только сегодня оплатили счёт, поэтому как можно скорее."
    },
    {
      "start": 28.49,
      "end": 30.27,
      "speaker": null,
      "text": "Угу. Хорошо-хорошо, я вас понял."
    },
    {
      "start": 31.74,
      "end": 32.88,
      "speaker": null,
      "text": "Всё, благодарю."
    },
    {
      "start": 32.88,
      "end": 35.82,
      "speaker": null,
      "text": "А согласование макета вы прислёте визуал или?"
    },
    {
      "start": 36.5,
      "end": 40.1,
      "speaker": null,
      "text": "После согласования макета я передам его в печать баннер."
    },
    {
      "start": 41.5,
      "end": 45.1,
      "speaker": null,
      "text": "Ммм. Ну вот то, что я скинула."
    },
    {
      "start": 45.4,
      "end": 51.9,
      "speaker": null,
      "text": "Да, я вам после этого присылал как раз от меня письмо, макет на согласование 25-го мая."
    },
    {
      "start": 52.5,
      "end": 53.44,
      "speaker": null,
      "text": "На почту?"
    },
    {
      "start": 53.66,
      "end": 54.48,
      "speaker": null,
      "text": "Да, на почту."
    },
    {
      "start": 55.92,
      "end": 58.5,
      "speaker": null,
      "text": "Ага, всё, я это до сегодня отвечу."
    },
    {
      "start": 59.0,
      "end": 60.24,
      "speaker": null,
      "text": "Угу. Всё, спасибо."
    },
    {
      "start": 61.09,
      "end": 61.57,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 62.33,
      "end": 63.11,
      "speaker": null,
      "text": "Да, до свидания."
    }
  ]
}