    {
      "start": 17.2,
      "end": 18.04,
      "speaker": null,
      "text": "Это не Светлана?"
    },
    {
      "start": 18.66,
      "end": 26.92,
      "speaker": null,
      "text": "Так, это не Светлана. Я снова бы не позвонил не Светлане. А как мне попасть на Светлану Будович? Я просто добавочную вожу, не получается."
    },
    {
      "start": 29.71,
      "end": 30.57,
      "speaker": null,
      "text": "Подождите, пожалуйста."
    },
    {
      "start": 46.78,
      "end": 49.98,
      "speaker": null,
      "text": "А как, в общем, звонят ей и не могут попасть в кофе?"
    },
    {
      "start": 51.7,
      "end": 53.52,
      "speaker": null,
      "text": "Алло, у неё добавочная 172."
    },
    {
      "start": 53.94,
      "end": 54.94,
      "speaker": null,
      "text": "172 я её ввёл."
    },
    {
      "start": 57.2,
      "end": 59.06,
      "speaker": null,
      "text": "Нет, это у меня 177."
    },
    {
      "start": 61.76,
      "end": 63.3,
      "speaker": null,
      "text": "172 добавочной добавочной."
    },
    {
      "start": 63.52,
      "end": 63.6,
      "speaker": null,
      "text": "Так, секундочку."
    },
    {
      "start": 63.96,
      "end": 65.48,
      "speaker": null,
      "text": "Нет, ввёл 172."
    },
    {
      "start": 66.06,
      "end": 67.44,
      "speaker": null,
      "text": "Прямо 172 вводил."
    },
    {
      "start": 69.85,
      "end": 72.71,
      "speaker": null,
      "text": "Могу вам помочь ничем у меня? 177 добавочной."
    },
    {
      "start": 74.03,
      "end": 75.09,
      "speaker": null,
      "text": "Хорошо, ладно, спасибо."
