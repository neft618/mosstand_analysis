{
  "file": "20.04.2026_11_09_39_74876290172_m29_d133481_d.1776672580.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 898.9,
  "segments": [
    {
      "start": 1.33,
      "end": 4.73,
      "speaker": null,
      "text": "Добрый день. Меня зовут Ксения, компания «Москент». Как я могу вам обращаться?"
    },
    {
      "start": 4.95,
      "end": 7.19,
      "speaker": null,
      "text": "Андрей. А прощите, я расскажу. Вас как зовут?"
    },
    {
      "start": 7.79,
      "end": 8.35,
      "speaker": null,
      "text": "Ксения."
    },
    {
      "start": 8.69,
      "end": 12.67,
      "speaker": null,
      "text": "Ксения. Очень приятно. Это вас беспокоит Турцкая область, Ксения?"
    },
    {
      "start": 13.23,
      "end": 13.39,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 14.15,
      "end": 20.03,
      "speaker": null,
      "text": "Микроево-Сокольники, город Новомосковск. А скажите, у вас можно заказать с нами Победы в 9 мая?"
    },
    {
      "start": 20.54,
      "end": 22.96,
      "speaker": null,
      "text": "Да, конечно. Какой размер флага будет?"
    },
    {
      "start": 23.91,
      "end": 27.96,
      "speaker": null,
      "text": "Ну, а какие размеры стандартные?"
    },
    {
      "start": 27.96,
      "end": 31.26,
      "speaker": null,
      "text": "Ну, любую можно сделать. Но на сколько большой вам нужен?"
    },
    {
      "start": 31.74,
      "end": 36.22,
      "speaker": null,
      "text": "Нам нужен, чтобы на здание повесить его."
    },
    {
      "start": 39.92,
      "end": 45.18,
      "speaker": null,
      "text": "На здании. То есть у вас будет просто надрезки и сесть именно на стене, правда ли?"
    },
    {
      "start": 45.18,
      "end": 49.36,
      "speaker": null,
      "text": "Да, надрезки он не на стене, а как бы он будет там стоять у нас на здании."
    },
    {
      "start": 49.48,
      "end": 55.74,
      "speaker": null,
      "text": "Не вот, знаете, не под углом будет на стене, вот флагшток там мы его воткнуть и как бы в это крепление."
    },
    {
      "start": 56.04,
      "end": 58.28,
      "speaker": null,
      "text": "А нам надо, чтобы вертикальный был поставить его."
    },
    {
      "start": 58.73,
      "end": 62.33,
      "speaker": null,
      "text": "Так, вертикальный. Хорошо, поняла вас."
    },
    {
      "start": 62.89,
      "end": 64.45,
      "speaker": null,
      "text": "Так, он будет на высоте, правильно?"
    },
    {
      "start": 64.99,
      "end": 66.29,
      "speaker": null,
      "text": "Да. На здании."
    },
    {
      "start": 66.43,
      "end": 68.39,
      "speaker": null,
      "text": "На втором этаже здания."
    },
    {
      "start": 68.97,
      "end": 75.41,
      "speaker": null,
      "text": "Смотрите, в целом такие размеры можно рассматривать либо 135 на 90,"
    },
    {
      "start": 75.41,
      "end": 84.25,
      "speaker": null,
      "text": "либо можно рассматривать, так, 210 на 150, к примеру."
    },
    {
      "start": 84.25,
      "end": 86.65,
      "speaker": null,
      "text": "Как вам такие размеры?"
    },
    {
      "start": 87.97,
      "end": 90.61,
      "speaker": null,
      "text": "Сейчас я 135 на 90."
    },
    {
      "start": 90.87,
      "end": 92.11,
      "speaker": null,
      "text": "62 метра."
    },
    {
      "start": 92.35,
      "end": 94.13,
      "speaker": null,
      "text": "Приблизительно, я понимаю, да, размер."
    },
    {
      "start": 94.13,
      "end": 100.4,
      "speaker": null,
      "text": "Раз, два, три, четыре."
    },
    {
      "start": 100.42,
      "end": 101.1,
      "speaker": null,
      "text": "Это метр."
    },
    {
      "start": 102.5,
      "end": 106.16,
      "speaker": null,
      "text": "Пять, шесть, семь."
    },
    {
      "start": 117.7,
      "end": 118.84,
      "speaker": null,
      "text": "Да, 2 и 135."
    },
    {
      "start": 119.22,
      "end": 120.24,
      "speaker": null,
      "text": "Говорит, сам такой вот."
    },
    {
      "start": 120.42,
      "end": 121.98,
      "speaker": null,
      "text": "Да, 135 это будет..."
    },
    {
      "start": 122.94,
      "end": 126.4,
      "speaker": null,
      "text": "Раз, три, четыре."
    },
    {
      "start": 126.56,
      "end": 127.14,
      "speaker": null,
      "text": "Это метр."
    },
    {
      "start": 127.68,
      "end": 130.48,
      "speaker": null,
      "text": "125 и 10."
    },
    {
      "start": 131.0,
      "end": 133.56,
      "speaker": null,
      "text": "А можно 135 в принципе даже хватит?"
    },
    {
      "start": 133.98,
      "end": 135.96,
      "speaker": null,
      "text": "135 на 90, да?"
    },
    {
      "start": 136.62,
      "end": 136.96,
      "speaker": null,
      "text": "Ну да."
    },
    {
      "start": 137.7,
      "end": 139.04,
      "speaker": null,
      "text": "А 90 сколько сейчас?"
    },
    {
      "start": 139.32,
      "end": 144.79,
      "speaker": null,
      "text": "Раз, два, это три, семьдесят пять."
    },
    {
      "start": 145.09,
      "end": 148.59,
      "speaker": null,
      "text": "Ну да, наверное, 135 на 90 в принципе даже хватит."
    },
    {
      "start": 149.81,
      "end": 151.07,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 151.81,
      "end": 153.67,
      "speaker": null,
      "text": "Подскажите, пожалуйста, по печати."
    },
    {
      "start": 153.71,
      "end": 156.75,
      "speaker": null,
      "text": "Вам нужно с двух сторон, с одной стороны как вообще сделать?"
    },
    {
      "start": 157.49,
      "end": 159.35,
      "speaker": null,
      "text": "А, по печати."
    },
    {
      "start": 160.41,
      "end": 161.51,
      "speaker": null,
      "text": "А как лучше-то?"
    },
    {
      "start": 161.65,
      "end": 162.25,
      "speaker": null,
      "text": "На чем вообще?"
    },
    {
      "start": 162.37,
      "end": 163.49,
      "speaker": null,
      "text": "На каком ткани делается?"
    },
    {
      "start": 164.17,
      "end": 165.11,
      "speaker": null,
      "text": "Да, на любом."
    },
    {
      "start": 165.27,
      "end": 170.45,
      "speaker": null,
      "text": "Есть атлас, шелк, флажная сетка, blackout, ну самые такие..."
    },
    {
      "start": 170.45,
      "end": 172.85,
      "speaker": null,
      "text": "Ну что понадежнее такое, чтобы на улице повесить?"
    },
    {
      "start": 173.75,
      "end": 179.63,
      "speaker": null,
      "text": "Ну смотрите, в целом самое такое вот ходовое это либо флажная сетка, либо blackout."
    },
    {
      "start": 179.85,
      "end": 185.41,
      "speaker": null,
      "text": "То есть blackout это плотная ткань, не просвечивается вообще, можно как раз с двух сторон сделать."
    },
    {
      "start": 185.57,
      "end": 186.59,
      "speaker": null,
      "text": "А она развиваться будет?"
    },
    {
      "start": 187.86,
      "end": 188.8,
      "speaker": null,
      "text": "Да, будет."
    },
    {
      "start": 188.92,
      "end": 193.16,
      "speaker": null,
      "text": "Но если нужно, чтобы прям очень сильно развиваться, лучше использовать флажную сетку,"
    },
    {
      "start": 193.26,
      "end": 198.32,
      "speaker": null,
      "text": "потому что там как раз таки идет именно, ну как бы насквозь и печать сама насквозь."
    },
    {
      "start": 198.36,
      "end": 202.42,
      "speaker": null,
      "text": "Она по сути односторонняя, а с другой стороны будет печать, это видно, но и зеркально."
    },
    {
      "start": 203.0,
      "end": 204.42,
      "speaker": null,
      "text": "А какая сетка еще раз?"
    },
    {
      "start": 205.92,
      "end": 206.4,
      "speaker": null,
      "text": "Флажная."
    },
    {
      "start": 207.83,
      "end": 209.27,
      "speaker": null,
      "text": "Флажная сетка, да, так называется?"
    },
    {
      "start": 209.37,
      "end": 211.03,
      "speaker": null,
      "text": "Да-да-да, правильно."
    },
    {
      "start": 212.52,
      "end": 213.48,
      "speaker": null,
      "text": "Флажная сетка."
    },
    {
      "start": 216.96,
      "end": 219.76,
      "speaker": null,
      "text": "Он не порвется сразу первую зиму?"
    },
    {
      "start": 219.76,
      "end": 227.23,
      "speaker": null,
      "text": "Нет-нет, вообще не порвется. Там по плотности можно сделать 100 грамм, либо 90 грамм."
    },
    {
      "start": 227.35,
      "end": 232.03,
      "speaker": null,
      "text": "Ну то есть она такая, ну она нервующая еще."
    },
    {
      "start": 233.07,
      "end": 235.27,
      "speaker": null,
      "text": "И сколько такой флаг будет стоить?"
    },
    {
      "start": 235.77,
      "end": 239.81,
      "speaker": null,
      "text": "Ну смотрите, у нас минимальная сумма заказа в любом случае 5 тысяч рублей."
    },
    {
      "start": 239.81,
      "end": 243.15,
      "speaker": null,
      "text": "В целом Вы сказали, что Вы в Тульской области, правильно?"
    },
    {
      "start": 243.31,
      "end": 243.45,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 246.43,
      "end": 248.15,
      "speaker": null,
      "text": "А Вам одна штука нужна?"
    },
    {
      "start": 249.12,
      "end": 254.1,
      "speaker": null,
      "text": "Ну нам еще древко и если есть у Вас еще крепление, которые сразу чтобы купить."
    },
    {
      "start": 254.65,
      "end": 260.53,
      "speaker": null,
      "text": "В целом это все есть, единственное мне нужно будет понять, как это все будет стоять."
    },
    {
      "start": 260.63,
      "end": 263.33,
      "speaker": null,
      "text": "Вы сказали, что это не под углом будет, а именно прямо."
    },
    {
      "start": 263.33,
      "end": 267.29,
      "speaker": null,
      "text": "А у Вас есть фотографии, где именно это все будет стоять?"
    },
    {
      "start": 268.5,
      "end": 269.18,
      "speaker": null,
      "text": "Ну..."
    },
    {
      "start": 269.18,
      "end": 271.66,
      "speaker": null,
      "text": "Ну или будет возможно сделать фотографию."
    },
    {
      "start": 271.68,
      "end": 273.24,
      "speaker": null,
      "text": "Да, фотографию можно найти."
    },
    {
      "start": 273.34,
      "end": 278.14,
      "speaker": null,
      "text": "Ну это просто на парапете мы поставим его в вертикальном положении."
    },
    {
      "start": 278.64,
      "end": 283.0,
      "speaker": null,
      "text": "У нас кровля плоская на здании."
    },
    {
      "start": 284.85,
      "end": 286.87,
      "speaker": null,
      "text": "Она мягкая кровля, плоская крыша."
    },
    {
      "start": 286.87,
      "end": 292.91,
      "speaker": null,
      "text": "И там на пропете здания мы установим этот флагшток, ну или держатель этот и туда его воткнем."
    },
    {
      "start": 293.9,
      "end": 294.76,
      "speaker": null,
      "text": "Угу, так."
    },
    {
      "start": 296.24,
      "end": 296.72,
      "speaker": null,
      "text": "Держатель..."
    },
    {
      "start": 298.82,
      "end": 301.56,
      "speaker": null,
      "text": "А скажите, а у Вас маленькие флажки сувенирные есть?"
    },
    {
      "start": 302.1,
      "end": 306.5,
      "speaker": null,
      "text": "Да, конечно, мы делаем эти, которые 22 на 15 сантиметров, да?"
    },
    {
      "start": 306.7,
      "end": 308.82,
      "speaker": null,
      "text": "Которые настольные, правильно?"
    },
    {
      "start": 309.34,
      "end": 313.58,
      "speaker": null,
      "text": "Ну да, настольные такие флажки надо, чтобы нам тоже 100 штук."
    },
    {
      "start": 314.03,
      "end": 315.99,
      "speaker": null,
      "text": "Да, конечно, не делаем."
    },
    {
      "start": 316.45,
      "end": 321.03,
      "speaker": null,
      "text": "А также нужно понять по печати, нужна с двух сторон, с одной стороны."
    },
    {
      "start": 321.73,
      "end": 323.23,
      "speaker": null,
      "text": "Какие древки нужны?"
    },
    {
      "start": 323.37,
      "end": 326.97,
      "speaker": null,
      "text": "Потому что есть там тройные, есть двойное, есть одинарные..."
    },
    {
      "start": 326.97,
      "end": 329.15,
      "speaker": null,
      "text": "Не-не-не, одинарные нам нужны, одинарные."
    },
    {
      "start": 329.29,
      "end": 330.07,
      "speaker": null,
      "text": "Одинарные, ага."
    },
    {
      "start": 330.39,
      "end": 336.94,
      "speaker": null,
      "text": "Да, нам чтобы детям раздать, одинарные."
    },
    {
      "start": 337.84,
      "end": 341.28,
      "speaker": null,
      "text": "Там у Вас дребка или пластиковая какая-нибудь палочка?"
    },
    {
      "start": 341.28,
      "end": 346.4,
      "speaker": null,
      "text": "Ну, чаще такая... не прям пластик, а сейчас я Вам скажу."
    },
    {
      "start": 347.69,
      "end": 348.95,
      "speaker": null,
      "text": "Так-так..."
    },
    {
      "start": 390.12,
      "end": 393.94,
      "speaker": null,
      "text": "Подставка у нас металл под серебро, то есть это не пластик."
    },
    {
      "start": 395.21,
      "end": 396.47,
      "speaker": null,
      "text": "А Вам нужен пластик?"
    },
    {
      "start": 396.77,
      "end": 398.55,
      "speaker": null,
      "text": "Нет, подставка для большого флага?"
    },
    {
      "start": 399.56,
      "end": 401.06,
      "speaker": null,
      "text": "Ну, это для маленьких точно."
    },
    {
      "start": 401.74,
      "end": 405.98,
      "speaker": null,
      "text": "А подставка нам не нужна, нам только вот на палочке, чтобы раздать, чтобы дети их вносили."
    },
    {
      "start": 405.98,
      "end": 407.32,
      "speaker": null,
      "text": "А, палочками."
    },
    {
      "start": 407.68,
      "end": 408.3,
      "speaker": null,
      "text": "Всё, я поняла."
    },
    {
      "start": 408.48,
      "end": 410.86,
      "speaker": null,
      "text": "Да, в таком случае да, мне нужно пластику использовать."
    },
    {
      "start": 411.74,
      "end": 411.9,
      "speaker": null,
      "text": "Да?"
    },
    {
      "start": 412.86,
      "end": 415.72,
      "speaker": null,
      "text": "Нам вот такие нужны, чтобы на палочки не были, на подставки не надо."
    },
    {
      "start": 416.38,
      "end": 417.66,
      "speaker": null,
      "text": "Так, всё, я поняла."
    },
    {
      "start": 417.8,
      "end": 419.36,
      "speaker": null,
      "text": "Теперь здесь подставки."
    },
    {
      "start": 421.38,
      "end": 423.42,
      "speaker": null,
      "text": "А какие у нас сроки, подскажите?"
    },
    {
      "start": 424.38,
      "end": 425.8,
      "speaker": null,
      "text": "Ну, нам 9 мая надо."
    },
    {
      "start": 427.4,
      "end": 428.36,
      "speaker": null,
      "text": "9 мая..."
    },
    {
      "start": 429.99,
      "end": 434.29,
      "speaker": null,
      "text": "Смотрите, у нас по печати 4 рабочих дней обычно идёт."
    },
    {
      "start": 435.31,
      "end": 436.85,
      "speaker": null,
      "text": "Спокойно мы с Вами успеваем."
    },
    {
      "start": 436.85,
      "end": 440.99,
      "speaker": null,
      "text": "По макетам, подскажите, получается большой флаг Вам нужен..."
    },
    {
      "start": 441.75,
      "end": 443.15,
      "speaker": null,
      "text": "Какой там макет будет?"
    },
    {
      "start": 443.47,
      "end": 444.77,
      "speaker": null,
      "text": "Ну, копия знаний Победы."
    },
    {
      "start": 448.81,
      "end": 450.91,
      "speaker": null,
      "text": "А маленькие такие же?"
    },
    {
      "start": 450.91,
      "end": 451.95,
      "speaker": null,
      "text": "И маленькие тоже, да."
    },
    {
      "start": 453.11,
      "end": 455.61,
      "speaker": null,
      "text": "Всё, поняла, они сидят такие одинаковые."
    },
    {
      "start": 455.93,
      "end": 458.17,
      "speaker": null,
      "text": "Так, и по маленьким, они какие должны быть?"
    },
    {
      "start": 458.25,
      "end": 465.83,
      "speaker": null,
      "text": "Тоже использовать, чтобы ткань очень хорошо через воздух проходила или поплотнее сделать?"
    },
    {
      "start": 465.83,
      "end": 470.17,
      "speaker": null,
      "text": "Ну, здесь можно, я не знаю, как вот эти сувенирные..."
    },
    {
      "start": 470.17,
      "end": 471.93,
      "speaker": null,
      "text": "Да, по-моему, такие простые какие-нибудь."
    },
    {
      "start": 472.29,
      "end": 474.05,
      "speaker": null,
      "text": "Не столь важно."
    },
    {
      "start": 480.5,
      "end": 481.52,
      "speaker": null,
      "text": "Тестоль, вот так."
    },
    {
      "start": 481.78,
      "end": 481.9,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 482.14,
      "end": 485.28,
      "speaker": null,
      "text": "Давайте я это сейчас посчитаю, потому что 100 штук у нас там уже..."
    },
    {
