    {
      "start": 869.58,
      "end": 873.8,
      "speaker": null,
      "text": "Потому что, чтобы контракт потом составляли, чтобы у нас было основание."
    },
    {
      "start": 875.97,
      "end": 877.17,
      "speaker": null,
      "text": "Ну я поняла вас."
    },
    {
      "start": 877.29,
      "end": 877.59,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 878.03,
      "end": 878.35,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 878.71,
      "end": 879.75,
      "speaker": null,
      "text": "Спасибо большое."
