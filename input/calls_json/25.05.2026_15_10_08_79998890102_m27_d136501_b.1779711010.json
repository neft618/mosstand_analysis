    {
      "start": 0.11,
      "end": 1.47,
      "speaker": null,
      "text": "Да, Симур, добрый день."
    },
    {
      "start": 1.83,
      "end": 3.67,
      "speaker": null,
      "text": "Добрый день, Валентин, ну как у нас там дела?"
    },
    {
      "start": 4.67,
      "end": 12.68,
      "speaker": null,
      "text": "Да, уже поп-ап отпечатан, я вам как раз фотографию отправлять собирался, а стойка как раз допечатывается."
    },
    {
      "start": 13.72,
      "end": 16.2,
      "speaker": null,
      "text": "Ну, сегодня всё успеваем отправлять, да?"
    },
    {
      "start": 16.52,
      "end": 19.26,
      "speaker": null,
      "text": "Да, скажите пожалуйста, до скольки можно доставить на площадку?"
    },
    {
      "start": 22.15,
      "end": 26.38,
      "speaker": null,
      "text": "Сейчас, секунду. Я вам отпишусь."
    },
    {
      "start": 27.17,
      "end": 28.65,
      "speaker": null,
      "text": "Да, хорошо, всё, я тогда ожидаю."
    },
    {
      "start": 28.71,
      "end": 31.47,
      "speaker": null,
      "text": "А по вашим расчётам когда готово будет?"
    },
    {
      "start": 31.47,
      "end": 39.14,
      "speaker": null,
      "text": "Смотрите, у нас готовность ожидается к 6 и ехать с учётом доставки."
    },
    {
      "start": 40.08,
      "end": 44.64,
      "speaker": null,
      "text": "Ну то есть, учитывая доставку 7-8 вечера получается."
    },
    {
      "start": 50.22,
      "end": 51.46,
      "speaker": null,
      "text": "Всё, я отпишусь."
    },
    {
      "start": 51.82,
      "end": 53.5,
      "speaker": null,
      "text": "Всё хорошо, я тогда ожидаю."
    },
    {
      "start": 54.14,
      "end": 56.44,
      "speaker": null,
      "text": "Всё, спасибо, это очень важно, завтра уже мероприятие."
    },
    {
      "start": 57.42,
      "end": 58.3,
      "speaker": null,
      "text": "Да, я понимаю."
    },
    {
      "start": 59.43,
      "end": 61.45,
      "speaker": null,
      "text": "Всё, спасибо Валентин, отпишусь."
    },
    {
      "start": 61.91,
      "end": 63.23,
      "speaker": null,
      "text": "Да, да, благодарю Тимур."
    }
  ]
