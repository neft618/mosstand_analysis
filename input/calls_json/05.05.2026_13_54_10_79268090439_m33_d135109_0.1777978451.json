    {
      "start": 468.4,
      "end": 468.96,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 469.74,
      "end": 469.9,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 470.56,
      "end": 470.84,
      "speaker": null,
      "text": "Что?"
    },
    {
      "start": 471.26,
      "end": 473.24,
      "speaker": null,
      "text": "Да, ну в любом случае, да."
    },
    {
      "start": 473.58,
      "end": 475.74,
      "speaker": null,
      "text": "Точно получится качественный лап."
    },
    {
      "start": 476.58,
      "end": 476.94,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 477.54,
      "end": 478.92,
      "speaker": null,
      "text": "Ага, все отлично."
    },
    {
      "start": 479.14,
      "end": 480.98,
      "speaker": null,
      "text": "Тогда там Максе напишите,"
    },
    {
      "start": 481.34,
      "end": 485.33,
      "speaker": null,
      "text": "а я вам уже отправлю макет этот"
    },
    {
      "start": 485.33,
      "end": 487.13,
      "speaker": null,
      "text": "и уже этот..."
    },
    {
      "start": 487.13,
      "end": 489.23,
      "speaker": null,
      "text": "Ну там, я думаю, хорошо."
    },
    {
      "start": 489.51,
      "end": 490.59,
      "speaker": null,
      "text": "Ну да, договорились."
    },
    {
      "start": 490.83,
      "end": 491.63,
      "speaker": null,
      "text": "А вот мы пришли."
    },
    {
      "start": 492.29,
      "end": 492.81,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 492.81,
      "end": 495.27,
      "speaker": null,
      "text": "У вас какой-то определенный дизайн уже есть?"
    },
    {
      "start": 495.45,
      "end": 496.31,
      "speaker": null,
      "text": "Ну, а когда он нужен?"
    },
    {
      "start": 497.41,
      "end": 498.99,
      "speaker": null,
      "text": "Так, я на всякий случай для себя..."
    },
    {
      "start": 498.99,
      "end": 499.87,
      "speaker": null,
      "text": "Ну, в идеале, конечно."
    },
    {
      "start": 500.49,
      "end": 504.52,
      "speaker": null,
      "text": "В идеале, если прям на этой неделе будет отлично,"
    },
    {
      "start": 504.68,
      "end": 506.38,
      "speaker": null,
      "text": "но если на этой неделе не получается,"
    },
    {
      "start": 506.74,
      "end": 510.72,
      "speaker": null,
      "text": "то до, знаете, ну на следующей неделе там,"
    },
    {
      "start": 510.72,
      "end": 512.1,
      "speaker": null,
      "text": "до пятницы."
    },
    {
      "start": 512.36,
      "end": 514.44,
      "speaker": null,
      "text": "А, ну тогда время есть."
    },
    {
      "start": 514.96,
      "end": 516.64,
      "speaker": null,
      "text": "Хорошо, давайте тогда сейчас..."
    },
    {
      "start": 516.64,
      "end": 517.32,
      "speaker": null,
      "text": "Ну, сейчас смешим."
    },
    {
      "start": 517.86,
      "end": 518.08,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 519.2,
      "end": 520.42,
      "speaker": null,
      "text": "Посмотрю, как у вас дизайн."
    },
    {
      "start": 520.54,
      "end": 522.56,
      "speaker": null,
      "text": "Ну, опять же, как быстро вы согласуете?"
    },
    {
      "start": 523.1,
      "end": 525.36,
      "speaker": null,
      "text": "Здесь уже от этого еще будет зависеть."
    },
    {
      "start": 525.58,
      "end": 525.82,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 526.78,
      "end": 528.12,
      "speaker": null,
      "text": "Все, тогда на следующей неделе."
    },
    {
      "start": 528.14,
      "end": 532.52,
      "speaker": null,
      "text": "Ну, в целом цена как бы там каким-то образом не увеличится."
    },
    {
      "start": 532.98,
      "end": 536.8,
      "speaker": null,
      "text": "Ну, вот если мы договорились 85 на 200 стандартная конструкция,"
    },
    {
      "start": 537.56,
      "end": 538.72,
      "speaker": null,
      "text": "дизайн с нашей стороны,"
    },
    {
      "start": 538.92,
      "end": 541.48,
      "speaker": null,
      "text": "то цена, наверное, так и останется 4,5."
    },
    {
      "start": 541.72,
      "end": 542.8,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 542.8,
      "end": 543.92,
      "speaker": null,
      "text": "Или сколько вы там сказали?"
    },
    {
      "start": 544.12,
      "end": 544.96,
      "speaker": null,
      "text": "Да, 4,5."
    },
    {
      "start": 545.32,
      "end": 546.22,
      "speaker": null,
      "text": "5,5, да, сказали?"
    },
    {
      "start": 547.24,
      "end": 547.6,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 548.36,
      "end": 549.38,
      "speaker": null,
      "text": "Ага, все, конечно."
    },
    {
      "start": 549.7,
      "end": 550.18,
      "speaker": null,
      "text": "Так, спасибо."
    },
    {
      "start": 552.68,
      "end": 554.24,
      "speaker": null,
      "text": "Все, давай, все-таки на следующей неделе."
    },
    {
      "start": 554.74,
      "end": 555.1,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 555.88,
      "end": 556.28,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 556.38,
      "end": 557.18,
      "speaker": null,
      "text": "Ага, всем добро."
    }
  ]
}