{
  "file": "03.04.2026_16_10_08_74996424609_m29_d131033_8.1775221809.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 78.6,
  "segments": [
    {
      "start": 0.0,
      "end": 6.68,
      "speaker": null,
      "text": "Здравствуйте! Спасибо за ваш звонок. Пожалуйста, наберите добавочный номер сотрудника или дождитесь ответа."
    },
    {
      "start": 10.62,
      "end": 11.18,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 20.26,
      "end": 22.14,
      "speaker": null,
      "text": "Спасибо, Грася, она рядом. Меня зовут Евелина."
    },
    {
      "start": 22.74,
      "end": 27.62,
      "speaker": null,
      "text": "Евелина, здравствуйте ещё раз. Мы сена, Анастасия, меня, пожалуйста, перевезти. Она уже звонила."
    },
    {
      "start": 28.16,
      "end": 28.72,
      "speaker": null,
      "text": "Секунду."
    },
    {
      "start": 44.39,
      "end": 48.15,
      "speaker": null,
      "text": "Анастасия, здравствуйте ещё раз. Это вот Ксения у меня от вас пропущенный."
    },
    {
      "start": 49.17,
      "end": 51.63,
      "speaker": null,
      "text": "Так, а я... Ксения, какая фирма?"
    },
    {
      "start": 52.61,
      "end": 54.71,
      "speaker": null,
      "text": "Мой стенд, мы по стойкам общались."
    },
    {
      "start": 55.23,
      "end": 58.09,
      "speaker": null,
      "text": "А, так, не знаю, почему у меня пропущенный."
    },
    {
      "start": 58.79,
      "end": 62.89,
      "speaker": null,
      "text": "А, видимо, наверное, из-за того, что мы с вами общались, может перезвон прошёл."
    },
    {
      "start": 63.09,
      "end": 63.93,
      "speaker": null,
      "text": "Всё, так занятный."
    },
    {
      "start": 64.07,
      "end": 64.75,
      "speaker": null,
      "text": "Да, да, да, я не знаю."
    },
    {
      "start": 66.31,
      "end": 67.77,
      "speaker": null,
      "text": "Всё хорошо, без проблем."
    },
    {
      "start": 68.17,
      "end": 70.79,
      "speaker": null,
      "text": "Если что, по расчётам я помню, на почте всё вышло."
    },
    {
      "start": 71.09,
      "end": 71.85,
      "speaker": null,
      "text": "Да, спасибо большое."
    },
    {
      "start": 72.47,
      "end": 73.73,
      "speaker": null,
      "text": "Всё, да, на связи."
    },
    {
      "start": 74.47,
      "end": 75.27,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}