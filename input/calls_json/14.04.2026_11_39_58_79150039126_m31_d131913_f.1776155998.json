{
  "file": "14.04.2026_11_39_58_79150039126_m31_d131913_f.1776155998.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 69.9,
  "segments": [
    {
      "start": 0.0,
      "end": 3.1,
      "speaker": null,
      "text": "Продолжаем дозваниваться. Оставайтесь на линии."
    },
    {
      "start": 6.05,
      "end": 6.51,
      "speaker": null,
      "text": "Алло?"
    },
    {
      "start": 7.27,
      "end": 18.27,
      "speaker": null,
      "text": "Здравствуйте, это Валерий из Мостэнд. Артём, общались с моей коллегой и Кириной. Говорили, что отправили нам на почту запрос. А мы с вами не общались?"
    },
    {
      "start": 20.23,
      "end": 23.06,
      "speaker": null,
      "text": "Наверное, нет. Не общались."
    },
    {
      "start": 24.55,
      "end": 28.07,
      "speaker": null,
      "text": "Ага, поняла. А Бергер правильно запросы?"
    },
    {
      "start": 28.55,
      "end": 29.43,
      "speaker": null,
      "text": "Да, всё правильно."
    },
    {
      "start": 30.59,
      "end": 35.09,
      "speaker": null,
      "text": "А уточните, пожалуйста, вы как рекламное агентство или вы уже как представитель?"
    },
    {
      "start": 36.01,
      "end": 37.05,
      "speaker": null,
      "text": "Нет, представитель."
    },
    {
      "start": 38.35,
      "end": 41.03,
      "speaker": null,
      "text": "Артём, мы, наверное, с вами общались с Валерией из Мостэнд."
    },
    {
      "start": 42.32,
      "end": 43.74,
      "speaker": null,
      "text": "Да-да-да, всё верно."
    },
    {
      "start": 44.84,
      "end": 54.06,
      "speaker": null,
      "text": "Вы просто, верно, написали нам на почту и у нас в этой же компании, но почему-то самое главное не можем найти на почте."
    },
    {
      "start": 54.94,
      "end": 57.8,
      "speaker": null,
      "text": "Ну, пишите на Телеграм, я вам отправлю, да."
    },
    {
      "start": 58.52,
      "end": 63.9,
      "speaker": null,
      "text": "Ага, хорошо. Давайте я вам сейчас напишу и я вам отправляю сейчас в Малик, потому что у нас уже есть переписка."
    },
    {
      "start": 64.32,
      "end": 65.58,
      "speaker": null,
      "text": "Вот, я вам цветочку отправила."
    },
    {
      "start": 66.18,
      "end": 66.52,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 67.12,
      "end": 68.86,
      "speaker": null,
      "text": "Угу, да, жду. Спасибо."
    },
    {
      "start": 68.86,
      "end": 69.04,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}