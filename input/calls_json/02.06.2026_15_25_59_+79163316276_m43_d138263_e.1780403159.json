      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 368.58,
      "end": 369.6,
      "speaker": null,
      "text": "И чего по чему?"
    },
    {
      "start": 370.85,
      "end": 375.57,
      "speaker": null,
      "text": "Если брать 85 на 200 – 4 500 инструкция плюс печать."
    },
    {
      "start": 376.56,
      "end": 376.98,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 377.4,
      "end": 377.82,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 377.98,
      "end": 379.58,
      "speaker": null,
      "text": "Ну давайте вот его ещё."
    },
    {
      "start": 381.06,
