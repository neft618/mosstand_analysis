{
  "file": "10.04.2026_13_11_47_79999624096_m21_d131723_2.1775815907.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 102.5,
  "segments": [
    {
      "start": 1.98,
      "end": 9.6,
      "speaker": null,
      "text": "Александр, здравствуйте. Причём у нас компания МОСТЕНД? Мы с вами общались по поводу вывески и просто так на почту направили в ТЗ полноценную."
    },
    {
      "start": 12.58,
      "end": 17.68,
      "speaker": null,
      "text": "Вы имеете в виду по поводу крыши? Да-да-да, чтобы примерно понимать, что нужно делать."
    },
    {
      "start": 17.94,
      "end": 22.64,
      "speaker": null,
      "text": "Я просто честно запутал, в организации много было. МОСТЕНД?"
    },
    {
      "start": 24.06,
      "end": 30.56,
      "speaker": null,
      "text": "Не знаю, вы не успеете, наверное, посчитать до 400 рублей. А сегодня? Не знаю, вряд ли тогда уже."
    },
    {
      "start": 31.78,
      "end": 34.16,
      "speaker": null,
      "text": "Ну, я не знаю. Есть смысл мне там отправить?"
    },
    {
      "start": 35.13,
      "end": 36.07,
      "speaker": null,
      "text": "Что в следующий раз?"
    },
    {
      "start": 36.31,
      "end": 41.5,
      "speaker": null,
      "text": "Я говорю, есть смысл мне отправлять, а тогда нет, но там струкция на до 4 часов."
    },
    {
      "start": 42.1,
      "end": 48.18,
      "speaker": null,
      "text": "Ну просто нужно понимать, с чем работает, т.е. нужно ТЗ, картинки, визуал, а так просто..."
    },
    {
      "start": 48.18,
      "end": 50.42,
      "speaker": null,
      "text": "А я вам дизайн проекта различного?"
    },
    {
      "start": 51.01,
      "end": 51.41,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 52.62,
      "end": 54.16,
      "speaker": null,
      "text": "Вы мне можете в МАКС написать?"
    },
    {
      "start": 55.32,
      "end": 56.88,
      "speaker": null,
      "text": "Пробовал, он у вас недоступен."
    },
    {
      "start": 58.52,
      "end": 60.06,
      "speaker": null,
      "text": "Вы сказали, на почту отправите?"
    },
    {
      "start": 61.5,
      "end": 64.5,
      "speaker": null,
      "text": "На ТЕЛЕГРАМ, по номеру телефона, который..."
    },
    {
      "start": 64.92,
      "end": 65.6,
      "speaker": null,
      "text": "Давайте проверим."
    },
    {
      "start": 65.62,
      "end": 66.56,
      "speaker": null,
      "text": "ТЕЛЕГРАМ у меня есть."
    },
    {
      "start": 67.75,
      "end": 71.19,
      "speaker": null,
      "text": "О, есть доступ вроде бы, уже ранее не было."
    },
    {
      "start": 73.01,
      "end": 73.93,
      "speaker": null,
      "text": "Сейчас вот пишу вам."
    },
    {
      "start": 74.23,
      "end": 87.12,
      "speaker": null,
      "text": "Я вам просто дизайн проект скину и вы по-быстрому посчитаете, за какую сумму вы его сделаете и в этот срок укладываете все мне..."
    },
    {
      "start": 88.98,
      "end": 90.3,
      "speaker": null,
      "text": "Что написал вам МАКС?"
    },
    {
      "start": 90.7,
      "end": 91.52,
      "speaker": null,
      "text": "Угу, спасибо."
    },
    {
      "start": 92.0,
      "end": 92.28,
      "speaker": null,
      "text": "МАКС?"
    },
    {
      "start": 92.34,
      "end": 92.48,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 93.18,
      "end": 94.08,
      "speaker": null,
      "text": "Да, да, в МАКСе."
    },
    {
      "start": 94.44,
      "end": 96.49,
      "speaker": null,
      "text": "Просто там был доступ быстрый."
    },
    {
      "start": 96.67,
      "end": 96.83,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 96.99,
      "end": 97.29,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 97.65,
      "end": 98.95,
      "speaker": null,
      "text": "А, ну вот все, я вижу."
    },
    {
      "start": 99.29,
      "end": 100.21,
      "speaker": null,
      "text": "Все, сейчас я вам написал."
    },
    {
      "start": 100.23,
      "end": 100.55,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 101.03,
      "end": 101.35,
      "speaker": null,
      "text": "Угу."
    }
  ]
}