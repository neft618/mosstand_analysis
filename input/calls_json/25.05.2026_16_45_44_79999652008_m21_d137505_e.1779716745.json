      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 222.97,
      "end": 223.01,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 223.31,
      "end": 223.43,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
