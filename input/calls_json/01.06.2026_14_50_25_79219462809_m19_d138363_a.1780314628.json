{
  "file": "01.06.2026_14_50_25_79219462809_m19_d138363_a.1780314628.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 441.9,
  "segments": [
    {
      "start": 1.1,
      "end": 3.18,
      "speaker": null,
      "text": "Компания «Мастэнк», меня зовут Влад, здравствуйте."
    },
    {
      "start": 4.46,
      "end": 18.4,
      "speaker": null,
      "text": "Здравствуйте, меня интересует Ваше предложение, которое тканью, где выставляются такие столбики и ткань между ними."
    },
    {
      "start": 19.0,
      "end": 20.44,
      "speaker": null,
      "text": "Что-то прислов на денег."
    },
    {
      "start": 21.26,
      "end": 22.2,
      "speaker": null,
      "text": "Ага, как Вам?"
    },
    {
      "start": 22.72,
      "end": 25.58,
      "speaker": null,
      "text": "Забор «Алтент», вот он у Вас так называется."
    },
    {
      "start": 26.65,
      "end": 28.23,
      "speaker": null,
      "text": "А, забор, да?"
    },
    {
      "start": 30.16,
      "end": 31.32,
      "speaker": null,
      "text": "Забор «Алтент»."
    },
    {
      "start": 31.7,
      "end": 32.26,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 38.6,
      "end": 40.82,
      "speaker": null,
      "text": "Может ли он быть высотой 2 метра?"
    },
    {
      "start": 43.0,
      "end": 44.1,
      "speaker": null,
      "text": "Секундочку, секундочку."
    },
    {
      "start": 46.44,
      "end": 47.78,
      "speaker": null,
      "text": "Отстроена позиция просто."
    },
    {
      "start": 57.72,
      "end": 62.95,
      "speaker": null,
      "text": "Так, ну нет, такая позиция идёт по стандарту именно 900."
    },
    {
      "start": 64.27,
      "end": 66.29,
      "speaker": null,
      "text": "А, то есть у неё максимально 100."
    },
    {
      "start": 67.62,
      "end": 68.2,
      "speaker": null,
      "text": "Понял."
    },
    {
      "start": 68.32,
      "end": 69.14,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 69.24,
      "end": 71.98,
      "speaker": null,
      "text": "А как Вы вообще хотите использовать такую позицию?"
    },
    {
      "start": 72.1,
      "end": 73.82,
      "speaker": null,
      "text": "То есть может быть я какую-то..."
    },
    {
      "start": 73.82,
      "end": 77.43,
      "speaker": null,
      "text": "В торговом центре поставишь."
    },
    {
      "start": 78.54,
      "end": 80.5,
      "speaker": null,
      "text": "Это будет просто как рекламный стенд, правильно?"
    },
    {
      "start": 81.44,
      "end": 82.0,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 82.7,
      "end": 84.0,
      "speaker": null,
      "text": "А ширину какую хотите?"
    },
    {
      "start": 85.8,
      "end": 86.56,
      "speaker": null,
      "text": "3х7."
    },
    {
      "start": 87.82,
      "end": 88.88,
      "speaker": null,
      "text": "Ой, 2х7."
    },
    {
      "start": 88.98,
      "end": 91.3,
      "speaker": null,
      "text": "Два высота и 7 метров длина."
    },
    {
      "start": 92.55,
      "end": 92.63,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 125.23,
      "end": 125.31,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 125.33,
      "end": 125.79,
      "speaker": null,
      "text": "Когда, знаете, когда..."
    },
    {
      "start": 126.59,
      "end": 129.23,
      "speaker": null,
      "text": "можно будет сделать 5 метров."
    },
    {
      "start": 129.23,
      "end": 130.09,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 133.38,
      "end": 139.68,
      "speaker": null,
      "text": "А если там 2 по 3,5 метра, чтобы общая 7 была?"
    },
    {
      "start": 139.68,
      "end": 145.95,
      "speaker": null,
      "text": "А, Вы имеете ввиду 3,5 ширину и 2 в длину, правильно?"
    },
    {
      "start": 146.05,
      "end": 146.53,
      "speaker": null,
      "text": "Ой, высоту."
    },
    {
      "start": 147.22,
      "end": 152.28,
      "speaker": null,
      "text": "Два в высоту и чтобы общая 7 в длину была."
    },
    {
      "start": 153.08,
      "end": 156.44,
      "speaker": null,
      "text": "То есть можно составить их нескольких, например."
    },
    {
      "start": 156.44,
      "end": 158.84,
      "speaker": null,
      "text": "А, да в целом конечно можно."
    },
    {
      "start": 159.38,
      "end": 162.0,
      "speaker": null,
      "text": "А это как стена будет у Вас, которая просто закрывается?"
    },
    {
      "start": 162.6,
      "end": 163.48,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 164.83,
      "end": 167.61,
      "speaker": null,
      "text": "Такие позиции можно будет составить из нескольких,"
    },
    {
      "start": 167.99,
      "end": 172.77,
      "speaker": null,
      "text": "просто рядом поставить их и они будут вместе выглядеть"
    },
    {
      "start": 172.77,
      "end": 174.51,
      "speaker": null,
      "text": "достаточно в общей композиции."
    },
    {
      "start": 174.51,
      "end": 176.89,
      "speaker": null,
      "text": "Там конструкция как собирается?"
    },
    {
      "start": 177.01,
      "end": 180.09,
      "speaker": null,
      "text": "Вы каркас сначала собираете по пронумерованным трубкам,"
    },
    {
      "start": 180.17,
      "end": 181.55,
      "speaker": null,
      "text": "то есть там соединяете друг с другом."
    },
    {
      "start": 181.85,
      "end": 184.65,
      "speaker": null,
      "text": "А сверху текстильное полотно надеваете, как наволочку."
    },
    {
      "start": 185.84,
      "end": 186.1,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 186.93,
      "end": 187.25,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 187.89,
      "end": 191.37,
      "speaker": null,
      "text": "Это текстильный стенд Altec F1?"
    },
    {
      "start": 192.09,
      "end": 193.25,
      "speaker": null,
      "text": "F1, все верно."
    },
    {
      "start": 194.52,
      "end": 194.8,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 195.44,
      "end": 197.76,
      "speaker": null,
      "text": "То есть если вы заходите на данную позицию,"
    },
    {
      "start": 197.86,
      "end": 200.1,
      "speaker": null,
      "text": "там в таблице тоже есть со мной,"
    },
    {
      "start": 200.18,
      "end": 201.1,
      "speaker": null,
      "text": "если вы на сайте у нас."
    },
    {
      "start": 201.83,
      "end": 202.59,
      "speaker": null,
      "text": "Да, на сайте."
    },
    {
      "start": 202.73,
      "end": 203.93,
      "speaker": null,
      "text": "Посмотрите, она надо нажать."
    },
    {
      "start": 203.96,
      "end": 206.24,
      "speaker": null,
      "text": "Да, здесь просто все указано будет."
    },
    {
      "start": 206.38,
      "end": 209.24,
      "speaker": null,
      "text": "И отдельная конструкция, и сколько будет с этой односторонней печати,"
    },
    {
      "start": 209.3,
      "end": 210.66,
      "speaker": null,
      "text": "если Вам односторонние не нужно."
    },
    {
      "start": 211.52,
      "end": 213.5,
      "speaker": null,
      "text": "Также можно выбрать двустороннее пожелание."
    },
    {
      "start": 214.1,
      "end": 217.3,
      "speaker": null,
      "text": "И как раз можно будет составить из двух одинаковых позиций,"
    },
    {
      "start": 217.34,
      "end": 218.54,
      "speaker": null,
      "text": "например по 3,5."
    },
    {
      "start": 220.05,
      "end": 225.15,
      "speaker": null,
      "text": "Ага, 2,5, 490, 2,300, да?"
    },
    {
      "start": 225.69,
      "end": 230.47,
      "speaker": null,
      "text": "3,490 это по множкам, то есть сколько длина ножек будет?"
    },
    {
      "start": 231.27,
      "end": 232.91,
      "speaker": null,
      "text": "Я помню, это ножки."
    },
    {
      "start": 232.91,
      "end": 235.95,
      "speaker": null,
      "text": "А то есть 2,300 это минимальная высота, да?"
    },
    {
      "start": 236.67,
      "end": 237.73,
      "speaker": null,
      "text": "Это минимальная высота."
    },
    {
      "start": 266.14,
      "end": 266.74,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 268.44,
      "end": 270.84,
      "speaker": null,
      "text": "3,5 на 2,300."
    },
    {
      "start": 271.14,
      "end": 276.06,
      "speaker": null,
      "text": "Это 69,800 это будет 1 стоить."
    },
    {
      "start": 277.69,
      "end": 281.91,
      "speaker": null,
      "text": "Да-да-да, 69,800 умножаем на 2, 139,600."
    },
    {
      "start": 282.49,
      "end": 286.93,
      "speaker": null,
      "text": "Так, и это Вы мне привозите, и я сам собираю, да?"
    },
    {
      "start": 286.93,
      "end": 289.02,
      "speaker": null,
      "text": "Да, и мы просто смотрите."
    },
    {
      "start": 289.14,
      "end": 292.42,
      "speaker": null,
      "text": "Мы на монтаж отдельно на такие позиции услуги не добавляем,"
    },
    {
      "start": 292.8,
      "end": 293.3,
      "speaker": null,
      "text": "как правило."
    },
    {
      "start": 293.48,
      "end": 293.94,
      "speaker": null,
      "text": "Почему?"
    },
    {
      "start": 294.08,
      "end": 299.72,
      "speaker": null,
      "text": "Потому что именно на таких позициях можно как в целом упразднить"
    },
    {
      "start": 299.72,
      "end": 303.1,
      "speaker": null,
      "text": "или оптимизировать бюджет, потому что собирается достаточно легко."
    },
    {
      "start": 303.1,
      "end": 307.52,
      "speaker": null,
      "text": "То есть там у Вас будет сумка размером 110 сантиметров,"
    },
    {
      "start": 307.8,
      "end": 310.76,
      "speaker": null,
      "text": "в ней лежит конструкция из трубок состоящей."
    },
    {
      "start": 310.82,
      "end": 313.78,
      "speaker": null,
      "text": "Она всегда пронумерована, Вы просто соединяете друг с другом эти трубки,"
    },
    {
      "start": 314.06,
      "end": 317.78,
      "speaker": null,
      "text": "а сверху сканевая полотна как наволочка надеваете внизу на замок застегиваете."
    },
    {
      "start": 318.71,
      "end": 319.23,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 320.44,
      "end": 323.68,
      "speaker": null,
      "text": "Так, это все ясно, 140 тысяч окей."
    },
    {
      "start": 324.04,
      "end": 326.34,
      "speaker": null,
      "text": "А еще момент такой, я в Питере нахожусь,"
    },
    {
      "start": 326.46,
      "end": 328.02,
      "speaker": null,
      "text": "Вы транспорт не сможете отправить?"
    },
    {
      "start": 329.01,
      "end": 333.99,
      "speaker": null,
      "text": "Конечно, а Вы в целом можете вызвать транспортную компанию любую,"
    },
    {
      "start": 334.17,
      "end": 336.01,
      "speaker": null,
      "text": "то есть курьера вызывайте к нам на адрес,"
    },
    {
      "start": 336.47,
      "end": 339.65,
      "speaker": null,
      "text": "он забирает и там даже доп. упаковка понадобится,"
    },
    {
      "start": 339.77,
      "end": 342.47,
      "speaker": null,
      "text": "потому что все будет упаковано в сумку."
    },
    {
      "start": 342.47,
      "end": 348.98,
      "speaker": null,
      "text": "А с ДЭКом сможете отвезти сами на пункты?"
    },
    {
      "start": 351.26,
      "end": 353.96,
      "speaker": null,
      "text": "Вам просто легче самому это будете делать даже."
    },
    {
      "start": 355.75,
      "end": 362.03,
      "speaker": null,
      "text": "То же самое, чтобы мы не включаем обычно счет курьерскую доставку."
    },
    {
      "start": 362.13,
      "end": 365.11,
      "speaker": null,
      "text": "Почему? Потому что у нас клиенты сами забирают любую транспортную компанию."
    },
    {
      "start": 365.17,
      "end": 368.15,
      "speaker": null,
      "text": "Они отправляют к нам курьера, курьеры называют номер заказа"
    },
    {
      "start": 369.1,
      "end": 371.28,
      "speaker": null,
      "text": "и его забирают на транспортную компанию."
    },
    {
      "start": 372.84,
      "end": 374.1,
      "speaker": null,
      "text": "Хорошо, спасибо. А с НДС?"
    },
    {
      "start": 375.1,
      "end": 377.26,
      "speaker": null,
      "text": "С НДС 22%, все верно."
    },
    {
      "start": 377.84,
      "end": 379.56,
      "speaker": null,
      "text": "А Вам готовые стенды когда будут нужны"
    },
    {
      "start": 379.56,
      "end": 381.58,
      "speaker": null,
      "text": "и когда Вы смогли бы макет предоставить?"
    },
    {
      "start": 382.84,
      "end": 386.42,
      "speaker": null,
      "text": "Пока нет информации, я сам рекламщик с Питера."
    },
    {
      "start": 387.02,
      "end": 389.0,
      "speaker": null,
      "text": "У Вас просто такое захотели."
    },
    {
      "start": 389.8,
      "end": 391.16,
      "speaker": null,
      "text": "Сейчас все буду выяснять,"
    },
    {
      "start": 391.26,
      "end": 394.14,
      "speaker": null,
      "text": "у нас тогда номер, как Вас зовут, чтобы на Вас потом попал второй."
    },
    {
      "start": 394.34,
      "end": 397.52,
      "speaker": null,
      "text": "Может быть я могу Вам куда-то в мессенджер по этому номеру написать?"
    },
    {
      "start": 397.78,
      "end": 401.12,
      "speaker": null,
      "text": "Я бы Вам кинул, как сумка выглядит, все вообще информация."
    },
    {
      "start": 401.5,
      "end": 402.7,
      "speaker": null,
      "text": "Отлично, давайте в Телеграм."
    },
    {
      "start": 402.7,
      "end": 405.1,
      "speaker": null,
      "text": "Все, в Телеграм когда напишу."
    },
    {
      "start": 405.26,
      "end": 408.4,
      "speaker": null,
      "text": "И когда сможем с Вами звонить по вопросам по данной позиции?"
    },
    {
      "start": 410.17,
      "end": 416.15,
      "speaker": null,
      "text": "Ну давайте, скидывайте все инфу, я передам заказчику и как решение будет, я отпишусь."
    },
    {
      "start": 417.18,
      "end": 418.04,
      "speaker": null,
      "text": "Хорошо, договорились."
    },
    {
      "start": 418.04,
      "end": 421.32,
      "speaker": null,
      "text": "Что же еще предварительно нужно будет предоставить?"
    },
    {
      "start": 422.06,
      "end": 423.48,
      "speaker": null,
      "text": "Ну, я имею в виду в качестве информации."
    },
    {
      "start": 423.56,
      "end": 424.66,
      "speaker": null,
      "text": "Нет, нет."
    },
    {
      "start": 425.18,
      "end": 427.3,
      "speaker": null,
      "text": "Просто пару фоток и все."
    },
    {
      "start": 428.64,
      "end": 429.26,
      "speaker": null,
      "text": "Все, отлично."
    },
    {
      "start": 429.66,
      "end": 431.26,
      "speaker": null,
      "text": "И на помощь, пожалуйста, с какого Вы обращаться?"
    },
    {
      "start": 432.09,
      "end": 432.59,
      "speaker": null,
      "text": "Антон."
    },
    {
      "start": 433.65,
      "end": 434.35,
      "speaker": null,
      "text": "Все, отлично."
    },
    {
      "start": 434.35,
      "end": 435.25,
      "speaker": null,
      "text": "Все, Антон."
    },
    {
      "start": 435.39,
      "end": 436.23,
      "speaker": null,
      "text": "Сейчас все направлю Вам."
    },
    {
      "start": 436.41,
      "end": 436.89,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 437.05,
      "end": 437.41,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 437.81,
      "end": 438.39,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 438.39,
      "end": 438.47,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 438.65,
      "end": 438.93,
      "speaker": null,
      "text": "Угу."
    }
  ]
}