{
  "file": "26.03.2026_12_58_14_79039790003_m27_d130069_6.1774519094.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 178.2,
  "segments": [
    {
      "start": 0.34,
      "end": 3.56,
      "speaker": null,
      "text": "Добрый день, я зовут Валентин, компания Матсанчева. Могу вам помочь?"
    },
    {
      "start": 3.94,
      "end": 4.92,
      "speaker": null,
      "text": "Да, здравствуйте."
    },
    {
      "start": 9.16,
      "end": 12.08,
      "speaker": null,
      "text": "Знаете что, мне нужно два рулапа."
    },
    {
      "start": 15.11,
      "end": 18.61,
      "speaker": null,
      "text": "Достаточно плохо вас слышал, услышал только, что необходимы рулапы."
    },
    {
      "start": 18.85,
      "end": 21.57,
      "speaker": null,
      "text": "Да-да-да, два рулапа, метр на два, метровые."
    },
    {
      "start": 23.25,
      "end": 25.17,
      "speaker": null,
      "text": "А как я могу к вам обращаться?"
    },
    {
      "start": 25.79,
      "end": 26.79,
      "speaker": null,
      "text": "Максим меня зовут."
    },
    {
      "start": 29.5,
      "end": 30.72,
      "speaker": null,
      "text": "Макета у вас уже готова?"
    },
    {
      "start": 30.72,
      "end": 37.96,
      "speaker": null,
      "text": "Не, мне не надо печатать, мы на самом деле ваши соседи, ну как соседи, со складом с вашими соседями."
    },
    {
      "start": 38.16,
      "end": 41.08,
      "speaker": null,
      "text": "На Красно-Богатырской у меня здесь тоже этот самый."
    },
    {
      "start": 42.6,
      "end": 42.98,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 43.9,
      "end": 45.6,
      "speaker": null,
      "text": "Вам необходимы интервент конструкции будут?"
    },
    {
      "start": 45.86,
      "end": 47.98,
      "speaker": null,
      "text": "Да-да-да, просто конструкция."
    },
    {
      "start": 49.36,
      "end": 51.18,
      "speaker": null,
      "text": "А классические или каприлетные?"
    },
    {
      "start": 51.6,
      "end": 53.18,
      "speaker": null,
      "text": "Не, обычные, обычные."
    },
    {
      "start": 55.37,
      "end": 55.95,
      "speaker": null,
      "text": "Классика."
    },
    {
      "start": 56.27,
      "end": 57.43,
      "speaker": null,
      "text": "Тогда они вам будут необходимы?"
    },
    {
      "start": 58.55,
      "end": 60.49,
      "speaker": null,
      "text": "Ну, как бы, необходимы уже."
    },
    {
      "start": 60.99,
      "end": 62.33,
      "speaker": null,
      "text": "А, уже необходимы."
    },
    {
      "start": 62.53,
      "end": 63.63,
      "speaker": null,
      "text": "Все хорошо, я вас понял."
    },
    {
      "start": 65.46,
      "end": 66.66,
      "speaker": null,
      "text": "Я понял-понял."
    },
    {
      "start": 67.92,
      "end": 70.26,
      "speaker": null,
      "text": "Получается у вас будут свои баня?"
    },
    {
      "start": 71.18,
      "end": 72.56,
      "speaker": null,
      "text": "Да-да, конечно, да."
    },
    {
      "start": 72.78,
      "end": 73.94,
      "speaker": null,
      "text": "Мы сами печатаем все."
    },
    {
      "start": 75.18,
      "end": 77.66,
      "speaker": null,
      "text": "Мы насколько знаем вы это и не печатаете по-моему."
    },
    {
      "start": 78.28,
      "end": 79.46,
      "speaker": null,
      "text": "Или вы не тут печатаете?"
    },
    {
      "start": 79.46,
      "end": 83.34,
      "speaker": null,
      "text": "Мы печатаем, но у нас склад исключительно вот для хранения."
    },
    {
      "start": 83.92,
      "end": 87.24,
      "speaker": null,
      "text": "Ну понятно, ну просто мы тут рядом со складом в вашем."
    },
    {
      "start": 88.68,
      "end": 89.08,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 90.32,
      "end": 91.34,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 93.12,
      "end": 96.98,
      "speaker": null,
      "text": "Так, Roll Up Classic 100 на 200, верно?"
    },
    {
      "start": 97.82,
      "end": 97.98,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 99.5,
      "end": 102.0,
      "speaker": null,
      "text": "Конструкция будет стоить 4000 рублей?"
    },
    {
      "start": 102.0,
      "end": 103.53,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 105.33,
      "end": 109.55,
      "speaker": null,
      "text": "Стойность входит непосредственно самоконструкция и сумка для переноса хранения."
    },
    {
      "start": 112.69,
      "end": 114.57,
      "speaker": null,
      "text": "Максим, спросите меня просто."
    },
    {
      "start": 115.09,
      "end": 117.15,
      "speaker": null,
      "text": "Мне для отчетности необходим этот вопрос."
    },
    {
      "start": 117.69,
      "end": 120.45,
      "speaker": null,
      "text": "У вас в каком формате будут проходить мероприятия?"
    },
    {
      "start": 120.59,
      "end": 122.55,
      "speaker": null,
      "text": "И чем непосредственно занимается ваша компания?"
    },
    {
      "start": 124.69,
      "end": 126.49,
      "speaker": null,
      "text": "Ну мы типография печатаем."
    },
    {
      "start": 126.49,
      "end": 126.81,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 130.71,
      "end": 131.73,
      "speaker": null,
      "text": "Хорошо, я понял."
    },
    {
      "start": 131.97,
      "end": 133.57,
      "speaker": null,
      "text": "Мероприятия кофейкового нету?"
    },
    {
      "start": 133.73,
      "end": 134.41,
      "speaker": null,
      "text": "Это заказ клиента?"
    },
    {
      "start": 135.19,
      "end": 135.91,
      "speaker": null,
      "text": "Да, да, конечно."
    },
    {
      "start": 138.09,
      "end": 140.05,
      "speaker": null,
      "text": "На выставку поедут в Краснодар."
    },
    {
      "start": 141.02,
      "end": 141.5,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 143.14,
      "end": 143.68,
      "speaker": null,
      "text": "Что я вас понял."
    },
    {
      "start": 143.9,
      "end": 147.58,
      "speaker": null,
      "text": "А как могу связаться с мессенджером, телеграммом, максом?"
    },
    {
      "start": 148.72,
      "end": 151.56,
      "speaker": null,
      "text": "Вы мне можете в макс написать почту свою."
    },
    {
      "start": 151.64,
      "end": 155.76,
      "speaker": null,
      "text": "Я сейчас реквизиты отправлю тогда и оплачу."
    },
    {
      "start": 157.03,
      "end": 158.79,
      "speaker": null,
      "text": "Потом как раз выберу."
    },
    {
      "start": 160.27,
      "end": 161.65,
      "speaker": null,
      "text": "Ага. Хорошо, хорошо."
    },
    {
      "start": 162.31,
      "end": 165.31,
      "speaker": null,
      "text": "Я тогда сейчас вам в максе по этому номеру разрешу, а то уже заканчивается."
    },
    {
      "start": 165.37,
      "end": 165.87,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 166.91,
      "end": 167.57,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 170.48,
      "end": 171.52,
      "speaker": null,
      "text": "Все хорошо тогда."
    },
    {
      "start": 174.4,
      "end": 175.28,
      "speaker": null,
      "text": "Спасибо вам."
    },
    {
      "start": 175.38,
      "end": 175.92,
      "speaker": null,
      "text": "Да, всего доброго."
    }
  ]
}