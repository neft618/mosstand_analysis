{
  "file": "18.05.2026_12_36_41_79652507925_m27_d75851_d.1779097002.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 88.0,
  "segments": [
    {
      "start": 0.5,
      "end": 1.06,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 2.0,
      "end": 5.16,
      "speaker": null,
      "text": "Евгения, добрый день, это Валентин Макцент. Я вашу письмо получил."
    },
    {
      "start": 5.82,
      "end": 21.02,
      "speaker": null,
      "text": "Да, смотрите, деньги на возврат мы поставили, ту сумму, которая остаточная. По роллапам я с Ириной когда общался, был предложен вариант, что мы переделаем эти роллапы в пользу того, что останутся те."
    },
    {
      "start": 21.02,
      "end": 33.56,
      "speaker": null,
      "text": "Я в плане типа, сейчас формулирую. Смотрите, мы переделаем эти роллапы, но те безвозвратные, и мы те вам также подготавливаем с новой цветопробой и с новым всем остальным."
    },
    {
      "start": 34.8,
      "end": 41.56,
      "speaker": null,
      "text": "Но вы приняли решение сделать возврат, и соответственно переделывать эти роллапы мы не будем."
    },
    {
      "start": 43.64,
      "end": 47.04,
      "speaker": null,
      "text": "Цветопробы утверждённой не было, я ничего с этим сделать не могу."
    },
    {
      "start": 49.96,
      "end": 52.14,
      "speaker": null,
      "text": "Я могу поговорить с Ириной, пообщаться."
    },
    {
      "start": 52.58,
      "end": 53.08,
      "speaker": null,
      "text": "Ну это да."
    },
    {
      "start": 53.16,
      "end": 54.36,
      "speaker": null,
      "text": "Но она сейчас в больнице."
    },
    {
      "start": 55.2,
      "end": 56.64,
      "speaker": null,
      "text": "Да, я понимаю."
    },
    {
      "start": 57.04,
      "end": 57.72,
      "speaker": null,
      "text": "В больнице?"
    },
    {
      "start": 58.54,
      "end": 62.1,
      "speaker": null,
      "text": "А, она, я так понимаю, она в больнице совсем, да?"
    },
    {
      "start": 62.76,
      "end": 64.7,
      "speaker": null,
      "text": "Ну пока да, в данный момент."
    },
    {
      "start": 66.2,
      "end": 67.92,
      "speaker": null,
      "text": "Это конечно лучше с ней."
    },
    {
      "start": 68.44,
      "end": 69.3,
      "speaker": null,
      "text": "Но я поняла."
    },
    {
      "start": 70.06,
      "end": 73.26,
      "speaker": null,
      "text": "Ладно, тогда скажи, если бы она связалась с вами."
    },
    {
      "start": 74.06,
      "end": 78.56,
      "speaker": null,
      "text": "Да, конечно, я просто с ней бы обсудил этот момент и уже..."
    },
    {
      "start": 78.62,
      "end": 78.86,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 79.08,
      "end": 80.24,
      "speaker": null,
      "text": "Всё, благодарю вас, Евгения."
    },
    {
      "start": 80.38,
      "end": 83.38,
      "speaker": null,
      "text": "Деньги вот буквально сегодня-завтра уже должны к вам вернуться."
    },
    {
      "start": 83.96,
      "end": 84.44,
      "speaker": null,
      "text": "Поняла."
    },
    {
      "start": 84.62,
      "end": 85.22,
      "speaker": null,
      "text": "Да, до свидания."
    },
    {
      "start": 85.62,
      "end": 86.26,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}