{
  "file": "12.03.2026_14_55_05_79266729210_m21_d128121_a.1773316506.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 212.6,
  "segments": [
    {
      "start": 0.75,
      "end": 3.37,
      "speaker": null,
      "text": "Компания «Москент», Артём, как мог к вам обращаться?"
    },
    {
      "start": 4.13,
      "end": 11.47,
      "speaker": null,
      "text": "Всем здравствуйте. Меня зовут Ангелина. Меня интересует буклетница с фотопанелью. Они у вас от одной штуки продаются?"
    },
    {
      "start": 12.41,
      "end": 13.39,
      "speaker": null,
      "text": "Да, можно, конечно."
    },
    {
      "start": 13.97,
      "end": 16.87,
      "speaker": null,
      "text": "А брендирование нанести вы тоже можете, да?"
    },
    {
      "start": 17.53,
      "end": 20.23,
      "speaker": null,
      "text": "Да-да-да. Какая интереса ещё можете сказать?"
    },
    {
      "start": 20.23,
      "end": 26.89,
      "speaker": null,
      "text": "Вот там, в буклетнице с фотопанелью, которая 12500 стоит с таким большим, ну, для..."
    },
    {
      "start": 28.3,
      "end": 34.04,
      "speaker": null,
      "text": "Как оно называется? Для плаката как бы, да, и сбоку три штучки такие стоят ещё для буклетов."
    },
    {
      "start": 34.32,
      "end": 35.42,
      "speaker": null,
      "text": "А, вы имеете в виду Стелла?"
    },
    {
      "start": 35.94,
      "end": 40.64,
      "speaker": null,
      "text": "Да, ну как она? Ну тут написано в буклетнице с фотопанелью у вас на сайте."
    },
    {
      "start": 42.86,
      "end": 46.48,
      "speaker": null,
      "text": "Только с фотопанелью и акриловыми карманами."
    },
    {
      "start": 46.48,
      "end": 48.58,
      "speaker": null,
      "text": "Да-да-да-да."
    },
    {
      "start": 48.66,
      "end": 51.68,
      "speaker": null,
      "text": "Так, а на какую дату необходимо?"
    },
    {
      "start": 52.64,
      "end": 56.36,
      "speaker": null,
      "text": "Ну, надо чтоб 19-го у нас было."
    },
    {
      "start": 56.98,
      "end": 59.52,
      "speaker": null,
      "text": "Ну край 20-го, но уже мероприятие, да."
    },
    {
      "start": 59.92,
      "end": 62.02,
      "speaker": null,
      "text": "Угу. Ну и соответственно лучше 19-го."
    },
    {
      "start": 62.46,
      "end": 63.8,
      "speaker": null,
      "text": "Да, лучше 15-го."
    },
    {
      "start": 64.56,
      "end": 68.26,
      "speaker": null,
      "text": "Да, естественно, смотрите, нужно будет макет подготовить требования на сайте,"
    },
    {
      "start": 68.46,
      "end": 70.14,
      "speaker": null,
      "text": "если так же продублировать."
    },
    {
      "start": 70.78,
      "end": 72.72,
      "speaker": null,
      "text": "Угу. Так, ещё..."
    },
    {
      "start": 73.24,
      "end": 74.88,
      "speaker": null,
      "text": "Скажите, вот Стелла просто..."
    },
    {
      "start": 74.88,
      "end": 78.3,
      "speaker": null,
      "text": "Стелла у вас тоже с таким вот стойко..."
    },
    {
      "start": 79.62,
      "end": 80.54,
      "speaker": null,
      "text": "Значит, 6500..."
    },
    {
      "start": 80.54,
      "end": 83.34,
      "speaker": null,
      "text": "А, ну там от 1000 штук, да, у вас они если поменьше?"
    },
    {
      "start": 84.14,
      "end": 85.24,
      "speaker": null,
      "text": "Да, да-да."
    },
    {
      "start": 86.3,
      "end": 87.32,
      "speaker": null,
      "text": "Они в таком тираже."
    },
    {
      "start": 88.02,
      "end": 91.24,
      "speaker": null,
      "text": "Так, а вот скажите, сколько будет слога стоить вот это вот"
    },
    {
      "start": 91.24,
      "end": 94.06,
      "speaker": null,
      "text": "с плакатом буклетница с фотопанелью?"
    },
    {
      "start": 94.16,
      "end": 98.0,
      "speaker": null,
      "text": "Ну вот, допустим, там что-то напечатано будет, чтоб мне надо в смету внестиру"
    },
    {
      "start": 98.0,
      "end": 98.86,
      "speaker": null,
      "text": "с руководством сейчас."
    },
    {
      "start": 98.96,
      "end": 102.5,
      "speaker": null,
      "text": "А, ну да, вы берёте, соответственно, стойкость 7-й стойки,"
    },
    {
      "start": 102.84,
      "end": 105.12,
      "speaker": null,
      "text": "ну буклетку, и выбираете печать."
    },
    {
      "start": 105.56,
      "end": 106.98,
      "speaker": null,
      "text": "Какие-то три варианта, соответственно, есть."
    },
    {
      "start": 108.01,
      "end": 109.81,
      "speaker": null,
      "text": "А печать где-то посмотрите?"
    },
    {
      "start": 110.51,
      "end": 112.19,
      "speaker": null,
      "text": "А вот, вы смотрите, вы заходите в Сантовар."
    },
    {
      "start": 113.02,
      "end": 113.64,
      "speaker": null,
      "text": "В Сантовар?"
    },
    {
      "start": 114.14,
      "end": 114.6,
      "speaker": null,
      "text": "Подробнее, да."
    },
    {
      "start": 115.36,
      "end": 116.08,
      "speaker": null,
      "text": "Подробнее, ага."
    },
    {
      "start": 116.44,
      "end": 117.76,
      "speaker": null,
      "text": "Да-да-да, и смотрите, да..."
    },
    {
      "start": 117.76,
      "end": 118.76,
      "speaker": null,
      "text": "А, вот баннер?"
    },
    {
      "start": 119.32,
      "end": 119.78,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 120.5,
      "end": 122.92,
      "speaker": null,
      "text": "Ну там простой удобный, но это баннер, соответственно."
    },
    {
      "start": 123.62,
      "end": 123.92,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 125.09,
      "end": 126.53,
      "speaker": null,
      "text": "Всё, ага, поняла."
    },
    {
      "start": 126.53,
      "end": 129.99,
      "speaker": null,
      "text": "Смотрите, писаться на Телеграм, он себя продублирует на всякий случай."
    },
    {
      "start": 130.15,
      "end": 132.89,
      "speaker": null,
      "text": "Так, потребность 19 марта где будет находиться?"
    },
    {
      "start": 133.53,
      "end": 134.15,
      "speaker": null,
      "text": "МОСФИЛЬМ."
    },
    {
      "start": 134.45,
      "end": 137.31,
      "speaker": null,
      "text": "МОСФИЛЬМ в помещении, МОСФИЛЬМ кинотеатр сам."
    },
    {
      "start": 137.67,
      "end": 138.99,
      "speaker": null,
      "text": "Угу, МОСФИЛЬМ."
    },
    {
      "start": 139.67,
      "end": 142.93,
      "speaker": null,
      "text": "Помимо буклетницы у меня потребуется полиграфия и суверенная продукция?"
    },
    {
      "start": 144.15,
      "end": 147.39,
      "speaker": null,
      "text": "Так, ну пока не знаю, пока мне сказали найти буклетницу,"
    },
    {
      "start": 147.67,
      "end": 149.89,
      "speaker": null,
      "text": "чтобы с брендированием можно было сделать."
    },
    {
      "start": 150.77,
      "end": 154.77,
      "speaker": null,
      "text": "Варианты мне им надо предложить, но это мне показалось интересным."
    },
    {
      "start": 154.85,
      "end": 156.91,
      "speaker": null,
      "text": "Может что-то попроще просто с какими-то..."
    },
    {
      "start": 158.63,
      "end": 161.43,
      "speaker": null,
      "text": "А кто будет именно, я так понял, афишей?"
    },
    {
      "start": 161.53,
      "end": 168.01,
      "speaker": null,
      "text": "Ну там премьера фильма будет и надо туда, видно, какие-то положить, не знаю."
    },
    {
      "start": 168.01,
      "end": 168.81,
      "speaker": null,
      "text": "А, я понял."
    },
    {
      "start": 168.91,
      "end": 171.15,
      "speaker": null,
      "text": "Чтобы было афиши и рекламки можно было разбираться."
    },
    {
      "start": 171.37,
      "end": 171.91,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 172.49,
      "end": 174.45,
      "speaker": null,
      "text": "Всё, да, Варен Хорошенко, давайте как?"
    },
    {
      "start": 174.79,
      "end": 177.97,
      "speaker": null,
      "text": "Я продублирую всё это вам на всякий случай на телефон."
    },
    {
      "start": 178.9,
      "end": 179.42,
      "speaker": null,
      "text": "Да, давайте."
    },
    {
      "start": 179.7,
      "end": 180.6,
      "speaker": null,
      "text": "Звоните с вами тогда."
    },
    {
      "start": 181.78,
      "end": 185.0,
      "speaker": null,
      "text": "Вы мне продублируйте, если они окнут, я вам напишу."
    },
    {
      "start": 185.84,
      "end": 187.5,
      "speaker": null,
      "text": "Хорошо, ну да, для себя чтобы тоже знать."
    },
    {
      "start": 187.88,
      "end": 188.36,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 190.98,
      "end": 194.16,
      "speaker": null,
      "text": "Либо на само мероприятие уже перевести на 20-го."
    },
    {
      "start": 194.16,
      "end": 194.64,
      "speaker": null,
      "text": "Ну заранее."
    },
    {
      "start": 194.64,
      "end": 195.58,
      "speaker": null,
      "text": "В какое-то время, да."
    },
    {
      "start": 196.28,
      "end": 197.16,
      "speaker": null,
      "text": "Да, хорошо, всё."
    },
    {
      "start": 197.26,
      "end": 198.2,
      "speaker": null,
      "text": "А доставка потребуется?"
    },
    {
      "start": 198.69,
      "end": 199.59,
      "speaker": null,
      "text": "Да, обязательно."
    },
    {
      "start": 200.27,
      "end": 201.39,
      "speaker": null,
      "text": "Всё, хорошо, тоже заставка."
    },
    {
      "start": 201.78,
      "end": 203.66,
      "speaker": null,
      "text": "Всё, сейчас отпишусь полноценно, всё."
    },
    {
      "start": 203.98,
      "end": 205.04,
      "speaker": null,
      "text": "И направляю."
    },
    {
      "start": 205.08,
      "end": 206.36,
      "speaker": null,
      "text": "Фигра может быть по этому номеру?"
    },
    {
      "start": 206.48,
      "end": 207.54,
      "speaker": null,
      "text": "Да, да, конечно."
    },
    {
      "start": 207.82,
      "end": 208.32,
      "speaker": null,
      "text": "Всё, супер."
    },
    {
      "start": 208.96,
      "end": 209.44,
      "speaker": null,
      "text": "Всего доброго."
    },
    {
      "start": 210.02,
      "end": 210.78,
      "speaker": null,
      "text": "Всего доброго."
    }
  ]
}