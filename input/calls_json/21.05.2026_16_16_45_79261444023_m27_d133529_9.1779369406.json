{
  "file": "21.05.2026_16_16_45_79261444023_m27_d133529_9.1779369406.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 163.7,
  "segments": [
    {
      "start": 1.12,
      "end": 3.18,
      "speaker": null,
      "text": "Денис, да, я вас слышу."
    },
    {
      "start": 4.02,
      "end": 15.15,
      "speaker": null,
      "text": "Валентин, добрый день еще раз. Посмотрите, поскольку мы с вами начали бумаги обмениваться, всё остальное тоже на бумаге. УПД надо на бумаге будет."
    },
    {
      "start": 15.65,
      "end": 24.53,
      "speaker": null,
      "text": "УПД на бумаге надо будет? Хорошо, я тогда передам на склад при отправлении с документами."
    },
    {
      "start": 24.53,
      "end": 30.95,
      "speaker": null,
      "text": "Да, хорошо. Я понял. Ну всё тогда, вопросов у нас вроде нет. А макет-то вы мне так и не прислали?"
    },
    {
      "start": 31.23,
      "end": 32.53,
      "speaker": null,
      "text": "Я вам только что..."
    },
    {
      "start": 33.49,
      "end": 33.97,
      "speaker": null,
      "text": "Отправили?"
    },
    {
      "start": 34.47,
      "end": 41.79,
      "speaker": null,
      "text": "Да, смотрите, там я вам последнюю фотографию прислал, у вас может градиент на фоне немножко полотеть."
    },
    {
      "start": 43.64,
      "end": 44.1,
      "speaker": null,
      "text": "Почему?"
    },
    {
      "start": 45.66,
      "end": 57.7,
      "speaker": null,
      "text": "У вас, ну из-за градиента необходимо, если вы хотите избавиться от того, чтобы он полотил, необходимо дизайнеру накинуть 2-3% шума на фон добавить."
    },
    {
      "start": 62.02,
      "end": 63.08,
      "speaker": null,
      "text": "Так, это что значит?"
    },
    {
      "start": 65.03,
      "end": 69.71,
      "speaker": null,
      "text": "У дизайнеров есть фильтр дополнительный, называется шум."
    },
    {
      "start": 70.65,
      "end": 71.07,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 71.51,
      "end": 76.86,
      "speaker": null,
      "text": "И необходимо добавить 2-3% только на фон на обоих макетах."
    },
    {
      "start": 77.0,
      "end": 78.5,
      "speaker": null,
      "text": "Так, это который маленький, правильно?"
    },
    {
      "start": 79.1,
      "end": 79.64,
      "speaker": null,
      "text": "Оба."
    },
    {
      "start": 80.64,
      "end": 82.6,
      "speaker": null,
      "text": "А у меня что, оба с градиентами?"
    },
    {
      "start": 83.28,
      "end": 86.66,
      "speaker": null,
      "text": "Оба с градиентами, да, там с белого в зелёный же переход."
    },
    {
      "start": 87.46,
      "end": 87.96,
      "speaker": null,
      "text": "Блин."
    },
    {
      "start": 88.54,
      "end": 90.32,
      "speaker": null,
      "text": "Так, и что надо сделать? Шума добавить?"
    },
    {
      "start": 90.5,
      "end": 92.16,
      "speaker": null,
      "text": "Да, на фон, 2-3%."
    },
    {
      "start": 92.16,
      "end": 94.28,
      "speaker": null,
      "text": "А вы можете это добавить?"
    },
    {
      "start": 94.28,
      "end": 100.88,
      "speaker": null,
      "text": "К сожалению нет, потому что файлы же идут уже в этом, в тифе."
    },
    {
      "start": 101.4,
      "end": 105.2,
      "speaker": null,
      "text": "А, в тифе. То есть вам надо шума добавить 2-3%, да?"
    },
    {
      "start": 105.34,
      "end": 105.52,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 105.58,
      "end": 106.16,
      "speaker": null,
      "text": "На градиент."
    },
    {
      "start": 106.5,
      "end": 107.62,
      "speaker": null,
      "text": "Да, все верно."
    },
    {
      "start": 108.0,
      "end": 109.4,
      "speaker": null,
      "text": "На фон только, только на фон."
    },
    {
      "start": 109.5,
      "end": 110.84,
      "speaker": null,
      "text": "На всю картинку не нужно."
    },
    {
      "start": 112.97,
      "end": 125.67,
      "speaker": null,
      "text": "Добавить на фон шума 2-3%, чтобы градиент не полотил, да?"
    },
    {
      "start": 126.15,
      "end": 127.35,
      "speaker": null,
      "text": "Да, да, все верно."
    },
    {
      "start": 129.27,
      "end": 129.73,
      "speaker": null,
      "text": "Чур."
    },
    {
      "start": 131.17,
      "end": 131.81,
      "speaker": null,
      "text": "Градиент."
    },
    {
      "start": 137.06,
      "end": 139.52,
      "speaker": null,
      "text": "Тогда подождите, я сейчас узнаю сможет она."
    },
    {
      "start": 139.76,
      "end": 141.84,
      "speaker": null,
      "text": "А прям это что, визуально будет сильно видно?"
    },
    {
      "start": 142.32,
      "end": 142.72,
      "speaker": null,
      "text": "Полоситка?"
    },
    {
      "start": 142.82,
      "end": 146.42,
      "speaker": null,
      "text": "Ооо, и я вам прислал пример в реальном размере."
    },
    {
      "start": 147.19,
      "end": 147.87,
      "speaker": null,
      "text": "Это где?"
    },
    {
      "start": 148.11,
      "end": 149.09,
      "speaker": null,
      "text": "А, вот все."
    },
    {
      "start": 149.21,
      "end": 150.13,
      "speaker": null,
      "text": "Вот этот кусочек, да?"
    },
    {
      "start": 150.39,
      "end": 150.89,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 151.03,
      "end": 153.93,
      "speaker": null,
      "text": "Это в реальном размере, поэтому может быть заметно."
    },
    {
      "start": 154.64,
      "end": 155.9,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 156.87,
      "end": 157.19,
      "speaker": null,
      "text": "Понятно."
    },
    {
      "start": 157.65,
      "end": 158.79,
      "speaker": null,
      "text": "Ладно, сейчас я ее наберу."
    },
    {
      "start": 159.27,
      "end": 159.61,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 159.73,
      "end": 160.37,
      "speaker": null,
      "text": "Все благодарю."
    },
    {
      "start": 160.37,
      "end": 161.29,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 161.43,
      "end": 162.09,
      "speaker": null,
      "text": "Давайте сейчас."
    },
    {
      "start": 162.21,
      "end": 162.43,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 162.43,
      "end": 162.45,
      "speaker": null,
      "text": "Угу."
    }
  ]
