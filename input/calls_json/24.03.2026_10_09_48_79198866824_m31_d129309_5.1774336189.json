{
  "file": "24.03.2026_10_09_48_79198866824_m31_d129309_5.1774336189.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 63.6,
  "segments": [
    {
      "start": 0.3,
      "end": 6.31,
      "speaker": null,
      "text": "Алло. Здравствуйте, Виктория, это Валерия из Москвы. Вы оставляли обратный звонок у нас на сайте."
    },
    {
      "start": 7.95,
      "end": 11.27,
      "speaker": null,
      "text": "Доброе утро. А ещё раз, пожалуйста, проговорите компанию, я слышала."
    },
    {
      "start": 11.94,
      "end": 15.56,
      "speaker": null,
      "text": "Компания может заниматься мобильным выставочным оборудованием."
    },
    {
      "start": 17.11,
      "end": 31.48,
      "speaker": null,
      "text": "Ага, поняла. Да, подскажите, пожалуйста, у вас есть опция доставки именно просто мебели? Не чтобы её арендовать у вас?"
    },
    {
      "start": 33.33,
      "end": 35.53,
      "speaker": null,
      "text": "А какой мебели?"
    },
    {
      "start": 38.92,
      "end": 42.16,
      "speaker": null,
      "text": "Пара столиков, кресла, диван там, стул."
    },
    {
      "start": 43.31,
      "end": 45.91,
      "speaker": null,
      "text": "Вам, наверное, нужно обращаться грузчиком не к нам."
    },
    {
      "start": 46.13,
      "end": 50.91,
      "speaker": null,
      "text": "Мы предоставляем оборудование и можем его доставить, но просто так мы как бы не доставляем мебель."
    },
    {
      "start": 51.17,
      "end": 51.73,
      "speaker": null,
      "text": "Мостки."
    },
    {
      "start": 54.2,
      "end": 55.98,
      "speaker": null,
      "text": "Так, хорошо, спасибо."
    },
    {
      "start": 57.68,
      "end": 59.12,
      "speaker": null,
      "text": "Да, тогда вам всего доброго."
    },
    {
      "start": 60.02,
      "end": 60.7,
      "speaker": null,
      "text": "Хорошего дня."
    },
    {
      "start": 61.18,
      "end": 62.38,
      "speaker": null,
      "text": "Хорошего дня, до свидания."
    }
  ]
}