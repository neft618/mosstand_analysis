  "segments": [
    {
      "start": 1.74,
      "end": 2.9,
      "speaker": null,
      "text": "Павел Анна, здравствуйте."
    },
    {
      "start": 3.86,
      "end": 7.02,
      "speaker": null,
      "text": "Владислав, простите, была срочная кризисная ситуация."
    },
    {
      "start": 7.7,
      "end": 8.46,
      "speaker": null,
      "text": "Да, я понимаю."
    },
    {
      "start": 12.24,
      "end": 16.54,
      "speaker": null,
      "text": "У вас возникли вопросы по Сигволу, правильно?"
    },
    {
      "start": 18.4,
      "end": 19.78,
      "speaker": null,
      "text": "Как её ещё раз именно звали?"
    },
    {
      "start": 20.46,
      "end": 22.26,
      "speaker": null,
      "text": "Сигвол, который вы..."
    },
    {
      "start": 22.26,
      "end": 23.46,
      "speaker": null,
      "text": "Да-да-да-да."
    },
    {
      "start": 23.8,
      "end": 30.58,
      "speaker": null,
      "text": "С вами, возможно, общалась уже моя коллега, не знаю, вы фиксируете или нет, Дарья Чугай, возможно, даже она запрашивала форму договора."
    },
    {
      "start": 30.58,
      "end": 32.8,
      "speaker": null,
      "text": "Давайте сразу проверим, чтобы..."
    },
    {
      "start": 32.8,
      "end": 32.96,
      "speaker": null,
      "text": "Одну секунду."
    },
    {
      "start": 34.26,
      "end": 37.24,
      "speaker": null,
      "text": "Московский авиационный институт, Дарья с вами общалась."
    },
    {
      "start": 37.5,
      "end": 41.46,
      "speaker": null,
      "text": "Она просто в отпуске и я, чтобы не терять время, решила переходить..."
    },
    {
      "start": 41.46,
      "end": 41.6,
      "speaker": null,
      "text": "А как она меня?"
    },
    {
      "start": 42.16,
      "end": 42.8,
      "speaker": null,
      "text": "Чугай."
    },
    {
      "start": 44.06,
      "end": 50.59,
      "speaker": null,
      "text": "Сейчас посмотрю."
    },
    {
      "start": 51.59,
      "end": 55.59,
      "speaker": null,
      "text": "Я могу по номеру телефона сказать, она сто процентов ушла, потому что она вас нашла."
    },
    {
      "start": 56.85,
      "end": 62.15,
      "speaker": null,
      "text": "И я пришёл её к договору запросить, сейчас секунду, я найду номер Чугай."
    },
    {
      "start": 64.3,
      "end": 64.94,
      "speaker": null,
      "text": "992"
    },
    {
      "start": 65.72,
      "end": 66.28,
      "speaker": null,
      "text": "992"
    },
    {
      "start": 66.84,
      "end": 67.7,
      "speaker": null,
      "text": "3-3-4"
    },
    {
      "start": 68.42,
      "end": 69.76,
      "speaker": null,
      "text": "3-3-4"
    },
    {
      "start": 69.76,
      "end": 71.96,
      "speaker": null,
      "text": "6-4-9-9"
    },
    {
      "start": 72.19,
      "end": 74.19,
