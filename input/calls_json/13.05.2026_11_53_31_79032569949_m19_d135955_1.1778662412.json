{
  "file": "13.05.2026_11_53_31_79032569949_m19_d135955_1.1778662412.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 328.5,
  "segments": [
    {
      "start": 1.52,
      "end": 3.4,
      "speaker": null,
      "text": "Компания «Мастер». Здравствуйте."
    },
    {
      "start": 6.11,
      "end": 21.49,
      "speaker": null,
      "text": "Скажите, пожалуйста, мы хотели бы заказать вот скачек своим логотипом и также вот роллап и папку бумажную, чтобы было, скажем, айдентика."
    },
    {
      "start": 22.18,
      "end": 32.58,
      "speaker": null,
      "text": "Скажите, а из какой ткани сделано? И может ли менеджер выехать, показать нам качество и ткани, которая нескользящая была, да, что и вода непроницаема была?"
    },
    {
      "start": 33.09,
      "end": 37.17,
      "speaker": null,
      "text": "Ну, мы можем только посоветовать определённую ткань, которую чаще всего заказывают."
    },
    {
      "start": 37.69,
      "end": 38.73,
      "speaker": null,
      "text": "С какой ткани выехать?"
    },
    {
      "start": 39.17,
      "end": 41.83,
      "speaker": null,
      "text": "С какой габардины обычно в ткани заказывают."
    },
    {
      "start": 41.83,
      "end": 42.17,
      "speaker": null,
      "text": "Вот такая."
    },
    {
      "start": 44.96,
      "end": 46.2,
      "speaker": null,
      "text": "Сейчас, секундочку."
    },
    {
      "start": 47.26,
      "end": 49.62,
      "speaker": null,
      "text": "Это белорусский габардин или Китай, конечно."
    },
    {
      "start": 50.76,
      "end": 52.02,
      "speaker": null,
      "text": "Этого точно не уточню."
    },
    {
      "start": 52.97,
      "end": 54.77,
      "speaker": null,
      "text": "Они же скончайшие, они скользят."
    },
    {
      "start": 55.21,
      "end": 59.91,
      "speaker": null,
      "text": "Так, 240 грамм."
    },
    {
      "start": 61.81,
      "end": 68.29,
      "speaker": null,
      "text": "Понимаю, скользит сентричкой 100% или свистовка?"
    },
    {
      "start": 69.57,
      "end": 72.67,
      "speaker": null,
      "text": "Нет-нет, настолько углубленной я вам не смогу помочь."
    },
    {
      "start": 72.67,
      "end": 73.25,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 73.64,
      "end": 77.68,
      "speaker": null,
      "text": "Нужно бы её записать, потому что свист скользит, то будем постоянно поправлять."
    },
    {
      "start": 79.3,
      "end": 81.96,
      "speaker": null,
      "text": "Сейчас это на столк идёт, скажем так, с логотипом."
    },
    {
      "start": 82.1,
      "end": 83.28,
      "speaker": null,
      "text": "Знаешь, должно быть..."
    },
    {
      "start": 83.44,
      "end": 87.6,
      "speaker": null,
      "text": "Я не говорю, что под него нужно мулетон, да, чтобы не скользнуло."
    },
    {
      "start": 88.43,
      "end": 89.93,
      "speaker": null,
      "text": "А нужна сама ткань тоже цеплялась."
    },
    {
      "start": 90.65,
      "end": 96.86,
      "speaker": null,
      "text": "Когда есть, когда не будет туда-сюда."
    },
    {
      "start": 99.46,
      "end": 101.52,
      "speaker": null,
      "text": "А по поводу рулапа, а что происходит?"
    },
    {
      "start": 101.78,
      "end": 103.1,
      "speaker": null,
      "text": "Вы сами производите откуда?"
    },
    {
      "start": 103.54,
      "end": 104.58,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 104.66,
      "end": 105.34,
      "speaker": null,
      "text": "Сами всё делаем."
    },
    {
      "start": 106.0,
      "end": 108.86,
      "speaker": null,
      "text": "Там видите, я видел там, которые без ножек."
    },
    {
      "start": 109.47,
      "end": 110.93,
      "speaker": null,
      "text": "Там где-то нужно видеть..."
    },
    {
      "start": 110.93,
      "end": 114.94,
      "speaker": null,
      "text": "А вообще где-то есть шоурум приезжать посмотреть, как выйдет?"
    },
    {
      "start": 115.04,
      "end": 117.42,
      "speaker": null,
      "text": "На битонах 5 метров 2 или на втором?"
    },
    {
      "start": 118.54,
      "end": 120.24,
      "speaker": null,
      "text": "Нет, самого шоурума нету."
    },
    {
      "start": 121.54,
      "end": 123.29,
      "speaker": null,
      "text": "Ну почему нету?"
    },
    {
      "start": 123.29,
      "end": 124.87,
      "speaker": null,
      "text": "Ну а как же тогда?"
    },
    {
      "start": 125.92,
      "end": 126.82,
      "speaker": null,
      "text": "Да либо менеджер выезжает?"
    },
    {
      "start": 130.56,
      "end": 131.0,
      "speaker": null,
      "text": "Нет, нет."
    },
    {
      "start": 131.12,
      "end": 131.82,
      "speaker": null,
      "text": "Менеджер не выезжает."
    },
    {
      "start": 131.9,
      "end": 133.46,
      "speaker": null,
      "text": "Ну рулап стандартная позиция."
    },
    {
      "start": 133.62,
      "end": 136.18,
      "speaker": null,
      "text": "Никто не приезжает смотреть на конструкцию рулапа."
    },
    {
      "start": 138.26,
      "end": 142.44,
      "speaker": null,
      "text": "Мы хотим теперь по вашему знать."
    },
    {
      "start": 147.96,
      "end": 149.8,
      "speaker": null,
      "text": "Я по машине авторит, пожалуйста, не слышал вас."
    },
    {
      "start": 150.9,
      "end": 158.53,
      "speaker": null,
      "text": "Я говорю, у вас написано там утяжелителем с логотипом."
    },
    {
      "start": 159.23,
      "end": 160.87,
      "speaker": null,
      "text": "Вы рассматриваете каплевидный?"
    },
    {
      "start": 162.69,
      "end": 163.79,
      "speaker": null,
      "text": "Каплевидный рассматриваете?"
    },
    {
      "start": 164.32,
      "end": 165.14,
      "speaker": null,
      "text": "Ну я не знаю."
    },
    {
      "start": 165.4,
      "end": 168.38,
      "speaker": null,
      "text": "Я посмотрю, да, типа какой-то образный что ли."
    },
    {
      "start": 169.02,
      "end": 171.14,
      "speaker": null,
      "text": "То есть все стоят на площадке на здоровье."
    },
    {
      "start": 210.21,
      "end": 214.74,
      "speaker": null,
      "text": "Уписано, есть у вас стандартный."
    },
    {
      "start": 214.74,
      "end": 220.35,
      "speaker": null,
      "text": "Сейчас есть вайс каплевидный."
    },
    {
      "start": 221.0,
      "end": 223.08,
      "speaker": null,
      "text": "Да, да, каплевидный вайсбейс."
    },
    {
      "start": 223.16,
      "end": 227.96,
      "speaker": null,
      "text": "Они отличаются от классического отсутствия ножек и более утешленным основанием в форме капли."
    },
    {
      "start": 228.42,
      "end": 230.4,
      "speaker": null,
      "text": "То есть не будет шататься мутация? Правильно?"
    },
    {
      "start": 231.13,
      "end": 232.43,
      "speaker": null,
      "text": "Нет, нет, нет."
    },
    {
      "start": 232.53,
      "end": 236.95,
      "speaker": null,
      "text": "Благодаря самой форме основания он будет держаться достаточно устойчиво."
    },
    {
      "start": 237.01,
      "end": 241.63,
      "speaker": null,
      "text": "Такие чаще заказывают, когда планируют устанавливать рулапы на улицу, потому что..."
    },
    {
      "start": 241.63,
      "end": 246.58,
      "speaker": null,
      "text": "Возможно, нам и другой подойдет."
    },
    {
      "start": 246.7,
      "end": 247.44,
      "speaker": null,
      "text": "Видите, надо видеть."
    },
    {
      "start": 248.0,
      "end": 249.36,
      "speaker": null,
      "text": "Нам нужно для семинара."
    },
    {
      "start": 250.38,
      "end": 253.18,
      "speaker": null,
      "text": "Во время семинара рядом будет со столом инфостойка."
    },
    {
      "start": 253.58,
      "end": 255.06,
      "speaker": null,
      "text": "Вот это стол с логотипом."
    },
    {
      "start": 256.3,
      "end": 257.46,
      "speaker": null,
      "text": "И да, чтобы там били."
    },
    {
      "start": 258.37,
      "end": 259.75,
      "speaker": null,
      "text": "Нам для этого нужно."
    },
    {
      "start": 259.97,
      "end": 263.21,
      "speaker": null,
      "text": "Если на улице вверх не склонируем это..."
    },
    {
      "start": 266.41,
      "end": 268.95,
      "speaker": null,
      "text": "Поэтому надо видеть."
    },
    {
      "start": 271.28,
      "end": 273.54,
      "speaker": null,
      "text": "Я могу фотографии прислать."
    },
    {
      "start": 274.39,
      "end": 275.75,
      "speaker": null,
      "text": "Фотографии ни о чем не говорить."
    },
    {
      "start": 275.97,
      "end": 277.17,
      "speaker": null,
      "text": "Я могу, но увидим."
    },
    {
      "start": 277.23,
      "end": 278.37,
      "speaker": null,
      "text": "Я вижу фотографии здесь."
    },
    {
      "start": 281.84,
      "end": 287.59,
      "speaker": null,
      "text": "И у нас достаточно вот такая вещь, что вряд ли на ножке кто-то наступит в фонерах."
    },
    {
      "start": 289.15,
      "end": 294.51,
      "speaker": null,
      "text": "Унимать людей подальше в полметра и совсем было."
    },
    {
      "start": 298.48,
      "end": 299.22,
      "speaker": null,
      "text": "На семинаре, чтобы..."
    },
    {
      "start": 302.71,
      "end": 303.55,
      "speaker": null,
      "text": "Да, я понял, понял."
    },
    {
      "start": 315.14,
      "end": 315.64,
      "speaker": null,
      "text": "Понимаю, да."
    },
    {
      "start": 316.0,
      "end": 318.72,
      "speaker": null,
      "text": "Но к сожалению просто..."
    },
    {
      "start": 326.3,
      "end": 326.84,
      "speaker": null,
      "text": "Хорошо, до свидания."
    }
  ]
}