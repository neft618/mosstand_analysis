{
  "file": "12.05.2026_15_22_03_79188920632_m27_d135305_8.1778588524.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 296.1,
  "segments": [
    {
      "start": 0.5,
      "end": 2.38,
      "speaker": null,
      "text": "Да, Инна, здравствуйте, это Валентин."
    },
    {
      "start": 2.88,
      "end": 4.6,
      "speaker": null,
      "text": "Да, Валентин, ага, здрасте ещё раз."
    },
    {
      "start": 5.08,
      "end": 8.84,
      "speaker": null,
      "text": "Да, смотрите, я уточнил на складе, на данный момент у нас Света нету."
    },
    {
      "start": 9.96,
      "end": 10.4,
      "speaker": null,
      "text": "Блин!"
    },
    {
      "start": 11.0,
      "end": 11.96,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 12.0,
      "end": 23.42,
      "speaker": null,
      "text": "Я здесь спрашивала, потому что вторая, вторые ваши ребята, ну, первые, ну, потому что я говорила, эти ждут Свет, когда придётся в таможне. Ну, ни хрена не пришёл ещё сегодня."
    },
    {
      "start": 24.34,
      "end": 24.6,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 25.26,
      "end": 28.06,
      "speaker": null,
      "text": "И вы их тоже ждёте, этот же Свет?"
    },
    {
      "start": 28.06,
      "end": 33.14,
      "speaker": null,
      "text": "Да, мы являемся официальным дистрибьютором данной продукции, поэтому..."
    },
    {
      "start": 34.06,
      "end": 34.88,
      "speaker": null,
      "text": "Ну, короче, видим."
    },
    {
      "start": 35.52,
      "end": 38.98,
      "speaker": null,
      "text": "Да, потому что ещё с ребятами общалась и думала, ну, здрасте, это..."
    },
    {
      "start": 38.98,
      "end": 43.46,
      "speaker": null,
      "text": "Ну, мало ли вдруг у кого-то бывает на складах остался, ну, всякое бывает."
    },
    {
      "start": 43.92,
      "end": 46.32,
      "speaker": null,
      "text": "Вот, и ещё одни ребята тоже ждут."
    },
    {
      "start": 48.12,
      "end": 50.62,
      "speaker": null,
      "text": "Да, да, все ждут этот Свет."
    },
    {
      "start": 51.12,
      "end": 52.72,
      "speaker": null,
      "text": "И перспектива?"
    },
    {
      "start": 53.52,
      "end": 54.98,
      "speaker": null,
      "text": "Ну, вообще..."
    },
    {
      "start": 54.98,
      "end": 55.54,
      "speaker": null,
      "text": "Что говорят?"
    },
    {
      "start": 55.8,
      "end": 57.62,
      "speaker": null,
      "text": "Вообще ожидается через неделю."
    },
    {
      "start": 58.97,
      "end": 59.73,
      "speaker": null,
      "text": "Ой, блин."
    },
    {
      "start": 60.39,
      "end": 60.71,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 60.95,
      "end": 62.75,
      "speaker": null,
      "text": "Там через неделю..."
    },
    {
      "start": 62.75,
      "end": 68.07,
      "speaker": null,
      "text": "Ну, значит, у вас, значит, всё одинаково идёт и у тех, у тех, потому что они тоже сказали, что они это..."
    },
    {
      "start": 68.07,
      "end": 71.05,
      "speaker": null,
      "text": "Вот по факту как отзвонятся, так отзвонятся."
    },
    {
      "start": 71.27,
      "end": 73.11,
      "speaker": null,
      "text": "Зато не узнать пришло или не пришло."
    },
    {
      "start": 73.11,
      "end": 73.79,
      "speaker": null,
      "text": "Ну, да."
    },
    {
      "start": 73.99,
      "end": 77.07,
      "speaker": null,
      "text": "Возможно, он уже даже вместе едет."
    },
    {
      "start": 78.12,
      "end": 79.06,
      "speaker": null,
      "text": "Всё возможно."
    },
    {
      "start": 79.52,
      "end": 83.76,
      "speaker": null,
      "text": "Валентия, слушайте, не сложно, а ответным письмом напишите мне, пожалуйста..."
    },
    {
      "start": 85.02,
      "end": 85.46,
      "speaker": null,
      "text": "Что..."
    },
    {
      "start": 85.46,
      "end": 87.24,
      "speaker": null,
      "text": "Что световых элементов нет."
    },
    {
      "start": 87.24,
      "end": 87.68,
      "speaker": null,
      "text": "Световых элементов нет, да."
    },
    {
      "start": 88.16,
      "end": 94.92,
      "speaker": null,
      "text": "Потому что я же тут не одна на себе завязана, у нас ещё тут куча народу, да, чтобы не голословно было."
    },
    {
      "start": 94.92,
      "end": 96.34,
      "speaker": null,
      "text": "Я-то поняла ситуацию."
    },
    {
      "start": 96.64,
      "end": 103.08,
      "speaker": null,
      "text": "Мы также как-то от друзей ждали запчасти для Хендай скорее месяца четыре."
    },
    {
      "start": 103.5,
      "end": 104.72,
      "speaker": null,
      "text": "Ну, да, да."
    },
    {
      "start": 105.04,
      "end": 105.34,
      "speaker": null,
      "text": "То есть..."
    },
    {
      "start": 105.34,
      "end": 106.8,
      "speaker": null,
      "text": "На таможне застряло."
    },
    {
      "start": 107.2,
      "end": 107.86,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 107.86,
      "end": 113.58,
      "speaker": null,
      "text": "Смотрите, Инна, а вариант, что потом вам свет довести не подойдёт?"
    },
    {
      "start": 115.46,
      "end": 117.06,
      "speaker": null,
      "text": "Блин, а если..."
    },
    {
      "start": 117.06,
      "end": 118.78,
      "speaker": null,
      "text": "Ну, смотрите."
    },
    {
      "start": 119.74,
      "end": 125.68,
      "speaker": null,
      "text": "Допустим, в среду конструкция у нас уже там с утра должна быть, чтобы мы её собрали и установили."
    },
    {
      "start": 126.52,
      "end": 129.7,
      "speaker": null,
      "text": "А если свет не приедет, то что мы будем делать?"
    },
    {
      "start": 131.57,
      "end": 132.75,
      "speaker": null,
      "text": "Ну да, да."
    },
    {
      "start": 132.95,
      "end": 135.45,
      "speaker": null,
      "text": "Но в любом случае на будущее свет."
    },
    {
      "start": 136.31,
      "end": 137.09,
      "speaker": null,
      "text": "Или вам..."
    },
    {
      "start": 137.09,
      "end": 138.01,
      "speaker": null,
      "text": "Да нет, не надо."
    },
    {
      "start": 138.23,
      "end": 139.27,
      "speaker": null,
      "text": "Это нам надо вот..."
    },
    {
      "start": 139.27,
      "end": 142.35,
      "speaker": null,
      "text": "Да, вот именно на это мероприятие, но другие-то не надо."
    },
    {
      "start": 142.63,
      "end": 148.09,
      "speaker": null,
      "text": "Я там девчонкам кинула вот прям все варианты, то что дальше форумы готовят,"
    },
    {
      "start": 148.31,
      "end": 151.17,
      "speaker": null,
      "text": "что вот есть ребята такие темные идеи делают."
    },
    {
      "start": 151.29,
      "end": 155.03,
      "speaker": null,
      "text": "Но пока сказали, обходятся они стандартными баннерами."
    },
    {
      "start": 155.75,
      "end": 156.35,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 156.61,
      "end": 157.43,
      "speaker": null,
      "text": "Без таких."
    },
    {
      "start": 158.21,
      "end": 160.39,
      "speaker": null,
      "text": "Ну, плохо дело с таможней."
    },
    {
      "start": 161.41,
      "end": 164.85,
      "speaker": null,
      "text": "А вам именно только световый вариант нужен, да?"
    },
    {
      "start": 165.61,
      "end": 167.63,
      "speaker": null,
      "text": "Да, мы хотели вот по чесноку."
    },
    {
      "start": 168.01,
      "end": 172.71,
      "speaker": null,
      "text": "У нас есть поставщики и мы хотели их выделить, чтобы они выпендрились."
    },
    {
      "start": 173.5,
      "end": 174.26,
      "speaker": null,
      "text": "Они такие..."
    },
    {
      "start": 174.26,
      "end": 175.8,
      "speaker": null,
      "text": "Они платят за то, чтобы они выпендрились."
    },
    {
      "start": 176.56,
      "end": 178.34,
      "speaker": null,
      "text": "Ну, не получилось."
    },
    {
      "start": 180.1,
      "end": 183.9,
      "speaker": null,
      "text": "Но вообще есть свет на секпро?"
    },
    {
      "start": 184.08,
      "end": 185.78,
      "speaker": null,
      "text": "На секпро они сильно дороже?"
    },
    {
      "start": 186.87,
      "end": 189.34,
      "speaker": null,
      "text": "Мы не вмещаемся вообще в бюджет."
    },
    {
      "start": 189.4,
      "end": 189.72,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 190.16,
      "end": 199.2,
      "speaker": null,
      "text": "У нас там коллега изначальный бюджет когда считал, не все учел и мы не вмещаемся."
    },
    {
      "start": 199.38,
      "end": 201.13,
      "speaker": null,
      "text": "И так сидим и думаем..."
    },
    {
      "start": 202.03,
      "end": 204.83,
      "speaker": null,
      "text": "Это вот эти шарики им купим и будут шариками."
    },
    {
      "start": 205.45,
      "end": 208.51,
      "speaker": null,
      "text": "А если вам уменьшить количество стендов?"
    },
    {
      "start": 209.27,
      "end": 209.77,
      "speaker": null,
      "text": "Никак."
    },
    {
      "start": 210.05,
      "end": 211.23,
      "speaker": null,
      "text": "Вот 5 именно надо."
    },
    {
      "start": 212.81,
      "end": 216.47,
      "speaker": null,
      "text": "Вот их 5 и 5 надо, не меньше, не больше."
    },
    {
      "start": 217.49,
      "end": 218.13,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 219.3,
      "end": 222.18,
      "speaker": null,
      "text": "Я так понимаю, общий бюджет в районе 500, да?"
    },
    {
      "start": 222.32,
      "end": 223.4,
      "speaker": null,
      "text": "На все 5 заложен?"
    },
    {
      "start": 223.92,
      "end": 224.22,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 225.74,
      "end": 229.72,
      "speaker": null,
      "text": "Ну, может 600 там откуда-нибудь с ним сюда прибавим."
    },
    {
      "start": 230.44,
      "end": 230.86,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 231.56,
      "end": 233.24,
      "speaker": null,
      "text": "Да, ну не больше, да."
    },
    {
      "start": 233.44,
      "end": 234.34,
      "speaker": null,
      "text": "Потому что у меня..."
    },
    {
      "start": 234.34,
      "end": 239.08,
      "speaker": null,
      "text": "Эта коллега вот Алла, она считала, то она у меня тут бюджетом больше занимается."
    },
    {
      "start": 239.58,
      "end": 242.44,
      "speaker": null,
      "text": "Она говорит, вот 100, говорит, да, там 101, там 110."
    },
    {
      "start": 242.74,
      "end": 244.2,
      "speaker": null,
      "text": "И мы все хорошо вмещаемся."
    },
    {
      "start": 244.34,
      "end": 246.86,
      "speaker": null,
      "text": "Он говорит, уже больше, уже все, говорит, пролетаем."
    },
    {
      "start": 248.46,
      "end": 248.76,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 248.84,
      "end": 249.76,
      "speaker": null,
      "text": "Ну, короче, я поняла."
    },
    {
      "start": 249.94,
      "end": 250.92,
      "speaker": null,
      "text": "Ладно, сейчас буду..."
    },
    {
      "start": 250.92,
      "end": 252.24,
      "speaker": null,
      "text": "Нет, если вам напишите, пожалуйста."
    },
    {
      "start": 252.92,
      "end": 258.58,
      "speaker": null,
      "text": "Я, да, ребят, предупрежу, чтобы вы думали, что можно сделать другое."
    },
    {
      "start": 258.58,
      "end": 263.06,
      "speaker": null,
      "text": "Я могу вам в этом же ответном письме предложить оптимативный вариант."
    },
    {
      "start": 263.4,
      "end": 268.12,
      "speaker": null,
      "text": "Но, ну, он на 80 тысяч за штуку подороже выходит, вот поэтому так."
    },
    {
      "start": 268.36,
      "end": 270.36,
      "speaker": null,
      "text": "Ну, а на нем свет есть как бы всегда."
    },
    {
      "start": 270.72,
      "end": 272.24,
      "speaker": null,
      "text": "Ну, можете предложить?"
    },
    {
      "start": 272.32,
      "end": 275.78,
      "speaker": null,
      "text": "Давайте так, чтобы не быть голосованы, типа того отказались и ничего нету."
    },
    {
      "start": 276.86,
      "end": 280.2,
      "speaker": null,
      "text": "Вдруг откуда ни возьмись, возьмут ВТМи еще деньги они."
    },
    {
      "start": 281.04,
      "end": 282.06,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 282.89,
      "end": 284.93,
      "speaker": null,
      "text": "Да, все хорошо, спасибо, что позвонили."
    },
    {
      "start": 285.35,
      "end": 288.15,
      "speaker": null,
      "text": "Все, именно благодарю вас, я тогда сейчас ответным письмом напишу."
    },
    {
      "start": 288.15,
      "end": 290.67,
      "speaker": null,
      "text": "Да, и Аллу Орлову в копию тоже поставьте."
    },
    {
      "start": 290.77,
      "end": 292.27,
      "speaker": null,
      "text": "Да, да, я общее ответ сделаю."
    },
    {
      "start": 292.51,
      "end": 293.13,
      "speaker": null,
      "text": "Угу, спасибо."
    },
    {
      "start": 293.49,
      "end": 294.21,
      "speaker": null,
      "text": "Все, благодарю."
    },
    {
      "start": 295.59,
      "end": 296.05,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}