{
  "file": "18.05.2026_17_58_45_79933575577_m27_d124079_0.1779116326.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 66.8,
  "segments": [
    {
      "start": 0.24,
      "end": 1.12,
      "speaker": null,
      "text": "Да, Артём."
    },
    {
      "start": 2.58,
      "end": 6.0,
      "speaker": null,
      "text": "Валентин, скажите, а вы утром во сколько начинаете работать?"
    },
    {
      "start": 6.44,
      "end": 8.7,
      "speaker": null,
      "text": "С 9-ти."
    },
    {
      "start": 9.14,
      "end": 11.0,
      "speaker": null,
      "text": "О, а мне в 9-30 на Ленинградку."
    },
    {
      "start": 12.24,
      "end": 17.9,
      "speaker": null,
      "text": "Так, я правда не успел посмотреть, делитесь ли это реально, это вы переведите на какие-то где примерно?"
    },
    {
      "start": 19.55,
      "end": 23.21,
      "speaker": null,
      "text": "Электрозаводка недалеко от арта. Бауманская электрозаводка, мы между ними прям."
    },
    {
      "start": 23.99,
      "end": 26.71,
      "speaker": null,
      "text": "Ну я как будто за полчаса успею до Ленинградки добраться."
    },
    {
      "start": 26.71,
      "end": 31.39,
      "speaker": null,
      "text": "Так, давайте я в 9 заеду к вам. Вы не планируете выдержаться утром?"
    },
    {
      "start": 31.99,
      "end": 36.19,
      "speaker": null,
      "text": "Да нет, вообще я могу и пораньше на самом деле, если есть необходимость в этом."
    },
    {
      "start": 38.02,
      "end": 42.18,
      "speaker": null,
      "text": "Да, я думаю в 9 нормально, я там потом по такси заскочу."
    },
    {
      "start": 43.74,
      "end": 46.64,
      "speaker": null,
      "text": "Давайте тогда в 9 я подъеду, по-моему."
    },
    {
      "start": 47.32,
      "end": 48.22,
      "speaker": null,
      "text": "Да, хорошо, хорошо."
    },
    {
      "start": 48.22,
      "end": 53.23,
      "speaker": null,
      "text": "Да, и по денежке тогда тоже остановят. А то у меня было теперь какое-то пропало, только вышла на связь."
    },
    {
      "start": 54.0,
      "end": 56.9,
      "speaker": null,
      "text": "И они по минуту 20 говорят только, что денег пришлют."
    },
    {
      "start": 57.44,
      "end": 58.82,
      "speaker": null,
      "text": "Поэтому давайте на утро все."
    },
    {
      "start": 59.44,
      "end": 60.78,
      "speaker": null,
      "text": "Да, хорошо, хорошо, без проблем."
    },
    {
      "start": 61.04,
      "end": 62.36,
      "speaker": null,
      "text": "Супер. Спасибо, до завтра."
    },
    {
      "start": 62.74,
      "end": 64.04,
      "speaker": null,
      "text": "Да, все, благодарю вас."
    },
    {
      "start": 64.94,
      "end": 65.74,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}