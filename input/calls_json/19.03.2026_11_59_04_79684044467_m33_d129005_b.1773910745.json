{
  "file": "19.03.2026_11_59_04_79684044467_m33_d129005_b.1773910745.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 220.7,
  "segments": [
    {
      "start": 1.58,
      "end": 3.54,
      "speaker": null,
      "text": "Добрый день, Иван. Компания Мустент."
    },
    {
      "start": 4.73,
      "end": 13.88,
      "speaker": null,
      "text": "Да, добрый день, Иван. Меня Игорь зовут. Смотрите, у вас на сайте идет роллап длина 2 метра."
    },
    {
      "start": 14.75,
      "end": 15.77,
      "speaker": null,
      "text": "Да, да, есть такой."
    },
    {
      "start": 16.74,
      "end": 18.54,
      "speaker": null,
      "text": "Вот я не могу стоимость его найти."
    },
    {
      "start": 19.57,
      "end": 25.91,
      "speaker": null,
      "text": "Так, секундочку. Единственное, он есть только в одной модели классической, то есть некой поливидной."
    },
    {
      "start": 25.91,
      "end": 26.93,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 28.31,
      "end": 30.75,
      "speaker": null,
      "text": "Ну, он разбирается как обычный роллап?"
    },
    {
      "start": 31.6,
      "end": 33.02,
      "speaker": null,
      "text": "Да-да-да, как обычный роллап."
    },
    {
      "start": 33.46,
      "end": 41.38,
      "speaker": null,
      "text": "Давайте я немножко уточню. Мы рекламное агентство, но у меня основное направление – это полиграфия."
    },
    {
      "start": 42.62,
      "end": 43.3,
      "speaker": null,
      "text": "А, понял."
    },
    {
      "start": 43.84,
      "end": 51.9,
      "speaker": null,
      "text": "Да, поскольку у меня договор с компанией Россессии общий и рамочный, то мне приходится это брать."
    },
    {
      "start": 51.9,
      "end": 56.84,
      "speaker": null,
      "text": "То есть, понимаете, мне мое знание хватает только для того, чтобы по ушам клетки сезть."
    },
    {
      "start": 58.05,
      "end": 59.33,
      "speaker": null,
      "text": "Я понимаю, понимаю."
    },
    {
      "start": 59.69,
      "end": 59.93,
      "speaker": null,
      "text": "Да ладно?"
    },
    {
      "start": 59.97,
      "end": 61.77,
      "speaker": null,
      "text": "Да, то есть вот так вот достаточно честно."
    },
    {
      "start": 64.1,
      "end": 66.26,
      "speaker": null,
      "text": "А больше есть? Бывают они очень больше?"
    },
    {
      "start": 66.68,
      "end": 70.56,
      "speaker": null,
      "text": "Не, роллапы вот… Именно сами роллапы 3х2 – это прям максимум. И то не у всех."
    },
    {
      "start": 71.56,
      "end": 72.5,
      "speaker": null,
      "text": "Ну я знаю."
    },
    {
      "start": 73.04,
      "end": 73.26,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 73.4,
      "end": 74.04,
      "speaker": null,
      "text": "Это я знаю."
    },
    {
      "start": 75.18,
      "end": 76.12,
      "speaker": null,
      "text": "Да, и сколько он стоит?"
    },
    {
      "start": 77.06,
      "end": 77.94,
      "speaker": null,
      "text": "Так, секундочку."
    },
    {
      "start": 78.34,
      "end": 78.42,
      "speaker": null,
      "text": "Сейчас."
    },
    {
      "start": 87.99,
      "end": 92.17,
      "speaker": null,
      "text": "Двадцать пять тысяч конструкция и пять восемьсот в печать."
    },
    {
      "start": 92.57,
      "end": 93.65,
      "speaker": null,
      "text": "Тридцать восемьсот."
    },
    {
      "start": 94.65,
      "end": 95.79,
      "speaker": null,
      "text": "Тридцать восемьсот?"
    },
    {
      "start": 96.15,
      "end": 96.35,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 96.47,
      "end": 98.11,
      "speaker": null,
      "text": "Так, отличненько."
    },
    {
      "start": 99.05,
      "end": 100.77,
      "speaker": null,
      "text": "Так, что я еще хотел спросить?"
    },
    {
      "start": 101.01,
      "end": 103.51,
      "speaker": null,
      "text": "В конструкции, да, ну как роллапы представляется."
    },
    {
      "start": 104.21,
      "end": 109.45,
      "speaker": null,
      "text": "Вот. Значит, что еще я хотел спросить? Вы работаете как с НДС или без?"
    },
    {
      "start": 109.67,
      "end": 111.59,
      "speaker": null,
      "text": "Двадцать два НДС уже в причем стоимости."
    },
    {
      "start": 112.99,
      "end": 115.85,
      "speaker": null,
      "text": "Отлично. Так, это раз. И второй вопрос еще о сроке."
    },
    {
      "start": 117.24,
      "end": 119.62,
      "speaker": null,
      "text": "Сроки достаточно быстрые – один-два рабочих дня."
    },
    {
      "start": 119.8,
      "end": 121.0,
      "speaker": null,
      "text": "Ролапы быстро печатаем, да."
    },
    {
      "start": 121.08,
      "end": 122.86,
      "speaker": null,
      "text": "После оплаты и утверждения макета."
    },
    {
      "start": 123.95,
      "end": 125.39,
      "speaker": null,
      "text": "Да, да, да. Понятно."
    },
    {
      "start": 126.39,
      "end": 128.57,
      "speaker": null,
      "text": "Проблема в том, что у нас нет проблемы с предоплатой."
    },
    {
      "start": 129.05,
      "end": 131.17,
      "speaker": null,
      "text": "То есть договор просто с банком есть и все."
    },
    {
      "start": 131.75,
      "end": 133.71,
      "speaker": null,
      "text": "Получили счеты и бонзай."
    },
    {
      "start": 134.35,
      "end": 135.43,
      "speaker": null,
      "text": "А потом уже…"
    },
    {
      "start": 136.29,
      "end": 136.77,
      "speaker": null,
      "text": "Макета."
    },
    {
      "start": 137.95,
      "end": 139.23,
      "speaker": null,
      "text": "Макет тоже я уже сделал."
    },
    {
      "start": 139.23,
      "end": 141.05,
      "speaker": null,
      "text": "А вам макет как предоставлять?"
    },
    {
      "start": 142.07,
      "end": 143.11,
      "speaker": null,
      "text": "Макет предоставлять…"
    },
    {
      "start": 143.11,
      "end": 144.13,
      "speaker": null,
      "text": "У нас прямо на сайте сейчас?"
    },
    {
      "start": 145.38,
      "end": 145.64,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 146.32,
      "end": 147.44,
      "speaker": null,
      "text": "Требования к макету."
    },
    {
      "start": 148.06,
      "end": 149.3,
      "speaker": null,
      "text": "Да, да, да. Я выбрал лапы."
    },
    {
      "start": 149.38,
      "end": 150.76,
      "speaker": null,
      "text": "Прямо требования к макету нажимаете."
    },
    {
      "start": 153.45,
      "end": 156.07,
      "speaker": null,
      "text": "Так, мне векторный вот удобнее будет, потому что…"
    },
    {
      "start": 156.37,
      "end": 170.22,
      "speaker": null,
      "text": "Ну, у вектора…"
    },
    {
      "start": 170.22,
      "end": 174.84,
      "speaker": null,
      "text": "А по размеру именно самого макета он должен быть 2,990 на 2030."
    },
    {
      "start": 175.75,
      "end": 176.91,
      "speaker": null,
      "text": "То есть чуть-чуть…"
    },
    {
      "start": 176.91,
      "end": 179.49,
      "speaker": null,
      "text": "10 миллиметров ширину убираем и 30 добавляем."
    },
    {
      "start": 181.63,
      "end": 182.65,
      "speaker": null,
      "text": "Не напонял."
    },
    {
      "start": 183.27,
      "end": 188.85,
      "speaker": null,
      "text": "Давайте я вам лучше скину тех требования, тогда будет проще, чтобы расписать и вы увидели прямо перед глазами."
    },
    {
      "start": 189.8,
      "end": 190.08,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 190.08,
      "end": 191.28,
      "speaker": null,
      "text": "Да, по размеру."
    },
    {
      "start": 191.34,
      "end": 193.52,
      "speaker": null,
      "text": "Может быть у вас к этому номеру Telegram или Макс привязан?"
    },
    {
      "start": 194.61,
      "end": 195.05,
      "speaker": null,
      "text": "Эээ…"
    },
    {
      "start": 195.05,
      "end": 195.97,
      "speaker": null,
      "text": "Макс привязан точно."
    },
    {
      "start": 196.39,
      "end": 197.05,
      "speaker": null,
      "text": "Макс точно."
    },
    {
      "start": 197.31,
      "end": 200.41,
      "speaker": null,
      "text": "Давайте я вам тогда сейчас, буквально через минутку, когда закончим разговаривать,"
    },
    {
      "start": 200.45,
      "end": 203.09,
      "speaker": null,
      "text": "я вам Макс напишу и скину тех требования и распису еще."
    },
    {
      "start": 203.47,
      "end": 204.29,
      "speaker": null,
      "text": "Ну, что я имею ввиду."
    },
    {
      "start": 204.41,
      "end": 204.67,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 205.49,
      "end": 205.87,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 205.87,
      "end": 206.03,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 207.66,
      "end": 208.38,
      "speaker": null,
      "text": "Хорошо, спасибо."
    },
    {
      "start": 208.8,
      "end": 209.8,
      "speaker": null,
      "text": "Все, договорились."
    },
    {
      "start": 209.86,
      "end": 210.56,
      "speaker": null,
      "text": "Может быть что-то еще?"
    },
    {
      "start": 210.74,
      "end": 210.86,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 211.5,
      "end": 211.76,
      "speaker": null,
      "text": "Ну…"
    },
    {
      "start": 211.76,
      "end": 211.82,
      "speaker": null,
      "text": "Есть?"
    },
    {
      "start": 212.22,
      "end": 212.84,
      "speaker": null,
      "text": "Есть, да."
    },
    {
      "start": 213.24,
      "end": 213.7,
      "speaker": null,
      "text": "Стенды нет."
    },
    {
      "start": 214.0,
      "end": 216.12,
      "speaker": null,
      "text": "Ну хорошо, если что, тогда пишите."
    },
    {
      "start": 216.48,
      "end": 216.62,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}