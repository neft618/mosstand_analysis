    {
      "start": 1.76,
      "end": 7.74,
      "speaker": null,
      "text": "Добрый день, меня зовут Ксения, компания Мостенд. У меня от вас пропущены. Чем могу помочь? Как могу обращаться к вам?"
    },
    {
      "start": 10.78,
      "end": 15.18,
      "speaker": null,
      "text": "По поводу... мы должны забрать роллап там. Вы с Екатериной общались?"
    },
    {
      "start": 17.36,
      "end": 19.32,
      "speaker": null,
      "text": "Вас хотел узнать, во сколько вы будете?"
    },
    {
      "start": 20.54,
      "end": 23.3,
      "speaker": null,
      "text": "Да, во сколько его можно забрать?"
    },
    {
      "start": 24.15,
      "end": 25.59,
      "speaker": null,
      "text": "А что у вас за заказ?"
    },
    {
      "start": 26.51,
      "end": 27.05,
      "speaker": null,
      "text": "Что-то?"
    },
    {
      "start": 27.84,
      "end": 29.86,
      "speaker": null,
      "text": "Что у вас за номер заказа?"
    },
    {
      "start": 30.48,
      "end": 32.2,
      "speaker": null,
      "text": "Номер заказа сейчас я вам скажу."
    },
    {
      "start": 32.26,
      "end": 33.52,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 34.4,
      "end": 45.18,
      "speaker": null,
      "text": "Так, номер заказа 110-677."
