{
  "file": "15.05.2026_12_57_28_79213378393_m27_d136305_7.1778839049.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 90.4,
  "segments": [
    {
      "start": 0.0,
      "end": 2.78,
      "speaker": null,
      "text": "Добрый день, я зовут Валентин Компания. Мы с вами можем помочь?"
    },
    {
      "start": 3.46,
      "end": 5.72,
      "speaker": null,
      "text": "Валентин, очень срочно роллап нажим."
    },
    {
      "start": 7.08,
      "end": 8.54,
      "speaker": null,
      "text": "Как я могу к вам обращаться?"
    },
    {
      "start": 9.08,
      "end": 9.68,
      "speaker": null,
      "text": "Сергей."
    },
    {
      "start": 10.96,
      "end": 12.64,
      "speaker": null,
      "text": "А у вас макет уже готов?"
    },
    {
      "start": 13.14,
      "end": 14.1,
      "speaker": null,
      "text": "Готов, готов."
    },
    {
      "start": 16.2,
      "end": 18.2,
      "speaker": null,
      "text": "В каком размере роллап необходим?"
    },
    {
      "start": 18.6,
      "end": 19.84,
      "speaker": null,
      "text": "200 на 85."
    },
    {
      "start": 20.44,
      "end": 23.64,
      "speaker": null,
      "text": "Или сколько там, 200 на 80, ну стандартный, как ещё вы поняли."
    },
    {
      "start": 24.3,
      "end": 25.74,
      "speaker": null,
      "text": "85 на 200."
    },
    {
      "start": 26.52,
      "end": 27.82,
      "speaker": null,
      "text": "Один необходим роллап?"
    },
    {
      "start": 28.06,
      "end": 28.58,
      "speaker": null,
      "text": "Один."
    },
    {
      "start": 30.42,
      "end": 32.42,
      "speaker": null,
      "text": "Когда будет необходим? Сегодня, понедельник?"
    },
    {
      "start": 33.48,
      "end": 37.52,
      "speaker": null,
      "text": "В воскресенье утро, самое позднее, чтобы доставили нам."
    },
    {
      "start": 37.76,
      "end": 41.36,
      "speaker": null,
      "text": "Ну я могу забрать, или курьер вызову."
    },
    {
      "start": 41.78,
      "end": 43.66,
      "speaker": null,
      "text": "Да, смотрите, выходные дни мы не работаем."
    },
    {
      "start": 45.04,
      "end": 50.66,
      "speaker": null,
      "text": "По срочной печати мне сейчас необходимо уточнить, потому что у нас есть определённая загруженность."
    },
    {
      "start": 50.74,
      "end": 54.2,
      "speaker": null,
      "text": "Вообще мы печатаем за один день, но мне необходимо уточнить этот момент."
    },
    {
      "start": 54.2,
      "end": 55.56,
      "speaker": null,
      "text": "Уточните про авто, да."
    },
    {
      "start": 55.86,
      "end": 60.36,
      "speaker": null,
      "text": "Если нужно там макет скинуть или ещё что-то, заявку продублировать, то можем списаться где-то с вами."
    },
    {
      "start": 60.9,
      "end": 61.38,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 61.68,
      "end": 64.14,
      "speaker": null,
      "text": "А у вас к этому номеру телефона привязаны мессенджеры какие-нибудь?"
    },
    {
      "start": 64.86,
      "end": 71.78,
      "speaker": null,
      "text": "Да, ну я в идеале ведь... А вы можете мне в WhatsApp написать? А я вас оттуда переведу на Telegram."
    },
    {
      "start": 72.3,
      "end": 74.26,
      "speaker": null,
      "text": "Да, да, могу вам в WhatsApp написать."
    },
    {
      "start": 74.78,
      "end": 78.04,
      "speaker": null,
      "text": "Да, отлично, давайте тогда там и буду признаться, если ориентируйте."
    },
    {
      "start": 78.08,
      "end": 79.8,
      "speaker": null,
      "text": "Если что, я тогда побегу дальше искать кого-то."
    },
    {
      "start": 80.59,
      "end": 81.79,
      "speaker": null,
      "text": "Хорошо, хорошо, я вас понял."
    },
    {
      "start": 81.95,
      "end": 84.47,
      "speaker": null,
      "text": "Я сейчас тогда уточняю этот момент и к вам вернусь."
    },
    {
      "start": 85.29,
      "end": 85.51,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 86.43,
      "end": 87.15,
      "speaker": null,
      "text": "Сергей, благодарю."
    },
    {
      "start": 87.27,
      "end": 89.45,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}