  "segments": [
    {
      "start": 2.26,
      "end": 3.78,
      "speaker": null,
      "text": "Екатерина, здравствуйте."
    },
    {
      "start": 4.14,
      "end": 5.84,
      "speaker": null,
      "text": "Елена, неожиданно, да? Здрасте."
