    {
      "start": 7.74,
      "end": 8.44,
      "speaker": null,
      "text": "Работаю."
    },
    {
      "start": 8.8,
      "end": 11.56,
      "speaker": null,
      "text": "Ой, хорошо, хорошо, я тоже работаю."
    },
    {
      "start": 12.96,
      "end": 21.64,
      "speaker": null,
      "text": "Да, и по этому поводу вам звоню. У меня есть срочный заказ на полиграфию. Может посмотрите на бизаре тендер наш?"
    },
    {
      "start": 23.18,
      "end": 25.34,
      "speaker": null,
      "text": "Да, конечно, посмотрю."
    },
    {
      "start": 25.68,
      "end": 28.5,
      "speaker": null,
      "text": "А как вы называете? Я его сейчас приглашу."
    },
    {
      "start": 28.9,
      "end": 29.38,
      "speaker": null,
      "text": "Стендру."
    },
    {
      "start": 30.1,
      "end": 34.42,
      "speaker": null,
      "text": "Стендру? Ага, сейчас я минуточку вас приглашу."
    },
    {
      "start": 36.35,
      "end": 38.79,
      "speaker": null,
      "text": "На бизаре, да, сувкомбанк."
    },
    {
      "start": 41.8,
      "end": 42.72,
      "speaker": null,
      "text": "Гляньте, пожалуйста."
    },
    {
      "start": 43.22,
      "end": 44.58,
      "speaker": null,
      "text": "Сейчас, секунду, конечно."
    },
    {
      "start": 44.72,
      "end": 46.86,
      "speaker": null,
      "text": "Я вам давайте номерок скажу этой записи, да?"
    },
    {
      "start": 47.06,
      "end": 48.84,
      "speaker": null,
      "text": "Секундочку, секундочку, сейчас."
    },
    {
      "start": 49.04,
      "end": 49.4,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 51.81,
      "end": 52.33,
      "speaker": null,
      "text": "Секунду."
    },
    {
      "start": 53.36,
      "end": 58.12,
      "speaker": null,
      "text": "Потому что я помню, что вы спасались у нас неоднократно в этих списках."
    },
    {
      "start": 58.22,
      "end": 60.34,
      "speaker": null,
      "text": "Вы сувкомбанке работаете в закупках?"
    },
    {
      "start": 60.36,
      "end": 61.56,
      "speaker": null,
      "text": "Да, да-да-да."
    },
    {
      "start": 62.54,
      "end": 63.06,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 64.06,
      "end": 66.76,
      "speaker": null,
      "text": "Так, сейчас секунду открою."
    },
    {
      "start": 67.62,
      "end": 69.94,
      "speaker": null,
      "text": "Сейчас, сейчас, сейчас."
    },
    {
      "start": 70.68,
      "end": 71.48,
      "speaker": null,
      "text": "Ну да ничего-ничего."
    },
    {
      "start": 72.32,
      "end": 74.2,
      "speaker": null,
      "text": "Как вы все еще взаимодействуете с РКК?"
