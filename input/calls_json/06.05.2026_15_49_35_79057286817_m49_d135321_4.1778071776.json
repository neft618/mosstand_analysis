    {
      "start": 77.45,
      "end": 78.51,
      "speaker": null,
      "text": "Периодически, да."
    },
    {
      "start": 82.44,
      "end": 83.96,
      "speaker": null,
      "text": "Вроде работаем."
    },
    {
      "start": 84.32,
      "end": 87.12,
      "speaker": null,
      "text": "Так, сейчас у меня почему-то..."
    },
    {
