  "segments": [
    {
      "start": 0.85,
      "end": 1.53,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 2.27,
      "end": 11.06,
      "speaker": null,
      "text": "Здравствуйте, Игорь, это Валерий из Мостенд. Вы направляли нам на почту запрос на флаги, на знамя."
    },
    {
      "start": 11.68,
      "end": 13.02,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 13.44,
      "end": 15.84,
      "speaker": null,
      "text": "Да, уточните, пожалуйста, Игорь, а это тендер?"
    },
    {
      "start": 18.25,
      "end": 18.75,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 20.23,
      "end": 23.53,
      "speaker": null,
      "text": "Мы просто, к сожалению, не участвуем в тендерных закупках."
    },
    {
      "start": 24.43,
      "end": 30.35,
      "speaker": null,
      "text": "Я вас не призываю участвовать. Вы мне посчитайте, сколько сделаете, за сколько сделать этот заказ."
    },
    {
      "start": 30.77,
      "end": 39.67,
      "speaker": null,
      "text": "Ну, хорошо. Смотрите, да я сейчас попробую уточнить производство, то есть в любом случае с технологом рассчитаю, так как это не самая стандартная такая печать."
    },
    {
      "start": 40.21,
      "end": 42.35,
      "speaker": null,
      "text": "И к вам тогда отпишусь на почту. Договорились?"
    },
    {
      "start": 42.85,
      "end": 44.27,
      "speaker": null,
      "text": "Я вот это иду, да."
    },
    {
      "start": 44.83,
      "end": 47.87,
      "speaker": null,
      "text": "А уточните, а какому сроку в целом-то они нужны будут?"
    },
    {
      "start": 51.82,
      "end": 59.2,
      "speaker": null,
      "text": "По-пам-му. Я сейчас не возле компьютера. Давайте попозже, что ли, как-то..."
    },
    {
      "start": 59.74,
      "end": 61.12,
      "speaker": null,
      "text": "Поняла. А я правильно..."
    },
    {
      "start": 61.12,
      "end": 61.92,
      "speaker": null,
      "text": "Как можно писать вообще?"
    },
    {
      "start": 63.02,
      "end": 64.24,
      "speaker": null,
      "text": "Валерий из Мостенд."
    },
    {
      "start": 66.38,
      "end": 67.16,
      "speaker": null,
      "text": "Мост как?"
    },
    {
      "start": 68.26,
      "end": 68.78,
      "speaker": null,
      "text": "Мостенд."
    },
    {
      "start": 70.39,
      "end": 71.41,
      "speaker": null,
      "text": "Мостенд, ага."
    },
    {
      "start": 71.98,
      "end": 75.7,
      "speaker": null,
      "text": "Угу. А уточните, Игорь, я правильно не понимаю, что вы участвуете в тендере?"
    },
    {
      "start": 75.84,
      "end": 76.72,
      "speaker": null,
      "text": "Вы уже выигрывали?"
    },
    {
      "start": 76.74,
      "end": 77.48,
      "speaker": null,
      "text": "Да, да, да, да."
    },
    {
      "start": 77.58,
      "end": 77.86,
      "speaker": null,
      "text": "А только..."
    },
    {
      "start": 78.94,
      "end": 79.98,
      "speaker": null,
      "text": "Нет, собираюсь."
    },
    {
      "start": 80.38,
      "end": 81.46,
      "speaker": null,
      "text": "Ага, поняла вас хорошо."
    },
    {
      "start": 81.46,
      "end": 83.22,
      "speaker": null,
      "text": "Мне нужна цена и сроки от вас."
    },
    {
      "start": 83.84,
      "end": 84.16,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 85.3,
      "end": 89.76,
      "speaker": null,
      "text": "Все, хорошо, тогда услышала вас и сейчас тогда рассчитаю к вам вернусь."
    },
    {
      "start": 92.72,
      "end": 94.18,
      "speaker": null,
      "text": "Угу, да, всего доброго."
    },
    {
      "start": 95.64,
      "end": 96.24,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 96.28,
      "end": 96.84,
      "speaker": null,
      "text": "Мост как?"
    },
    {
      "start": 97.5,
      "end": 98.02,
      "speaker": null,
      "text": "Мостенд."
    },
    {
      "start": 98.54,
      "end": 99.06,
      "speaker": null,
      "text": "Мостенд."
    },
    {
      "start": 99.64,
      "end": 101.86,
      "speaker": null,
      "text": "Я вот вижу, что вы мне на почте ответили."
    },
    {
      "start": 101.98,
      "end": 106.26,
      "speaker": null,
      "text": "У меня там после собаки идет название нашей компании."
    },
    {
      "start": 112.51,
      "end": 114.37,
      "speaker": null,
      "text": "Угу, да, тогда всего доброго."
    },
    {
      "start": 114.49,
      "end": 115.11,
      "speaker": null,
      "text": "Вернусь к вам."
    },
    {
      "start": 115.49,
      "end": 117.55,
      "speaker": null,
      "text": "А вы на этом телевидении в Максе есть?"
    },
    {
      "start": 117.55,
      "end": 118.97,
      "speaker": null,
      "text": "Да, есть."
    },
    {
      "start": 119.19,
      "end": 120.13,
      "speaker": null,
      "text": "Есть, Максе."
    },
    {
      "start": 120.49,
      "end": 122.23,
      "speaker": null,
      "text": "Я вам туда буду писать."
    },
    {
      "start": 122.63,
      "end": 122.79,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 123.05,
      "end": 124.48,
      "speaker": null,
      "text": "Хорошо, хорошо, супер."
    },
    {
      "start": 124.62,
      "end": 124.86,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 124.86,
      "end": 125.38,
