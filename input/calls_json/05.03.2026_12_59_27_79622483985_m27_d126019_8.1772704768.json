    {
      "start": 374.64,
      "end": 375.34,
      "speaker": null,
      "text": "и уточню."
    },
    {
      "start": 375.94,
      "end": 376.86,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 377.57,
      "end": 378.39,
      "speaker": null,
      "text": "Все, благодарю вас."
    },
    {
      "start": 378.59,
      "end": 379.79,
      "speaker": null,
      "text": "Куда вы переставите"
    },
    {
      "start": 379.79,
      "end": 380.67,
      "speaker": null,
      "text": "счет, да, получается?"
    },
    {
      "start": 381.43,
      "end": 381.93,
      "speaker": null,
      "text": "А счет"
    },
    {
      "start": 381.93,
      "end": 382.81,
      "speaker": null,
      "text": "я вам"
    },
    {
      "start": 382.81,
      "end": 383.61,
      "speaker": null,
      "text": "первый"
    },
    {
      "start": 383.61,
      "end": 384.29,
      "speaker": null,
      "text": "направил"
    },
    {
      "start": 384.29,
      "end": 385.17,
      "speaker": null,
      "text": "и второй"
    },
    {
      "start": 385.17,
      "end": 386.59,
      "speaker": null,
      "text": "на визитки"
    },
    {
      "start": 386.59,
      "end": 387.17,
      "speaker": null,
      "text": "и"
    },
    {
      "start": 387.17,
      "end": 387.99,
      "speaker": null,
      "text": "монтаж"
    },
    {
      "start": 387.99,
      "end": 388.67,
      "speaker": null,
      "text": "я вам отдельно"
    },
    {
      "start": 388.67,
      "end": 389.09,
      "speaker": null,
      "text": "направлю."
    },
    {
      "start": 389.75,
      "end": 390.51,
      "speaker": null,
      "text": "Ага, хорошо."
    },
    {
      "start": 391.57,
      "end": 392.19,
      "speaker": null,
      "text": "Так,"
    },
    {
      "start": 392.63,
      "end": 393.25,
      "speaker": null,
      "text": "и тогда сейчас"
    },
    {
      "start": 393.25,
      "end": 394.07,
      "speaker": null,
      "text": "я жду от вас"
    },
    {
      "start": 394.07,
      "end": 394.91,
      "speaker": null,
      "text": "и жду звонка"
    },
    {
      "start": 394.91,
      "end": 395.73,
      "speaker": null,
      "text": "и тогда мы еще раз"
    },
    {
      "start": 395.73,
      "end": 396.31,
      "speaker": null,
      "text": "пробежимся."
    },
    {
      "start": 396.61,
      "end": 397.33,
      "speaker": null,
      "text": "Да-да-да,"
    },
    {
      "start": 397.41,
      "end": 398.33,
      "speaker": null,
      "text": "так будет удобнее"
    },
    {
      "start": 398.33,
      "end": 398.99,
      "speaker": null,
      "text": "и оптимально."
    },
    {
      "start": 399.57,
      "end": 399.93,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 400.51,
      "end": 401.43,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 401.87,
