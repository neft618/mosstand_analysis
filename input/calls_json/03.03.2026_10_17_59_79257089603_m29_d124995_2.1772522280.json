{
  "file": "03.03.2026_10_17_59_79257089603_m29_d124995_2.1772522280.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 221.3,
  "segments": [
    {
      "start": 0.5,
      "end": 1.54,
      "speaker": null,
      "text": "Да, слушаю."
    },
    {
      "start": 2.06,
      "end": 3.86,
      "speaker": null,
      "text": "Здравствуйте, Сергей, это Ксения из Москвы."
    },
    {
      "start": 4.0,
      "end": 6.1,
      "speaker": null,
      "text": "Да, да, Ксения, смотрите."
    },
    {
      "start": 6.74,
      "end": 8.7,
      "speaker": null,
      "text": "Да, я просто сейчас очень поздно освободился."
    },
    {
      "start": 9.12,
      "end": 13.54,
      "speaker": null,
      "text": "Смотри, Ксения, я из Москвы поеду, буду в электрический, я вам тогда наберу, хорошо?"
    },
    {
      "start": 14.06,
      "end": 20.56,
      "speaker": null,
      "text": "К совещанию готовлюсь, но это будет где-то с двух до четырёх я поеду обратно."
    },
    {
      "start": 21.62,
      "end": 28.86,
      "speaker": null,
      "text": "И там надо будет обсудить и по смете, и чуть-чуть там подкорректировали мне."
    },
    {
      "start": 28.86,
      "end": 29.9,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 29.96,
      "end": 37.76,
      "speaker": null,
      "text": "Ну, я просто буду и смету перед собой держать, чтобы было удобно у меня всё распечатано и по корректировке чертизы там всё поправил."
    },
    {
      "start": 38.79,
      "end": 40.59,
      "speaker": null,
      "text": "Хорошо-хорошо, без проблем."
    },
    {
      "start": 41.17,
      "end": 47.13,
      "speaker": null,
      "text": "А, и ещё хотел узнать, где окошко с двумя полками?"
    },
    {
      "start": 47.73,
      "end": 51.81,
      "speaker": null,
      "text": "Его размер метр двадцать может быть в ширину?"
    },
    {
      "start": 52.68,
      "end": 53.06,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 53.5,
      "end": 55.24,
      "speaker": null,
      "text": "Глубина сорок, это понятно."
    },
    {
      "start": 57.06,
      "end": 61.94,
      "speaker": null,
      "text": "Ну вот, я вам там расписывала с одной витрины, две центральные полки подсветки."
    },
    {
      "start": 61.94,
      "end": 66.6,
      "speaker": null,
      "text": "Да-да-да, нет, с двумя полками, вот, витрина с двумя полками."
    },
    {
      "start": 66.6,
      "end": 75.32,
      "speaker": null,
      "text": "И у нас атомные подводные лодки, они, ну, они лёгкие, но они почти метр десять в длину."
    },
    {
      "start": 75.32,
      "end": 94.13,
      "speaker": null,
      "text": "Так, ну, в целом мы просто с вами собирались сделать ещё одну конструкцию метровую точно."
    },
    {
      "start": 94.39,
      "end": 100.04,
      "speaker": null,
      "text": "Это для этого... для проектора."
    },
    {
      "start": 100.04,
      "end": 100.92,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 101.34,
      "end": 101.94,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 101.94,
      "end": 102.4,
      "speaker": null,
      "text": "Для монитора."
    },
    {
      "start": 102.64,
      "end": 103.96,
      "speaker": null,
      "text": "Для монитора, да."
    },
    {
      "start": 104.18,
      "end": 107.68,
      "speaker": null,
      "text": "Ну, да, для монитора как раз-таки лазерного."
    },
    {
      "start": 108.04,
      "end": 108.58,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 108.74,
      "end": 114.84,
      "speaker": null,
      "text": "А вы хотели свою экспозицию поставить на ещё что-то?"
    },
    {
      "start": 115.53,
      "end": 117.41,
      "speaker": null,
      "text": "Я просто немножко не поняла."
    },
    {
      "start": 117.41,
      "end": 127.52,
      "speaker": null,
      "text": "Нет, вот смотрите, конструкция поп-ап с окошком, где две полки мы рассчитывали."
    },
    {
      "start": 129.0,
      "end": 129.8,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 130.69,
      "end": 131.71,
      "speaker": null,
      "text": "У меня вопрос."
    },
    {
      "start": 132.51,
      "end": 137.19,
      "speaker": null,
      "text": "Эти полки в ширину могут быть метр двадцать сделать их?"
    },
    {
      "start": 138.28,
      "end": 143.28,
      "speaker": null,
      "text": "Ну, вот мы вот большую можем сделать под манекен как раз-таки с подсветкой."
    },
    {
      "start": 143.44,
      "end": 145.02,
      "speaker": null,
      "text": "То, что вот вы запрашивали."
    },
    {
      "start": 145.1,
      "end": 148.84,
      "speaker": null,
      "text": "Вот этот мы сможем сделать под размер вашего манекена."
    },
    {
      "start": 149.18,
      "end": 151.5,
      "speaker": null,
      "text": "Вам нужно, чтобы все секции мы сделали?"
    },
    {
      "start": 151.72,
      "end": 151.96,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 152.12,
      "end": 152.52,
      "speaker": null,
      "text": "Одна."
    },
    {
      "start": 152.64,
      "end": 154.94,
      "speaker": null,
      "text": "Одна секция метр двадцать."
    },
    {
      "start": 157.24,
      "end": 158.02,
      "speaker": null,
      "text": "Ну, вот."
    },
    {
      "start": 158.22,
      "end": 161.2,
      "speaker": null,
      "text": "То есть с одной большой витриной, которая под манекеном."
    },
    {
      "start": 161.28,
      "end": 161.58,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 161.92,
      "end": 162.84,
      "speaker": null,
      "text": "Манекен остаётся."
    },
    {
      "start": 162.84,
      "end": 165.44,
      "speaker": null,
      "text": "Ну, одна полка..."
    },
    {
      "start": 165.44,
      "end": 171.14,
      "speaker": null,
      "text": "Ну, один стенд, где стандартное окно, там, ну, грубо говоря, две полки."
    },
    {
      "start": 171.62,
      "end": 174.46,
      "speaker": null,
      "text": "Его длина нужна метр двадцать."
    },
    {
      "start": 181.88,
      "end": 182.38,
      "speaker": null,
      "text": "Одно."
    },
    {
      "start": 183.2,
      "end": 187.72,
      "speaker": null,
      "text": "Один стенд, вот который там их три или четыре с двумя полками."
    },
    {
      "start": 187.96,
      "end": 188.82,
      "speaker": null,
      "text": "Я не помню."
    },
    {
      "start": 189.22,
      "end": 193.78,
      "speaker": null,
      "text": "Вот размер нужен сто двадцать, чтобы была ширина его."
    },
    {
      "start": 194.67,
      "end": 197.87,
      "speaker": null,
      "text": "Так, я запрошу, но по-моему мы как раз таки так и считали,"
    },
    {
      "start": 197.87,
      "end": 201.01,
      "speaker": null,
      "text": "так как у вас начальные запросы были, я вот записывала,"
    },
    {
      "start": 202.0,
      "end": 203.62,
      "speaker": null,
      "text": "что вам так и надо было."
    },
    {
      "start": 204.26,
      "end": 205.1,
      "speaker": null,
      "text": "Я понял."
    },
    {
      "start": 205.62,
      "end": 208.68,
      "speaker": null,
      "text": "Всё, тогда давайте я вот поеду в электрический"
    },
    {
      "start": 208.68,
      "end": 211.34,
      "speaker": null,
      "text": "и вам наберу, буду уже очень много времени будет"
    },
    {
      "start": 211.34,
      "end": 212.66,
      "speaker": null,
      "text": "и я смогу с вами пообщаться."
    },
    {
      "start": 213.1,
      "end": 213.54,
      "speaker": null,
      "text": "Угу, да."
    },
    {
      "start": 213.54,
      "end": 214.82,
      "speaker": null,
      "text": "С лучшим знаменателем придём."
    },
    {
      "start": 214.96,
      "end": 216.0,
      "speaker": null,
      "text": "Всё, спасибо огромное."
    },
    {
      "start": 216.62,
      "end": 218.0,
      "speaker": null,
      "text": "Да, тогда буду ждать."
    }
  ]
}