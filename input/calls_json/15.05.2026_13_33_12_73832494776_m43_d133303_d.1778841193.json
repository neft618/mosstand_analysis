  "segments": [
    {
      "start": 1.54,
      "end": 2.8,
      "speaker": null,
      "text": "Добрый день, Дмитрий."
    },
    {
      "start": 3.85,
      "end": 7.77,
      "speaker": null,
      "text": "Здравствуйте, Дмитрий, это Владимир Одинра по роллапам."
    },
    {
      "start": 8.17,
      "end": 13.7,
      "speaker": null,
      "text": "Вы мне тут уже описали, я ответил, что пока неизвестно, когда тираж запускаем."
    },
    {
      "start": 14.02,
      "end": 21.08,
      "speaker": null,
      "text": "У меня от клиента запрос предварительно, там я вам на 10 штук просил посчитать."
    },
    {
      "start": 22.08,
      "end": 28.8,
      "speaker": null,
      "text": "Они хотят на следующей неделе 3 сначала запустить, потом попозже остальные. На 3 цена какая будет?"
    },
    {
      "start": 29.0,
      "end": 30.04,
      "speaker": null,
      "text": "Три тех, три тех."
    },
    {
      "start": 30.04,
      "end": 33.22,
      "speaker": null,
      "text": "А напомнишь, какой мы считали?"
    },
    {
      "start": 33.6,
      "end": 36.74,
      "speaker": null,
      "text": "Там роллап 85 на 200 и пресс-вол..."
    },
    {
      "start": 37.26,
      "end": 39.48,
      "speaker": null,
      "text": "Нет, конструкция какая, классическая?"
    },
    {
      "start": 40.57,
      "end": 41.85,
      "speaker": null,
      "text": "Да, классическая."
    },
    {
      "start": 42.47,
      "end": 49.76,
      "speaker": null,
      "text": "Ну, если до 10 штук, то 4 500 на баннере."
    },
    {
      "start": 50.73,
      "end": 56.21,
      "speaker": null,
      "text": "Понял, а пресс-вол однотрубный 2 на 1,5 на баннере."
    },
    {
      "start": 56.63,
      "end": 58.19,
      "speaker": null,
      "text": "Если 3 штуки тоже будет?"
    },
    {
      "start": 58.77,
      "end": 59.17,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 68.07,
      "end": 68.59,
      "speaker": null,
      "text": "Шесть."
    },
    {
      "start": 68.59,
      "end": 69.13,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 72.53,
      "end": 75.99,
      "speaker": null,
      "text": "Клиент передам, скорее всего на следующей неделе что-то у вас запрошу."
    },
    {
      "start": 77.23,
      "end": 77.71,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 78.33,
      "end": 78.99,
      "speaker": null,
      "text": "Все, спасибо."
    }
  ]
}