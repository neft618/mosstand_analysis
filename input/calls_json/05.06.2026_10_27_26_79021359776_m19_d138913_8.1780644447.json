{
  "file": "05.06.2026_10_27_26_79021359776_m19_d138913_8.1780644447.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 414.2,
  "segments": [
    {
      "start": 1.74,
      "end": 3.88,
      "speaker": null,
      "text": "Компания «Москент», меня зовут Влад. Здравствуйте."
    },
    {
      "start": 4.28,
      "end": 9.3,
      "speaker": null,
      "text": "Добрый день. Скажите, пожалуйста, нам нужна промостойка, но в определённых размерах."
    },
    {
      "start": 11.25,
      "end": 14.37,
      "speaker": null,
      "text": "Можете подсказать? Сейчас, секунду."
    },
    {
      "start": 14.83,
      "end": 15.99,
      "speaker": null,
      "text": "Конечно, а как Вам расчёт?"
    },
    {
      "start": 16.59,
      "end": 17.05,
      "speaker": null,
      "text": "Анна."
    },
    {
      "start": 17.61,
      "end": 20.79,
      "speaker": null,
      "text": "Очень приятно. И каких размеров нужна промостойка?"
    },
    {
      "start": 21.05,
      "end": 28.33,
      "speaker": null,
      "text": "Смотрите, ширина 1000, глубина 300, высота 2250 мм."
    },
    {
      "start": 28.33,
      "end": 32.66,
      "speaker": null,
      "text": "А, высота 2250 мм, я так понимаю, стоппером в месте, правильно?"
    },
    {
      "start": 33.08,
      "end": 33.32,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 34.86,
      "end": 36.08,
      "speaker": null,
      "text": "Ага, секундочку прямо."
    },
    {
      "start": 63.11,
      "end": 68.39,
      "speaker": null,
      "text": "Уточните пока что, я вот смотрю по моделям. Вам на одно мероприятие нужно, да?"
    },
    {
      "start": 69.16,
      "end": 74.81,
      "speaker": null,
      "text": "Нам вообще не на мероприятие нужно, мы пока просчитываем цены, в общем."
    },
    {
      "start": 76.74,
      "end": 79.74,
      "speaker": null,
      "text": "Ага, но пока что неизвестно когда понадобится, это правильно?"
    },
    {
      "start": 80.24,
      "end": 83.18,
      "speaker": null,
      "text": "Неизвестно когда, зачем, почему и как."
    },
    {
      "start": 83.34,
      "end": 87.12,
      "speaker": null,
      "text": "Просто дали ТЗ, нужно знать цены."
    },
    {
      "start": 88.84,
      "end": 89.28,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 89.82,
      "end": 93.2,
      "speaker": null,
      "text": "Смотрите, размеры прямо исключительно должны быть 1500."
    },
    {
      "start": 93.9,
      "end": 102.48,
      "speaker": null,
      "text": "Просто, например, если мы рассматриваем промостойку М5, наша позиция, то она идёт в размерах 965 в высоту."
    },
    {
      "start": 102.48,
      "end": 103.74,
      "speaker": null,
      "text": "Это сама тумба."
    },
    {
      "start": 104.14,
      "end": 104.64,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 105.96,
      "end": 111.62,
      "speaker": null,
      "text": "600 в ширину, глубина 300 мм и высота общая идёт 270."
    },
    {
      "start": 113.63,
      "end": 114.41,
      "speaker": null,
      "text": "Сколько?"
    },
    {
      "start": 114.81,
      "end": 115.71,
      "speaker": null,
      "text": "Еще раз."
    },
    {
      "start": 115.97,
      "end": 122.85,
      "speaker": null,
      "text": "Общая высота идёт 2070 мм. Ну чуть больше двух метров, это вместе с топпером."
    },
    {
      "start": 123.37,
      "end": 123.85,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 124.83,
      "end": 127.85,
      "speaker": null,
      "text": "Сама тумба по высоте идёт 965."
    },
    {
      "start": 129.23,
      "end": 130.55,
      "speaker": null,
      "text": "965 тумба."
    },
    {
      "start": 131.21,
      "end": 131.49,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 131.49,
      "end": 132.73,
      "speaker": null,
      "text": "Какая она стоимость?"
    },
    {
      "start": 134.54,
      "end": 135.06,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 136.1,
      "end": 138.58,
      "speaker": null,
      "text": "Данная промостойка будет стоимость 17 тысяч рублей."
    },
    {
      "start": 139.02,
      "end": 142.56,
      "speaker": null,
      "text": "Вы уточните, вы мне говорили 1000 на 500, это что у вас?"
    },
    {
      "start": 143.08,
      "end": 143.18,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 143.22,
      "end": 144.24,
      "speaker": null,
      "text": "Это ширина."
    },
    {
      "start": 144.7,
      "end": 145.76,
      "speaker": null,
      "text": "А, ширина 1000."
    },
    {
      "start": 145.76,
      "end": 146.08,
      "speaker": null,
      "text": "Все?"
    },
    {
      "start": 146.28,
      "end": 146.4,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 146.66,
      "end": 147.94,
      "speaker": null,
      "text": "Не вопрос, секундочку есть сейчас."
    },
    {
      "start": 150.88,
      "end": 151.2,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 151.86,
      "end": 152.06,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 164.18,
      "end": 165.08,
      "speaker": null,
      "text": "Теперь нашел."
    },
    {
      "start": 166.46,
      "end": 170.43,
      "speaker": null,
      "text": "Промостойка М9 мини на нашем сайте."
    },
    {
      "start": 171.11,
      "end": 171.21,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 171.37,
      "end": 175.23,
      "speaker": null,
      "text": "Она как раз будет и по ширине, и по высоте 1000."
    },
    {
      "start": 175.55,
      "end": 178.23,
      "speaker": null,
      "text": "Но с топпером 2150."
    },
    {
      "start": 179.37,
      "end": 181.31,
      "speaker": null,
      "text": "По-моему вы такой размер, да говорили мне?"
    },
    {
      "start": 184.15,
      "end": 185.43,
      "speaker": null,
      "text": "Высота 2250."
    },
    {
      "start": 185.93,
      "end": 186.95,
      "speaker": null,
      "text": "А, 2200."
    },
    {
      "start": 186.95,
      "end": 187.81,
      "speaker": null,
      "text": "Вот это 2150."
    },
    {
      "start": 188.55,
      "end": 189.43,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 189.65,
      "end": 191.29,
      "speaker": null,
      "text": "На 10 мм получается меньше."
    },
    {
      "start": 192.43,
      "end": 193.13,
      "speaker": null,
      "text": "Меньше, да."
    },
    {
      "start": 193.98,
      "end": 195.8,
      "speaker": null,
      "text": "И она в какую стоимость?"
    },
    {
      "start": 196.38,
      "end": 201.24,
      "speaker": null,
      "text": "И данная промостойка идёт конструкция плюс печать 39 тысяч рублей."
    },
    {
      "start": 201.76,
      "end": 202.76,
      "speaker": null,
      "text": "39 тысяч."
    },
    {
      "start": 203.21,
      "end": 203.73,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 204.05,
      "end": 210.15,
      "speaker": null,
      "text": "Вам по комплектации только размер известный или может быть как она собирается и всё стоит?"
    },
    {
      "start": 210.49,
      "end": 214.39,
      "speaker": null,
      "text": "У нас есть LDSP 16 миллиметров."
    },
    {
      "start": 216.74,
      "end": 219.54,
      "speaker": null,
      "text": "5 миллиметров."
    },
    {
      "start": 243.61,
      "end": 245.01,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 245.58,
      "end": 253.82,
      "speaker": null,
      "text": "Собирается пополам и получается, ну как маленькая перевозная собачка потому что она на колесиках идёт."
    },
    {
      "start": 280.26,
      "end": 281.02,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 281.02,
      "end": 282.98,
      "speaker": null,
      "text": "Я сейчас на сайте её посмотрю подробнее."
    },
    {
      "start": 283.66,
      "end": 291.0,
      "speaker": null,
      "text": "Да, может быть я куда-то могу вам скриншот скинуть именно с самой позиции, чтобы вы посмотрели и не искали?"
    },
    {
      "start": 291.0,
      "end": 294.7,
      "speaker": null,
      "text": "Я уже нашла её."
    },
    {
      "start": 295.18,
      "end": 295.98,
      "speaker": null,
      "text": "А, уже нашли."
    },
    {
      "start": 296.0,
      "end": 296.1,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 296.34,
      "end": 297.14,
      "speaker": null,
      "text": "М9 НИИ."
    },
    {
      "start": 298.11,
      "end": 299.71,
      "speaker": null,
      "text": "Так, да, нашла."
    },
    {
      "start": 300.11,
      "end": 300.69,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 300.99,
      "end": 301.25,
      "speaker": null,
      "text": "Отлично."
    },
    {
      "start": 301.25,
      "end": 305.35,
      "speaker": null,
      "text": "Анна, подскажите, а ты единственная позиция, которая вас интересует для расчёта?"
    },
    {
      "start": 305.85,
      "end": 308.03,
      "speaker": null,
      "text": "У вас только промостойки или ещё что-то?"
    },
    {
      "start": 308.31,
      "end": 308.99,
      "speaker": null,
      "text": "Нет, нет, конечно."
    },
    {
      "start": 309.41,
      "end": 316.88,
      "speaker": null,
      "text": "Промостойки, прессовы, тканевые стенды мобильные, лайтбоксы, сувенирная продукция, полиграфия."
    },
    {
      "start": 316.88,
      "end": 325.28,
      "speaker": null,
      "text": "Так, сувенирная продукция у вас, вы наносите на изделия наши или у вас свои?"
    },
    {
      "start": 325.97,
      "end": 329.61,
      "speaker": null,
      "text": "Ну в основном заказывают, ну, заказывают вместе с изделиями."
    },
    {
      "start": 330.41,
      "end": 348.89,
      "speaker": null,
      "text": "Угу, а нас интересуют футболки, так, футболки, секундукетки, манишки и, так, уличный зонт."
    },
    {
      "start": 349.53,
      "end": 350.25,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 352.39,
      "end": 355.46,
      "speaker": null,
      "text": "Шопер и фартук для персонала."
    },
    {
      "start": 357.75,
      "end": 362.45,
      "speaker": null,
      "text": "Ага, ну я вам могу фотопримеры направить наших работ по этим позициям, чтобы вы примерно ознакомились там,"
    },
    {
      "start": 365.06,
      "end": 367.5,
      "speaker": null,
      "text": "пока, я так понимаю, тираж неизвестен у вас, правильно?"
    },
    {
      "start": 367.76,
      "end": 369.34,
      "speaker": null,
      "text": "Да, тираж неизвестен."
    },
    {
      "start": 369.36,
      "end": 372.86,
      "speaker": null,
      "text": "Вот я вам фотопримеры направлю, чтобы вы знали, что мы это делаем, как мы это делаем."
    },
    {
      "start": 373.66,
      "end": 378.74,
      "speaker": null,
      "text": "Да, я вам писала вообще вчера, по-моему, запрос на почту,"
    },
    {
      "start": 378.74,
      "end": 380.8,
      "speaker": null,
      "text": "О, у меня на него, по-моему…"
    },
    {
      "start": 380.8,
      "end": 381.66,
      "speaker": null,
      "text": "Вам кто-то отвечал уже?"
    },
    {
      "start": 382.48,
      "end": 384.98,
      "speaker": null,
      "text": "Нет, нам, по-моему, никто не отвечал."
    },
    {
      "start": 385.94,
      "end": 387.72,
      "speaker": null,
      "text": "Ага, тогда знаете как делаем?"
    },
    {
      "start": 389.02,
      "end": 391.2,
      "speaker": null,
      "text": "А, ответили, да, еще я посмотрела."
    },
    {
      "start": 391.28,
      "end": 391.9,
      "speaker": null,
      "text": "А кто ответил?"
    },
    {
      "start": 394.29,
      "end": 399.34,
      "speaker": null,
      "text": "Так, нам ответила Никита Крутилин."
    },
    {
      "start": 400.58,
      "end": 407.82,
      "speaker": null,
      "text": "А, потрясающе. Я тогда сейчас передам ему всю информацию, чтобы он вас ориентировал по этой позиции и по акционерной продукции."
    },
    {
      "start": 408.48,
      "end": 409.5,
      "speaker": null,
      "text": "Да, хорошо, спасибо."
    },
    {
      "start": 409.64,
      "end": 410.24,
      "speaker": null,
      "text": "Напишу вам сейчас?"
    },
    {
      "start": 410.42,
      "end": 411.52,
      "speaker": null,
      "text": "Да, хорошо. Смотрите."
    },
    {
      "start": 411.52,
      "end": 412.46,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 412.48,
      "end": 412.54,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}