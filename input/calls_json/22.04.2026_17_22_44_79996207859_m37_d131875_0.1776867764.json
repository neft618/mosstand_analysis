{
  "file": "22.04.2026_17_22_44_79996207859_m37_d131875_0.1776867764.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 300.3,
  "segments": [
    {
      "start": 1.88,
      "end": 3.58,
      "speaker": null,
      "text": "Екатерина, компания «Мастэм», чего могу помочь?"
    },
    {
      "start": 5.14,
      "end": 14.06,
      "speaker": null,
      "text": "Здравствуйте. Я вот уже к вам обратилась с заявкой, так сказать, мы общались с девушкой, ой, ну, с кем-то, в общем, мы общались по Максу."
    },
    {
      "start": 14.96,
      "end": 24.38,
      "speaker": null,
      "text": "В общем, у меня здесь вводные, я так скажу. Мы, получается, уже с вами сотрудничали, наша организация называется «ГлавНИФС»."
    },
    {
      "start": 24.38,
      "end": 27.42,
      "speaker": null,
      "text": "Вот, являемся вашим знакомым агентами. Какие делаются?"
    },
    {
      "start": 28.22,
      "end": 29.06,
      "speaker": null,
      "text": "«ГлавНИФС»."
    },
    {
      "start": 29.22,
      "end": 29.9,
      "speaker": null,
      "text": "Глав..."
    },
    {
      "start": 29.9,
      "end": 31.12,
      "speaker": null,
      "text": "Во время делания президента."
    },
    {
      "start": 32.46,
      "end": 33.3,
      "speaker": null,
      "text": "«ГлавНИФСа»."
    },
    {
      "start": 33.3,
      "end": 34.38,
      "speaker": null,
      "text": "«НИФС»."
    },
    {
      "start": 34.57,
      "end": 36.11,
      "speaker": null,
      "text": "«ГлавНИФС», да?"
    },
    {
      "start": 37.02,
      "end": 38.16,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 39.66,
      "end": 42.48,
      "speaker": null,
      "text": "Мы у вас год назад заказывали баннер."
    },
    {
      "start": 42.88,
      "end": 48.62,
      "speaker": null,
      "text": "Вот, и, в общем, сейчас нам нужен просто баннер три на два..."
    },
    {
      "start": 49.54,
      "end": 50.36,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 50.84,
      "end": 51.54,
      "speaker": null,
      "text": "Точка."
    },
    {
      "start": 51.54,
      "end": 53.44,
      "speaker": null,
      "text": "Ну, там эти..."
    },
    {
      "start": 54.36,
      "end": 55.46,
      "speaker": null,
      "text": "«Люрикс» или как называется?"
    },
    {
      "start": 55.7,
      "end": 56.1,
      "speaker": null,
      "text": "«Люрикс»."
    },
    {
      "start": 56.1,
      "end": 56.9,
      "speaker": null,
      "text": "«Люрикс», конечно, нам..."
    },
    {
      "start": 57.48,
      "end": 57.68,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 57.8,
      "end": 59.28,
      "speaker": null,
      "text": "Нам тоже они будут нужны."
    },
    {
      "start": 59.76,
      "end": 60.3,
      "speaker": null,
      "text": "Ну, всё вот."
    },
    {
      "start": 60.38,
      "end": 61.54,
      "speaker": null,
      "text": "То есть и доставка."
    },
    {
      "start": 62.59,
      "end": 64.95,
      "speaker": null,
      "text": "А вы уверены, что вам всё-таки три на два нужно?"
    },
    {
      "start": 65.05,
      "end": 66.61,
      "speaker": null,
      "text": "У вас же сама конструкция три на два."
    },
    {
      "start": 66.77,
      "end": 68.23,
      "speaker": null,
      "text": "А вы хотите бока закрыть, правильно?"
    },
    {
      "start": 69.01,
      "end": 73.36,
      "speaker": null,
      "text": "Ну, как мне объяснил наш дизайнер, что..."
    },
    {
      "start": 73.36,
      "end": 74.1,
      "speaker": null,
      "text": "Это наша конструкция."
    },
    {
      "start": 74.16,
      "end": 75.16,
      "speaker": null,
      "text": "Это уже конструкция."
    },
    {
      "start": 77.94,
      "end": 79.78,
      "speaker": null,
      "text": "Я вас немного подложить."
    },
    {
      "start": 80.16,
      "end": 82.32,
      "speaker": null,
      "text": "Что вы если говорите, что год назад заказывали?"
    },
    {
      "start": 82.38,
      "end": 85.0,
      "speaker": null,
      "text": "Ну, это ваша конструкция или какая-то другая?"
    },
    {
      "start": 85.22,
      "end": 86.76,
      "speaker": null,
      "text": "В общем, вопрос смотрите в чём."
    },
    {
      "start": 87.0,
      "end": 90.8,
      "speaker": null,
      "text": "Если вам нужно вот так бока закрыть, как у вас на фотографии"
    },
    {
      "start": 90.8,
      "end": 94.24,
      "speaker": null,
      "text": "вы присылали в чат, то у вас должен быть баннер не ровно"
    },
    {
      "start": 94.24,
      "end": 97.42,
      "speaker": null,
      "text": "в размер конструкции, а чуть больше с припусками"
    },
    {
      "start": 97.42,
      "end": 98.92,
      "speaker": null,
      "text": "на закрытие этих боковин."
    },
    {
      "start": 99.38,
      "end": 102.32,
      "speaker": null,
      "text": "Дизайнер не может утверждать стопроцентно, потому что..."
    },
    {
      "start": 102.32,
      "end": 105.0,
      "speaker": null,
      "text": "Ну, я очень сомневаюсь, что он разбирается в том, как"
    },
    {
      "start": 105.0,
      "end": 107.82,
      "speaker": null,
      "text": "именно должно быть это всё сделано для того, чтобы"
    },
    {
      "start": 107.82,
      "end": 109.06,
      "speaker": null,
      "text": "закрывалась конструкция."
    },
    {
      "start": 109.2,
      "end": 112.0,
      "speaker": null,
      "text": "То есть тут больше именно монтажники должны эти"
    },
    {
      "start": 112.0,
      "end": 112.86,
      "speaker": null,
      "text": "вопросы решать."
    },
    {
      "start": 112.98,
      "end": 114.4,
      "speaker": null,
      "text": "Это больше технические вопросы."
    },
    {
      "start": 115.16,
      "end": 117.76,
      "speaker": null,
      "text": "И дизайнеру даёт техническое здание, а он по нему делает"
    },
    {
      "start": 117.76,
      "end": 118.96,
      "speaker": null,
      "text": "макет в размер."
    },
    {
      "start": 119.2,
      "end": 121.96,
      "speaker": null,
      "text": "Нет, если вы утверждаете три на два, хорошо, мы сделаем"
    },
    {
      "start": 121.96,
      "end": 122.9,
      "speaker": null,
      "text": "вам три на два без проблем."
    },
    {
      "start": 123.0,
      "end": 125.62,
      "speaker": null,
      "text": "Просто чтобы вы потом не говорили, что у вас не натягивается"
    },
    {
      "start": 125.62,
      "end": 129.64,
      "speaker": null,
      "text": "на боковины баннер, что он не закрывает."
    },
    {
      "start": 130.14,
      "end": 132.92,
      "speaker": null,
      "text": "Я вам могу присылать фотографию, как выглядит тип М конструкция,"
    },
    {
      "start": 133.54,
      "end": 136.94,
      "speaker": null,
      "text": "которая у вас как раз с дуна трубами с незакрытыми"
    },
    {
      "start": 136.94,
      "end": 137.36,
      "speaker": null,
      "text": "боками."
    },
    {
      "start": 137.44,
      "end": 139.68,
      "speaker": null,
      "text": "Вот у вас такой баннер и будет, если его сделать в размер"
    },
    {
      "start": 139.68,
      "end": 140.38,
      "speaker": null,
      "text": "конструкции."
    },
    {
      "start": 141.92,
      "end": 147.14,
      "speaker": null,
      "text": "Как мне объяснил наш дизайнер, что мы заказываем баннер"
    },
    {
      "start": 147.14,
      "end": 153.9,
      "speaker": null,
      "text": "три на два, и это логичным идёт образом, что вы печатаете"
    },
    {
      "start": 153.9,
      "end": 155.38,
      "speaker": null,
      "text": "уже с припуском."
    },
    {
      "start": 155.9,
      "end": 159.32,
      "speaker": null,
      "text": "То есть, макет наш дизайнер пришлёт как бы с учётом"
    },
    {
      "start": 159.64,
      "end": 162.64,
      "speaker": null,
      "text": "припусков, потому что она знает, сколько вы обычно"
    },
    {
      "start": 162.64,
      "end": 163.64,
      "speaker": null,
      "text": "делаете припуск."
    },
    {
      "start": 167.76,
      "end": 169.6,
      "speaker": null,
      "text": "Ну да, правильно."
    },
    {
      "start": 169.82,
      "end": 173.92,
      "speaker": null,
      "text": "Баннер зачатывается с припусками по 12 см с каждой"
    },
    {
      "start": 173.92,
      "end": 174.24,
      "speaker": null,
      "text": "стороны."
    },
    {
      "start": 175.33,
      "end": 178.23,
      "speaker": null,
      "text": "Это значит, что и сам баннер должен вот такой быть,"
    },
    {
      "start": 178.39,
      "end": 180.77,
      "speaker": null,
      "text": "то есть не три на два, а вот он с припусками по"
    },
    {
      "start": 180.77,
      "end": 182.31,
      "speaker": null,
      "text": "12 см с каждой стороны."
    },
    {
      "start": 182.31,
      "end": 186.33,
      "speaker": null,
      "text": "То есть, он идёт 3.24 на 2.24."
    },
    {
      "start": 188.2,
      "end": 190.18,
      "speaker": null,
      "text": "Какая получается стоимость баннера?"
    },
    {
      "start": 192.48,
      "end": 195.74,
      "speaker": null,
      "text": "Если три, которые я присылала, не нужно считать то, что"
    },
    {
      "start": 195.74,
      "end": 196.96,
      "speaker": null,
      "text": "данные я вам уговорила."
    },
    {
      "start": 199.38,
      "end": 203.68,
      "speaker": null,
      "text": "Если три на два мы печатаем, то вам сообщали стоимость"
    },
    {
      "start": 203.68,
      "end": 205.4,
      "speaker": null,
      "text": "6000 рублей – это с лизерсами."
    },
    {
      "start": 205.9,
      "end": 210.44,
      "speaker": null,
      "text": "Если мы говорим больше, то есть 3.24 на 2.24 – это 7000"
    },
    {
      "start": 210.44,
      "end": 211.46,
      "speaker": null,
      "text": "рублей с лизерсами."
    },
    {
      "start": 211.46,
      "end": 219.11,
      "speaker": null,
      "text": "3.24 на сколько?"
    },
    {
      "start": 219.77,
      "end": 220.67,
      "speaker": null,
      "text": "На 2.24."
    },
    {
      "start": 222.62,
      "end": 226.62,
      "speaker": null,
      "text": "А если он чётко три на два, то он не закрывает"
    },
    {
      "start": 226.62,
      "end": 227.34,
      "speaker": null,
      "text": "боковины, да?"
    },
    {
      "start": 227.52,
      "end": 227.78,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 228.06,
      "end": 229.24,
      "speaker": null,
      "text": "Нет, не закрывает."
    },
    {
      "start": 229.3,
      "end": 230.02,
      "speaker": null,
      "text": "Он не начальница."
    },
    {
      "start": 231.02,
      "end": 233.2,
      "speaker": null,
      "text": "Не хватит натяжения закрыть боковины."
    },
    {
      "start": 234.52,
      "end": 236.98,
      "speaker": null,
      "text": "То есть, фотографию пришлю, как он будет выявить,"
    },
    {
      "start": 237.16,
      "end": 239.24,
      "speaker": null,
      "text": "он и так вот и будет с открытыми боковинами."
    },
    {
      "start": 243.07,
      "end": 247.23,
      "speaker": null,
      "text": "Получается 12 сантиметров вверх, 12 вниз и по бокам"
    },
    {
      "start": 247.23,
      "end": 248.27,
      "speaker": null,
      "text": "12 сантиметров?"
    },
    {
      "start": 248.51,
      "end": 248.75,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 248.97,
      "end": 249.29,
      "speaker": null,
      "text": "Всё правильно."
    },
    {
      "start": 250.86,
      "end": 254.24,
      "speaker": null,
      "text": "Но очень странно, потому что мы сейчас измеряли"
    },
    {
      "start": 254.24,
      "end": 257.34,
      "speaker": null,
      "text": "когда баннер, и вот этот мы заказывали у вас, у нас"
    },
    {
      "start": 257.34,
      "end": 259.05,
      "speaker": null,
      "text": "сбоку 8 сантиметров."
    },
    {
      "start": 259.05,
      "end": 260.63,
      "speaker": null,
      "text": "Ну, по 8."
    },
    {
      "start": 260.81,
      "end": 263.79,
      "speaker": null,
      "text": "То есть 16 на 24, если в сумме."
    },
    {
      "start": 264.33,
      "end": 266.09,
      "speaker": null,
      "text": "Я не могу сказать почему так."
    },
    {
      "start": 266.39,
      "end": 270.03,
      "speaker": null,
      "text": "Я не делала вам этот стенд, поэтому я не могу отвечать"
    },
    {
      "start": 270.03,
      "end": 273.17,
      "speaker": null,
      "text": "за то, какой там размер и правильно ли вы измерили."
    },
    {
      "start": 273.35,
      "end": 275.19,
      "speaker": null,
      "text": "Если правильно, то почему он такого размера?"
    },
    {
      "start": 275.19,
      "end": 278.05,
      "speaker": null,
      "text": "Я вот вам сейчас говорю, как есть, что вот если"
    },
    {
      "start": 278.05,
      "end": 280.37,
      "speaker": null,
      "text": "такая конструкция у вас 3 на 2, для того чтобы вам"
    },
    {
      "start": 280.37,
      "end": 282.81,
      "speaker": null,
      "text": "за вторую трубу зацепиться, нужно делать припуски по"
    },
    {
      "start": 282.81,
      "end": 284.37,
      "speaker": null,
      "text": "12 сантиметров с каждой стороны."
    },
    {
      "start": 285.32,
      "end": 288.0,
      "speaker": null,
      "text": "Кто вам сделал по 8, ну я не могу сказать, к сожалению,"
    },
    {
      "start": 288.26,
      "end": 289.38,
      "speaker": null,
      "text": "не могу за это отвечать."
    },
    {
      "start": 290.45,
      "end": 293.95,
      "speaker": null,
      "text": "Ну вот мы, вот сейчас, например, он у нас не тянутся,"
    },
    {
      "start": 294.07,
      "end": 295.61,
      "speaker": null,
      "text": "у него есть некоторые складки."
    },
    {
      "start": 295.71,
      "end": 297.93,
      "speaker": null,
      "text": "Мы, например, думали, что нужно меньше заказывать"
    },
    {
      "start": 297.93,
      "end": 298.27,
      "speaker": null,
      "text": "размер."
    },
    {
      "start": 298.49,
      "end": 298.67,
      "speaker": null,
      "text": "Нет?"
    },
    {
      "start": 298.67,
      "end": 298.79,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 299.57,
      "end": 300.23,
      "speaker": null,
      "text": "А вы..."
    }
  ]
}