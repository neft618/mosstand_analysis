{
  "file": "27.04.2026_11_49_08_79166909177_m29_d134349_d.1777279748.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 294.4,
  "segments": [
    {
      "start": 0.94,
      "end": 4.38,
      "speaker": null,
      "text": "Добрый день, меня зовут Сеня, компания «Стенд», как я могу коммерчесаться?"
    },
    {
      "start": 5.64,
      "end": 11.44,
      "speaker": null,
      "text": "Алло, здравствуйте. Подскажите, пожалуйста, мы у вас заказывали стойку, могу сказать, номер счёта."
    },
    {
      "start": 12.1,
      "end": 14.38,
      "speaker": null,
      "text": "Да, давайте. У кого заказывали?"
    },
    {
      "start": 16.17,
      "end": 16.99,
      "speaker": null,
      "text": "Повторите вопрос."
    },
    {
      "start": 17.53,
      "end": 20.81,
      "speaker": null,
      "text": "У кого заказывали? Какой менеджер у вас был?"
    },
    {
      "start": 20.85,
      "end": 22.55,
      "speaker": null,
      "text": "«Стендс.ру». Не знаю."
    },
    {
      "start": 24.06,
      "end": 25.06,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 25.18,
      "end": 28.28,
      "speaker": null,
      "text": "Есть только счёт, больше нет никакой информации."
    },
    {
      "start": 28.28,
      "end": 32.18,
      "speaker": null,
      "text": "Давайте по счёту я посмотрю, кто у вас менеджер."
    },
    {
      "start": 33.77,
      "end": 36.23,
      "speaker": null,
      "text": "МС – это как доллар?"
    },
    {
      "start": 36.75,
      "end": 37.33,
      "speaker": null,
      "text": "69."
    },
    {
      "start": 38.71,
      "end": 39.71,
      "speaker": null,
      "text": "59."
    },
    {
      "start": 40.23,
      "end": 41.01,
      "speaker": null,
      "text": "215."
    },
    {
      "start": 42.95,
      "end": 43.87,
      "speaker": null,
      "text": "215."
    },
    {
      "start": 44.79,
      "end": 45.15,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 56.14,
      "end": 58.04,
      "speaker": null,
      "text": "Так, а у вас только эта информация?"
    },
    {
      "start": 60.38,
      "end": 61.6,
      "speaker": null,
      "text": "Какая вам ещё нужна?"
    },
    {
      "start": 64.23,
      "end": 66.57,
      "speaker": null,
      "text": "А какого года этот счёт?"
    },
    {
      "start": 67.71,
      "end": 70.67,
      "speaker": null,
      "text": "Года 25-го. 12.09.25."
    },
    {
      "start": 71.54,
      "end": 72.12,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 74.28,
      "end": 74.44,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 74.78,
      "end": 76.64,
      "speaker": null,
      "text": "А какой вопрос по этому счёту у вас?"
    },
    {
      "start": 76.72,
      "end": 81.02,
      "speaker": null,
      "text": "Хотели бы повторить или там что-то с закрывающими документами?"
    },
    {
      "start": 81.62,
      "end": 87.62,
      "speaker": null,
      "text": "Нет, нужно заказать то, что тут стойка осталась, а вот то, что одевать на стойку новую."
    },
    {
      "start": 99.45,
      "end": 100.03,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 100.03,
      "end": 108.83,
      "speaker": null,
      "text": "А если вы там скажете, какой у вас ННН-компания или название, то так я смогу понять, что именно вам необходимо, чтобы было заказано в тот раз."
    },
    {
      "start": 112.44,
      "end": 113.04,
      "speaker": null,
      "text": "39…"
    },
    {
      "start": 113.62,
      "end": 115.08,
      "speaker": null,
      "text": "Так, сейчас, секундочку."
    },
    {
      "start": 124.93,
      "end": 125.85,
      "speaker": null,
      "text": "Написываю ННН."
    },
    {
      "start": 128.21,
      "end": 128.73,
      "speaker": null,
      "text": "06."
    },
    {
      "start": 131.15,
      "end": 131.63,
      "speaker": null,
      "text": "07."
    },
    {
      "start": 131.77,
      "end": 132.19,
      "speaker": null,
      "text": "21."
    },
    {
      "start": 133.63,
      "end": 135.17,
      "speaker": null,
      "text": "21, да."
    },
    {
      "start": 138.56,
      "end": 138.98,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 139.24,
      "end": 139.76,
      "speaker": null,
      "text": "Так, поняла."
    },
    {
      "start": 139.82,
      "end": 140.86,
      "speaker": null,
      "text": "У вас был Владислав."
    },
    {
      "start": 142.48,
      "end": 142.82,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 142.98,
      "end": 144.88,
      "speaker": null,
      "text": "На данный момент он сейчас в отпуске."
    },
    {
      "start": 145.0,
      "end": 149.36,
      "speaker": null,
      "text": "Я тогда его руководителю передам как раз таки, чтобы он с вами связался."
    },
    {
      "start": 149.52,
      "end": 152.32,
      "speaker": null,
      "text": "А подскажите, вам нужно, получается…"
    },
    {
      "start": 152.32,
      "end": 154.88,
      "speaker": null,
      "text": "Вот у вас альтек изогнутый и промостойка."
    },
    {
      "start": 155.06,
      "end": 157.26,
      "speaker": null,
      "text": "Вам нужно только на промостойку, правильно?"
    },
    {
      "start": 157.72,
      "end": 159.78,
      "speaker": null,
      "text": "Нам мог с трибуну перепечатать полотно."
    },
    {
      "start": 160.32,
      "end": 161.24,
      "speaker": null,
      "text": "Ну, новый, да."
    },
    {
      "start": 161.72,
      "end": 163.86,
      "speaker": null,
      "text": "Какой новый чехольчик, ткань…"
    },
    {
      "start": 163.86,
      "end": 165.42,
      "speaker": null,
      "text": "Ну, я поняла, хорошо."
    },
    {
      "start": 165.84,
      "end": 167.42,
      "speaker": null,
      "text": "А на стенд вам не нужно, правильно?"
    },
    {
      "start": 167.54,
      "end": 168.4,
      "speaker": null,
      "text": "Только на стойку."
    },
    {
      "start": 170.53,
      "end": 171.59,
      "speaker": null,
      "text": "На какой стенд?"
    },
    {
      "start": 172.76,
      "end": 176.6,
      "speaker": null,
      "text": "У вас тут еще написано, что тканевый стенд вы еще заказывали."
    },
    {
      "start": 181.92,
      "end": 186.22,
      "speaker": null,
      "text": "На который он мне нужен на чехол, на ресепшн, который такой внизу как баром."
    },
    {
      "start": 186.32,
      "end": 187.7,
      "speaker": null,
      "text": "Все, я поняла, поняла."
    },
    {
      "start": 188.28,
      "end": 189.4,
      "speaker": null,
      "text": "Хорошо, без проблем."
    },
    {
      "start": 189.64,
      "end": 193.44,
      "speaker": null,
      "text": "А здесь получается вот первая позиция – это изогнутые, это целая конструкция, правильно?"
    },
    {
      "start": 193.44,
      "end": 196.1,
      "speaker": null,
      "text": "Да-да-да, это у вас конструкция была."
    },
    {
      "start": 196.56,
      "end": 198.16,
      "speaker": null,
      "text": "3 на 2.3."
    },
    {
      "start": 198.32,
      "end": 201.44,
      "speaker": null,
      "text": "Если только на бокс трибуна, хорошо, без проблем, я тогда передам…"
    },
    {
      "start": 201.98,
      "end": 203.7,
      "speaker": null,
      "text": "А по цене примерно сколько это будет?"
    },
    {
      "start": 206.42,
      "end": 206.9,
      "speaker": null,
      "text": "Так…"
    },
    {
      "start": 206.9,
      "end": 208.58,
      "speaker": null,
      "text": "Ну, не 49 тысячи, правильно?"
    },
    {
      "start": 208.88,
      "end": 211.58,
      "speaker": null,
      "text": "Нет-нет-нет, это полностью еще было."
    },
    {
      "start": 211.84,
      "end": 221.1,
      "speaker": null,
      "text": "А макета у вас готова, правильно?"
    },
    {
      "start": 222.47,
      "end": 225.11,
      "speaker": null,
      "text": "Макета у нас пока нету, но мы сделаем."
    },
    {
      "start": 225.11,
      "end": 226.03,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 226.91,
      "end": 227.45,
      "speaker": null,
      "text": "Хорошо, поняла."
    },
    {
      "start": 228.09,
      "end": 228.41,
      "speaker": null,
      "text": "Так, ну смотрите…"
    },
    {
      "start": 228.41,
      "end": 229.65,
      "speaker": null,
      "text": "Или у вас можно какой-то?"
    },
    {
      "start": 230.03,
      "end": 233.03,
      "speaker": null,
      "text": "Да, можно либо у нас разработку макетов."
    },
    {
      "start": 233.75,
      "end": 238.85,
      "speaker": null,
      "text": "По моей стоимости, если печать фото панели для бокс трибуны – 5500 у нас по стоимости."
    },
    {
      "start": 239.19,
      "end": 242.35,
      "speaker": null,
      "text": "Ну, соответственно, после оплаты согласования макетов…"
    },
    {
      "start": 243.13,
      "end": 245.49,
      "speaker": null,
      "text": "5500 у нас там чехол как бы стоит, да?"
    },
    {
      "start": 246.13,
      "end": 248.91,
      "speaker": null,
      "text": "Да-да, это только само полотно новое."
    },
    {
      "start": 249.65,
      "end": 253.41,
      "speaker": null,
      "text": "По срокам два рабочих дня…"
    },
    {
      "start": 253.41,
      "end": 256.51,
      "speaker": null,
      "text": "А если мы захотим через вас сделать дизайн?"
    },
    {
      "start": 257.46,
      "end": 260.16,
      "speaker": null,
      "text": "Это нужно уточнять именно у мамича, потому что…"
    },
    {
      "start": 260.16,
      "end": 260.5,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 260.64,
      "end": 264.18,
      "speaker": null,
      "text": "Плюс еще все нюансы уточняют."
    },
    {
      "start": 264.68,
      "end": 269.56,
      "speaker": null,
      "text": "Поэтому если только вы можете уточнить его руководителя."
    },
    {
      "start": 270.5,
      "end": 273.96,
      "speaker": null,
      "text": "Потому что Влад сейчас в отпуске не сможет никак подсказать."
    },
    {
      "start": 274.55,
      "end": 277.11,
      "speaker": null,
      "text": "Хорошо, вы туда приступите со мной, что не связались, хорошо?"
    },
    {
      "start": 277.69,
      "end": 279.35,
      "speaker": null,
      "text": "Да, по этому номеру телефона, правильно?"
    },
    {
      "start": 279.51,
      "end": 280.23,
      "speaker": null,
      "text": "Да, поэтому, да."
    },
    {
      "start": 280.41,
      "end": 281.17,
      "speaker": null,
      "text": "Спасибо вам большое."
    },
    {
      "start": 281.19,
      "end": 282.13,
      "speaker": null,
      "text": "А как вас зовут?"
    },
    {
      "start": 282.13,
      "end": 283.27,
      "speaker": null,
      "text": "Валентина."
    },
    {
      "start": 283.75,
      "end": 285.07,
      "speaker": null,
      "text": "Валентина, очень приятно."
    },
    {
      "start": 285.27,
      "end": 288.79,
      "speaker": null,
      "text": "Все, сейчас тогда все передам и с вами вяжем."
    },
    {
      "start": 289.55,
      "end": 290.63,
      "speaker": null,
      "text": "На связи."
    },
    {
      "start": 291.01,
      "end": 291.61,
      "speaker": null,
      "text": "Хорошего дня."
    },
    {
      "start": 291.69,
      "end": 292.97,
      "speaker": null,
      "text": "Спасибо вам даже прекрасно."
    },
    {
      "start": 293.55,
      "end": 294.13,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}