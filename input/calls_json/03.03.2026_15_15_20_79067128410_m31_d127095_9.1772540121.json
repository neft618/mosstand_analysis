  "segments": [
    {
      "start": 0.94,
      "end": 2.44,
      "speaker": null,
      "text": "Здравствуйте, Валерия с Мостенд."
    },
    {
      "start": 3.29,
      "end": 13.65,
      "speaker": null,
      "text": "Здравствуйте. Посмотрите, пожалуйста, запросом на почту отправила. Нам буклетница одна напольная срочно нужна. Смотрите, пожалуйста, может есть наличие, чтобы мы сразу купили?"
    },
    {
      "start": 15.02,
      "end": 19.5,
      "speaker": null,
      "text": "Так, одну секунду. Вы направили на почту какую именно?"
    },
    {
      "start": 20.98,
      "end": 25.04,
      "speaker": null,
      "text": "Какая у вас на сайте указана, Мостенд. Мне даже отбивка пришла."
    },
    {
      "start": 25.8,
      "end": 27.4,
      "speaker": null,
      "text": "А вы направили на инфо, да?"
    },
    {
      "start": 28.02,
      "end": 29.04,
      "speaker": null,
      "text": "Да, на инфо."
    },
    {
      "start": 29.78,
      "end": 31.52,
      "speaker": null,
      "text": "А как могу к вам обращаться?"
    },
    {
      "start": 31.86,
      "end": 35.86,
      "speaker": null,
      "text": "Ирина, меня зовут. Это компания технологии визуализации успеха. Я менеджер по закупкам."
    },
    {
      "start": 36.49,
      "end": 37.33,
      "speaker": null,
      "text": "А, я поняла."
    },
    {
      "start": 38.01,
      "end": 40.23,
      "speaker": null,
      "text": "Но реквизиты вложены с письмом."
    },
    {
      "start": 43.9,
      "end": 48.16,
      "speaker": null,
      "text": "Надо будет сейчас на этом найти, прежде всего, ваше письмо, потому что попали..."
    },
    {
      "start": 48.16,
      "end": 50.88,
      "speaker": null,
      "text": "Позвонили мне, написали на общую почту."
    },
    {
      "start": 51.79,
      "end": 52.27,
      "speaker": null,
      "text": "Секунду."
    },
    {
      "start": 54.6,
      "end": 56.36,
      "speaker": null,
      "text": "Напишите, какой почтой вы написали?"
    },
    {
      "start": 57.14,
      "end": 58.14,
      "speaker": null,
      "text": "Продисуйте, пожалуйста."
    },
    {
      "start": 59.42,
      "end": 60.36,
      "speaker": null,
      "text": "Инфо собака."
    },
    {
      "start": 60.36,
      "end": 63.34,
      "speaker": null,
      "text": "Нет, нет. Какой почтой вы написали?"
    },
    {
      "start": 63.34,
      "end": 65.0,
      "speaker": null,
      "text": "А, я написала."
    },
    {
      "start": 65.52,
      "end": 67.38,
      "speaker": null,
      "text": "Сорокинаи собакстанблайн.ру"
    },
    {
      "start": 69.33,
      "end": 78.02,
      "speaker": null,
      "text": "15-15. Минут назад."
    },
    {
      "start": 79.19,
      "end": 79.53,
      "speaker": null,
      "text": "Две."
    },
    {
      "start": 122.22,
      "end": 124.82,
      "speaker": null,
      "text": "Ну вы знаете, а можете протектовать более подробно?"
    },
    {
      "start": 125.14,
      "end": 126.2,
      "speaker": null,
      "text": "Не успеваю записывать."
    },
    {
      "start": 126.36,
      "end": 127.38,
      "speaker": null,
      "text": "Сорокин.ру"
    },
    {
      "start": 127.38,
      "end": 128.2,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 129.5,
      "end": 130.26,
      "speaker": null,
      "text": "Буква О."
    },
    {
      "start": 131.6,
      "end": 132.44,
      "speaker": null,
      "text": "Буква Р."
    },
    {
      "start": 133.81,
      "end": 134.77,
      "speaker": null,
      "text": "Буква У."
    },
    {
      "start": 136.65,
      "end": 138.07,
      "speaker": null,
      "text": "Буква К, как русская."
    },
    {
      "start": 140.34,
      "end": 143.02,
      "speaker": null,
      "text": "Буква И с точкой сверху."
    },
    {
      "start": 144.4,
      "end": 145.3,
      "speaker": null,
      "text": "Буква Н."
    },
    {
      "start": 145.58,
      "end": 146.67,
      "speaker": null,
      "text": "И А, да?"
    },
    {
      "start": 147.07,
      "end": 147.41,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 148.66,
      "end": 149.9,
      "speaker": null,
      "text": "Собака стальвайн точка?"
    },
    {
      "start": 150.04,
      "end": 150.38,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 150.56,
      "end": 150.98,
      "speaker": null,
      "text": "Точка."
    },
    {
      "start": 151.12,
      "end": 151.72,
      "speaker": null,
      "text": "И."
    },
    {
      "start": 154.08,
      "end": 154.82,
      "speaker": null,
      "text": "Все, да."
    },
    {
      "start": 154.92,
      "end": 156.02,
      "speaker": null,
      "text": "Собака стальвайн точка."
    },
    {
      "start": 168.66,
      "end": 169.26,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 170.53,
      "end": 172.29,
      "speaker": null,
      "text": "Давайте, как с вами тогда поступим."
    },
    {
      "start": 172.41,
      "end": 177.45,
      "speaker": null,
      "text": "Я сейчас уточню именно у человека, у которого есть доступ в общую почту,"
    },
    {
      "start": 177.57,
      "end": 178.45,
      "speaker": null,
      "text": "пока не распределяется."
    },
    {
      "start": 178.45,
      "end": 179.07,
      "speaker": null,
      "text": "Вам перезвоню."
    },
    {
      "start": 179.43,
      "end": 179.89,
      "speaker": null,
      "text": "Договорились?"
    },
    {
      "start": 180.92,
      "end": 182.82,
      "speaker": null,
      "text": "А мне перезвонить вам или как?"
    },
    {
      "start": 183.44,
      "end": 184.32,
      "speaker": null,
      "text": "А я вам перезвоню."
    },
    {
      "start": 185.06,
      "end": 185.82,
      "speaker": null,
      "text": "А давайте жду."
    },
    {
      "start": 186.04,
      "end": 186.32,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 186.32,
      "end": 186.46,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
