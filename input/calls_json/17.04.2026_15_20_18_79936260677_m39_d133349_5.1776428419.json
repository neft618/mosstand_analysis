  "segments": [
    {
      "start": 1.6,
      "end": 2.16,
      "speaker": null,
      "text": "Иена?"
    },
    {
      "start": 2.86,
      "end": 3.2,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 4.02,
      "end": 11.88,
      "speaker": null,
      "text": "Здравствуйте, компания Макцент. Общаюсь сейчас с моим коллегой Валентином по поводу запроса на воскресенье, прислал и два роллап, верно?"
    },
    {
      "start": 12.1,
      "end": 13.18,
      "speaker": null,
      "text": "Да, да-да-да."
    },
    {
      "start": 13.52,
      "end": 16.46,
      "speaker": null,
      "text": "Да, скажите, есть ли у вас приложение макет?"
    },
    {
      "start": 17.02,
      "end": 17.92,
      "speaker": null,
      "text": "Макс есть."
    },
    {
      "start": 18.44,
      "end": 24.82,
      "speaker": null,
      "text": "Да, я вам написал сейчас сообщение, в Телеграме не получилось, пишут, что номер скрыт. Написал вам в Максе."
    },
    {
      "start": 25.22,
      "end": 27.56,
      "speaker": null,
      "text": "Могли проверить, пришло ли вам сообщение?"
    },
    {
      "start": 27.56,
      "end": 35.18,
      "speaker": null,
      "text": "Да, сейчас хорошо. Я правда его удалила, потому что у меня из-за масла все эти шелчки и эхо появилось."
    },
    {
      "start": 35.73,
      "end": 42.84,
      "speaker": null,
      "text": "А скажите, а вам не сложно будет, вот я вам продиктую очень лёгкий ник для Телеграма?"
    },
    {
      "start": 43.28,
      "end": 43.78,
      "speaker": null,
      "text": "Можете, нет?"
    },
    {
      "start": 44.0,
      "end": 44.24,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 45.06,
      "end": 45.36,
      "speaker": null,
      "text": "Да?"
    },
    {
      "start": 46.02,
      "end": 46.62,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 46.92,
      "end": 52.6,
      "speaker": null,
      "text": "Большие буквы Елена, обычно английские буквы как пишутся, слышишь, что это пишется?"
    },
    {
      "start": 52.6,
      "end": 59.82,
      "speaker": null,
      "text": "Елена. И также видно, после Елены большая буква М и И с точкой."
    },
    {
      "start": 59.94,
      "end": 60.94,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 61.78,
      "end": 63.08,
      "speaker": null,
      "text": "Две Р, Р."
    },
    {
      "start": 63.98,
      "end": 64.8,
      "speaker": null,
      "text": "Р, Р?"
    },
    {
      "start": 65.7,
      "end": 65.9,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 66.14,
      "end": 67.34,
      "speaker": null,
      "text": "У как наша И."
    },
    {
      "start": 68.64,
      "end": 69.02,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 69.78,
      "end": 70.96,
      "speaker": null,
      "text": "И А как наша А."
    },
    {
      "start": 71.22,
      "end": 72.16,
      "speaker": null,
      "text": "НИ, НИРУА."
    },
    {
      "start": 72.26,
      "end": 73.12,
      "speaker": null,
      "text": "Елена, НИРУА."
    },
    {
      "start": 73.18,
      "end": 73.86,
      "speaker": null,
      "text": "Ну это с видной."
    },
    {
      "start": 74.1,
      "end": 76.82,
      "speaker": null,
      "text": "Елена с большой буквы и НИРУА с большой буквы."
    },
    {
      "start": 77.5,
      "end": 78.14,
      "speaker": null,
      "text": "Ага, да."
    },
    {
      "start": 78.44,
      "end": 83.56,
      "speaker": null,
      "text": "Тогда секунду попробую написать, на крайний случай со второго рабочего телефона напишу."
    },
    {
      "start": 83.56,
