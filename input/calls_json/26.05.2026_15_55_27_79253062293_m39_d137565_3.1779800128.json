    {
      "start": 88.89,
      "end": 90.57,
      "speaker": null,
      "text": "Я вот не знаю."
    },
    {
      "start": 90.83,
      "end": 92.39,
      "speaker": null,
      "text": "Ну если вас бы вы видели наверняка."
