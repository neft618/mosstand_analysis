  "segments": [
    {
      "start": 0.88,
      "end": 1.86,
      "speaker": null,
      "text": "Да, Лёх."
    },
    {
      "start": 2.6,
      "end": 4.3,
      "speaker": null,
      "text": "Да, Никит, это Ксенеуран."
    },
    {
      "start": 4.58,
      "end": 9.54,
      "speaker": null,
      "text": "Смотрите, я вот всё такой вопрос, вы написали ткани без стенд, это вот мистер лапа, да, как мы с вами узнали?"
    },
    {
      "start": 10.06,
      "end": 13.24,
      "speaker": null,
      "text": "Ну почему-то размер указали 110 на 110, это ошибка."
    },
    {
      "start": 13.48,
      "end": 17.32,
      "speaker": null,
      "text": "Это на ресепшн не указал, возможно дальше."
    },
    {
      "start": 18.06,
      "end": 18.82,
      "speaker": null,
      "text": "Я ещё открою."
    },
    {
      "start": 19.92,
      "end": 25.32,
      "speaker": null,
      "text": "А тогда я не понимаю, текстильный стенд, альтек, это стойка."
    },
    {
      "start": 26.78,
      "end": 29.42,
      "speaker": null,
      "text": "Почему 2 на 230, я не понимаю."
    },
    {
      "start": 37.14,
      "end": 40.62,
      "speaker": null,
      "text": "Это вот задник, я так понимаю, что это он только размеры, да, не те?"
    },
    {
      "start": 40.92,
      "end": 43.4,
      "speaker": null,
      "text": "Да, давайте сейчас ещё раз переделаю."
    },
    {
      "start": 44.52,
      "end": 47.82,
      "speaker": null,
      "text": "Просто очень много похожих запросов, возможно просто..."
    },
    {
      "start": 47.82,
      "end": 47.94,
      "speaker": null,
      "text": "Я поняла."
    },
    {
      "start": 48.3,
      "end": 52.24,
      "speaker": null,
      "text": "Так, у нас там получается не 43, а 28."
    },
    {
      "start": 53.08,
      "end": 54.04,
      "speaker": null,
      "text": "Нет слов."
    },
    {
      "start": 55.26,
      "end": 58.02,
      "speaker": null,
      "text": "Так, это то, что я вам отправляю."
    },
    {
      "start": 58.6,
      "end": 61.84,
      "speaker": null,
      "text": "Это текстильный стенд, это где задник?"
    },
    {
      "start": 61.84,
      "end": 64.04,
      "speaker": null,
      "text": "Тот, который вы отгружали, да, девочкам недавно?"
    },
    {
      "start": 64.72,
      "end": 65.18,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 65.94,
      "end": 68.64,
      "speaker": null,
      "text": "И это размер как раз, да, метр на два."
    },
    {
      "start": 68.64,
      "end": 68.66,
      "speaker": null,
      "text": "Текстильный стенд."
    },
    {
      "start": 69.91,
      "end": 72.21,
      "speaker": null,
      "text": "Да, труба, обычная стойка."
    },
    {
      "start": 72.77,
      "end": 73.63,
      "speaker": null,
      "text": "Так, текстильный..."
    },
    {
      "start": 73.63,
      "end": 74.57,
      "speaker": null,
      "text": "Давайте ещё раз вправлю."
    },
    {
      "start": 75.19,
      "end": 76.83,
      "speaker": null,
      "text": "Так, сейчас ушло, всё точно прийти."
    },
    {
      "start": 77.8,
      "end": 79.04,
      "speaker": null,
      "text": "Да, спасибо огромное."
    },
    {
      "start": 79.12,
      "end": 80.36,
      "speaker": null,
      "text": "И я вам там адрес спрашиваю."
    },
    {
      "start": 80.36,
      "end": 80.58,
      "speaker": null,
      "text": "Текстильный стенд."
    },
    {
      "start": 80.58,
      "end": 84.8,
      "speaker": null,
      "text": "Да, я видел сейчас, знаю, да, у монтажника так и по времени считаю."
    },
    {
      "start": 85.42,
      "end": 87.56,
      "speaker": null,
      "text": "Смотрите, а ваши девочки сюда забирали уже, да, Станик?"
