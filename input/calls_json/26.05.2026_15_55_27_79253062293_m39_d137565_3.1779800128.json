    {
      "start": 101.02,
      "end": 102.74,
      "speaker": null,
      "text": "Сказали, что заберу самовывозом."
    },
    {
      "start": 102.92,
      "end": 103.98,
      "speaker": null,
      "text": "У меня информации не было."
