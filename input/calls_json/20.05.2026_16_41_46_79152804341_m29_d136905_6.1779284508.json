  "segments": [
    {
      "start": 0.5,
      "end": 1.14,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 1.8,
      "end": 7.28,
      "speaker": null,
      "text": "Ирина, ещё раз здравствуйте. Это Ксения из Мостэнда. Пока не получила от вас сообщение на почте."
    },
    {
      "start": 8.14,
      "end": 16.4,
      "speaker": null,
      "text": "А мне пришёл ответ. Да я знаете какую почту? Вот скопировала с контактов на сайте. Только там не инфа была, а всё какая-то другая."
    },
    {
      "start": 18.75,
      "end": 30.5,
      "speaker": null,
      "text": "Так, ну вы перед собачкой поставили кей-кей? Вот вряд ли я поставила кей-кей. А мне пришло автоматически ответ, что да-да, менеджер свяжется с вами."
    },
    {
      "start": 31.74,
      "end": 34.4,
      "speaker": null,
      "text": "Ну вы, скорее всего, на общую почту просто вышли."
    },
    {
      "start": 34.78,
      "end": 39.24,
      "speaker": null,
      "text": "Да? А вы не посмотрите на общую? Наверное, скорее всего."
    },
    {
      "start": 40.12,
      "end": 47.26,
      "speaker": null,
      "text": "Я сейчас попробую, просто у меня нет доступа к общей-общей, в зависимости от того, куда как я снова вышла."
    },
    {
      "start": 47.26,
      "end": 52.62,
      "speaker": null,
      "text": "А может быть, если я вам продиктую свою, может быть, вы мне черканёшь какое-нибудь тестовое письмо?"
    },
    {
      "start": 52.62,
      "end": 55.24,
      "speaker": null,
      "text": "А я это давайте посмотрю, попробую."
    },
    {
      "start": 55.84,
      "end": 57.52,
      "speaker": null,
      "text": "Угу, какие-то..."
    },
    {
      "start": 57.52,
      "end": 60.22,
      "speaker": null,
      "text": "Ну чтобы не мучиться, я бы вам сказала свою."
    },
    {
      "start": 60.88,
      "end": 62.78,
      "speaker": null,
      "text": "Она у меня несложненькая вроде."
    },
    {
      "start": 64.04,
      "end": 64.32,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 66.99,
      "end": 68.49,
      "speaker": null,
      "text": "От Ирины Рогова."
    },
    {
      "start": 68.49,
      "end": 69.47,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 80.06,
      "end": 81.94,
      "speaker": null,
      "text": "А вы сверху что-нибудь писали?"
    },
    {
      "start": 83.05,
      "end": 84.99,
      "speaker": null,
      "text": "Тема не указала, я забыла."
    },
    {
      "start": 85.91,
      "end": 86.31,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 86.73,
      "end": 86.95,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 87.97,
      "end": 88.85,
      "speaker": null,
      "text": "И тема."
    },
    {
      "start": 89.33,
      "end": 89.35,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 91.74,
      "end": 94.16,
      "speaker": null,
      "text": "И не сможете, да, вспомнить..."
    },
    {
      "start": 95.16,
      "end": 96.2,
      "speaker": null,
      "text": "На какое?"
    },
    {
      "start": 96.54,
      "end": 101.96,
      "speaker": null,
      "text": "Да я могу вспомнить просто, если я подойду к компьютеру и у меня прервился звонок."
    },
    {
      "start": 101.96,
      "end": 105.17,
      "speaker": null,
      "text": "Ну давайте, вы сейчас подождите, я же посмотрю."
    },
    {
      "start": 105.75,
      "end": 105.95,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 106.37,
      "end": 106.79,
      "speaker": null,
      "text": "Хорошо, давайте."
    },
    {
      "start": 107.35,
      "end": 108.29,
      "speaker": null,
      "text": "Да, еще секунду."
    },
    {
      "start": 156.84,
      "end": 157.54,
      "speaker": null,
      "text": "Алло, да."
    },
    {
      "start": 158.52,
      "end": 161.46,
      "speaker": null,
      "text": "Почта Мэйн, мостентру."
    },
    {
      "start": 163.41,
      "end": 163.79,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 164.67,
      "end": 165.01,
      "speaker": null,
      "text": "Мэйн."
    },
    {
      "start": 165.07,
      "end": 167.87,
      "speaker": null,
      "text": "Тогда я тебя запрошу, чтобы мне переслали коллеги."
    },
    {
      "start": 169.2,
      "end": 170.6,
      "speaker": null,
      "text": "Ну извините, пожалуйста."
    },
    {
      "start": 170.88,
      "end": 171.28,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 171.38,
      "end": 172.92,
      "speaker": null,
      "text": "Прямо страшного бывает."
    },
    {
      "start": 172.92,
      "end": 174.62,
      "speaker": null,
      "text": "Веротенка в попухах, ага."
    },
    {
      "start": 174.88,
      "end": 175.5,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 175.8,
      "end": 177.84,
      "speaker": null,
      "text": "Сейчас когда запрошу, да, вам отвечу."
    },
    {
      "start": 178.6,
      "end": 179.46,
      "speaker": null,
      "text": "Спасибо, спасибо."
    },
    {
      "start": 179.78,
      "end": 180.6,
      "speaker": null,
      "text": "Да, пожалуйста."
    },
    {
      "start": 181.06,
      "end": 181.2,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 181.54,
      "end": 182.3,
      "speaker": null,
      "text": "До свидания."
    }
  ]
