  "segments": [
    {
      "start": 0.11,
      "end": 0.83,
      "speaker": null,
      "text": "Да, алло."
    },
    {
      "start": 1.51,
      "end": 3.39,
      "speaker": null,
      "text": "Да, Мария, здравствуйте, вы звонили?"
    },
    {
      "start": 3.75,
      "end": 10.49,
      "speaker": null,
      "text": "Да, Валерий, извините, по поводу нашего роллапа, подскажите, пожалуйста, вам нужно присылать какие-то данные на машину курьера?"
    },
    {
      "start": 11.07,
      "end": 13.21,
      "speaker": null,
      "text": "Нет, ничего не нужно."
    },
    {
      "start": 14.26,
      "end": 19.02,
      "speaker": null,
      "text": "Ага, и ещё такой вопрос, вам оплата полностью дошла или вот мы всё-таки должны ещё вот эту 1400?"
    },
    {
      "start": 20.28,
      "end": 21.1,
      "speaker": null,
      "text": "Секундочку сейчас."
    },
    {
      "start": 21.88,
      "end": 22.18,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 41.99,
      "end": 45.59,
      "speaker": null,
      "text": "Смотрите, да, я не могу, не вижу оплату в вчерашний день."
    },
    {
      "start": 45.91,
      "end": 46.47,
      "speaker": null,
      "text": "Не дошли."
    },
    {
      "start": 47.71,
      "end": 51.39,
      "speaker": null,
      "text": "Ага, смотрите, у нас есть ещё платёжный день сегодня, то есть мы её доплатим."
    },
    {
      "start": 51.97,
      "end": 54.05,
      "speaker": null,
      "text": "Мне важно клиентам не сорвать мероприятия."
    },
    {
      "start": 54.33,
      "end": 56.73,
      "speaker": null,
      "text": "Могу, правда, вам на карточку сейчас перейти сюда 1400?"
    },
    {
      "start": 56.97,
      "end": 58.27,
      "speaker": null,
      "text": "Как получите от нас оплату?"
    },
    {
      "start": 58.43,
      "end": 60.93,
      "speaker": null,
      "text": "Вы мне перекинете назад 1400 и, собственно, всё."
    },
    {
      "start": 60.93,
      "end": 65.03,
      "speaker": null,
      "text": "Давайте просто мы ещё будем взять оплату и всё, всё супер будет."
    },
    {
      "start": 65.57,
      "end": 67.15,
      "speaker": null,
      "text": "Ну, а вы заказ отдадите нам там в 12?"
    },
    {
      "start": 67.67,
      "end": 68.75,
      "speaker": null,
      "text": "Да-да-да, конечно."
    },
    {
      "start": 69.49,
      "end": 73.45,
      "speaker": null,
      "text": "Всё, вы не переживайте, мы точно оплатим вообще даже, ну там, не думайте ничего плохого."
    },
    {
      "start": 73.73,
      "end": 73.97,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 74.45,
      "end": 76.45,
      "speaker": null,
      "text": "Да, конечно-конечно, хорошо, тогда да."
    },
    {
      "start": 78.93,
      "end": 79.81,
      "speaker": null,
      "text": "А ещё пока не идёт."
    },
    {
      "start": 81.02,
      "end": 83.38,
      "speaker": null,
      "text": "Всё, хорошо, тогда сейчас вызывай курьера, так вам в 12."
    },
    {
      "start": 83.66,
      "end": 84.44,
      "speaker": null,
      "text": "Спасибо вам большое."
    },
    {
      "start": 84.58,
      "end": 84.78,
      "speaker": null,
      "text": "Да, всего доброго."
    },
    {
      "start": 84.98,
      "end": 85.76,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}