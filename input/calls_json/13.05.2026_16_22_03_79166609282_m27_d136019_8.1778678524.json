{
  "file": "13.05.2026_16_22_03_79166609282_m27_d136019_8.1778678524.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 193.9,
  "segments": [
    {
      "start": 0.0,
      "end": 2.3,
      "speaker": null,
      "text": "Добрый день, Валентин. Компания «Мостэнчин». Могу вам помочь?"
    },
    {
      "start": 3.3,
      "end": 10.32,
      "speaker": null,
      "text": "Здравствуйте. Подскажите, пожалуйста, достаточно срочный заказ на пресс-вол на 15-е на утро."
    },
    {
      "start": 12.09,
      "end": 21.94,
      "speaker": null,
      "text": "Вот конструкция люкс, что-то там двойное, которое я имею в виду, и там натягивается баннер. Вы успеете сделать до завтра?"
    },
    {
      "start": 23.9,
      "end": 26.36,
      "speaker": null,
      "text": "Завтра? А в какое время вам необходимо?"
    },
    {
      "start": 26.36,
      "end": 33.14,
      "speaker": null,
      "text": "Ну, он необходим 15-го, чтобы в 11 утра уже стоял. Точнее даже в 10-30."
    },
    {
      "start": 33.7,
      "end": 35.78,
      "speaker": null,
      "text": "А вам монтаж и доставка потребуется?"
    },
    {
      "start": 36.24,
      "end": 36.42,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 37.22,
      "end": 38.48,
      "speaker": null,
      "text": "И монтаж и доставка?"
    },
    {
      "start": 38.66,
      "end": 39.32,
      "speaker": null,
      "text": "Да, обязательно."
    },
    {
      "start": 39.62,
      "end": 40.76,
      "speaker": null,
      "text": "А в каком размере необходим?"
    },
    {
      "start": 41.26,
      "end": 48.02,
      "speaker": null,
      "text": "Два на два. Два на два пресс-вол L, который люкс."
    },
    {
      "start": 48.02,
      "end": 48.52,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 48.86,
      "end": 54.0,
      "speaker": null,
      "text": "С двойной конструкцией с натяжкой так, чтобы железок не было видно, то есть поверх конструкции."
    },
    {
      "start": 54.0,
      "end": 59.8,
      "speaker": null,
      "text": "Угу, угу. Так, теперь два на два. А макет у вас уже готов?"
    },
    {
      "start": 60.28,
      "end": 64.62,
      "speaker": null,
      "text": "Вот в процессе. Мы, на самом деле, может быть, успеем и сегодня макет сдать."
    },
    {
      "start": 65.04,
      "end": 65.6,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 65.76,
      "end": 68.14,
      "speaker": null,
      "text": "Но вообще планируем завтра его сдать."
    },
    {
      "start": 68.89,
      "end": 70.39,
      "speaker": null,
      "text": "А как я могу к вам обращаться?"
    },
    {
      "start": 70.95,
      "end": 71.41,
      "speaker": null,
      "text": "Мария."
    },
    {
      "start": 71.77,
      "end": 72.33,
      "speaker": null,
      "text": "Мария."
    },
    {
      "start": 72.96,
      "end": 74.66,
      "speaker": null,
      "text": "А где у вас проходят мероприятия?"
    },
    {
      "start": 75.08,
      "end": 76.2,
      "speaker": null,
      "text": "В музеоне."
    },
    {
      "start": 77.3,
      "end": 78.34,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 78.9,
      "end": 80.42,
      "speaker": null,
      "text": "Да, парк Горького там напротив."
    },
    {
      "start": 81.28,
      "end": 81.64,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 86.26,
      "end": 90.96,
      "speaker": null,
      "text": "Получается мероприятие у вас в 11-15 уже, да?"
    },
    {
      "start": 91.53,
      "end": 95.81,
      "speaker": null,
      "text": "Да, уже старт. То есть здесь в 30 нужно, чтобы пришел стоял."
    },
    {
      "start": 96.39,
      "end": 98.65,
      "speaker": null,
      "text": "10-30 сдача."
    },
    {
      "start": 99.63,
      "end": 99.93,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 100.41,
      "end": 103.79,
      "speaker": null,
      "text": "А там есть парковка, заезд, место для разгрузки?"
    },
    {
      "start": 104.18,
      "end": 112.9,
      "speaker": null,
      "text": "А, нету. Но там как раз место, где рядом это кафе, там можно подъехать и на аварийках постоять."
    },
    {
      "start": 114.18,
      "end": 117.54,
      "speaker": null,
      "text": "Угу. Просто без парковки мы монтаж не сможем провести."
    },
    {
      "start": 118.65,
      "end": 120.67,
      "speaker": null,
      "text": "А вам парковка как?"
    },
    {
      "start": 121.19,
      "end": 126.75,
      "speaker": null,
      "text": "Ну, трубы, они идут двухметровые, и нам необходимо будет как минимум разгрузиться."
    },
    {
      "start": 127.21,
      "end": 128.97,
      "speaker": null,
      "text": "Ну, с парковкой разберемся."
    },
    {
      "start": 128.97,
      "end": 130.91,
      "speaker": null,
      "text": "Хорошо, хорошо."
    },
    {
      "start": 132.12,
      "end": 136.4,
      "speaker": null,
      "text": "Так, а вот в каком формате мероприятие будет проходить?"
    },
    {
      "start": 137.22,
      "end": 140.38,
      "speaker": null,
      "text": "Вы же можете разгрузиться и уехать просто, правильно?"
    },
    {
      "start": 140.76,
      "end": 141.72,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 141.76,
      "end": 144.42,
      "speaker": null,
      "text": "Потом приехать, ну вот, в чем проблема тогда."
    },
    {
      "start": 145.95,
      "end": 148.05,
      "speaker": null,
      "text": "В формате предзаскивка."
    },
    {
      "start": 148.69,
      "end": 150.47,
      "speaker": null,
      "text": "Угу. Хорошо я вас понял."
    },
    {
      "start": 151.84,
      "end": 156.94,
      "speaker": null,
      "text": "Так, хорошо."
    },
    {
      "start": 157.36,
      "end": 160.28,
      "speaker": null,
      "text": "Я тогда сейчас стоимость посчитаю вместе с доставкой."
    },
    {
      "start": 160.38,
      "end": 160.4,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 160.8,
      "end": 161.94,
      "speaker": null,
      "text": "А демонтаж потребуется?"
    },
    {
      "start": 162.82,
      "end": 163.24,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 164.25,
      "end": 166.03,
      "speaker": null,
      "text": "На демонтаж потребуется, а во сколько?"
    },
    {
      "start": 167.6,
      "end": 169.06,
      "speaker": null,
      "text": "В 13.30."
    },
    {
      "start": 170.3,
      "end": 171.2,
      "speaker": null,
      "text": "В 13.30."
    },
    {
      "start": 172.4,
      "end": 174.1,
      "speaker": null,
      "text": "Ну да, он по сути на два часа."
    },
    {
      "start": 175.21,
      "end": 177.77,
      "speaker": null,
      "text": "Угу. Хорошо я вас понял."
    },
    {
      "start": 178.19,
      "end": 180.09,
      "speaker": null,
      "text": "Я тогда сейчас все посчитаю."
    },
    {
      "start": 180.89,
      "end": 181.81,
      "speaker": null,
      "text": "Да, хорошо, спасибо."
    },
    {
      "start": 182.45,
      "end": 183.43,
      "speaker": null,
      "text": "Да, и перезвоню."
    },
    {
      "start": 183.89,
      "end": 186.05,
      "speaker": null,
      "text": "Номер мой высветился у вас, да?"
    },
    {
      "start": 186.87,
      "end": 187.43,
      "speaker": null,
      "text": "9282."
    },
    {
      "start": 187.77,
      "end": 188.87,
      "speaker": null,
      "text": "Да, все верно."
    },
    {
      "start": 189.73,
      "end": 190.85,
      "speaker": null,
      "text": "Все, Мария, благодарю вас."
    },
    {
      "start": 191.51,
      "end": 192.21,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}