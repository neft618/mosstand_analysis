{
  "file": "26.05.2026_09_47_29_79636510111_m31_d137533_2.1779778050.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 278.6,
  "segments": [
    {
      "start": 0.53,
      "end": 3.33,
      "speaker": null,
      "text": "Здравствуйте, меня зовут Валерия из компании МОССЕНД."
    },
    {
      "start": 4.63,
      "end": 5.57,
      "speaker": null,
      "text": "Здравствуйте, Валерия."
    },
    {
      "start": 6.39,
      "end": 11.53,
      "speaker": null,
      "text": "Да, я звонила и написала вчера сообщение о том, что нужна стойка..."
    },
    {
      "start": 12.42,
      "end": 14.4,
      "speaker": null,
      "text": "Я не знаю как она, промо-стойка у вас называется?"
    },
    {
      "start": 14.6,
      "end": 15.84,
      "speaker": null,
      "text": "Угу, есть промо-стойка."
    },
    {
      "start": 17.55,
      "end": 20.59,
      "speaker": null,
      "text": "Так, сейчас, я только не помню какая номерация, сейчас одну секунду."
    },
    {
      "start": 38.66,
      "end": 40.9,
      "speaker": null,
      "text": "Смотрите, есть промо-стойка, есть..."
    },
    {
      "start": 40.9,
      "end": 44.12,
      "speaker": null,
      "text": "Здравствуйте, секундочку, я ищу номер какой у неё."
    },
    {
      "start": 44.44,
      "end": 44.64,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 46.68,
      "end": 47.88,
      "speaker": null,
      "text": "Какая стойка..."
    },
    {
      "start": 47.88,
      "end": 50.54,
      "speaker": null,
      "text": "Сейчас, одну секунду, я почти ищу."
    },
    {
      "start": 53.0,
      "end": 54.28,
      "speaker": null,
      "text": "Так, сейчас, сейчас, всё."
    },
    {
      "start": 60.49,
      "end": 62.13,
      "speaker": null,
      "text": "Вот, промо-стойка МС7."
    },
    {
      "start": 64.19,
      "end": 65.37,
      "speaker": null,
      "text": "Так, секундочку."
    },
    {
      "start": 65.67,
      "end": 69.86,
      "speaker": null,
      "text": "Именно МС или М?"
    },
    {
      "start": 71.77,
      "end": 72.37,
      "speaker": null,
      "text": "МС7."
    },
    {
      "start": 73.07,
      "end": 74.43,
      "speaker": null,
      "text": "Ага, всё, я поняла."
    },
    {
      "start": 74.55,
      "end": 78.25,
      "speaker": null,
      "text": "Смотрите, если что, эта стойка, она не мобильная."
    },
    {
      "start": 79.93,
      "end": 80.99,
      "speaker": null,
      "text": "Ну, то есть она стоит?"
    },
    {
      "start": 80.99,
      "end": 84.49,
      "speaker": null,
      "text": "Ну, она стоит, ну, то есть, как объяснить."
    },
    {
      "start": 84.81,
      "end": 87.39,
      "speaker": null,
      "text": "Вот есть мобильные стойки, которые легко транспортировать,"
    },
    {
      "start": 87.47,
      "end": 91.37,
      "speaker": null,
      "text": "то есть они легко перевозятся, вы их там складываете, там раскладываете..."
    },
    {
      "start": 91.37,
      "end": 92.53,
      "speaker": null,
      "text": "Нет, мне такое не надо."
    },
    {
      "start": 92.89,
      "end": 95.29,
      "speaker": null,
      "text": "Мне нужно именно то, что я прошу."
    },
    {
      "start": 96.15,
      "end": 97.63,
      "speaker": null,
      "text": "Хорошо, а как могу к вам обращаться?"
    },
    {
      "start": 98.11,
      "end": 98.79,
      "speaker": null,
      "text": "Меня зовут Ирина."
    },
    {
      "start": 99.51,
      "end": 100.87,
      "speaker": null,
      "text": "Ирина, приятно познакомиться."
    },
    {
      "start": 100.91,
      "end": 102.17,
      "speaker": null,
      "text": "Какому сроку она вам нужна?"
    },
    {
      "start": 104.01,
      "end": 107.39,
      "speaker": null,
      "text": "Ну, как можно быстрее, скажем там, к пятнице."
    },
    {
      "start": 108.44,
      "end": 108.76,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 108.76,
      "end": 111.8,
      "speaker": null,
      "text": "Уточните, пожалуйста, макета у вас уже готовая?"
    },
    {
      "start": 112.79,
      "end": 116.17,
      "speaker": null,
      "text": "Ну, мы возьмём так, как она есть, такой, как есть."
    },
    {
      "start": 116.31,
      "end": 117.87,
      "speaker": null,
      "text": "Нам не нужно ничего приклеивать."
    },
    {
      "start": 118.09,
      "end": 119.47,
      "speaker": null,
      "text": "Мы сами всё сделаем."
    },
    {
      "start": 120.25,
      "end": 121.85,
      "speaker": null,
      "text": "Ну, как бы это..."
    },
    {
      "start": 121.85,
      "end": 123.85,
      "speaker": null,
      "text": "Без печати, правильно?"
    },
    {
      "start": 124.11,
      "end": 126.53,
      "speaker": null,
      "text": "Да-да, без печати, просто базовую историю."
    },
    {
      "start": 127.19,
      "end": 129.85,
      "speaker": null,
      "text": "Единственное, я бы, конечно, на всякий случай попросила"
    },
    {
      "start": 129.85,
      "end": 133.61,
      "speaker": null,
      "text": "вас, там, не знаю, прислать вариацию, как это выглядит."
    },
    {
      "start": 133.79,
      "end": 136.11,
      "speaker": null,
      "text": "Потому что я точно знаю, что нам нужно."
    },
    {
      "start": 136.41,
      "end": 143.15,
      "speaker": null,
      "text": "Я точно знаю, что она называется MS7, но могут быть мало ли какие-то разночтения."
    },
    {
      "start": 143.35,
      "end": 144.45,
      "speaker": null,
      "text": "Мы уже у вас покупали."
    },
    {
      "start": 144.93,
      "end": 146.61,
      "speaker": null,
      "text": "А, вы уже у нас покупали?"
    },
    {
      "start": 146.89,
      "end": 146.91,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 147.67,
      "end": 148.45,
      "speaker": null,
      "text": "Давно уже у вас покупали?"
    },
    {
      "start": 150.35,
      "end": 151.53,
      "speaker": null,
      "text": "Где-то, наверное, в августе."
    },
    {
      "start": 151.59,
      "end": 155.71,
      "speaker": null,
      "text": "Сейчас я посмотрю, от какого числа там счёт у меня есть."
    },
    {
      "start": 155.71,
      "end": 158.87,
      "speaker": null,
      "text": "А, может быть, вы продержуете именно вашей компании, чтобы я нашла?"
    },
    {
      "start": 159.11,
      "end": 160.29,
      "speaker": null,
      "text": "Потому что..."
    },
    {
      "start": 160.29,
      "end": 160.93,
      "speaker": null,
      "text": "А, ну давайте."
    },
    {
      "start": 162.65,
      "end": 164.71,
      "speaker": null,
      "text": "Сейчас я посмотрю."
    },
    {
      "start": 165.93,
      "end": 169.11,
      "speaker": null,
      "text": "Наверное, делал партнер, чтобы покупали."
    },
    {
      "start": 171.61,
      "end": 173.93,
      "speaker": null,
      "text": "Вы знаете, мне кажется, что с вами работали."
    },
    {
      "start": 173.99,
      "end": 175.85,
      "speaker": null,
      "text": "Я не очень уверена, но мне кажется, с вами."
    },
    {
      "start": 177.24,
      "end": 177.72,
      "speaker": null,
      "text": "Возможно."
    },
    {
      "start": 178.9,
      "end": 179.38,
      "speaker": null,
      "text": "Возможно."
    },
    {
      "start": 180.22,
      "end": 180.88,
      "speaker": null,
      "text": "Не отрицаю."
    },
    {
      "start": 181.54,
      "end": 184.52,
      "speaker": null,
      "text": "Так, посмотрите, значит, MNM 77."
    },
    {
      "start": 185.28,
      "end": 185.94,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 186.65,
      "end": 187.85,
      "speaker": null,
      "text": "Так, сейчас, одну секунду."
    },
    {
      "start": 188.05,
      "end": 189.11,
      "speaker": null,
      "text": "Прямо одну секунду."
    },
    {
      "start": 193.4,
      "end": 194.72,
      "speaker": null,
      "text": "77-14?"
    },
    {
      "start": 195.84,
      "end": 196.2,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 197.9,
      "end": 199.88,
      "speaker": null,
      "text": "90-77-50."
    },
    {
      "start": 201.27,
      "end": 202.09,
      "speaker": null,
      "text": "Есть такое?"
    },
    {
      "start": 204.5,
      "end": 206.4,
      "speaker": null,
      "text": "О, деловое партнёрство, да?"
    },
    {
      "start": 206.88,
      "end": 208.24,
      "speaker": null,
      "text": "Угу, угу, угу."
    },
    {
      "start": 208.48,
      "end": 208.88,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 209.7,
      "end": 212.04,
      "speaker": null,
      "text": "Да, мы с вами как раз работали."
    },
    {
      "start": 212.87,
      "end": 213.99,
      "speaker": null,
      "text": "Я помню, помню."
    },
    {
      "start": 215.31,
      "end": 216.89,
      "speaker": null,
      "text": "Всё, поняла вас хорошо."
    },
    {
      "start": 217.07,
      "end": 218.31,
      "speaker": null,
      "text": "Давайте тогда как поступим?"
    },
    {
      "start": 218.31,
      "end": 220.05,
      "speaker": null,
      "text": "Я вот вам написала в Максе."
    },
    {
      "start": 220.07,
      "end": 221.97,
      "speaker": null,
      "text": "Вы уже получили сообщение от меня в Максе?"
    },
    {
      "start": 222.01,
      "end": 223.75,
      "speaker": null,
      "text": "Я посмотрю, подождите секунду."
    },
    {
      "start": 227.7,
      "end": 228.0,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 228.24,
      "end": 230.02,
      "speaker": null,
      "text": "А, подожди, у меня буквально не включится."
    },
    {
      "start": 235.04,
      "end": 235.58,
      "speaker": null,
      "text": "Сейчас включу."
    },
    {
      "start": 237.54,
      "end": 238.14,
      "speaker": null,
      "text": "Получили, да?"
    },
    {
      "start": 238.76,
      "end": 239.4,
      "speaker": null,
      "text": "Пока нет."
    },
    {
      "start": 240.73,
      "end": 241.01,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 242.76,
      "end": 247.32,
      "speaker": null,
      "text": "Да, это от вас, да?"
    },
    {
      "start": 247.76,
      "end": 248.61,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 250.66,
      "end": 251.58,
      "speaker": null,
      "text": "Так, и чего дальше?"
    },
    {
      "start": 252.32,
      "end": 253.8,
      "speaker": null,
      "text": "Давайте как с вами поступим."
    },
    {
      "start": 253.8,
      "end": 257.58,
      "speaker": null,
      "text": "Да, я направлю вам туда сейчас фотографии, как это увидеть будет."
    },
    {
      "start": 257.96,
      "end": 262.44,
      "speaker": null,
      "text": "Вам же нужно будет также её стопером, то есть наверху тоже должна быть такая табличка, да?"
    },
    {
      "start": 262.86,
      "end": 264.96,
      "speaker": null,
      "text": "Нет, наоборот, как раз без неё."
    },
    {
      "start": 265.56,
      "end": 266.78,
      "speaker": null,
      "text": "То есть без стоперов."
    },
    {
      "start": 266.92,
      "end": 267.4,
      "speaker": null,
      "text": "Всё, поняла."
    },
    {
      "start": 267.4,
      "end": 272.26,
      "speaker": null,
      "text": "Давайте тогда направлю вам фотографии и уже с вами решим."
    },
    {
      "start": 272.8,
      "end": 273.54,
      "speaker": null,
      "text": "Всё, давайте."
    },
    {
      "start": 273.54,
      "end": 274.62,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 275.94,
      "end": 276.6,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 276.6,
      "end": 276.84,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}