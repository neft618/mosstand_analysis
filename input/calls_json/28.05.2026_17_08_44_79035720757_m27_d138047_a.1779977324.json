    {
      "start": 351.48,
      "end": 352.82,
      "speaker": null,
      "text": "Спасибо, договорились давайте."
    },
    {
      "start": 352.96,
      "end": 354.26,
      "speaker": null,
      "text": "Да, все благодарю, до свидания."
