    },
    {
      "start": 193.06,
      "end": 194.38,
      "speaker": null,
      "text": "А листовки в каком количестве?"
    },
    {
      "start": 196.2,
      "end": 198.44,
      "speaker": null,
      "text": "Ну, я думаю штук там 200-300."
    },
    {
      "start": 199.7,
