    {
      "start": 244.78,
      "end": 246.3,
      "speaker": null,
      "text": "А вы что можете изготавливать?"
    },
    {
      "start": 246.38,
      "end": 247.6,
      "speaker": null,
      "text": "У вас русский тоже делаете?"
    },
    {
      "start": 248.52,
      "end": 250.04,
      "speaker": null,
      "text": "А с дизайном?"
    },
    {
      "start": 250.85,
      "end": 251.15,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 251.15,
      "end": 252.61,
      "speaker": null,
      "text": "Да, так же делаем."
