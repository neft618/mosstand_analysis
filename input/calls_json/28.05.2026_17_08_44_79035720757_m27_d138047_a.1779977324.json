    },
    {
      "start": 320.89,
      "end": 321.37,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 322.18,
      "end": 323.28,
      "speaker": null,
      "text": "Да, слушаю вас, здравствуйте."
