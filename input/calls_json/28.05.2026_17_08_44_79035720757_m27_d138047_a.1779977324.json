    {
      "start": 169.42,
      "end": 169.84,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 171.64,
      "end": 172.72,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 172.9,
      "end": 175.9,
      "speaker": null,
      "text": "А вам может потребоваться на выставку полиграфия сценированная продукция?"
    },
    {
      "start": 177.78,
      "end": 179.42,
      "speaker": null,
      "text": "Ммм... Да, да."
    },
    {
      "start": 180.25,
      "end": 182.15,
      "speaker": null,
      "text": "А что конкретно вам необходимо будет?"
    },
    {
      "start": 183.89,
      "end": 185.29,
      "speaker": null,
      "text": "Нам нужны будут листовки."
