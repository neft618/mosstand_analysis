{
  "file": "15.05.2026_09_49_42_79166394217_m31_d136241_7.1778827782.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 248.0,
  "segments": [
    {
      "start": 2.23,
      "end": 7.61,
      "speaker": null,
      "text": "Здравствуйте, Виталий. Это Валерий из Монстенд. Вы оставляли обратный звонок у вас на сайте вчера вечером."
    },
    {
      "start": 8.39,
      "end": 14.51,
      "speaker": null,
      "text": "Ага. Валерий, добрый день. А минимальный размер 60х180, да?"
    },
    {
      "start": 16.0,
      "end": 17.02,
      "speaker": null,
      "text": "Чего именно?"
    },
    {
      "start": 17.82,
      "end": 18.5,
      "speaker": null,
      "text": "Роллап."
    },
    {
      "start": 20.07,
      "end": 22.03,
      "speaker": null,
      "text": "Роллап ваша 60х160."
    },
    {
      "start": 24.34,
      "end": 24.94,
      "speaker": null,
      "text": "60х160."
    },
    {
      "start": 25.74,
      "end": 29.36,
      "speaker": null,
      "text": "А стоимость, если у нас будет свой оригинал макет?"
    },
    {
      "start": 31.79,
      "end": 32.11,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 32.29,
      "end": 33.47,
      "speaker": null,
      "text": "И вы же в Москве, да?"
    },
    {
      "start": 34.55,
      "end": 36.41,
      "speaker": null,
      "text": "Да, мы в Москве находимся, всё верно."
    },
    {
      "start": 37.09,
      "end": 40.09,
      "speaker": null,
      "text": "А забрать можно с инсайта или это у вас какая-то доставка?"
    },
    {
      "start": 40.96,
      "end": 43.4,
      "speaker": null,
      "text": "У нас есть доставка, либо можно самого вызов."
    },
    {
      "start": 44.54,
      "end": 49.24,
      "speaker": null,
      "text": "Стоит такой роллап 4000 рублей, но у нас минимальный заказ 5000 рублей."
    },
    {
      "start": 49.24,
      "end": 57.08,
      "speaker": null,
      "text": "Могу предложить, например, доставку в заказ включить и тогда будет минимальному заказу точно."
    },
    {
      "start": 57.34,
      "end": 58.96,
      "speaker": null,
      "text": "А листовки вы делаете?"
    },
    {
      "start": 59.6,
      "end": 63.08,
      "speaker": null,
      "text": "Да, конечно, делаем листовки. Какие необходимые?"
    },
    {
      "start": 63.1,
      "end": 66.76,
      "speaker": null,
      "text": "Ну я интересуюсь, когда вот стандартные это получается..."
    },
    {
      "start": 67.52,
      "end": 68.74,
      "speaker": null,
      "text": "6 что ли, да?"
    },
    {
      "start": 70.31,
      "end": 76.77,
      "speaker": null,
      "text": "Ну, есть ещё опять, это такие более стандартные."
    },
    {
      "start": 77.77,
      "end": 79.05,
      "speaker": null,
      "text": "Стандартные опять делают, да?"
    },
    {
      "start": 79.05,
      "end": 81.03,
      "speaker": null,
      "text": "Ну да, это стандартные."
    },
    {
      "start": 81.65,
      "end": 83.67,
      "speaker": null,
      "text": "А 4 пополам, да?"
    },
    {
      "start": 84.43,
      "end": 84.79,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 86.08,
      "end": 87.44,
      "speaker": null,
      "text": "А меньше уже не делают, да?"
    },
    {
      "start": 88.0,
      "end": 88.78,
      "speaker": null,
      "text": "Делают, конечно."
    },
    {
      "start": 89.52,
      "end": 91.88,
      "speaker": null,
      "text": "Просто опять это стандартные."
    },
    {
      "start": 93.04,
      "end": 94.04,
      "speaker": null,
      "text": "Ну, раздатки..."
    },
    {
      "start": 95.1,
      "end": 101.0,
      "speaker": null,
      "text": "Получается тогда с одной стороны, вот, раздаточной листовки, вот нам на выставку надо будет пришли,"
    },
    {
      "start": 101.24,
      "end": 103.56,
      "speaker": null,
      "text": "там Макс и Телеграм куда-нибудь прислать."
    },
    {
      "start": 104.18,
      "end": 106.04,
      "speaker": null,
      "text": "Да, а какой тираж вам необходим?"
    },
    {
      "start": 107.56,
      "end": 109.44,
      "speaker": null,
      "text": "Так, листовок..."
    },
    {
      "start": 110.37,
      "end": 111.43,
      "speaker": null,
      "text": "Сейчас я подумаю."
    },
    {
      "start": 112.06,
      "end": 112.54,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 113.78,
      "end": 116.44,
      "speaker": null,
      "text": "Давайте, наверное, у вас от 1000 или от 100 сколько там у вас?"
    },
    {
      "start": 117.45,
      "end": 118.17,
      "speaker": null,
      "text": "В листовке?"
    },
    {
      "start": 118.63,
      "end": 118.93,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 119.88,
      "end": 123.46,
      "speaker": null,
      "text": "Ну почему можно что-то сделать и 200, и 500, и 1000 и больше?"
    },
    {
      "start": 125.29,
      "end": 126.89,
      "speaker": null,
      "text": "Я сейчас подумаю..."
    },
    {
      "start": 126.89,
      "end": 128.75,
      "speaker": null,
      "text": "Давайте вы посчитаете мне стоимость за 1000."
    },
    {
      "start": 130.64,
      "end": 131.3,
      "speaker": null,
      "text": "Вот..."
    },
    {
      "start": 131.3,
      "end": 137.3,
      "speaker": null,
      "text": "И Roll Up, да, Roll Up 60 на 160."
    },
    {
      "start": 138.64,
      "end": 142.32,
      "speaker": null,
      "text": "А еще уточните, пожалуйста, бумагу потоньше или поплотнее?"
    },
    {
      "start": 142.32,
      "end": 144.18,
      "speaker": null,
      "text": "То есть нужно на листовке."
    },
    {
      "start": 144.54,
      "end": 147.66,
      "speaker": null,
      "text": "По-моему, мы последний раз сделали 320 что ли?"
    },
    {
      "start": 148.92,
      "end": 152.34,
      "speaker": null,
      "text": "320 это уже как картон, это прям очень плотно на листовке."
    },
    {
      "start": 152.72,
      "end": 153.4,
      "speaker": null,
      "text": "Есть такая..."
    },
    {
      "start": 153.4,
      "end": 153.96,
      "speaker": null,
      "text": "А, нет, Roll."
    },
    {
      "start": 154.32,
      "end": 155.2,
      "speaker": null,
      "text": "Точно, я понял."
    },
    {
      "start": 155.74,
      "end": 157.06,
      "speaker": null,
      "text": "Это я вру."
    },
    {
      "start": 157.62,
      "end": 160.1,
      "speaker": null,
      "text": "Давайте напомните какие плоты бывают?"
    },
    {
      "start": 160.56,
      "end": 163.72,
      "speaker": null,
      "text": "130, 170 это такие более стандартные."
    },
    {
      "start": 163.96,
      "end": 166.72,
      "speaker": null,
      "text": "130 это потоньше, 170 и плотнее."
    },
    {
      "start": 167.67,
      "end": 169.03,
      "speaker": null,
      "text": "Давайте 170 считайте, пожалуйста."
    },
    {
      "start": 169.53,
      "end": 170.93,
      "speaker": null,
      "text": "С одной стороны, да?"
    },
    {
      "start": 171.43,
      "end": 172.93,
      "speaker": null,
      "text": "С одной стороны, да. Хорошо."
    },
    {
      "start": 172.93,
      "end": 175.57,
      "speaker": null,
      "text": "А какому сроку вам в целом необходимо все это?"
    },
    {
      "start": 175.75,
      "end": 177.19,
      "speaker": null,
      "text": "Вообще, 7 июля."
    },
    {
      "start": 177.53,
      "end": 178.19,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 178.55,
      "end": 179.99,
      "speaker": null,
      "text": "У нас выставка."
    },
    {
      "start": 180.21,
      "end": 182.35,
      "speaker": null,
      "text": "Я сейчас пока собираю данные по ценам."
    },
    {
      "start": 183.46,
      "end": 184.8,
      "speaker": null,
      "text": "А, все хорошо, конечно."
    },
    {
      "start": 185.38,
      "end": 188.28,
      "speaker": null,
      "text": "А 7 июля у вас выставка будет..."
    },
    {
      "start": 188.28,
      "end": 189.98,
      "speaker": null,
      "text": "Какая отрасль, если не считает?"
    },
    {
      "start": 191.54,
      "end": 195.56,
      "speaker": null,
      "text": "Там вам отношения, взаимоотношения детей и родителей."
    },
    {
      "start": 196.16,
      "end": 197.02,
      "speaker": null,
      "text": "А, я поняла."
    },
    {
      "start": 197.52,
      "end": 197.9,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 197.9,
      "end": 198.0,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 198.5,
      "end": 201.72,
      "speaker": null,
      "text": "А давайте, да, сейчас смогу Максим, например, еще направить."
    },
    {
      "start": 202.1,
      "end": 204.08,
      "speaker": null,
      "text": "Доставку рассчитываете или самовую везем?"
    },
    {
      "start": 205.78,
      "end": 206.26,
      "speaker": null,
      "text": "Ну..."
    },
    {
      "start": 206.48,
      "end": 210.32,
      "speaker": null,
      "text": "Вы мне ее посчитаете с доставкой, но только выделите ее отдельно."
    },
    {
      "start": 210.42,
      "end": 213.4,
      "speaker": null,
      "text": "Потому что я вполне мобильный, могли бы и сами."
    },
    {
      "start": 213.96,
      "end": 215.26,
      "speaker": null,
      "text": "Там все входит в 5 тысяч."
    },
    {
      "start": 216.12,
      "end": 217.26,
      "speaker": null,
      "text": "Да, хорошо, конечно."
    },
    {
      "start": 217.78,
      "end": 221.02,
      "speaker": null,
      "text": "Тогда я просто добавил доставку, вы ее можете убрать в случае чего."
    },
    {
      "start": 221.86,
      "end": 223.08,
      "speaker": null,
      "text": "Все, спасибо вам большое."
    },
    {
      "start": 223.08,
      "end": 223.52,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 224.5,
      "end": 225.84,
      "speaker": null,
      "text": "А в этом..."
    },
    {
      "start": 225.84,
      "end": 228.04,
      "speaker": null,
      "text": "А и вам, да, присылать надо будет?"
    },
    {
      "start": 228.6,
      "end": 229.56,
      "speaker": null,
      "text": "Оригинал макет."
    },
    {
      "start": 230.24,
      "end": 232.84,
      "speaker": null,
      "text": "Ну, макет, да, можно направить все так же."
    },
    {
      "start": 233.28,
      "end": 237.2,
      "speaker": null,
      "text": "Если все в целом подойдет по стоимости, ну, по нашему предложению."
    },
    {
      "start": 238.87,
      "end": 239.97,
      "speaker": null,
      "text": "Все, здесь Валерия."
    },
    {
      "start": 240.07,
      "end": 240.61,
      "speaker": null,
      "text": "Валерия, да?"
    },
    {
      "start": 240.79,
      "end": 243.23,
      "speaker": null,
      "text": "Да, Валерия, тогда сейчас вам напишу в Максе."
    },
    {
      "start": 243.95,
      "end": 245.05,
      "speaker": null,
      "text": "Давай, спасибо, пока."
    },
    {
      "start": 245.09,
      "end": 246.89,
      "speaker": null,
      "text": "Угу, да, на связи."
    }
  ]
}