{
  "file": "14.04.2026_12_01_23_79126166661_m49_d132755_9.1776157283.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 178.1,
  "segments": [
    {
      "start": 1.52,
      "end": 4.22,
      "speaker": null,
      "text": "Елена, здравствуйте. Компания «Мостенд»."
    },
    {
      "start": 4.38,
      "end": 13.9,
      "speaker": null,
      "text": "Елена, добрый день. Подскажите, пожалуйста, меня интересует аренда стоек, промо-стоек на 19-20 апреля в количестве 7 штук."
    },
    {
      "start": 15.02,
      "end": 17.26,
      "speaker": null,
      "text": "В аренду не предоставляем."
    },
    {
      "start": 19.79,
      "end": 23.76,
      "speaker": null,
      "text": "А написано на сайте, что промо-стоек и в аренду?"
    },
    {
      "start": 25.33,
      "end": 30.05,
      "speaker": null,
      "text": "Ну нету, сейчас в данный момент нету промо-стоек в аренду."
    },
    {
      "start": 30.05,
      "end": 34.31,
      "speaker": null,
      "text": "А производство по стоимости сколько будет?"
    },
    {
      "start": 35.07,
      "end": 36.21,
      "speaker": null,
      "text": "Подскажите, как вас зовут?"
    },
    {
      "start": 36.61,
      "end": 37.29,
      "speaker": null,
      "text": "Ксения."
    },
    {
      "start": 37.79,
      "end": 40.87,
      "speaker": null,
      "text": "Ксения, а какая конкретная промо-стоека вас интересует?"
    },
    {
      "start": 41.17,
      "end": 44.27,
      "speaker": null,
      "text": "У которой ширина 78 сантиметров."
    },
    {
      "start": 44.92,
      "end": 47.68,
      "speaker": null,
      "text": "Ну, у неё есть название, подскажите."
    },
    {
      "start": 47.72,
      "end": 48.06,
      "speaker": null,
      "text": "М8?"
    },
    {
      "start": 48.76,
      "end": 49.68,
      "speaker": null,
      "text": "М8, да?"
    },
    {
      "start": 50.18,
      "end": 50.5,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 53.69,
      "end": 60.75,
      "speaker": null,
      "text": "Промо-стоек М8, 26500."
    },
    {
      "start": 64.23,
      "end": 66.57,
      "speaker": null,
      "text": "Это с учётом оплаты по счёту?"
    },
    {
      "start": 66.99,
      "end": 67.25,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 68.83,
      "end": 69.81,
      "speaker": null,
      "text": "А МДС какой?"
    },
    {
      "start": 70.35,
      "end": 70.97,
      "speaker": null,
      "text": "22."
    },
    {
      "start": 71.72,
      "end": 73.06,
      "speaker": null,
      "text": "Он уже включён?"
    },
    {
      "start": 73.28,
      "end": 73.5,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 76.76,
      "end": 78.6,
      "speaker": null,
      "text": "Это без брендинга, я правильно понимаю?"
    },
    {
      "start": 78.94,
      "end": 79.3,
      "speaker": null,
      "text": "Почему?"
    },
    {
      "start": 79.48,
      "end": 80.06,
      "speaker": null,
      "text": "Это с печати."
    },
    {
      "start": 80.62,
      "end": 80.84,
      "speaker": null,
      "text": "А."
    },
    {
      "start": 82.78,
      "end": 85.5,
      "speaker": null,
      "text": "С учётом с печати это по панели."
    },
    {
      "start": 86.86,
      "end": 91.14,
      "speaker": null,
      "text": "Я правильно не понимаю, что она самая обычная, то есть квадратная столешница?"
    },
    {
      "start": 91.14,
      "end": 100.04,
      "speaker": null,
      "text": "Ну, я не могу сказать, что она обычная."
    },
    {
      "start": 100.24,
      "end": 103.72,
      "speaker": null,
      "text": "Она в тубусе, она сборно-разборная, она на колёсиках."
    },
    {
      "start": 104.24,
      "end": 111.5,
      "speaker": null,
      "text": "У неё лицевая панель, она, скажем, ну такая, как на сайте, она немножко полукруглая."
    },
    {
      "start": 112.06,
      "end": 115.86,
      "speaker": null,
      "text": "Подождите, а нет ни полукруглых?"
    },
    {
      "start": 116.77,
      "end": 117.21,
      "speaker": null,
      "text": "М7."
    },
    {
      "start": 118.44,
      "end": 120.42,
      "speaker": null,
      "text": "М7 полностью прямоугольная."
    },
    {
      "start": 120.42,
      "end": 122.16,
      "speaker": null,
      "text": "Так, сейчас секундочку сразу."
    },
    {
      "start": 122.5,
      "end": 124.68,
      "speaker": null,
      "text": "Она там же, чуть-чуть выше."
    },
    {
      "start": 125.9,
      "end": 126.68,
      "speaker": null,
      "text": "М7."
    },
    {
      "start": 127.59,
      "end": 130.33,
      "speaker": null,
      "text": "Ага, а по стоимости она сколько будет?"
    },
    {
      "start": 130.75,
      "end": 132.73,
      "speaker": null,
      "text": "М7 получается..."
    },
    {
      "start": 134.59,
      "end": 136.44,
      "speaker": null,
      "text": "Ну немножко, она 26."
    },
    {
      "start": 137.8,
      "end": 139.12,
      "speaker": null,
      "text": "А, просто 26."
    },
    {
      "start": 140.26,
      "end": 140.84,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 140.84,
      "end": 150.64,
      "speaker": null,
      "text": "И вы сможете таких 7 штук нам сделать к воскресенью?"
    },
    {
      "start": 151.72,
      "end": 153.04,
      "speaker": null,
      "text": "К этому воскресенью?"
    },
    {
      "start": 153.3,
      "end": 153.8,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 154.73,
      "end": 156.67,
      "speaker": null,
      "text": "Ну это прям надо сегодня запускать."
    },
    {
      "start": 158.1,
      "end": 160.32,
      "speaker": null,
      "text": "А, да, давайте сейчас её уточнём."
    },
    {
      "start": 160.62,
      "end": 160.88,
      "speaker": null,
      "text": "Хорошо?"
    },
    {
      "start": 161.62,
      "end": 161.82,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 162.5,
      "end": 167.82,
      "speaker": null,
      "text": "Нужен макет и оформление заказа и оплату сегодня, чтобы успеть."
    },
    {
      "start": 171.86,
      "end": 173.46,
      "speaker": null,
      "text": "Хорошо, вернусь к вам."
    },
    {
      "start": 173.78,
      "end": 174.4,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 175.08,
      "end": 175.38,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 175.38,
      "end": 175.56,
      "speaker": null,
      "text": "О, конечно."
    }
  ]
}