    {
      "start": 21.69,
      "end": 25.01,
      "speaker": null,
      "text": "Не получается тоже..."
    },
    {
      "start": 25.01,
      "end": 28.67,
      "speaker": null,
      "text": "Давайте в Телеграме, скажите свой номер, куда мне написать?"
    },
    {
      "start": 28.76,
      "end": 38.4,
      "speaker": null,
      "text": "У меня общий номер МОМОСЕНТ, поэтому переписка идёт из Битерекса, поэтому я не могу сказать вам номер, я его не знаю."
    },
    {
      "start": 39.08,
      "end": 41.04,
      "speaker": null,
      "text": "Ну давайте тогда, я не могу сказать."
    },
    {
      "start": 41.16,
      "end": 41.78,
      "speaker": null,
      "text": "Да, вот это все."
    },
    {
      "start": 42.28,
      "end": 46.94,
      "speaker": null,
      "text": "ДАС, D-I-S, ДАС, нижнее подчёркивание..."
    },
    {
      "start": 47.07,
      "end": 48.79,
      "speaker": null,
      "text": "Так, секундочку. ДАС?"
