      "start": 727.62,
      "end": 728.84,
      "speaker": null,
      "text": "и не надо парить,"
    },
    {
      "start": 728.88,
      "end": 731.0,
      "speaker": null,
      "text": "я дома его взяла, разложила, сложила"
    },
    {
      "start": 731.0,
      "end": 732.96,
      "speaker": null,
      "text": "и все как бы зацепить."
    },
    {
      "start": 733.34,
      "end": 736.42,
      "speaker": null,
      "text": "Вот такую штуку мы делаем каждый год."
    },
    {
      "start": 737.36,
      "end": 737.88,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 738.02,
      "end": 739.22,
      "speaker": null,
      "text": "Вот такой, вот такой."
    },
    {
      "start": 739.9,
      "end": 742.0,
      "speaker": null,
      "text": "Сейчас закрою."
    },
    {
      "start": 742.97,
      "end": 744.55,
      "speaker": null,
      "text": "И вот такое ощущение..."
    },
    {
      "start": 744.55,
      "end": 745.95,
      "speaker": null,
      "text": "Какая-то просвола обычная."
    },
    {
      "start": 746.19,
      "end": 747.45,
      "speaker": null,
      "text": "Это как будто просто..."
    },
    {
      "start": 747.45,
      "end": 747.61,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 748.03,
      "end": 749.79,
      "speaker": null,
      "text": "Я знаю, но вот я решила,"
    },
    {
      "start": 749.95,
      "end": 752.25,
      "speaker": null,
      "text": "что я сделаю вместо вот этой хрени"
    },
    {
      "start": 753.41,
      "end": 753.89,
      "speaker": null,
      "text": "раскладной"
    },
    {
      "start": 753.89,
      "end": 756.09,
      "speaker": null,
      "text": "вот этот вот полтора метров штуки."
    },
    {
      "start": 757.53,
      "end": 758.49,
      "speaker": null,
      "text": "Мне странно..."
    },
    {
      "start": 758.49,
      "end": 759.55,
      "speaker": null,
      "text": "Да, встали люди,"
    },
    {
      "start": 759.91,
      "end": 761.15,
      "speaker": null,
      "text": "больше четырех человек,"
    },
    {
      "start": 761.37,
      "end": 763.39,
      "speaker": null,
      "text": "нормально как бы все унестились."
    },
    {
      "start": 763.55,
      "end": 765.03,
      "speaker": null,
      "text": "И если больше человек,"
    },
    {
      "start": 765.35,
      "end": 767.85,
      "speaker": null,
      "text": "у меня этот баннер все равно выходит за края"
    },
    {
      "start": 767.85,
      "end": 769.03,
      "speaker": null,
      "text": "и хрень получается."
    },
    {
      "start": 769.03,
      "end": 771.37,
      "speaker": null,
      "text": "поэтому решил, думаю, нафиг париться."
    },
    {
      "start": 771.67,
      "end": 772.45,
      "speaker": null,
      "text": "А этот..."
    }
  ]
}