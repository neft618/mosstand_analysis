{
  "file": "04.03.2026_14_48_19_79859993991_m27_d126123_a.1772624900.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 60.9,
  "segments": [
    {
      "start": 1.71,
      "end": 3.27,
      "speaker": null,
      "text": "Добрый день, Никита Компания на стенд."
    },
    {
      "start": 4.04,
      "end": 5.14,
      "speaker": null,
      "text": "А Валентин?"
    },
    {
      "start": 6.06,
      "end": 7.88,
      "speaker": null,
      "text": "Валентин сейчас отошёл."
    },
    {
      "start": 9.17,
      "end": 12.17,
      "speaker": null,
      "text": "Вы знаете, это Ольга, у нас с ним встреча."
    },
    {
      "start": 12.79,
      "end": 15.39,
      "speaker": null,
      "text": "Да, вы на три часа договаривались."
    },
    {
      "start": 16.25,
      "end": 23.15,
      "speaker": null,
      "text": "Да, вы меня не сориентируете как пройти? Я вот сейчас подошла, написано пиццерия какая-то."
    },
    {
      "start": 24.25,
      "end": 29.27,
      "speaker": null,
      "text": "Там должен быть вход один, рядом есть ещё магазин Озон."
    },
    {
      "start": 29.78,
      "end": 35.02,
      "speaker": null,
      "text": "Вот, Озон вижу. Какой пишет там магазин? Около называется?"
    },
    {
      "start": 35.8,
      "end": 41.56,
      "speaker": null,
      "text": "Вот где Озон, соседняя дверь, центральный вход в бизнес-центр, главный вход номер один."
    },
    {
      "start": 43.2,
      "end": 46.24,
      "speaker": null,
      "text": "Ага, на нем написано что-то, то ли Союз?"
    },
    {
      "start": 46.56,
      "end": 48.3,
      "speaker": null,
      "text": "Да, да, да, бизнес-центр Союз."
    },
    {
      "start": 48.38,
      "end": 49.08,
      "speaker": null,
      "text": "Что-то такое."
    },
    {
      "start": 50.25,
      "end": 52.03,
      "speaker": null,
      "text": "Да, вижу уже. Так, а дальше как?"
    },
    {
      "start": 52.83,
      "end": 57.37,
      "speaker": null,
      "text": "Вы сейчас подходите туда, внутрь заходите, я Валентина схожу, он спустится."
    },
    {
      "start": 58.35,
      "end": 60.81,
      "speaker": null,
      "text": "Отлично, спасибо. До встречи, до свидания."
    }
  ]
}