{
  "file": "28.04.2026_13_06_44_79067402040_m29_d134447_8.1777370805.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 66.6,
  "segments": [
    {
      "start": 0.05,
      "end": 2.31,
      "speaker": null,
      "text": "Запись разговоров активирована."
    },
    {
      "start": 2.75,
      "end": 4.75,
      "speaker": null,
      "text": "Компания «Сарова питания», здравствуйте."
    },
    {
      "start": 5.29,
      "end": 7.91,
      "speaker": null,
      "text": "Здравствуйте, меня Ксения зовут, компания «Мистент»."
    },
    {
      "start": 7.91,
      "end": 15.97,
      "speaker": null,
      "text": "Вы вчера к нам обращались по поводу однофикционной конструкции для пресс-вола 2 на 1.8."
    },
    {
      "start": 16.07,
      "end": 18.07,
      "speaker": null,
      "text": "Подскажите, пожалуйста, актуальный запрос?"
    },
    {
      "start": 19.44,
      "end": 23.36,
      "speaker": null,
      "text": "Сейчас секундочку. Передадим Вас человеку, который интересовал."
    },
    {
      "start": 23.66,
      "end": 25.04,
      "speaker": null,
      "text": "Хорошо, да. Спасибо."
    },
    {
      "start": 28.64,
      "end": 30.42,
      "speaker": null,
      "text": "Пресс-вол значит, да?"
    },
    {
      "start": 30.42,
      "end": 31.9,
      "speaker": null,
      "text": "Да, всё верно."
    },
    {
      "start": 37.18,
      "end": 37.7,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 38.66,
      "end": 40.2,
      "speaker": null,
      "text": "Здравствуйте, Анастасия, верно?"
    },
    {
      "start": 40.64,
      "end": 40.88,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 41.54,
      "end": 45.46,
      "speaker": null,
      "text": "Давай, это Ксения «Мистент». Мы вчера с вами созвонились по поводу конструкции."
    },
    {
      "start": 45.56,
      "end": 47.48,
      "speaker": null,
      "text": "Подскажите, пожалуйста, актуальная заявка?"
    },
    {
      "start": 49.74,
      "end": 54.7,
      "speaker": null,
      "text": "Заявка актуальна. Сейчас не очень удобно разговаривать. Давайте я вам перезвоню и закажу."
    },
    {
      "start": 55.36,
      "end": 58.84,
      "speaker": null,
      "text": "Слышен, а когда? Сегодня или завтра? Как вам удобнее?"
    },
    {
      "start": 60.24,
      "end": 64.9,
      "speaker": null,
      "text": "Сегодня или завтра? Не могу пока сказать. Давайте я вам наберу сама. Спасибо большое."
    },
    {
      "start": 64.9,
      "end": 66.62,
      "speaker": null,
      "text": "Хорошо, тогда догадывайся."
    }
  ]
}