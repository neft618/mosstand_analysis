{
  "file": "20.04.2026_11_12_56_79663891616_m39_d133483_8.1776672777.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 119.6,
  "segments": [
    {
      "start": 0.53,
      "end": 4.19,
      "speaker": null,
      "text": "Добрый день, Никит, компания «Маккент»."
    },
    {
      "start": 4.32,
      "end": 9.14,
      "speaker": null,
      "text": "Здравствуйте. Интересует брендвулу. Размер 4 на 2,5."
    },
    {
      "start": 10.58,
      "end": 12.08,
      "speaker": null,
      "text": "Скажите, как можно брендвулу?"
    },
    {
      "start": 12.26,
      "end": 15.28,
      "speaker": null,
      "text": "Глубина у него 400. Алексей."
    },
    {
      "start": 17.44,
      "end": 18.7,
      "speaker": null,
      "text": "Когда вам необходим?"
    },
    {
      "start": 20.4,
      "end": 21.24,
      "speaker": null,
      "text": "До июня."
    },
    {
      "start": 25.42,
      "end": 27.04,
      "speaker": null,
      "text": "Помимо брендвулу потребуется?"
    },
    {
      "start": 28.68,
      "end": 34.92,
      "speaker": null,
      "text": "Да, роллап потребуется. Там немного одна штука."
    },
    {
      "start": 34.92,
      "end": 46.75,
      "speaker": null,
      "text": "У вас, кстати, номер телефона на мессенджере какой-нибудь есть? Макс, Телеграм, куда могу отправить вам расчёт, так же вот примеры."
    },
    {
      "start": 48.04,
      "end": 49.6,
      "speaker": null,
      "text": "Да, Макс можете определить."
    },
    {
      "start": 51.54,
      "end": 54.5,
      "speaker": null,
      "text": "А так сказать не можете в целом?"
    },
    {
      "start": 54.88,
      "end": 58.62,
      "speaker": null,
      "text": "Могу. 28000 брендвулу 4 на 2,5."
    },
    {
      "start": 59.93,
      "end": 62.89,
      "speaker": null,
      "text": "Это за счёт монтажа, демонтажа и доставки."
    },
    {
      "start": 67.11,
      "end": 70.13,
      "speaker": null,
      "text": "Скажем как, это на чём? На металлокаркасе? На чём это?"
    },
    {
      "start": 70.59,
      "end": 73.01,
      "speaker": null,
      "text": "Нет, брендвул идёт на брусе."
    },
    {
      "start": 73.01,
      "end": 84.42,
      "speaker": null,
      "text": "Это будет брус какой-то, да? То есть он будет целиковый или надо будет натягивать?"
    },
    {
      "start": 85.14,
      "end": 91.74,
      "speaker": null,
      "text": "Нет, это стоимость с конструкцией и печатью. Без исчёт монтажа, демонтажа. 28000."
    },
    {
      "start": 94.08,
      "end": 99.52,
      "speaker": null,
      "text": "Я вас понял. Сколько у вас роллап стоит, если что?"
    },
    {
      "start": 100.22,
      "end": 101.4,
      "speaker": null,
      "text": "А роллап какой по размеру?"
    },
    {
      "start": 103.02,
      "end": 103.98,
      "speaker": null,
      "text": "850 на 2."
    },
    {
      "start": 105.64,
      "end": 108.36,
      "speaker": null,
      "text": "4500. Это конструкция, сумка и печать."
    },
    {
      "start": 113.86,
      "end": 116.54,
      "speaker": null,
      "text": "Я вас понял. Ладно, спасибо большое."
    },
    {
      "start": 116.92,
      "end": 117.7,
      "speaker": null,
      "text": "Окей. Да?"
    },
    {
      "start": 117.98,
      "end": 118.8,
      "speaker": null,
      "text": "Да. До свидания."
    }
  ]
}