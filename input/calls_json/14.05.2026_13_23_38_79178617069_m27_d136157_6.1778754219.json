{
  "file": "14.05.2026_13_23_38_79178617069_m27_d136157_6.1778754219.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 220.4,
  "segments": [
    {
      "start": 0.0,
      "end": 2.86,
      "speaker": null,
      "text": "Добрый день, меня зовут Валентин, компания. Мы станем всем могу вам помочь?"
    },
    {
      "start": 3.42,
      "end": 7.74,
      "speaker": null,
      "text": "Здравствуйте, подскажите, пожалуйста, сколько будет заниматься по времени печать РУАПа?"
    },
    {
      "start": 8.76,
      "end": 12.56,
      "speaker": null,
      "text": "Один рабочий день после согласования макета и оплаты. Скажите, пожалуйста, как вас зовут?"
    },
    {
      "start": 13.12,
      "end": 13.64,
      "speaker": null,
      "text": "Кристина."
    },
    {
      "start": 14.12,
      "end": 16.6,
      "speaker": null,
      "text": "Кристина. В каком размере роллап вам необходим?"
    },
    {
      "start": 17.1,
      "end": 18.42,
      "speaker": null,
      "text": "Так, 60 на 160."
    },
    {
      "start": 19.69,
      "end": 24.37,
      "speaker": null,
      "text": "60 на 160. Угу. А по дате когда он вам необходим?"
    },
    {
      "start": 25.02,
      "end": 26.22,
      "speaker": null,
      "text": "Вообще, желательно завтра."
    },
    {
      "start": 28.88,
      "end": 30.76,
      "speaker": null,
      "text": "А макет уже готов?"
    },
    {
      "start": 32.22,
      "end": 35.54,
      "speaker": null,
      "text": "Макет, наверное, подойдёт. Да, в принципе, готов."
    },
    {
      "start": 36.55,
      "end": 41.25,
      "speaker": null,
      "text": "Угу. Хорошо, я вас понял. А доставка потребуется?"
    },
    {
      "start": 42.03,
      "end": 43.17,
      "speaker": null,
      "text": "А во время хочешь?"
    },
    {
      "start": 44.76,
      "end": 49.84,
      "speaker": null,
      "text": "Если вам необходимо будет уже готовность завтра и забрать на улицу Ухтомской."
    },
    {
      "start": 51.22,
      "end": 57.96,
      "speaker": null,
      "text": "Ухтомская. Ага. Так, сейчас тогда уточню. А если заказывать, как куда отправлять?"
    },
    {
      "start": 58.22,
      "end": 59.64,
      "speaker": null,
      "text": "Смотрите, что происходит."
    },
    {
      "start": 60.18,
      "end": 64.08,
      "speaker": null,
      "text": "Я могу с вами еще и завтра в мессенджере, если у вас к этому номеру телефона привязан?"
    },
    {
      "start": 64.12,
      "end": 65.24,
      "speaker": null,
      "text": "Да, да, привязан."
    },
    {
      "start": 65.84,
      "end": 71.66,
      "speaker": null,
      "text": "Давайте я сейчас сразу тогда проверю, потому что достаточно часто номера скрыты бывают в Телеграме."
    },
    {
      "start": 74.02,
      "end": 77.26,
      "speaker": null,
      "text": "Так, да, почему-то в Телеграме не могу вам написать."
    },
    {
      "start": 78.31,
      "end": 82.4,
      "speaker": null,
      "text": "Так, удобно будет по нику найти?"
    },
    {
      "start": 83.23,
      "end": 84.39,
      "speaker": null,
      "text": "Да, я записываю."
    },
    {
      "start": 85.18,
      "end": 86.44,
      "speaker": null,
      "text": "Так, английское Т."
    },
    {
      "start": 87.0,
      "end": 87.78,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 88.4,
      "end": 88.64,
      "speaker": null,
      "text": "И."
    },
    {
      "start": 89.4,
      "end": 89.84,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 89.84,
      "end": 90.7,
      "speaker": null,
      "text": "Н."
    },
    {
      "start": 90.82,
      "end": 90.98,
      "speaker": null,
      "text": "А."
    },
    {
      "start": 92.74,
      "end": 95.12,
      "speaker": null,
      "text": "Нижнее подчеркивание, буква Е."
    },
    {
      "start": 96.31,
      "end": 96.83,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 97.39,
      "end": 98.33,
      "speaker": null,
      "text": "Так получится, значит."
    },
    {
      "start": 99.02,
      "end": 100.42,
      "speaker": null,
      "text": "Ти на Е, да?"
    },
    {
      "start": 100.72,
      "end": 101.02,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 101.36,
      "end": 101.78,
      "speaker": null,
      "text": "Да, это так."
    },
    {
      "start": 102.18,
      "end": 103.68,
      "speaker": null,
      "text": "Так, сейчас давайте проверим."
    },
    {
      "start": 123.25,
      "end": 125.09,
      "speaker": null,
      "text": "Только что он в Телеграме написал."
    },
    {
      "start": 126.08,
      "end": 126.88,
      "speaker": null,
      "text": "Сейчас посмотрим."
    },
    {
      "start": 128.96,
      "end": 129.96,
      "speaker": null,
      "text": "Пока не пришло."
    },
    {
      "start": 130.36,
      "end": 134.59,
      "speaker": null,
      "text": "Надо попробовать зайти."
    },
    {
      "start": 137.96,
      "end": 143.04,
      "speaker": null,
      "text": "Скажите, пожалуйста, у вас мероприятия планируются или куда-то на постоянную основу поставить?"
    },
    {
      "start": 143.04,
      "end": 143.12,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 143.62,
      "end": 149.24,
      "speaker": null,
      "text": "А вообще на постоянной основе, но завтра мероприятия, поэтому прям очень нужно срочно."
    },
    {
      "start": 149.82,
      "end": 150.68,
      "speaker": null,
      "text": "Так, ага, все вижу."
    },
    {
      "start": 151.43,
      "end": 153.57,
      "speaker": null,
      "text": "Да, а к мероприятию может потребоваться что-то еще?"
    },
    {
      "start": 153.67,
      "end": 154.89,
      "speaker": null,
      "text": "Прикрасивиться нервная продукция?"
    },
    {
      "start": 155.53,
      "end": 156.39,
      "speaker": null,
      "text": "Нет, пока ничего."
    },
    {
      "start": 157.84,
      "end": 161.35,
      "speaker": null,
      "text": "Можно сюда открыть, поэтому срочно понадобился."
    },
    {
      "start": 161.97,
      "end": 162.47,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 163.36,
      "end": 166.32,
      "speaker": null,
      "text": "Хорошо, а ранее с роллапами уже работали, заказали?"
    },
    {
      "start": 167.2,
      "end": 168.32,
      "speaker": null,
      "text": "Ой, нет по-моему."
    },
    {
      "start": 169.22,
      "end": 169.4,
      "speaker": null,
      "text": "Нет?"
    },
    {
      "start": 169.82,
      "end": 170.1,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 171.28,
      "end": 188.7,
      "speaker": null,
      "text": "Да, смотрите, у вас, если макет уже подготовлен, я могу вам сразу сказать, ну я вам технические требования в любом случае направляю, но размер должен быть 590 миллиметров на 1630 миллиметров."
    },
    {
      "start": 189.89,
      "end": 191.73,
      "speaker": null,
      "text": "Угу, хорошо."
    },
    {
      "start": 192.62,
      "end": 195.02,
      "speaker": null,
      "text": "Да, я тогда сейчас по стоимости посчитаю."
    },
    {
      "start": 195.83,
      "end": 196.37,
      "speaker": null,
      "text": "Да, пожалуйста."
    },
    {
      "start": 197.37,
      "end": 200.27,
      "speaker": null,
      "text": "И не то, что у вас самостойка есть в продаже или нет?"
    },
    {
      "start": 202.34,
      "end": 202.9,
      "speaker": null,
      "text": "Эээээ..."
    },
    {
      "start": 202.9,
      "end": 203.62,
      "speaker": null,
      "text": "Только конструкция?"
    },
    {
      "start": 203.88,
      "end": 209.62,
      "speaker": null,
      "text": "Ну, ну, получается, запечатаем баннер и вот она конструкция, которая крепится."
    },
    {
      "start": 209.8,
      "end": 211.0,
      "speaker": null,
      "text": "Вот эта конструкция видела?"
    },
    {
      "start": 211.34,
      "end": 214.36,
      "speaker": null,
      "text": "Да-да-да, я вам стоимость вместе с конструкцией подготовлю."
    },
    {
      "start": 214.93,
      "end": 216.53,
      "speaker": null,
      "text": "Все хорошо, тогда я за информацию."
    },
    {
      "start": 216.87,
      "end": 217.17,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 217.31,
      "end": 218.69,
      "speaker": null,
      "text": "Да, все благодарю, до свидания."
    },
    {
      "start": 218.69,
      "end": 219.19,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 219.25,
      "end": 219.35,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 219.65,
      "end": 219.71,
      "speaker": null,
      "text": "Всего дня."
    },
    {
      "start": 219.75,
      "end": 219.87,
      "speaker": null,
      "text": "Поехали..."
    },
    {
      "start": 219.87,
      "end": 219.93,
      "speaker": null,
      "text": "Продолжение следует..."
    }
