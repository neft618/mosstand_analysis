  "segments": [
    {
      "start": 1.07,
      "end": 3.33,
      "speaker": null,
      "text": "Компания «Москент», Артём, слушаю вас."
    },
    {
      "start": 4.21,
      "end": 7.77,
      "speaker": null,
      "text": "Добрый день, пожалуйста, могу услышать Марию Оленёву?"
    },
    {
      "start": 9.48,
      "end": 14.42,
      "speaker": null,
      "text": "Марии сейчас нету, к сожалению, я её коллега могу услышать с вами, Алина Витамовна."
    },
    {
      "start": 15.34,
      "end": 19.28,
      "speaker": null,
      "text": "Ну, нет, я ей запрос на электронную почту отправила, она не отвечает её как..."
    },
    {
      "start": 19.28,
      "end": 23.92,
      "speaker": null,
      "text": "Её просто нету, к сожалению, да, я как раз в всех легох с ней работал, да, какой вопрос у вас."
    },
    {
      "start": 24.48,
      "end": 27.62,
      "speaker": null,
      "text": "То есть она уволилась, что ли?"
    },
    {
      "start": 27.84,
      "end": 29.9,
      "speaker": null,
      "text": "Да, да, она уволилась, да, её нету, да."
    },
    {
      "start": 29.9,
      "end": 36.0,
      "speaker": null,
      "text": "Так, поняла. Тогда запрос мне на какую электронную почту выслушать?"
    },
    {
      "start": 36.64,
      "end": 40.51,
      "speaker": null,
      "text": "Записывайте, АЗ или Кибуковский."
    },
    {
      "start": 40.53,
      "end": 40.95,
      "speaker": null,
      "text": "Подождите."
    },
    {
      "start": 46.39,
      "end": 48.99,
      "speaker": null,
      "text": "А переадресация не идёт, что ли?"
    },
    {
      "start": 50.05,
      "end": 54.47,
      "speaker": null,
      "text": "Не знаю, видимо, не пришлось ещё писать, ну, не смотрели ещё, честно говоря."
    },
    {
      "start": 55.5,
      "end": 56.12,
      "speaker": null,
      "text": "АЗ?"
    },
    {
      "start": 57.94,
      "end": 59.2,
      "speaker": null,
      "text": "Собакамостен.ру"
    },
    {
      "start": 59.87,
      "end": 64.01,
      "speaker": null,
      "text": "А, З, да, и Собакамостен.ру"
    },
    {
      "start": 64.01,
      "end": 70.11,
      "speaker": null,
      "text": "Да, две буквы А, первая английская буква алфавита, и З последняя, две буквы Собакамостен.ру"
    },
    {
      "start": 70.11,
      "end": 70.55,
      "speaker": null,
      "text": "Да, правда."
    },
    {
      "start": 70.71,
      "end": 73.15,
      "speaker": null,
      "text": "Как у Марии такая же почта, просто ли буквы первые другие."
    },
    {
      "start": 73.81,
      "end": 74.63,
      "speaker": null,
      "text": "А вас как зовут?"
    },
    {
      "start": 75.71,
      "end": 76.07,
      "speaker": null,
      "text": "Екатерина."
    },
    {
      "start": 76.83,
      "end": 79.57,
      "speaker": null,
      "text": "Екатерина, очень приятно. Хорошо, тогда же было запрос, а потом..."
    },
    {
      "start": 79.57,
      "end": 82.51,
      "speaker": null,
      "text": "Я пересылаю тогда сообщение и там..."
    },
    {
      "start": 82.51,
      "end": 83.09,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 83.39,
      "end": 84.35,
      "speaker": null,
      "text": "Да, давайте ждать тогда."
    },
    {
      "start": 84.49,
      "end": 84.69,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 85.07,
      "end": 85.99,
      "speaker": null,
      "text": "Хорошо, спасибо тебе."
    },
    {
      "start": 85.99,
      "end": 86.17,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 86.25,
