      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 238.8,
      "end": 239.18,
      "speaker": null,
      "text": "Y."
    },
    {
      "start": 239.96,
      "end": 240.28,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 241.29,
      "end": 242.13,
      "speaker": null,
      "text": "Снова A."
    },
    {
      "start": 243.0,
      "end": 243.38,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 244.02,
      "end": 244.8,
      "speaker": null,
      "text": "И затем B."
    },
    {
      "start": 245.28,
      "end": 246.68,
      "speaker": null,
      "text": "Н на Зиаб."
    },
    {
      "start": 246.94,
      "end": 249.32,
      "speaker": null,
      "text": "Так, получается Н зиаб."
    },
    {
      "start": 249.89,
      "end": 250.93,
      "speaker": null,
      "text": "Да, верно."
    },
    {
      "start": 251.49,
      "end": 252.07,
      "speaker": null,
      "text": "Все, хорошо."
    },
    {
      "start": 252.23,
      "end": 254.89,
      "speaker": null,
      "text": "Я вам тогда сейчас телеграм напишу, мы с вами там продолжим диалог."
    },
    {
      "start": 255.78,
      "end": 256.44,
      "speaker": null,
      "text": "Да, отлично."
    },
    {
      "start": 256.56,
      "end": 257.74,
      "speaker": null,
      "text": "Спасибо большое, Валентин."
    },
    {
      "start": 257.8,
      "end": 258.52,
      "speaker": null,
      "text": "Будем на связи."
    },
    {
      "start": 258.78,
      "end": 259.62,
      "speaker": null,
      "text": "Всего благодарю, Анна."
    },
    {
      "start": 259.74,
      "end": 260.18,
      "speaker": null,
      "text": "Всего доброго."
    },
    {
      "start": 260.44,
      "end": 261.32,
      "speaker": null,
      "text": "Да, до свидания."
    },
    {
      "start": 261.62,
