  "segments": [
    {
      "start": 0.14,
      "end": 9.08,
      "speaker": null,
      "text": "Алло. Алло, Александр, Данил, компания МОСТЭ. Скажите, пожалуйста, почему КП прислали на Лифлет, а не на Сигвол?"
    },
    {
      "start": 11.7,
      "end": 18.2,
      "speaker": null,
      "text": "Должен быть ещё и Сигвол. Там просто вот я смотрю, спецификация, и здесь только Лифлет."
    },
    {
      "start": 18.26,
      "end": 24.82,
      "speaker": null,
      "text": "Ну это нормально, у нас там несколько закупок в параллель проходит, видимо их не объединили."
    },
    {
      "start": 26.97,
      "end": 34.82,
      "speaker": null,
      "text": "Просто и мы вам КП высылали, а там только на Сигвол. Вам нужна общая КП?"
    },
    {
      "start": 35.51,
      "end": 39.07,
      "speaker": null,
      "text": "Нет, два раздельных, покупать двумя отдельными счетами."
    },
    {
      "start": 39.39,
      "end": 42.25,
      "speaker": null,
      "text": "Да, всё, просто я тоже думаю, что у нас это разно."
    },
    {
      "start": 43.26,
      "end": 53.72,
      "speaker": null,
      "text": "И наверное ещё тогда в обозримом будущем будет маленький запрос на три небольших мобильных роллапа."
    },
    {
      "start": 55.83,
      "end": 56.77,
      "speaker": null,
      "text": "Каких ещё раз?"
    },
    {
      "start": 57.71,
      "end": 60.55,
      "speaker": null,
      "text": "Три каплевидных ролла по 120 на 2."
    },
    {
      "start": 61.73,
      "end": 64.61,
      "speaker": null,
      "text": "Угу, супер. Ну это вы тоже так же там с Филеной?"
    },
    {
      "start": 65.57,
      "end": 68.65,
      "speaker": null,
      "text": "Да, да. Вот тут я делаю, всё дорожят."
    },
    {
      "start": 69.09,
      "end": 71.61,
      "speaker": null,
      "text": "Это думаю не раньше, на следующей неделе."
    },
    {
      "start": 72.29,
      "end": 75.86,
      "speaker": null,
      "text": "Угу, тогда я жду КП на Сигвол и Провостойку."
    },
    {
      "start": 76.37,
      "end": 76.75,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 77.17,
      "end": 78.09,
      "speaker": null,
      "text": "Всё, хорошо, спасибо."
    },
    {
      "start": 78.61,
      "end": 79.37,
      "speaker": null,
      "text": "Вам спасибо."
    },
    {
      "start": 79.57,
      "end": 79.99,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}