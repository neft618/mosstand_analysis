    {
      "start": 0.0,
      "end": 0.5,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 1.24,
      "end": 12.83,
      "speaker": null,
      "text": "Добрый день, меня зовут Пхения, компания Носент. Вы к нам обратились по поводу скатерсти. Подскажите, пожалуйста, как я могу к вам обращаться? То в ответ на 5 дней мы угадали, как к вам обращаться. Как ещё раз?"
    },
    {
      "start": 13.03,
      "end": 13.99,
      "speaker": null,
      "text": "Ренат, Ренат."
    },
    {
      "start": 14.75,
      "end": 25.37,
      "speaker": null,
      "text": "А, Ренат, очень приятно с вами познакомиться. Так, подскажите, пожалуйста, у нас просто минимальный самозаказ вот 7000, может, мы не одну скатерть сделаем, а там 2-3 штучки?"
    },
    {
      "start": 26.54,
      "end": 28.42,
      "speaker": null,
      "text": "Ну вы же отвесили там розовую, да?"
    },
    {
      "start": 29.06,
      "end": 31.3,
      "speaker": null,
      "text": "Да, я уже вам там всё прописала."
    },
    {
      "start": 31.74,
      "end": 33.5,
      "speaker": null,
      "text": "Ага, мы ответим, спасибо."
    },
    {
      "start": 35.03,
      "end": 37.25,
      "speaker": null,
      "text": "Ну, а ответ положительный?"
    },
    {
      "start": 38.34,
      "end": 42.48,
      "speaker": null,
      "text": "Ну, сейчас я перешлю там, кто решит этот вопрос."
    },
    {
      "start": 43.6,
      "end": 44.8,
      "speaker": null,
      "text": "А, хорошо, хорошо."
    },
    {
      "start": 45.24,
      "end": 47.73,
      "speaker": null,
      "text": "Ну что, да, до конца рабочего дня."
    },
    {
      "start": 48.75,
      "end": 51.97,
      "speaker": null,
      "text": "Всё, хорошо, это до сегодня жду, если что завтра помню."
    },
    {
      "start": 52.45,
      "end": 53.63,
      "speaker": null,
      "text": "Хорошо, да, спасибо."
    },
    {
      "start": 54.43,
      "end": 55.75,
      "speaker": null,
      "text": "Да, спасибо, до свидания."
    },
    {
      "start": 55.91,
      "end": 56.19,
      "speaker": null,
      "text": "До свидания."
    }
  ]
