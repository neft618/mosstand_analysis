    {
      "start": 2.78,
      "end": 4.18,
      "speaker": null,
      "text": "Алло, Мария, здравствуйте."
    },
    {
      "start": 5.07,
      "end": 9.89,
      "speaker": null,
      "text": "Да, здравствуйте. Скажите, пожалуйста, меня Александр зовут, а я просто телефон взял."
    },
    {
      "start": 10.99,
      "end": 16.74,
      "speaker": null,
      "text": "По поводу поп-стенды хотел бы заказать у вас. Хотел бы узнать стоимость."
    },
    {
      "start": 17.06,
      "end": 18.36,
      "speaker": null,
      "text": "Поп-ап вас интересует?"
    },
    {
      "start": 18.8,
      "end": 19.42,
      "speaker": null,
      "text": "Да, поп-ап."
    },
    {
      "start": 20.31,
      "end": 21.19,
      "speaker": null,
      "text": "Да, всё хорошо."
    },
    {
      "start": 22.77,
      "end": 25.87,
      "speaker": null,
      "text": "Могу ли я вам на почту прислать характеристики и узнать стоимость?"
    },
    {
      "start": 26.85,
      "end": 29.05,
      "speaker": null,
      "text": "Можете, конечно. Вы можете записать почту?"
    },
    {
      "start": 29.86,
      "end": 30.32,
      "speaker": null,
      "text": "Что-что?"
    },
    {
      "start": 30.32,
      "end": 32.28,
      "speaker": null,
      "text": "Записать мою почту можете?"
    },
    {
      "start": 33.39,
      "end": 35.85,
      "speaker": null,
      "text": "А, там, лично какая-то ещё раздавайте."
    },
    {
      "start": 36.19,
      "end": 37.89,
      "speaker": null,
      "text": "Да, у меня личная почта."
    },
    {
      "start": 38.27,
      "end": 43.61,
      "speaker": null,
      "text": "Да, чтобы потом просто ваша заявка может сейчас потеряться и мы потратим время, я бы вам так быстрее ответил."
    },
    {
      "start": 44.64,
      "end": 45.38,
      "speaker": null,
      "text": "Да, записано."
    },
    {
      "start": 45.4,
      "end": 50.28,
      "speaker": null,
      "text": "Вместо инфо просто VF, V галочка F, Филипп."
    },
    {
      "start": 50.38,
      "end": 50.94,
      "speaker": null,
      "text": "Секунду."
    },
    {
      "start": 52.86,
      "end": 56.26,
      "speaker": null,
      "text": "Да, V галочка F, собакамосттен.ру"
    },
    {
      "start": 56.26,
      "end": 65.61,
      "speaker": null,
      "text": "Так, VF, собакамосттен.ру"
    },
    {
      "start": 65.61,
      "end": 66.45,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 67.25,
      "end": 69.25,
      "speaker": null,
      "text": "Сейчас вам напишу."
    },
    {
      "start": 69.87,
