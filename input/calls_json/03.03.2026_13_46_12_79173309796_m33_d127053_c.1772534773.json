      "speaker": null,
      "text": "Рабочему?"
    },
    {
      "start": 61.32,
      "end": 62.54,
      "speaker": null,
      "text": "Да, он меня доступен."
    },
    {
      "start": 63.58,
      "end": 64.3,
      "speaker": null,
      "text": "А, всё, ага."
    },
    {
      "start": 65.86,
      "end": 67.06,
      "speaker": null,
      "text": "Когда выйти из отпуска?"
