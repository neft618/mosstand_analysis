  "segments": [
    {
      "start": 4.09,
      "end": 11.26,
      "speaker": null,
      "text": "Здравствуйте, меня зовут Влад. Получил вашу заявку на обратный звонок. Хотел узнать, что могу помочь вам?"
    },
    {
      "start": 14.23,
      "end": 20.67,
      "speaker": null,
      "text": "Можете ещё раз повторить о чём? Это компания МОСТЕНД, Влад."
    },
    {
      "start": 21.86,
      "end": 24.64,
      "speaker": null,
      "text": "Да-да-да, я у вас заемку спалял сегодня."
    },
    {
      "start": 26.94,
      "end": 28.36,
      "speaker": null,
      "text": "Вы не знаете, что могу помнить?"
    },
    {
      "start": 31.8,
      "end": 40.14,
      "speaker": null,
      "text": "Я вот вроде бы ещё на почту вашу написал заказ. Я забыл, как он называется по поводу заказа."
    },
    {
      "start": 40.78,
      "end": 41.84,
      "speaker": null,
      "text": "А вам кто-то ответил уже?"
    },
    {
      "start": 43.24,
      "end": 43.46,
      "speaker": null,
      "text": "А?"
    },
    {
      "start": 44.04,
      "end": 45.64,
      "speaker": null,
      "text": "Вам кто-то ответил уже на почту?"
    },
    {
      "start": 46.18,
      "end": 47.72,
      "speaker": null,
      "text": "А вот сейчас..."
    },
    {
      "start": 48.92,
      "end": 52.34,
      "speaker": null,
      "text": "Да, просто мало ли какой-то мэйфомендер уже там продублировался."
    },
    {
      "start": 77.54,
      "end": 79.52,
      "speaker": null,
      "text": "Нет, по заявке никто не ответил."
    },
    {
      "start": 81.69,
      "end": 84.45,
      "speaker": null,
      "text": "Ага, тогда можете мне продублировать что у вас заявки?"
    },
    {
      "start": 84.77,
      "end": 86.57,
      "speaker": null,
      "text": "Потому что я самого письма не вижу."
    },
    {
      "start": 87.49,
      "end": 89.17,
      "speaker": null,
      "text": "Могу вам только эту помощь."
    },
    {
      "start": 91.68,
      "end": 93.74,
      "speaker": null,
      "text": "Два, получается, рулапа."
    },
    {
      "start": 94.22,
      "end": 94.76,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 94.9,
      "end": 98.46,
      "speaker": null,
      "text": "У вас фактически есть и экономные или как-то я забыл."
    },
    {
      "start": 102.15,
      "end": 103.73,
      "speaker": null,
      "text": "Так, а вам какой нужен?"
    },
    {
      "start": 104.23,
      "end": 107.93,
      "speaker": null,
      "text": "Просто что эконом, такой позиции нет, это пластиковые."
