      "speaker": null,
      "text": "Все."
    },
    {
      "start": 146.49,
      "end": 147.01,
      "speaker": null,
      "text": "Потрясающе."
    },
    {
      "start": 147.13,
      "end": 149.53,
      "speaker": null,
      "text": "У вас один макет будет на двух рулапах или разные будут?"
    },
    {
      "start": 149.79,
      "end": 150.25,
      "speaker": null,
      "text": "Да, да."
