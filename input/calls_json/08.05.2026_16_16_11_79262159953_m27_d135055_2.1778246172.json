{
  "file": "08.05.2026_16_16_11_79262159953_m27_d135055_2.1778246172.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 161.5,
  "segments": [
    {
      "start": 0.88,
      "end": 1.48,
      "speaker": null,
      "text": "Алло?"
    },
    {
      "start": 1.72,
      "end": 4.28,
      "speaker": null,
      "text": "Да, Легендра звонили. Не мог взять трубку."
    },
    {
      "start": 5.06,
      "end": 16.54,
      "speaker": null,
      "text": "Да, звонил. Знаете, хотел спросить, смотрите, а вот вы мне прислали эту стоимость на ресепшн, этот текст, который 2х2, а он с учётом этой печати или это ещё отдельный печатница, баннер на него?"
    },
    {
      "start": 16.9,
      "end": 18.86,
      "speaker": null,
      "text": "Нет, это я вам стоимость печати везде написал."
    },
    {
      "start": 23.52,
      "end": 28.14,
      "speaker": null,
      "text": "Смотрите, а это как стойка? Нам надо двусторонние, там 1000 рублей прибавляется, да?"
    },
    {
      "start": 29.18,
      "end": 34.02,
      "speaker": null,
      "text": "Двусторонние, так, сейчас скажу вам, это 2500 на..."
    },
    {
      "start": 35.65,
      "end": 36.53,
      "speaker": null,
      "text": "Так, секунду."
    },
    {
      "start": 36.57,
      "end": 40.31,
      "speaker": null,
      "text": "Ну я просто посмотрел, там разница 1000 рублей на стороне двухстороннее, правильно, нет?"
    },
    {
      "start": 41.41,
      "end": 43.15,
      "speaker": null,
      "text": "52 800 двустороннее будет."
    },
    {
      "start": 44.52,
      "end": 46.08,
      "speaker": null,
      "text": "С каркасом."
    },
    {
      "start": 46.42,
      "end": 49.64,
      "speaker": null,
      "text": "Да-да-да, да-да, это каркасная печать и сумка."
    },
    {
      "start": 49.94,
      "end": 56.42,
      "speaker": null,
      "text": "Да, а баннер вот этот, промостойка 34, это что сюда входит? Стоимость стойки плюс печать?"
    },
    {
      "start": 56.42,
      "end": 61.46,
      "speaker": null,
      "text": "Да-да, это стойка, печать и полочки. Полочки из пола х2 штуки."
    },
    {
      "start": 62.54,
      "end": 67.92,
      "speaker": null,
      "text": "Ага, всё, потому что здесь не указано это именно с печатью. Что-то, да? Понял."
    },
    {
      "start": 68.22,
      "end": 72.9,
      "speaker": null,
      "text": "И смотрите, а можно ли на промостойку сделать ещё дополнительную ткань?"
    },
    {
      "start": 73.54,
      "end": 75.66,
      "speaker": null,
      "text": "Да, отдельно полотно также можно сделать."
    },
    {
      "start": 76.91,
      "end": 77.71,
      "speaker": null,
      "text": "Сколько вы стоите?"
    },
    {
      "start": 78.51,
      "end": 79.55,
      "speaker": null,
      "text": "Так, сейчас секунду."
    },
    {
      "start": 82.09,
      "end": 84.95,
      "speaker": null,
      "text": "Мне надо посчитать, потому что у меня под рукой нету."
    },
    {
      "start": 85.45,
      "end": 88.01,
      "speaker": null,
      "text": "Давайте я вам тогда напишу в письме в этой же теме."
    },
    {
      "start": 88.01,
      "end": 91.67,
      "speaker": null,
      "text": "Ну, напишите, да. У меня, в принципе, единственный вопрос сейчас."
    },
    {
      "start": 91.95,
      "end": 93.23,
      "speaker": null,
      "text": "Потому что мы хотим две компании."
    },
    {
      "start": 93.41,
      "end": 97.51,
      "speaker": null,
      "text": "Вот у нас двусторонний ветвь будем делать и стойки тоже хотим два баннера сделать."
    },
    {
      "start": 98.73,
      "end": 101.65,
      "speaker": null,
      "text": "И на разные выставки их возить двух компаний."
    },
    {
      "start": 101.77,
      "end": 104.31,
      "speaker": null,
      "text": "Поэтому вот посчитайте сразу, напишите мне сколько вы стоите."
    },
    {
      "start": 104.79,
      "end": 105.19,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 106.21,
      "end": 107.19,
      "speaker": null,
      "text": "Хорошо, я вас понял."
    },
    {
      "start": 108.04,
      "end": 108.44,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 109.6,
      "end": 109.86,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 110.06,
      "end": 110.88,
      "speaker": null,
      "text": "А, нет, вот ещё вопрос."
    },
    {
      "start": 111.08,
      "end": 111.36,
      "speaker": null,
      "text": "Смотрите."
    },
    {
      "start": 113.66,
      "end": 116.78,
      "speaker": null,
      "text": "Секции промостойка MS4 2x2 36000 и 34000."
    },
    {
      "start": 117.36,
      "end": 117.68,
      "speaker": null,
      "text": "Вот это."
    },
    {
      "start": 117.78,
      "end": 118.42,
      "speaker": null,
      "text": "Это что значит?"
    },
    {
      "start": 118.5,
      "end": 125.19,
      "speaker": null,
      "text": "А, первая промостойка MS4 – это идёт она как поп-ап на фото примеров, которые вы присылали."
    },
    {
      "start": 125.41,
      "end": 126.05,
      "speaker": null,
      "text": "Вот которая…"
    },
    {
      "start": 126.05,
      "end": 126.45,
      "speaker": null,
      "text": "А, всё."
    },
    {
      "start": 127.28,
      "end": 128.0,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 128.22,
      "end": 128.4,
      "speaker": null,
      "text": "Она…"
    },
    {
      "start": 128.4,
      "end": 129.16,
      "speaker": null,
      "text": "Да, да, всё понятно."
    },
    {
      "start": 129.16,
      "end": 129.62,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 129.8,
      "end": 130.68,
      "speaker": null,
      "text": "Которая полукруглая такая."
    },
    {
      "start": 131.6,
      "end": 132.5,
      "speaker": null,
      "text": "Да, я понял."
    },
    {
      "start": 133.02,
      "end": 135.28,
      "speaker": null,
      "text": "А это текстильный, да, баннер на ткани?"
    },
    {
      "start": 135.72,
      "end": 137.68,
      "speaker": null,
      "text": "Да, это прям ткань-ткань."
    },
    {
      "start": 138.45,
      "end": 138.83,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 139.13,
      "end": 140.63,
      "speaker": null,
      "text": "А по весу они одинаковые примерно?"
    },
    {
      "start": 140.93,
      "end": 147.63,
      "speaker": null,
      "text": "По весу, которая обычная, не текстильная, она будет потяжелее в районе, наверное, 12 кг."
    },
    {
      "start": 148.43,
      "end": 151.07,
      "speaker": null,
      "text": "Да, вот я как раз хотел полегче, но это больше текстиль."
    },
    {
      "start": 151.29,
      "end": 154.17,
      "speaker": null,
      "text": "Ну, пришлите мне стоимость. Давайте на эту и на эту, на обе стойки."
    },
    {
      "start": 154.31,
      "end": 155.33,
      "speaker": null,
      "text": "Пришлите стоимость."
    },
    {
      "start": 155.45,
      "end": 155.69,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 155.93,
      "end": 156.63,
      "speaker": null,
      "text": "Хорошо, хорошо."
    },
    {
      "start": 157.66,
      "end": 158.56,
      "speaker": null,
      "text": "Ага, спасибо большое."
    },
    {
      "start": 158.56,
      "end": 159.74,
      "speaker": null,
      "text": "Вам спасибо, до свидания."
    }
  ]
