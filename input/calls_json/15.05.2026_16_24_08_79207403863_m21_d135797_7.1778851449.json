{
  "file": "15.05.2026_16_24_08_79207403863_m21_d135797_7.1778851449.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 215.8,
  "segments": [
    {
      "start": 1.62,
      "end": 4.9,
      "speaker": null,
      "text": "Галина, добрый день. Артём, компания «Макцент»."
    },
    {
      "start": 5.16,
      "end": 6.76,
      "speaker": null,
      "text": "Да, мне передали ваш телефон."
    },
    {
      "start": 8.4,
      "end": 9.34,
      "speaker": null,
      "text": "Ваши коллеги вообще."
    },
    {
      "start": 12.78,
      "end": 17.02,
      "speaker": null,
      "text": "Подскажите мне, пожалуйста, можем ли мы с вами сработать по счёту без договора?"
    },
    {
      "start": 17.18,
      "end": 22.44,
      "speaker": null,
      "text": "Да, можем, просто в первую очередь рассказали с вашей стороны, что договор там нужен и я такой, ну ладно, пожалуйста."
    },
    {
      "start": 22.54,
      "end": 30.14,
      "speaker": null,
      "text": "Боже мой, ну Ольга у нас очень такой творческий человек, понимаете, она вот набегами бывает в компании,"
    },
    {
      "start": 30.26,
      "end": 32.76,
      "speaker": null,
      "text": "и, к сожалению, конструктор знает очень плохо."
    },
    {
      "start": 33.1,
      "end": 37.46,
      "speaker": null,
      "text": "Поэтому будьте добры, пожалуйста, мне можно номер телефона там или же…"
    },
    {
      "start": 37.46,
      "end": 38.44,
      "speaker": null,
      "text": "Мне почта нужна."
    },
    {
      "start": 38.62,
      "end": 41.48,
      "speaker": null,
      "text": "Просто нам приглашать почту."
    },
    {
      "start": 41.66,
      "end": 46.56,
      "speaker": null,
      "text": "У меня там почта такая кривая у нас в доме, органика есть достаточно кривой."
    },
    {
      "start": 46.84,
      "end": 48.22,
      "speaker": null,
      "text": "Не хочу по буквам его диктовать."
    },
    {
      "start": 48.54,
      "end": 52.16,
      "speaker": null,
      "text": "Могу вас попросить в гугл-бистером органические кислоты"
    },
    {
      "start": 52.16,
      "end": 56.24,
      "speaker": null,
      "text": "и там здесь моя почта в контактах Галины Солдатова."
    },
    {
      "start": 59.02,
      "end": 60.7,
      "speaker": null,
      "text": "Органические кислоты."
    },
    {
      "start": 61.2,
      "end": 63.14,
      "speaker": null,
      "text": "Сейчас обеспечиваем за компьютером."
    },
    {
      "start": 64.14,
      "end": 64.52,
      "speaker": null,
      "text": "Да, и там…"
    },
    {
      "start": 64.52,
      "end": 67.14,
      "speaker": null,
      "text": "Такое у нас получилось, как в аварийную компанию."
    },
    {
      "start": 67.14,
      "end": 68.36,
      "speaker": null,
      "text": "А какой сайт именно тут?"
    },
    {
      "start": 70.52,
      "end": 71.98,
      "speaker": null,
      "text": "Какой именно сайт?"
    },
    {
      "start": 72.44,
      "end": 73.62,
      "speaker": null,
      "text": "Тут Плеяна…"
    },
    {
      "start": 74.58,
      "end": 75.06,
      "speaker": null,
      "text": "Там…"
    },
    {
      "start": 75.06,
      "end": 76.0,
      "speaker": null,
      "text": "Подождите."
    },
    {
      "start": 76.22,
      "end": 78.8,
      "speaker": null,
      "text": "Мы, по-моему, сам первый должны вылезать, насколько я помню."
    },
    {
      "start": 79.86,
      "end": 79.92,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 80.12,
      "end": 80.88,
      "speaker": null,
      "text": "Что мы сейчас…"
    },
    {
      "start": 81.92,
      "end": 82.88,
      "speaker": null,
      "text": "Сейчас прям…"
    },
    {
      "start": 84.54,
      "end": 85.02,
      "speaker": null,
      "text": "Уголовение…"
    },
    {
      "start": 85.02,
      "end": 87.54,
      "speaker": null,
      "text": "А в реквизиты случайно у вас не бывает там с сайта, кстати?"
    },
    {
      "start": 87.84,
      "end": 89.7,
      "speaker": null,
      "text": "Нет, мы пока сайт туда не имеем."
    },
    {
      "start": 89.82,
      "end": 93.96,
      "speaker": null,
      "text": "А, ну самое первое, где главное написано органические кислоты.рум."
    },
    {
      "start": 94.98,
      "end": 95.46,
      "speaker": null,
      "text": "Органик…"
    },
    {
      "start": 96.14,
      "end": 96.62,
      "speaker": null,
      "text": "Органик…"
    },
    {
      "start": 96.62,
      "end": 97.64,
      "speaker": null,
      "text": "Вот, я вижу…"
    },
    {
      "start": 97.64,
      "end": 98.18,
      "speaker": null,
      "text": "Органик…"
    },
    {
      "start": 99.12,
      "end": 100.42,
      "speaker": null,
      "text": "В контакты зайти надо, да?"
    },
    {
      "start": 100.6,
      "end": 101.1,
      "speaker": null,
      "text": "Заходите."
    },
    {
      "start": 101.36,
      "end": 102.98,
      "speaker": null,
      "text": "Да-да-да, в контакты."
    },
    {
      "start": 103.14,
      "end": 103.6,
      "speaker": null,
      "text": "Так…"
    },
    {
      "start": 103.6,
      "end": 106.56,
      "speaker": null,
      "text": "И там отдел «Снабжение» Солдатова Галины Игоревна."
    },
    {
      "start": 106.72,
      "end": 107.86,
      "speaker": null,
      "text": "Все, я вижу вашу почту."
    },
    {
      "start": 107.96,
      "end": 108.4,
      "speaker": null,
      "text": "Пять минут."
    },
    {
      "start": 108.5,
      "end": 110.6,
      "speaker": null,
      "text": "Я сейчас счет направлю тогда."
    },
    {
      "start": 111.46,
      "end": 113.78,
      "speaker": null,
      "text": "Смотрите, я сейчас его заведу в оплату."
    },
    {
      "start": 113.88,
      "end": 116.94,
      "speaker": null,
      "text": "У нас он будет, скорее всего, оплачен 20-21-го."
    },
    {
      "start": 116.94,
      "end": 118.3,
      "speaker": null,
      "text": "Ну, вам для сведения."
    },
    {
      "start": 118.44,
      "end": 118.78,
      "speaker": null,
      "text": "Я прошу."
    },
    {
      "start": 118.8,
      "end": 121.78,
      "speaker": null,
      "text": "Если что, по коммерческой части со мной и, пожалуйста,"
    },
    {
      "start": 122.08,
      "end": 124.54,
      "speaker": null,
      "text": "потом по ИДО отправите нам ОПД?"
    },
    {
      "start": 125.88,
      "end": 127.34,
      "speaker": null,
      "text": "Оператор поскажите у вас, и все."
    },
    {
      "start": 128.14,
      "end": 128.62,
      "speaker": null,
      "text": "Контур…"
    },
    {
      "start": 128.62,
      "end": 133.5,
      "speaker": null,
      "text": "Да, мне название оператора достаточно, мы по ИНН найдем."
    },
    {
      "start": 133.78,
      "end": 135.6,
      "speaker": null,
      "text": "Слушайте, вы прям вообще шикарны."
    },
    {
      "start": 136.62,
      "end": 139.56,
      "speaker": null,
      "text": "Так, счет у вас, так, 20-21-го."
    },
    {
      "start": 139.64,
      "end": 140.96,
      "speaker": null,
      "text": "Когда необходимо спернуть еще раз?"
    },
    {
      "start": 141.46,
      "end": 142.48,
      "speaker": null,
      "text": "От 28-го."
    },
    {
      "start": 142.92,
      "end": 146.0,
      "speaker": null,
      "text": "Ну там доставка, я не знаю, когда у вас было оговорено."
    },
    {
      "start": 146.0,
      "end": 148.92,
      "speaker": null,
      "text": "Да, тут сейчас уже, видите, в разработке макета."
    },
    {
      "start": 149.08,
      "end": 151.78,
      "speaker": null,
      "text": "А у нас толком ТЗ-то такого-то нету."
    },
    {
      "start": 151.84,
      "end": 155.16,
      "speaker": null,
      "text": "Сделайте то-то вот это вот так-то, а что именно, я там не знаю."
    },
    {
      "start": 156.0,
      "end": 158.82,
      "speaker": null,
      "text": "Я сейчас смогу подкрепку информацию от Ольги,"
    },
    {
      "start": 158.9,
      "end": 160.36,
      "speaker": null,
      "text": "взял логотипы, фотографии."
    },
    {
      "start": 160.74,
      "end": 164.04,
      "speaker": null,
      "text": "Ну, что смог, то направлю дизайнеру, когда есть оплата пройдет."
    },
    {
      "start": 164.16,
      "end": 164.72,
      "speaker": null,
      "text": "Просто висит."
    },
    {
      "start": 166.18,
      "end": 170.04,
      "speaker": null,
      "text": "Ну, с Ольгой сложно иногда бывает, да, я понимаю."
    },
    {
      "start": 170.36,
      "end": 174.24,
      "speaker": null,
      "text": "Но там уточните, пожалуйста, сколько нужно для разработки вообще?"
    },
    {
      "start": 174.24,
      "end": 177.04,
      "speaker": null,
      "text": "Да я бриф направлял, его нужно заполнить."
    },
    {
      "start": 177.18,
      "end": 180.88,
      "speaker": null,
      "text": "А там он не заполнит, просто направлю сообщение с этим, что надо сделать и все."
    },
    {
      "start": 181.64,
      "end": 183.62,
      "speaker": null,
      "text": "Ну, я попробую, что я смогу."
    },
    {
      "start": 185.26,
      "end": 186.96,
      "speaker": null,
      "text": "Давайте сделаем следующим образом."
    },
    {
      "start": 186.96,
      "end": 188.8,
      "speaker": null,
      "text": "Вы мне сейчас направите счет."
    },
    {
      "start": 190.08,
      "end": 198.28,
      "speaker": null,
      "text": "Я продублирую, ну, отправлю его на согласование и продублирую Ольге вот этот вот заполнить листик, который нужно."
    },
    {
      "start": 198.44,
      "end": 199.64,
      "speaker": null,
      "text": "Боюсь ошибиться с названием."
    },
    {
      "start": 199.64,
      "end": 203.06,
      "speaker": null,
      "text": "Я его продублирую, чтобы вы тоже посмотрели, ознакомились с ним для себя."
    },
    {
      "start": 203.18,
      "end": 203.54,
      "speaker": null,
      "text": "Мало ли."
    },
    {
      "start": 204.32,
      "end": 207.12,
      "speaker": null,
      "text": "Ну, мало ли, да, может быть когда-нибудь пригодится."
    },
    {
      "start": 207.5,
      "end": 208.68,
      "speaker": null,
      "text": "Ладно, хорошо, давайте."
    },
    {
      "start": 208.96,
      "end": 209.96,
      "speaker": null,
      "text": "Пять минут буквально."
    },
    {
      "start": 209.96,
      "end": 211.5,
      "speaker": null,
      "text": "Да, Андрей, огонь."
    },
    {
      "start": 211.62,
      "end": 212.26,
      "speaker": null,
      "text": "Просто супер."
    },
    {
      "start": 212.36,
      "end": 213.04,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 213.38,
      "end": 214.22,
      "speaker": null,
      "text": "Всего-всего доброго."
    },
    {
      "start": 214.4,
      "end": 214.82,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 214.82,
      "end": 214.92,
      "speaker": null,
      "text": "До свидания."
    }
  ]
}