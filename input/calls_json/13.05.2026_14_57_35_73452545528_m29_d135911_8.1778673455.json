  "segments": [
    {
      "start": 1.46,
      "end": 4.66,
      "speaker": null,
      "text": "Добрый день, меня зовут Ксения, компания Мастан. Каждый могу к вам дышать."
    },
    {
      "start": 5.66,
      "end": 6.8,
      "speaker": null,
      "text": "Добрый день, Елена."
    },
    {
      "start": 7.57,
      "end": 8.93,
      "speaker": null,
      "text": "Елена, чем могу вам помочь?"
    },
    {
      "start": 9.93,
      "end": 20.07,
      "speaker": null,
      "text": "Подскажите, пожалуйста, у нас руководитель недавно КП запрашивала на фотопанель для поп-ап моей конференции в развилке."
    },
    {
      "start": 21.34,
      "end": 23.14,
      "speaker": null,
      "text": "Так, у какого менеджера?"
    },
    {
      "start": 23.14,
      "end": 36.32,
      "speaker": null,
      "text": "Так, написано, так-так-так. Ай, не знаю, вот у меня только КП на руках, но подпись вот Юрий Саковский только ещё."
    },
    {
      "start": 36.96,
      "end": 39.54,
      "speaker": null,
      "text": "Так, а номер коммерческого предложения?"
    },
    {
      "start": 39.86,
      "end": 45.0,
      "speaker": null,
      "text": "Номер МС 1 7 0 3 1."
    },
    {
      "start": 45.77,
      "end": 48.17,
      "speaker": null,
      "text": "Так, сейчас секундочку, секундочку."
    },
    {
      "start": 48.55,
      "end": 49.49,
      "speaker": null,
      "text": "От сегодняшнего числа."
    },
    {
      "start": 49.49,
      "end": 53.71,
      "speaker": null,
      "text": "Так, ещё раз 1 2."
    },
    {
      "start": 55.32,
      "end": 59.62,
      "speaker": null,
      "text": "Не-не-не, номер предложения МС 1 7 0 3 1."
    },
    {
      "start": 60.14,
      "end": 63.28,
      "speaker": null,
      "text": "А, 1 7 0 3 1."
    },
    {
      "start": 63.64,
      "end": 65.8,
      "speaker": null,
      "text": "1 7 0 3 1."
    },
    {
      "start": 66.35,
      "end": 68.07,
      "speaker": null,
      "text": "3 1, угу, так."
    },
    {
      "start": 89.0,
      "end": 90.32,
      "speaker": null,
      "text": "Почему-то не ищутся."
    },
    {
      "start": 90.92,
      "end": 92.06,
      "speaker": null,
      "text": "Как там нашла?"
    },
    {
      "start": 92.78,
      "end": 94.5,
      "speaker": null,
      "text": "Да, я понимаю просто."
    },
    {
      "start": 95.86,
      "end": 97.0,
      "speaker": null,
      "text": "Со вчера, да?"
    },
    {
      "start": 97.89,
      "end": 99.15,
      "speaker": null,
      "text": "Нет, сегодня вот."
    },
    {
      "start": 102.23,
      "end": 103.11,
      "speaker": null,
      "text": "Тяжело, конечно."
    },
    {
      "start": 104.57,
      "end": 108.51,
      "speaker": null,
      "text": "Просто я ничего не смогу помочь, если это не моё коммерческое предложение."
    },
    {
      "start": 108.71,
      "end": 111.37,
      "speaker": null,
      "text": "Вам надеются нужными со своим менеджером общаться."
    },
    {
      "start": 112.05,
      "end": 117.93,
      "speaker": null,
      "text": "Давайте я могу уточнить со своих коллег вот этот номер коммерческого предложения."
    },
    {
      "start": 118.11,
      "end": 121.13,
      "speaker": null,
      "text": "Запросить тогда, да, и тогда вам перезвонят."
    },
    {
      "start": 121.21,
      "end": 124.01,
      "speaker": null,
      "text": "Насколько срочный запрос, чтобы я тоже предупредила?"
    },
    {
      "start": 124.25,
      "end": 125.49,
      "speaker": null,
      "text": "У нас очень сильно срочно."
    },
    {
      "start": 125.69,
      "end": 126.69,
      "speaker": null,
      "text": "Всё, хорошо."
    },
    {
      "start": 126.99,
      "end": 128.13,
      "speaker": null,
      "text": "Сейчас тогда поищем."
    },
    {
      "start": 128.82,
      "end": 129.68,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 129.68,
      "end": 130.54,
      "speaker": null,
      "text": "Да, пожалуйста."
    },
    {
      "start": 131.02,
      "end": 131.66,
      "speaker": null,
      "text": "На связи."
    },
    {
      "start": 131.96,
      "end": 132.18,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 132.68,
      "end": 133.5,
      "speaker": null,
      "text": "Да, до свидания."
    }
  ]
