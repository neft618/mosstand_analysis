    {
      "start": 31.81,
      "end": 35.17,
      "speaker": null,
      "text": "Роллап нам необходим к 17 апреля."
    },
    {
      "start": 35.88,
      "end": 40.02,
      "speaker": null,
      "text": "К 17 апреля. А макеты у вас уже готовы или вы их подготавливаете?"
    },
    {
      "start": 40.56,
      "end": 45.34,
      "speaker": null,
      "text": "Макет готов, вот сегодня он будет. Уже могли бы отправить вам."
    },
    {
      "start": 45.62,
      "end": 47.82,
      "speaker": null,
      "text": "А в каком размере роллап вам необходим?"
