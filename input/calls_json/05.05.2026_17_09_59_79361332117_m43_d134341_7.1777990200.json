    {
      "start": 0.72,
      "end": 2.28,
      "speaker": null,
      "text": "Да, Мария."
    },
    {
      "start": 3.62,
      "end": 9.76,
      "speaker": null,
      "text": "Да, по поводу тиража. Вы имеете в виду по количеству запрашиваемых позиций?"
    },
    {
      "start": 10.08,
      "end": 10.8,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 11.94,
      "end": 28.31,
      "speaker": null,
      "text": "Ну вот, пока нет точных цифр, но это будет необходимо, конечно, да, в нескольких позициях. Но это частями будет выбираться. Это планируется, чтобы вы понимали годовой договор."
    },
    {
      "start": 31.93,
      "end": 32.93,
      "speaker": null,
      "text": "Слышно меня?"
    },
    {
      "start": 33.45,
      "end": 34.61,
      "speaker": null,
      "text": "Да, слышу вас."
    },
    {
      "start": 35.13,
      "end": 43.75,
      "speaker": null,
      "text": "Это планируется заключение годового договора и в течение этого времени по заявкам можно выбирать."
    },
    {
      "start": 44.71,
      "end": 45.47,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 46.59,
      "end": 48.67,
      "speaker": null,
      "text": "То есть это не одним марком?"
    },
    {
      "start": 49.03,
      "end": 49.87,
      "speaker": null,
      "text": "Да, я понял."
    },
    {
      "start": 51.36,
      "end": 53.08,
      "speaker": null,
      "text": "Нет, вам не интересно."
    },
    {
      "start": 53.52,
      "end": 53.68,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 55.63,
      "end": 57.49,
      "speaker": null,
      "text": "Вот, всё, спасибо тогда."
    },
    {
      "start": 57.91,
      "end": 58.73,
      "speaker": null,
      "text": "Всё, спасибо."
    },
    {
      "start": 59.79,
      "end": 60.93,
