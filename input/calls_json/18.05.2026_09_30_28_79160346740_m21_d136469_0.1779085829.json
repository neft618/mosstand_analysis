    {
      "start": 176.62,
      "end": 178.44,
      "speaker": null,
      "text": "Нет, это мой рабочий номер."
    },
    {
      "start": 178.5,
      "end": 180.04,
      "speaker": null,
      "text": "Давайте лично продиктую его туда мне."
