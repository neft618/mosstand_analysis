  "segments": [
    {
      "start": 1.64,
      "end": 3.14,
      "speaker": null,
      "text": "Что не так опять?"
    },
    {
      "start": 4.63,
      "end": 17.39,
      "speaker": null,
      "text": "Здравствуйте, Игорь. Нет, всё в порядке. Я просто звоню уточнить на момент. Подписали только один документ из двух. Второе юрлицо не подписали."
    },
    {
      "start": 19.33,
      "end": 24.45,
      "speaker": null,
      "text": "Не понял это что значит. Мы вам две УКД направили."
    },
    {
      "start": 26.53,
      "end": 28.75,
      "speaker": null,
      "text": "Вы документы по ЭТО направили, правильно?"
    },
    {
      "start": 29.17,
      "end": 30.11,
      "speaker": null,
      "text": "Да, всё верно."
    },
    {
      "start": 30.11,
      "end": 31.13,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 33.17,
      "end": 33.91,
      "speaker": null,
      "text": "Подписали?"
    },
    {
      "start": 34.23,
      "end": 35.91,
      "speaker": null,
      "text": "Да, подписали."
    },
    {
      "start": 36.41,
      "end": 40.01,
      "speaker": null,
      "text": "Который присылал с Альтеками."
    },
    {
      "start": 41.81,
      "end": 44.73,
      "speaker": null,
      "text": "И на 200 с чем-то там."
    },
    {
      "start": 45.21,
      "end": 48.51,
      "speaker": null,
      "text": "Да, 225 он по-моему, если я не ошибаюсь."
    },
    {
      "start": 50.37,
      "end": 53.65,
      "speaker": null,
      "text": "Второй на 40 тысяч рублей, да, не подписан еще."
    },
    {
      "start": 54.44,
      "end": 58.06,
      "speaker": null,
      "text": "Ну, подпишут она. Наверное уехал там Андрей Алексеевич?"
    },
    {
      "start": 59.98,
      "end": 65.4,
      "speaker": null,
      "text": "Хорошо, хорошо. Я вас понял. Я просто звоню уточнить мало ли может случайно."
    },
    {
      "start": 65.4,
      "end": 67.42,
      "speaker": null,
      "text": "Нет, я ей передал подписку."
    },
    {
      "start": 68.32,
      "end": 69.66,
      "speaker": null,
      "text": "Всё, спасибо вам большое."
    },
    {
      "start": 70.14,
      "end": 70.94,
      "speaker": null,
      "text": "Всё, ага."
    },
    {
      "start": 71.64,
      "end": 72.18,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 72.18,
