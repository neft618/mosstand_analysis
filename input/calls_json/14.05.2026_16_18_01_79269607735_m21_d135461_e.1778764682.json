{
  "file": "14.05.2026_16_18_01_79269607735_m21_d135461_e.1778764682.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 84.7,
  "segments": [
    {
      "start": 0.72,
      "end": 3.32,
      "speaker": null,
      "text": "Компания Макцентр, как мы к Вам обращаться?"
    },
    {
      "start": 5.21,
      "end": 12.71,
      "speaker": null,
      "text": "Добрый день, я перевёл оплату. Скажите, когда будет готов и баннер, и поставка к ним?"
    },
    {
      "start": 14.82,
      "end": 16.5,
      "speaker": null,
      "text": "По какому заказу Вы, скорее всего?"
    },
    {
      "start": 18.19,
      "end": 20.33,
      "speaker": null,
      "text": "Я буквально сегодня по-английски приезжал."
    },
    {
      "start": 21.6,
      "end": 23.08,
      "speaker": null,
      "text": "А с кем вы общались, кто у Вас менеджер?"
    },
    {
      "start": 24.56,
      "end": 25.5,
      "speaker": null,
      "text": "Что, простите?"
    },
    {
      "start": 25.68,
      "end": 29.86,
      "speaker": null,
      "text": "Кто у Вас менеджер, простите? Просто не показано, с кем Вы ранее общались."
    },
    {
      "start": 31.98,
      "end": 35.11,
      "speaker": null,
      "text": "Кто у Вас менеджер, чтобы понять, передать дальше вопросы?"
    },
    {
      "start": 35.11,
      "end": 36.15,
      "speaker": null,
      "text": "Ну, Елена, наверное."
    },
    {
      "start": 36.69,
      "end": 40.07,
      "speaker": null,
      "text": "А, всё, я понял. Давайте передам ей информацию. Просто не только как Вы зовут?"
    },
    {
      "start": 41.81,
      "end": 47.07,
      "speaker": null,
      "text": "Ну, Григорий, я просто произвёл оплату, а я не могу понять обратную связь. Пришла она, не пришла."
    },
    {
      "start": 47.11,
      "end": 48.61,
      "speaker": null,
      "text": "Хорошо, всё, давайте передам информацию."
    },
    {
      "start": 48.97,
      "end": 52.51,
      "speaker": null,
      "text": "У меня-то всё списалось, а Вам-то пришло."
    },
    {
      "start": 53.01,
      "end": 55.49,
      "speaker": null,
      "text": "Хорошо, Вы на физике оплачили, да, я так понял, по ссылке?"
    },
    {
      "start": 56.88,
      "end": 58.02,
      "speaker": null,
      "text": "Да, и по ссылке оплачиваю."
    },
    {
      "start": 58.16,
      "end": 61.7,
      "speaker": null,
      "text": "Значит, скорее всего, оплата сразу пошла. Я передам вопросы. Хорошо."
    },
    {
      "start": 62.32,
      "end": 62.72,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 63.94,
      "end": 67.76,
      "speaker": null,
      "text": "Ну, можно мне какую-то обратную связь, что деньги получили и куда можно..."
    },
    {
      "start": 67.76,
      "end": 70.6,
      "speaker": null,
      "text": "Просто если это не мой заказ, Григорий, я передам..."
    },
    {
      "start": 70.6,
      "end": 73.16,
      "speaker": null,
      "text": "Просто если это был бы мой заказ..."
    },
    {
      "start": 73.16,
      "end": 73.86,
      "speaker": null,
      "text": "Понял, я..."
    },
    {
      "start": 73.86,
      "end": 74.48,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 74.86,
      "end": 75.8,
      "speaker": null,
      "text": "Я просто не могу знать."
    },
    {
      "start": 75.8,
      "end": 76.64,
      "speaker": null,
      "text": "Я Вас понял."
    },
    {
      "start": 77.02,
      "end": 77.1,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 77.3,
      "end": 79.82,
      "speaker": null,
      "text": "Ну, давайте попросту Вам ответили тогда."
    },
    {
      "start": 80.73,
      "end": 81.89,
      "speaker": null,
      "text": "Ну, если можно."
    },
    {
      "start": 82.41,
      "end": 82.79,
      "speaker": null,
      "text": "Да, конечно."
    },
    {
      "start": 82.89,
      "end": 83.31,
      "speaker": null,
      "text": "Спасибо большое."
    },
    {
      "start": 83.53,
      "end": 83.61,
      "speaker": null,
      "text": "Пожалуйста."
    }
  ]
}