    {
      "start": 183.99,
      "end": 185.19,
      "speaker": null,
      "text": "А, ну всё понял."
    },
    {
      "start": 186.09,
      "end": 187.79,
      "speaker": null,
      "text": "Нам вот стенды не умеют делать."
