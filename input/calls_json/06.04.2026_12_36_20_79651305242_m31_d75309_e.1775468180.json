  "segments": [
    {
      "start": 0.05,
      "end": 1.53,
      "speaker": null,
      "text": "Танна, здравствуйте, да."
    },
    {
      "start": 2.58,
      "end": 11.74,
      "speaker": null,
      "text": "Валерия, добрый день! Получила ваше сообщение. Смотрите, у нас немного изменялся логотип и сами буквы чуть-чуть."
    },
    {
      "start": 11.84,
      "end": 16.76,
      "speaker": null,
      "text": "Мы как раз таки занимались маркетологи, которые изначально с вами взаимодействовали."
    },
    {
      "start": 18.12,
      "end": 23.66,
      "speaker": null,
      "text": "Поэтому, насколько я понимаю, теперь, исходя из макета, эти буквы будут чуть уже, да?"
    },
    {
      "start": 24.0,
      "end": 26.36,
      "speaker": null,
      "text": "Уже, да, и они будут более круглые."
    },
    {
      "start": 26.36,
      "end": 31.94,
      "speaker": null,
      "text": "У вас, если те, которые сейчас стоят, они более такие вычинутые вверх."
    },
    {
      "start": 32.04,
      "end": 35.26,
      "speaker": null,
      "text": "Те, которые сейчас в логотипе, они более округлые."
    },
    {
      "start": 35.6,
      "end": 37.68,
      "speaker": null,
      "text": "Ну и, естественно, ширина там отличается."
    },
    {
      "start": 37.84,
      "end": 39.96,
      "speaker": null,
      "text": "Например, букву L, которую мы сравниваем."
    },
    {
      "start": 40.28,
      "end": 43.92,
      "speaker": null,
      "text": "Мы пытались, например, букву L по ширине делать больше,"
    },
    {
      "start": 44.48,
      "end": 47.36,
      "speaker": null,
      "text": "она очень сильно выделяется на фоне всего логотипа."
    },
    {
      "start": 47.74,
      "end": 53.68,
      "speaker": null,
      "text": "То есть тогда у нас буква I тоже, то есть если мы сравним буквы I и L,"
    },
    {
      "start": 53.68,
      "end": 55.32,
      "speaker": null,
      "text": "они будут очень разные тогда."
    },
    {
      "start": 55.86,
      "end": 56.96,
      "speaker": null,
      "text": "То есть это я смела."
    },
    {
      "start": 58.12,
      "end": 60.62,
      "speaker": null,
      "text": "Ну, давайте тогда оставляем по тем параметрам."
    },
    {
      "start": 60.64,
      "end": 61.52,
      "speaker": null,
      "text": "Как логотип, да?"
    },
    {
      "start": 61.52,
      "end": 62.56,
      "speaker": null,
      "text": "Которые, да."
    },
    {
      "start": 62.78,
      "end": 65.1,
      "speaker": null,
      "text": "Как вот вам скинула Виктория тогда, да?"
    },
    {
      "start": 65.3,
      "end": 65.78,
      "speaker": null,
      "text": "Вот этот логотип."
    },
    {
      "start": 79.36,
      "end": 80.0,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 80.0,
      "end": 80.3,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 80.44,
      "end": 82.04,
      "speaker": null,
      "text": "Они будут сверху скругленные."
    },
    {
      "start": 82.14,
      "end": 88.04,
      "speaker": null,
      "text": "Поэтому вот я как раз таки общалась сейчас с подачеком по этому поводу."
    },
    {
      "start": 88.3,
      "end": 88.78,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 89.02,
      "end": 91.9,
      "speaker": null,
      "text": "Тогда сейчас я вас услышала."
    },
    {
      "start": 92.04,
      "end": 92.48,
      "speaker": null,
      "text": "Супер."
    },
    {
      "start": 92.66,
      "end": 93.58,
      "speaker": null,
      "text": "Все замечательно."
    },
    {
      "start": 94.22,
      "end": 95.9,
      "speaker": null,
      "text": "И тогда начинаем работу."
    },
    {
      "start": 97.28,
      "end": 97.74,
      "speaker": null,
      "text": "Все хорошо."
    },
    {
      "start": 97.86,
      "end": 98.1,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 98.3,
      "end": 98.8,
      "speaker": null,
      "text": "Какие сроки?"
    },
    {
      "start": 98.82,
      "end": 99.24,
      "speaker": null,
      "text": "Две недели?"
    },
    {
      "start": 99.6,
