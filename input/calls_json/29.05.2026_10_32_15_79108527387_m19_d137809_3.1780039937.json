{
  "file": "29.05.2026_10_32_15_79108527387_m19_d137809_3.1780039937.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 188.0,
  "segments": [
    {
      "start": 1.81,
      "end": 2.81,
      "speaker": null,
      "text": "Алло, да, Марина."
    },
    {
      "start": 3.7,
      "end": 6.0,
      "speaker": null,
      "text": "Алло, да, Влад, здравствуйте. Это ваш номер?"
    },
    {
      "start": 6.16,
      "end": 8.58,
      "speaker": null,
      "text": "Да-да-да, всё верно."
    },
    {
      "start": 8.84,
      "end": 13.14,
      "speaker": null,
      "text": "А то я вам пишу опять в Максе, чтобы вы мне перезвонили."
    },
    {
      "start": 13.64,
      "end": 21.36,
      "speaker": null,
      "text": "Смотрите, нам вот сейчас от вас нужен договор, чтобы вы нам прислали, какой мы с вами будем заключать."
    },
    {
      "start": 21.6,
      "end": 24.82,
      "speaker": null,
      "text": "Потом три коммерческих предложения, три фирмы."
    },
    {
      "start": 26.26,
      "end": 30.92,
      "speaker": null,
      "text": "Ещё скажите срок изготовления и нам нужна ещё окончательная стоимость."
    },
    {
      "start": 32.83,
      "end": 38.57,
      "speaker": null,
      "text": "Так, окончательную стоимость нужно будет рассчитать, когда я рассчитаю для вас доставку?"
    },
    {
      "start": 39.11,
      "end": 40.91,
      "speaker": null,
      "text": "Да-да, доставку."
    },
    {
      "start": 41.11,
      "end": 42.01,
      "speaker": null,
      "text": "У меня нужен будет..."
    },
    {
      "start": 42.01,
      "end": 43.55,
      "speaker": null,
      "text": "Ну у вас же адрес, правильно?"
    },
    {
      "start": 44.03,
      "end": 44.43,
      "speaker": null,
      "text": "Не просто?"
    },
    {
      "start": 44.57,
      "end": 44.97,
      "speaker": null,
      "text": "Да-да."
    },
    {
      "start": 45.95,
      "end": 47.53,
      "speaker": null,
      "text": "Поэтому нужен будет точный адрес."
    },
    {
      "start": 47.67,
      "end": 52.86,
      "speaker": null,
      "text": "И смотрите, мы сможем сделать для вас счёт договор."
    },
    {
      "start": 53.02,
      "end": 54.02,
      "speaker": null,
      "text": "Счёт договор подойдёт?"
    },
    {
      "start": 54.86,
      "end": 57.74,
      "speaker": null,
      "text": "Мы просто договор подключаем от 100 тысяч рублей."
    },
    {
      "start": 59.31,
      "end": 61.87,
      "speaker": null,
      "text": "В счёте договоре тоже все условия будут прописаны."
    },
    {
      "start": 61.87,
      "end": 66.93,
      "speaker": null,
      "text": "Ну вы нам присылаете чёт договор, а я бухгалтеру нашему отошлю, она посмотрит."
    },
    {
      "start": 66.97,
      "end": 68.71,
      "speaker": null,
      "text": "Она сказала, вы дома работаем."
    },
    {
      "start": 69.51,
      "end": 70.27,
      "speaker": null,
      "text": "Всё отлично."
    },
    {
      "start": 70.27,
      "end": 70.57,
      "speaker": null,
      "text": "Всё отлично."
    },
    {
      "start": 71.31,
      "end": 75.69,
      "speaker": null,
      "text": "Вот, вы нам присылаете и мы так дальше тоже будем как-то написать."
    },
    {
      "start": 75.81,
      "end": 75.97,
      "speaker": null,
      "text": "Хорошо?"
    },
    {
      "start": 76.79,
      "end": 81.67,
      "speaker": null,
      "text": "Да, и от вас тогда понадобятся реквизиты и адрес точный."
    },
    {
      "start": 81.67,
      "end": 85.77,
      "speaker": null,
      "text": "Так, реквизиты нашей организации?"
    },
    {
      "start": 85.99,
      "end": 87.03,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 87.17,
      "end": 89.59,
      "speaker": null,
      "text": "Куда коммерческие предложения направлять нужно будет?"
    },
    {
      "start": 91.78,
      "end": 93.5,
      "speaker": null,
      "text": "Пока давайте на электронку."
    },
    {
      "start": 93.56,
      "end": 97.53,
      "speaker": null,
      "text": "Я вам электронку нашу сброшу вы прислёте."
    },
    {
      "start": 97.65,
      "end": 101.13,
      "speaker": null,
      "text": "То есть, вы пришлёте нам три фирмы, мы делаем вам запрос, правильно?"
    },
    {
      "start": 102.28,
      "end": 102.56,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 102.72,
      "end": 103.02,
      "speaker": null,
      "text": "Правильно?"
    },
    {
      "start": 103.18,
      "end": 103.56,
      "speaker": null,
      "text": "Понимаю."
    },
    {
      "start": 103.62,
      "end": 105.06,
      "speaker": null,
      "text": "И вы нам потом отвечаете."
    },
    {
      "start": 105.48,
      "end": 105.7,
      "speaker": null,
      "text": "Да?"
    },
    {
      "start": 105.82,
      "end": 108.8,
      "speaker": null,
      "text": "Вы же тоже на электронку нам пришли, чтобы это побыстрее было."
    },
    {
      "start": 108.8,
      "end": 110.84,
      "speaker": null,
      "text": "Не почты же, а не быть такие."
    },
    {
      "start": 112.53,
      "end": 112.71,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 113.09,
      "end": 115.15,
      "speaker": null,
      "text": "Вам просто адрес электронной почты нужен?"
    },
    {
      "start": 115.27,
      "end": 115.79,
      "speaker": null,
      "text": "Правильно я понял?"
    },
    {
      "start": 117.25,
      "end": 117.89,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 118.05,
      "end": 124.13,
      "speaker": null,
      "text": "Мы напишем вам и электронную почту адрес и на фамилии ночь руководитель,"
    },
    {
      "start": 124.21,
      "end": 125.55,
      "speaker": null,
      "text": "как фирма называется."
    },
    {
      "start": 126.47,
      "end": 127.97,
      "speaker": null,
      "text": "Пропишем всё как положено."
    },
    {
      "start": 128.27,
      "end": 128.91,
      "speaker": null,
      "text": "Отправляйте."
    },
    {
      "start": 129.09,
      "end": 133.11,
      "speaker": null,
      "text": "Я понимаю, что мы сделаем вам три запроса, руководитель"
    },
    {
      "start": 133.11,
      "end": 135.61,
      "speaker": null,
      "text": "подпишите, я вам на электронную почту их пришлю."
    },
    {
      "start": 135.79,
      "end": 136.77,
      "speaker": null,
      "text": "На вашу фирму."
    },
    {
      "start": 137.11,
      "end": 137.33,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 137.33,
      "end": 138.41,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 138.63,
      "end": 138.87,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 139.09,
      "end": 142.37,
      "speaker": null,
      "text": "Но только на адрес, на мой нужно будет адрес электронной"
    },
    {
      "start": 142.37,
      "end": 142.65,
      "speaker": null,
      "text": "почты."
    },
    {
      "start": 143.79,
      "end": 146.39,
      "speaker": null,
      "text": "Ну как скажете, на ваш, на какой там."
    },
    {
      "start": 146.63,
      "end": 146.95,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 147.37,
      "end": 147.75,
      "speaker": null,
      "text": "Сейчас направо."
    },
    {
      "start": 148.79,
      "end": 149.39,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 150.03,
      "end": 150.17,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 150.29,
      "end": 155.15,
      "speaker": null,
      "text": "От меня сейчас я вам также скидываю адрес наш почту,"
    },
    {
      "start": 155.25,
      "end": 155.53,
      "speaker": null,
      "text": "правильно?"
    },
    {
      "start": 156.53,
      "end": 157.03,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 157.25,
      "end": 159.05,
      "speaker": null,
      "text": "Реквизиты организации."
    },
    {
      "start": 161.27,
      "end": 161.91,
      "speaker": null,
      "text": "Реквизиты."
    },
    {
      "start": 163.07,
      "end": 163.37,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 164.74,
      "end": 166.18,
      "speaker": null,
      "text": "Скину реквизиты."
    },
    {
      "start": 167.3,
      "end": 168.26,
      "speaker": null,
      "text": "И всё, да?"
    },
    {
      "start": 169.17,
      "end": 171.33,
      "speaker": null,
      "text": "А и адрес точные доставки."
    },
    {
      "start": 171.43,
      "end": 174.31,
      "speaker": null,
      "text": "А мы будем с ДЭКом, да?"
    },
    {
      "start": 174.45,
      "end": 175.07,
      "speaker": null,
      "text": "Вы будете с ДЭК?"
    },
    {
      "start": 175.62,
      "end": 176.12,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 177.08,
      "end": 177.54,
      "speaker": null,
      "text": "ДЭК."
    },
    {
      "start": 177.7,
      "end": 179.98,
      "speaker": null,
      "text": "Всё, сейчас мы тогда посмотрим, где нам будет удобнее"
    },
    {
      "start": 180.35,
      "end": 180.6,
      "speaker": null,
      "text": "забирать."
    },
    {
      "start": 180.82,
      "end": 183.14,
      "speaker": null,
      "text": "Тогда я вам максимум пишу пришлю."
    },
    {
      "start": 183.14,
      "end": 184.42,
      "speaker": null,
      "text": "Да, хорошо."
    },
    {
      "start": 184.92,
      "end": 185.4,
      "speaker": null,
      "text": "Всё."
    },
    {
      "start": 185.66,
      "end": 186.26,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 186.78,
      "end": 187.22,
      "speaker": null,
      "text": "До свидания."
    },
    {
      "start": 187.22,
      "end": 187.5,
      "speaker": null,
      "text": "Кардес."
    },
    {
      "start": 187.5,
      "end": 187.76,
      "speaker": null,
      "text": "Оставь её из..."
    }
  ]
