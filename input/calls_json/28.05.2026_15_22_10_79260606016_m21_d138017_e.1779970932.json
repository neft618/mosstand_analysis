    {
      "start": 188.3,
      "end": 189.58,
      "speaker": null,
      "text": "Но тут тоже с монтажом."
    },
    {
      "start": 189.84,
      "end": 194.88,
      "speaker": null,
      "text": "Просто если вот поставить угловой, вот эти носки, я не знаю вам как, подходят?"
    },
    {
      "start": 194.88,
      "end": 196.6,
      "speaker": null,
      "text": "Ну вот вопрос тоже."
