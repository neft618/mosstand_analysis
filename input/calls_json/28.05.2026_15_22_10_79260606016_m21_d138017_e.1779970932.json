    {
      "start": 73.06,
      "end": 75.52,
      "speaker": null,
      "text": "Нет, максимум, что менять сам баннер."
    },
    {
      "start": 76.25,
      "end": 78.11,
      "speaker": null,
      "text": "Так, менять сам баннер."
