{
  "file": "06.04.2026_15_16_59_79623621997_m19_d131049_3.1775477820.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 321.0,
  "segments": [
    {
      "start": 0.0,
      "end": 0.98,
      "speaker": null,
      "text": "Переодеться хочу."
    },
    {
      "start": 2.62,
      "end": 4.3,
      "speaker": null,
      "text": "О, да, возьму фотографию."
    },
    {
      "start": 5.38,
      "end": 6.3,
      "speaker": null,
      "text": "Конечно, конечно."
    },
    {
      "start": 7.04,
      "end": 12.62,
      "speaker": null,
      "text": "Да, смотрите, КПР собирал четыре и все четыре отказали."
    },
    {
      "start": 13.51,
      "end": 14.57,
      "speaker": null,
      "text": "Все четыре отказали?"
    },
    {
      "start": 15.55,
      "end": 21.39,
      "speaker": null,
      "text": "Ну, премиума цена ваша была, там ещё один был, который ближе вам, но, опять же, чуть дороже был."
    },
    {
      "start": 21.59,
      "end": 23.99,
      "speaker": null,
      "text": "Всё так говорят, что за четыре с кем-то нашли."
    },
    {
      "start": 24.57,
      "end": 27.82,
      "speaker": null,
      "text": "За сколько нашли?"
    },
    {
      "start": 27.82,
      "end": 28.96,
      "speaker": null,
      "text": "За пятьсот."
    },
    {
      "start": 30.14,
      "end": 30.78,
      "speaker": null,
      "text": "Пятьсот?"
    },
    {
      "start": 31.22,
      "end": 31.58,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 32.58,
      "end": 33.22,
      "speaker": null,
      "text": "Это..."
    },
    {
      "start": 33.22,
      "end": 35.28,
      "speaker": null,
      "text": "Объём, как бы, за пятьсот тысяч."
    },
    {
      "start": 36.09,
      "end": 37.39,
      "speaker": null,
      "text": "Весь брус с монтажом?"
    },
    {
      "start": 37.71,
      "end": 38.03,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 38.61,
      "end": 39.53,
      "speaker": null,
      "text": "Я даже не знаю."
    },
    {
      "start": 40.3,
      "end": 43.38,
      "speaker": null,
      "text": "Я не увидел, я зашёл просто в область никому."
    },
    {
      "start": 44.4,
      "end": 47.16,
      "speaker": null,
      "text": "Просто получу доступ, тогда могу поделиться."
    },
    {
      "start": 49.6,
      "end": 53.36,
      "speaker": null,
      "text": "Просто, вы знаете, мне бы там без шапки хотя бы просто посмотреть позиции сами,"
    },
    {
      "start": 53.44,
      "end": 57.92,
      "speaker": null,
      "text": "они точно те же самые, которые мы считали, что это слишком большая разница?"
    },
    {
      "start": 57.92,
      "end": 58.16,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 58.68,
      "end": 63.5,
      "speaker": null,
      "text": "Я вот скидывал КПР собрать, как бы, четыре-пять КПР собрать, чтобы понять, и я ценю вот это всё дело."
    },
    {
      "start": 64.22,
      "end": 66.58,
      "speaker": null,
      "text": "Так же, видимо, она сама тоже искала."
    },
    {
      "start": 68.33,
      "end": 71.79,
      "speaker": null,
      "text": "И если посмотреть, что было дороже, там нашли дешевле."
    },
    {
      "start": 72.31,
      "end": 74.11,
      "speaker": null,
      "text": "Но она этим часто занимается."
    },
    {
      "start": 74.11,
      "end": 76.02,
      "speaker": null,
      "text": "Ну, это понятно."
    },
    {
      "start": 76.26,
      "end": 79.56,
      "speaker": null,
      "text": "Просто стоимость такая загрузка, конечно, интересная."
    },
    {
      "start": 80.48,
      "end": 80.56,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 80.56,
      "end": 81.38,
      "speaker": null,
      "text": "Ну, да."
    },
    {
      "start": 81.54,
      "end": 85.6,
      "speaker": null,
      "text": "Тут, как бы, два сента меня считали, а тут, как бы, миллион уже, типа, как бы, да."
    },
    {
      "start": 85.84,
      "end": 87.98,
      "speaker": null,
      "text": "А тут, оказывается, нет и ещё чего-то такое."
    },
    {
      "start": 88.46,
      "end": 90.56,
      "speaker": null,
      "text": "Даже не знаю, что там, как говорится."
    },
    {
      "start": 91.32,
      "end": 94.98,
      "speaker": null,
      "text": "Ну, вот я тоже, как бы, думаю, что может какую-то позицию убрали."
    },
    {
      "start": 95.34,
      "end": 97.68,
      "speaker": null,
      "text": "Соответственно, если увижу этот КП, я вам пришлю."
    },
    {
      "start": 97.68,
      "end": 103.86,
      "speaker": null,
      "text": "Да, просто если взять что-то с позиции, там, да, пересмотрели, так далее, я бы пересмотрел."
    },
    {
      "start": 103.98,
      "end": 105.12,
      "speaker": null,
      "text": "Может быть, там совсем другие."
    },
    {
      "start": 106.26,
      "end": 110.88,
      "speaker": null,
      "text": "Ну, я сразу сказал о том, что, как бы, может, там что-то поменялось."
    },
    {
      "start": 111.64,
      "end": 113.22,
      "speaker": null,
      "text": "Сейчас не до этого мне сказали опять."
    },
    {
      "start": 113.64,
      "end": 114.7,
      "speaker": null,
      "text": "Чуть позже давай обсудим."
    },
    {
      "start": 115.34,
      "end": 115.66,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 115.86,
      "end": 119.68,
      "speaker": null,
      "text": "Потому что я уверен, что, как бы, ну, не можем так, как бы, цена..."
    },
    {
      "start": 120.3,
      "end": 126.76,
      "speaker": null,
      "text": "Потому что, знаете, если смотреть на то КП, которое, помните, там два с половиной вы направляли."
    },
    {
      "start": 126.76,
      "end": 126.98,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 127.16,
      "end": 132.66,
      "speaker": null,
      "text": "Там вообще прописано в ТЗ, что они, якобы, собирают их сначала себе на производстве,"
    },
    {
      "start": 132.84,
      "end": 134.42,
      "speaker": null,
      "text": "а потом ещё у вас."
    },
    {
      "start": 134.64,
      "end": 139.52,
      "speaker": null,
      "text": "И учитывая то, что Брусон разовой сборки является и они собирают его два раза,"
    },
    {
      "start": 139.6,
      "end": 140.76,
      "speaker": null,
      "text": "это тоже вспоминительная история."
    },
    {
      "start": 141.18,
      "end": 143.6,
      "speaker": null,
      "text": "Вот мне интересно, вот те, которые предоставили вам КП,"
    },
    {
      "start": 144.32,
      "end": 146.06,
      "speaker": null,
      "text": "последнее на вот 500 вы говорите,"
    },
    {
      "start": 147.46,
      "end": 154.06,
      "speaker": null,
      "text": "какова у них принцип сборки там или вообще, может быть, там что-то тоже совсем другое считаем?"
    },
    {
      "start": 154.54,
      "end": 156.48,
      "speaker": null,
      "text": "Ну, даже если, думаю, как бы..."
    },
    {
      "start": 156.48,
      "end": 161.04,
      "speaker": null,
      "text": "Ну, нет, там была одна компания, которая сказала, типа можно сделать на раму."
    },
    {
      "start": 161.24,
      "end": 163.42,
      "speaker": null,
      "text": "Но на сути, как бы нам сказали, что нет."
    },
    {
      "start": 164.16,
      "end": 166.8,
      "speaker": null,
      "text": "Уходитель сказал, что, как бы, рамка должна быть глубиной."
    },
    {
      "start": 167.6,
      "end": 168.06,
      "speaker": null,
      "text": "То есть вот..."
    },
    {
      "start": 168.06,
      "end": 170.34,
      "speaker": null,
      "text": "Ну, мы вам объёмно просто считали на КП."
    },
    {
      "start": 170.5,
      "end": 174.86,
      "speaker": null,
      "text": "Если не объёмно, соответственно, может там что-то будет, но при этом не знаю, вот честно."
    },
    {
      "start": 175.2,
      "end": 177.98,
      "speaker": null,
      "text": "Этот КП, как бы, мне присылали."
    },
    {
      "start": 178.1,
      "end": 180.86,
      "speaker": null,
      "text": "У меня, как бы, самые низкие цены, это, естественно, у вас было."
    },
    {
      "start": 181.36,
      "end": 186.06,
      "speaker": null,
      "text": "Поэтому сказал, что, как бы, люди, соответственно, как бы, коммуникабельники обсуждают,"
    },
    {
      "start": 187.9,
      "end": 188.3,
      "speaker": null,
      "text": "беспокоятся."
    },
    {
      "start": 191.09,
      "end": 194.35,
      "speaker": null,
      "text": "А, да."
    },
    {
      "start": 196.39,
      "end": 197.45,
      "speaker": null,
      "text": "Ну да, да."
    },
    {
      "start": 197.75,
      "end": 202.97,
      "speaker": null,
      "text": "Сроки сдвинули немножко, поэтому они немножко опустили сроки."
    },
    {
      "start": 203.03,
      "end": 206.87,
      "speaker": null,
      "text": "Типа мероприятия будет не 26 до 25-го там."
    },
    {
      "start": 206.87,
      "end": 208.99,
      "speaker": null,
      "text": "Ну, наоборот."
    },
    {
      "start": 209.33,
      "end": 209.73,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 210.31,
      "end": 214.33,
      "speaker": null,
      "text": "Но там даже разницы особо не будет от этого."
    },
    {
      "start": 214.45,
      "end": 217.11,
      "speaker": null,
      "text": "Мне кажется, там всё-таки что-то в позициях, ну просто полмиллиона."
    },
    {
      "start": 217.96,
      "end": 218.78,
      "speaker": null,
      "text": "Это тоже..."
    },
    {
      "start": 218.78,
      "end": 222.78,
      "speaker": null,
      "text": "Ну да, поэтому, как бы, как только получили, я ещё напишу вам."
    },
    {
      "start": 223.04,
      "end": 227.36,
      "speaker": null,
      "text": "А по поводу вот этих стойк, промостойк, один тут точно мне нужен,"
    },
    {
      "start": 227.5,
      "end": 230.44,
      "speaker": null,
      "text": "мне просто как бы другой человек оброчёлся по поводу этого."
    },
    {
      "start": 230.64,
      "end": 233.96,
      "speaker": null,
      "text": "Ну, когда такое проводили, и, соответственно, говорю, такие промостойки,"
    },
    {
      "start": 233.96,
      "end": 236.28,
      "speaker": null,
      "text": "и коллега увидел, говорит, о, вот это мне нужно."
    },
    {
      "start": 237.14,
      "end": 238.06,
      "speaker": null,
      "text": "Один с штукой вы говорите?"
    },
    {
      "start": 238.4,
      "end": 239.06,
      "speaker": null,
      "text": "Один, один."
    },
    {
      "start": 239.62,
      "end": 240.16,
      "speaker": null,
      "text": "А, одна."
    },
    {
      "start": 240.3,
      "end": 243.52,
      "speaker": null,
      "text": "Лично коллеги там для чего-то, для кого-то своего проекта."
    },
    {
      "start": 244.18,
      "end": 245.58,
      "speaker": null,
      "text": "Я понял, я понял, хорошо."
    },
    {
      "start": 245.74,
      "end": 247.14,
      "speaker": null,
      "text": "А стойка вам будет нужна или без?"
    },
    {
      "start": 249.36,
      "end": 250.02,
      "speaker": null,
      "text": "С стойкой."
    },
    {
      "start": 250.28,
      "end": 251.08,
      "speaker": null,
      "text": "Будет с ушами."
    },
    {
      "start": 252.1,
      "end": 254.28,
      "speaker": null,
      "text": "Ну, я имею в виду вот с этой табличкой?"
    },
    {
      "start": 254.4,
      "end": 256.36,
      "speaker": null,
      "text": "Да, да, с этой табличкой, да."
    },
    {
      "start": 257.44,
      "end": 262.34,
      "speaker": null,
      "text": "Ну, когда мы ещё после вот этого всего обучались,"
    },
    {
      "start": 262.34,
      "end": 265.96,
      "speaker": null,
      "text": "я типа, как бы, начеком сказал, вот, а у кого взял контакт с передашей?"
    },
    {
      "start": 266.08,
      "end": 266.48,
      "speaker": null,
      "text": "Я говорю, хорошо."
    },
    {
      "start": 267.38,
      "end": 271.68,
      "speaker": null,
      "text": "Я типа, как бы, что-то отвлеклись и, соответственно, как бы, я им не передал."
    },
    {
      "start": 271.76,
      "end": 272.2,
      "speaker": null,
      "text": "Ну, я передам."
    },
    {
      "start": 272.34,
      "end": 275.7,
      "speaker": null,
      "text": "Либо как сам выйду на связь, либо..."
    },
    {
      "start": 275.7,
      "end": 277.74,
      "speaker": null,
      "text": "Там, кстати, ещё одна есть."
    },
    {
      "start": 277.86,
      "end": 278.94,
      "speaker": null,
      "text": "Там, по-моему, у них разница."
    },
    {
      "start": 278.94,
      "end": 281.5,
      "speaker": null,
      "text": "Я вам М7 предлагал, а есть ещё М8."
    },
    {
      "start": 281.92,
      "end": 283.5,
      "speaker": null,
      "text": "У них разница в том, что..."
    },
    {
      "start": 283.5,
      "end": 286.52,
      "speaker": null,
      "text": "Там чуть форма другая, совсем немножко."
    },
    {
      "start": 288.02,
      "end": 291.24,
      "speaker": null,
      "text": "Но вторая, она в разнице там 500 рублей, что ли, по-моему,"
    },
    {
      "start": 291.38,
      "end": 293.04,
      "speaker": null,
      "text": "но она переносится в тубусе."
    },
    {
      "start": 293.26,
      "end": 294.84,
      "speaker": null,
      "text": "То есть там отдельно тубус на неё есть."
    },
    {
      "start": 294.98,
      "end": 296.12,
      "speaker": null,
      "text": "Я могу фотки тоже направить."
    },
    {
      "start": 296.18,
      "end": 298.64,
      "speaker": null,
      "text": "Я делал такие стойки для нутеллы."
    },
    {
      "start": 298.86,
      "end": 299.56,
      "speaker": null,
      "text": "61 штуку."
    },
    {
      "start": 300.4,
      "end": 300.8,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 301.92,
      "end": 302.18,
      "speaker": null,
      "text": "Вот."
    },
    {
      "start": 302.72,
      "end": 304.78,
      "speaker": null,
      "text": "Ну, да, если есть возможность, хорошо пришлите."
    },
    {
      "start": 304.96,
      "end": 307.38,
      "speaker": null,
      "text": "А так вот, как бы, я сейчас дойду до колеч."
    },
    {
      "start": 307.62,
      "end": 308.28,
      "speaker": null,
      "text": "Поговорю с ними."
    },
    {
      "start": 308.6,
      "end": 310.2,
      "speaker": null,
      "text": "Либо он сам, либо я выйду."
    },
    {
      "start": 310.7,
      "end": 311.52,
      "speaker": null,
      "text": "По поводу этого."
    },
    {
      "start": 311.7,
      "end": 313.74,
      "speaker": null,
      "text": "А по поводу того, как только какой-то будет,"
    },
    {
      "start": 314.3,
      "end": 315.7,
      "speaker": null,
      "text": "я вам пришлю, посмотрите."
    },
    {
      "start": 316.62,
      "end": 317.7,
      "speaker": null,
      "text": "Всё, договорились, хорошо."
    },
    {
      "start": 318.0,
      "end": 318.52,
      "speaker": null,
      "text": "На связи."
    },
    {
      "start": 318.92,
      "end": 319.46,
      "speaker": null,
      "text": "Да, на связи."
    }
  ]
}