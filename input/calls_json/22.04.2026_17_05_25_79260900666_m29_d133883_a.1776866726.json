{
  "file": "22.04.2026_17_05_25_79260900666_m29_d133883_a.1776866726.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 276.5,
  "segments": [
    {
      "start": 0.43,
      "end": 1.05,
      "speaker": null,
      "text": "Алло."
    },
    {
      "start": 1.97,
      "end": 7.19,
      "speaker": null,
      "text": "Милика, здравствуйте ещё раз. Это Ксения из Мустэнда. Вы к нам обращались по поводу конструкции?"
    },
    {
      "start": 7.29,
      "end": 7.37,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 7.59,
      "end": 21.13,
      "speaker": null,
      "text": "Вот. Смотрите, эконом уже у нас в таком количестве точно нет и не будет, потому что стараемся вообще не продавать данную конструкцию, так как на один раз это не очень хорошо."
    },
    {
      "start": 21.61,
      "end": 33.63,
      "speaker": null,
      "text": "По поводу классической конструкции, с учётом того, что это у нас большой тираж, я посчитала, как это будет для вас просто конструкция и не конструкция с печатью, то есть под ключ всё вместе."
    },
    {
      "start": 33.63,
      "end": 56.3,
      "speaker": null,
      "text": "С учётом, что тираж 1773 штуки, у нас за одну штуку, если просто конструкция 200 выходит за штуку, под ключ 3600. То есть с учётом как раз таки всех из-за тиража. Такой бюджет вам подходит?"
    },
    {
      "start": 56.3,
      "end": 59.92,
      "speaker": null,
      "text": "Так, сейчас немножко."
    },
    {
      "start": 72.92,
      "end": 73.5,
      "speaker": null,
      "text": "Дороговато."
    },
    {
      "start": 74.35,
      "end": 75.83,
      "speaker": null,
      "text": "А сколько вам предлагают?"
    },
    {
      "start": 76.37,
      "end": 79.65,
      "speaker": null,
      "text": "Нам дешевле предлагают."
    },
    {
      "start": 82.53,
      "end": 85.9,
      "speaker": null,
      "text": "Ну, а на сколько просто нечлесно даже."
    },
    {
      "start": 85.98,
      "end": 88.94,
      "speaker": null,
      "text": "Так, у вас тысяча за 2200 просто конструкция, да?"
    },
    {
      "start": 89.56,
      "end": 90.12,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 90.22,
      "end": 90.34,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 91.38,
      "end": 94.04,
      "speaker": null,
      "text": "3600 – это 1400 печатью."
    },
    {
      "start": 96.2,
      "end": 96.54,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 97.04,
      "end": 100.02,
      "speaker": null,
      "text": "То есть 1400 вам предлагают за конструкцию?"
    },
    {
      "start": 100.24,
      "end": 101.34,
      "speaker": null,
      "text": "Нет, дешевле."
    },
    {
      "start": 101.58,
      "end": 103.5,
      "speaker": null,
      "text": "За 500 нам дешевле предлагают."
    },
    {
      "start": 103.5,
      "end": 117.68,
      "speaker": null,
      "text": "То есть получается вам предлагают за 2200 уже с печатью?"
    },
    {
      "start": 118.5,
      "end": 119.96,
      "speaker": null,
      "text": "Нет, не 2200."
    },
    {
      "start": 120.12,
      "end": 120.94,
      "speaker": null,
      "text": "Дороже."
    },
    {
      "start": 121.16,
      "end": 139.99,
      "speaker": null,
      "text": "Дороже получать, пожалуй, 1100 за печать."
    },
    {
      "start": 141.88,
      "end": 143.1,
      "speaker": null,
      "text": "1100 за печатью."
    },
    {
      "start": 146.52,
      "end": 151.3,
      "speaker": null,
      "text": "Ну тогда это скорее всего вам эконом предлагают, если не конструкцию классическую."
    },
    {
      "start": 153.92,
      "end": 158.68,
      "speaker": null,
      "text": "Нет, я имею в виду, что там печать на вот этой, на бане 1100."
    },
    {
      "start": 160.5,
      "end": 162.3,
      "speaker": null,
      "text": "А у вас получается 1400."
    },
    {
      "start": 165.22,
      "end": 165.74,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 165.76,
      "end": 167.16,
      "speaker": null,
      "text": "Здесь же 2200 конструкция."
    },
    {
      "start": 167.52,
      "end": 168.74,
      "speaker": null,
      "text": "Это уже без, правильно?"
    },
    {
      "start": 169.34,
      "end": 170.54,
      "speaker": null,
      "text": "Просто самоконструкция."
    },
    {
      "start": 171.12,
      "end": 171.46,
      "speaker": null,
      "text": "Ну да."
    },
    {
      "start": 171.64,
      "end": 173.7,
      "speaker": null,
      "text": "Вы мне подключите 3600."
    },
    {
      "start": 173.96,
      "end": 175.92,
      "speaker": null,
      "text": "Получается 1400 печатью."
    },
    {
      "start": 176.96,
      "end": 177.28,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 177.28,
      "end": 179.54,
      "speaker": null,
      "text": "А вам, получается, предлагают за 3300."
    },
    {
      "start": 179.64,
      "end": 179.96,
      "speaker": null,
      "text": "Правильно?"
    },
    {
      "start": 181.0,
      "end": 181.38,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 182.85,
      "end": 183.13,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 187.28,
      "end": 190.04,
      "speaker": null,
      "text": "Ну в целом мы такую цену можем тогда предоставить."
    },
    {
      "start": 190.24,
      "end": 192.21,
      "speaker": null,
      "text": "Ну ладно."
    },
    {
      "start": 192.69,
      "end": 193.53,
      "speaker": null,
      "text": "Что-то думать."
    },
    {
      "start": 193.69,
      "end": 194.57,
      "speaker": null,
      "text": "Что такое стоило?"
    },
    {
      "start": 196.16,
      "end": 196.74,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 196.92,
      "end": 199.08,
      "speaker": null,
      "text": "А когда сможете с обратной связью вернуться?"
    },
    {
      "start": 199.08,
      "end": 199.8,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 201.0,
      "end": 203.26,
      "speaker": null,
      "text": "Я не знаю, кому заказчик ответит."
    },
    {
      "start": 205.26,
      "end": 207.84,
      "speaker": null,
      "text": "А вы какую-то свою сумму, да, ему называете?"
    },
    {
      "start": 208.02,
      "end": 208.76,
      "speaker": null,
      "text": "Ну то есть…"
    },
    {
      "start": 209.3,
      "end": 209.82,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 209.9,
      "end": 211.24,
      "speaker": null,
      "text": "Себе больше учите ему?"
    },
    {
      "start": 211.46,
      "end": 211.68,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 213.46,
      "end": 213.62,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 213.62,
      "end": 217.12,
      "speaker": null,
      "text": "А какая конечная у вас, чтобы тоже не понимать вообще?"
    },
    {
      "start": 218.3,
      "end": 222.56,
      "speaker": null,
      "text": "Не, я пока что не знаю, потому что у меня другой еще один подрядчик"
    },
    {
      "start": 222.56,
      "end": 224.02,
      "speaker": null,
      "text": "кто ждал с вами, я же говорю."
    },
    {
      "start": 224.9,
      "end": 225.26,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 228.06,
      "end": 228.4,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 228.4,
      "end": 229.0,
      "speaker": null,
      "text": "Ну, ну хорошо."
    },
    {
      "start": 229.04,
      "end": 233.38,
      "speaker": null,
      "text": "Сейчас у нас конструкция 200 стоит и 500-600 печать."
    },
    {
      "start": 233.58,
      "end": 234.86,
      "speaker": null,
      "text": "Внутри 600 под ключ."
    },
    {
      "start": 238.35,
      "end": 241.39,
      "speaker": null,
      "text": "Это то, что еще вам предложили?"
    },
    {
      "start": 242.04,
      "end": 247.86,
      "speaker": null,
      "text": "Нет, вы мне даете, а мне просто пока печать предложили дешевле, чем у вас."
    },
    {
      "start": 249.9,
      "end": 250.26,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 251.42,
      "end": 257.02,
      "speaker": null,
      "text": "Ну я говорю, я могу тоже… в таком случае я могу чуть ниже дать стоимость,"
    },
    {
      "start": 257.1,
      "end": 260.26,
      "speaker": null,
      "text": "но еще меньше к сожалению никак не получится."
    },
    {
      "start": 260.26,
      "end": 266.5,
      "speaker": null,
      "text": "Ну ладно, там как есть-то там видно будет."
    },
    {
      "start": 267.34,
      "end": 267.64,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 267.68,
      "end": 268.24,
      "speaker": null,
      "text": "Хорошо."
    },
    {
      "start": 268.74,
      "end": 269.62,
      "speaker": null,
      "text": "Да, спасибо."
    },
    {
      "start": 270.0,
      "end": 271.58,
      "speaker": null,
      "text": "Тогда буду ждать обратную связь."
    },
    {
      "start": 272.18,
      "end": 272.44,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 272.62,
      "end": 273.48,
      "speaker": null,
      "text": "Давай, до свидания."
    }
  ]
}