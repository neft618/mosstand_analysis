    {
      "start": 2.1,
      "end": 4.48,
      "speaker": null,
      "text": "Компания «Мост Тенкнер», Влад, здравствуйте."
    },
    {
      "start": 5.02,
      "end": 12.24,
      "speaker": null,
      "text": "Добрый день. Скажите, пожалуйста, а сколько у вас дней занимает печать одного флага размером 90 на 35?"
    },
    {
      "start": 14.39,
      "end": 15.63,
      "speaker": null,
      "text": "А как к вам обращаться?"
    },
    {
      "start": 16.07,
      "end": 16.51,
      "speaker": null,
      "text": "Лилия."
    },
    {
      "start": 17.14,
      "end": 21.5,
      "speaker": null,
      "text": "Лилия, очень приятно. Лилия, данный флаг печатается три рабочего дня."
    },
    {
      "start": 23.19,
      "end": 25.35,
      "speaker": null,
      "text": "Получается, сегодня вы уже в заявку не успеете?"
    },
    {
      "start": 26.51,
      "end": 28.03,
      "speaker": null,
      "text": "Сегодня его уже точно нет."
    },
    {
      "start": 28.15,
      "end": 31.98,
      "speaker": null,
      "text": "И будет он готов, наверное, в понедельник, да, в таком случае?"
    },
    {
      "start": 32.5,
      "end": 39.4,
      "speaker": null,
      "text": "Если завтра будет предоставлен макет, тогда он будет готов, скорее всего, да, в понедельник, во второй половине дня."
    },
    {
      "start": 39.82,
      "end": 42.1,
      "speaker": null,
      "text": "А в пятницу вечером не получится, да?"
    },
    {
      "start": 42.28,
      "end": 42.96,
      "speaker": null,
      "text": "Не успеем."
    },
    {
      "start": 43.9,
      "end": 44.8,
      "speaker": null,
      "text": "Хорошо, спасибо."
    },
    {
      "start": 45.46,
      "end": 45.98,
      "speaker": null,
      "text": "Всё хорошо."
    },
    {
      "start": 46.3,
      "end": 48.24,
      "speaker": null,
      "text": "А вам только нужно будет до пятницы вам, правильно?"
    },
    {
      "start": 48.62,
      "end": 49.04,
      "speaker": null,
      "text": "Ну да."
    },
    {
      "start": 50.51,
      "end": 50.77,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 50.89,
      "end": 53.23,
      "speaker": null,
      "text": "Я понял, хорошо."
    },
    {
      "start": 53.37,
      "end": 55.35,
      "speaker": null,
      "text": "Это единственная позиция, что вам сейчас требуется?"
    },
    {
      "start": 55.47,
      "end": 55.59,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 55.59,
      "end": 56.83,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 56.83,
      "end": 62.65,
      "speaker": null,
      "text": "Ну вот там, собственно говоря, логотип только вывести на флаг на размер 90 на 35 и всё."
    },
    {
      "start": 63.43,
      "end": 63.75,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 64.79,
      "end": 65.73,
      "speaker": null,
      "text": "Я понял, хорошо."
    },
    {
      "start": 65.87,
      "end": 67.61,
      "speaker": null,
      "text": "Но, к сожалению, таким сроком не успеем."
    },
    {
      "start": 68.3,
      "end": 69.24,
      "speaker": null,
      "text": "Спасибо вам, до свидания."
    },
    {
      "start": 69.34,
