{
  "file": "27.03.2026_15_34_40_89859246680_m21_d130161_e.1774614880.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 979.4,
  "segments": [
    {
      "start": 3.34,
      "end": 3.9,
      "speaker": null,
      "text": "Алло?"
    },
    {
      "start": 4.46,
      "end": 9.3,
      "speaker": null,
      "text": "Михаил, здравствуйте. Это Артём из компании НУСПЕНТ. Вы оставили заявку на обратный звонок?"
    },
    {
      "start": 9.4,
      "end": 9.96,
      "speaker": null,
      "text": "Да, абсолютно."
    },
    {
      "start": 11.92,
      "end": 13.36,
      "speaker": null,
      "text": "Какой вопрос? Что интересует?"
    },
    {
      "start": 13.84,
      "end": 16.14,
      "speaker": null,
      "text": "Да, смотрите..."
    },
    {
      "start": 17.94,
      "end": 20.56,
      "speaker": null,
      "text": "А, там уже не на конкретные пункты."
    },
    {
      "start": 20.56,
      "end": 21.3,
      "speaker": null,
      "text": "То есть, у меня..."
    },
    {
      "start": 21.3,
      "end": 25.3,
      "speaker": null,
      "text": "Да-да, я хотя отправил заявку, ну да, там уже, наверное, общая."
    },
    {
      "start": 25.58,
      "end": 27.56,
      "speaker": null,
      "text": "Значит, речь идёт о..."
    },
    {
      "start": 31.35,
      "end": 32.31,
      "speaker": null,
      "text": "Давай как речь?"
    },
    {
      "start": 32.65,
      "end": 34.81,
      "speaker": null,
      "text": "У меня по-другому нету этой..."
    },
    {
      "start": 35.77,
      "end": 38.91,
      "speaker": null,
      "text": "Тот, который от двух тысяч дополнительные устойчивости."
    },
    {
      "start": 39.59,
      "end": 40.87,
      "speaker": null,
      "text": "Это вот стенды, как они называются..."
    },
    {
      "start": 41.61,
      "end": 42.47,
      "speaker": null,
      "text": "Вы имеете за рулап?"
    },
    {
      "start": 43.62,
      "end": 44.5,
      "speaker": null,
      "text": "А, нет, это..."
    },
    {
      "start": 44.5,
      "end": 48.18,
      "speaker": null,
      "text": "Ну, это а-ля рулап, да, но на рулап моделайся по словам такие чувства."
    },
    {
      "start": 48.6,
      "end": 49.84,
      "speaker": null,
      "text": "Стенды, да, и как-то там..."
    },
    {
      "start": 50.42,
      "end": 54.78,
      "speaker": null,
      "text": "Ну, стенд — это большое название. То есть, это что угодно может быть..."
    },
    {
      "start": 54.78,
      "end": 57.44,
      "speaker": null,
      "text": "Короче, 120, я сейчас по размеру скажу, можете поймите."
    },
    {
      "start": 57.52,
      "end": 59.5,
      "speaker": null,
      "text": "120 на 200 стоит у вас 3700."
    },
    {
      "start": 60.36,
      "end": 61.6,
      "speaker": null,
      "text": "Так, это рулап, я понял."
    },
    {
      "start": 61.84,
      "end": 62.58,
      "speaker": null,
      "text": "Посмотря какой..."
    },
    {
      "start": 62.58,
      "end": 64.28,
      "speaker": null,
      "text": "Сколько вы сказали стоимость?"
    },
    {
      "start": 65.21,
      "end": 65.75,
      "speaker": null,
      "text": "3700."
    },
    {
      "start": 66.96,
      "end": 67.5,
      "speaker": null,
      "text": "3700..."
    },
    {
      "start": 69.13,
      "end": 69.99,
      "speaker": null,
      "text": "Чего именно?"
    },
    {
      "start": 70.45,
      "end": 73.09,
      "speaker": null,
      "text": "3700 рублей, ну ничего."
    },
    {
      "start": 73.9,
      "end": 74.78,
      "speaker": null,
      "text": "120 на 200?"
    },
    {
      "start": 78.43,
      "end": 79.65,
      "speaker": null,
      "text": "Размер, наверное."
    },
    {
      "start": 80.35,
      "end": 82.3,
      "speaker": null,
      "text": "Давай сейчас проверим другой стоимости, что..."
    },
    {
      "start": 82.3,
      "end": 89.05,
      "speaker": null,
      "text": "Ну, по размеру стандартно это подходит рулап."
    },
    {
      "start": 89.15,
      "end": 91.37,
      "speaker": null,
      "text": "Если рулап, то самый быстрый — это рулап классик."
    },
    {
      "start": 92.41,
      "end": 95.91,
      "speaker": null,
      "text": "Смотрите, 120 на 200, расскажи ещё раз, да?"
    },
    {
      "start": 97.03,
      "end": 98.69,
      "speaker": null,
      "text": "Да, сейчас я смотрю его..."
    },
    {
      "start": 98.69,
      "end": 99.89,
      "speaker": null,
      "text": "Это 7300 получается."
    },
    {
      "start": 103.23,
      "end": 105.65,
      "speaker": null,
      "text": "Называется баннерная стенда, вот они называются."
    },
    {
      "start": 105.85,
      "end": 107.61,
      "speaker": null,
      "text": "Так, хорошо, какой именно?"
    },
    {
      "start": 108.37,
      "end": 108.97,
      "speaker": null,
      "text": "Икс..."
    },
    {
      "start": 109.03,
      "end": 110.13,
      "speaker": null,
      "text": "Вы смотрите, какой именно?"
    },
    {
      "start": 110.83,
      "end": 111.81,
      "speaker": null,
      "text": "Сейчас я смотрю."
    },
    {
      "start": 111.95,
      "end": 113.89,
      "speaker": null,
      "text": "Из баннерной стенды усиленная пора."
    },
    {
      "start": 113.99,
      "end": 114.81,
      "speaker": null,
      "text": "Цена от 2000."
    },
    {
      "start": 115.27,
      "end": 117.99,
      "speaker": null,
      "text": "Всё, это от тиража."
    },
    {
      "start": 118.53,
      "end": 121.97,
      "speaker": null,
      "text": "Вам нужно, смотрите, стоимость получается 120 на 200 — 3700."
    },
    {
      "start": 122.47,
      "end": 124.21,
      "speaker": null,
      "text": "Это стоимость за конструкцию."
    },
    {
      "start": 124.43,
      "end": 126.99,
      "speaker": null,
      "text": "И к ней прибавит, получается, стоимость печати."
    },
    {
      "start": 126.99,
      "end": 131.19,
      "speaker": null,
      "text": "Стоимость печати на 120 на 200 — 2200 рублей."
    },
    {
      "start": 132.7,
      "end": 134.2,
      "speaker": null,
      "text": "То есть, всё полностью под ключ."
    },
    {
      "start": 134.4,
      "end": 137.82,
      "speaker": null,
      "text": "У нас с вами получается, Михаил, это будет 5900 рублей."
    },
    {
      "start": 137.98,
      "end": 138.98,
      "speaker": null,
      "text": "Конструкция печати в баннере."
    },
    {
      "start": 138.98,
      "end": 140.38,
      "speaker": null,
      "text": "У вас где будет стоимость?"
    },
    {
      "start": 140.76,
      "end": 141.72,
      "speaker": null,
      "text": "Скажите, а зачем мне печать?"
    },
    {
      "start": 141.94,
      "end": 143.98,
      "speaker": null,
      "text": "Я сам это..."
    },
    {
      "start": 144.94,
      "end": 146.7,
      "speaker": null,
      "text": "Вам просто конструкция необходима?"
    },
    {
      "start": 147.24,
      "end": 147.44,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 147.68,
      "end": 149.96,
      "speaker": null,
      "text": "Мне конструкция, потому что там дизайнерам отдают."
    },
    {
      "start": 151.89,
      "end": 153.07,
      "speaker": null,
      "text": "Честно говоря, это не знаю."
    },
    {
      "start": 154.19,
      "end": 155.65,
      "speaker": null,
      "text": "Трансчези мне будет..."
    },
    {
      "start": 157.56,
      "end": 159.54,
      "speaker": null,
      "text": "У вас уже есть напечатанный баннер?"
    },
    {
      "start": 160.87,
      "end": 161.23,
      "speaker": null,
      "text": "Или..."
    },
    {
      "start": 161.23,
      "end": 163.13,
      "speaker": null,
      "text": "Они будут сейчас..."
    },
    {
      "start": 164.41,
      "end": 167.47,
      "speaker": null,
      "text": "Дизайнеры начали его отольют, а потом будут..."
    },
    {
      "start": 168.75,
      "end": 171.13,
      "speaker": null,
      "text": "Не понял, у вас дизайнер делает макет. Правильно?"
    },
    {
      "start": 171.83,
      "end": 172.05,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 172.51,
      "end": 174.67,
      "speaker": null,
      "text": "Который потом вы будете печатать."
    },
    {
      "start": 177.32,
      "end": 178.4,
      "speaker": null,
      "text": "Вы сами будете печатать?"
    },
    {
      "start": 178.62,
      "end": 179.32,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 181.24,
      "end": 184.64,
      "speaker": null,
      "text": "Я вот знаю, просто мне написал там регламент францези,"
    },
    {
      "start": 184.72,
      "end": 186.42,
      "speaker": null,
      "text": "я не знаю, они сами это делают либо..."
    },
    {
      "start": 186.42,
      "end": 187.86,
      "speaker": null,
      "text": "Я понял, что с вашей..."
    },
    {
      "start": 188.92,
      "end": 192.42,
      "speaker": null,
      "text": "Мы у вас купим баннер и дальше просто,"
    },
    {
      "start": 192.68,
      "end": 195.82,
      "speaker": null,
      "text": "если печать нужна, просто нужно будет на печати отдельно отдать."
    },
    {
      "start": 195.96,
      "end": 196.14,
      "speaker": null,
      "text": "Правильно?"
    },
    {
      "start": 196.9,
      "end": 197.86,
      "speaker": null,
      "text": "Ну вы можете всё вместе."
    },
    {
      "start": 199.5,
      "end": 202.72,
      "speaker": null,
      "text": "Проще, на самом деле, покупать сразу и конструкцию, и печать."
    },
    {
      "start": 203.78,
      "end": 208.72,
      "speaker": null,
      "text": "Чтобы не делать две разные оплаты, и чтобы в дальнейшем не искать что-либо."
    },
    {
      "start": 208.86,
      "end": 209.92,
      "speaker": null,
      "text": "Просто мы сразу и конструкцию..."
    },
    {
      "start": 209.92,
      "end": 212.78,
      "speaker": null,
      "text": "Для этого вам нужно полностью..."
    },
    {
      "start": 214.04,
      "end": 215.0,
      "speaker": null,
      "text": "Ну как бы..."
    },
    {
      "start": 215.0,
      "end": 215.6,
      "speaker": null,
      "text": "Макет, да."
    },
    {
      "start": 215.74,
      "end": 218.94,
      "speaker": null,
      "text": "То есть нам нужен макет именно вот того размера,"
    },
    {
      "start": 218.94,
      "end": 220.76,
      "speaker": null,
      "text": "как вам необходимо, то есть 120 на 200."
    },
    {
      "start": 221.12,
      "end": 222.46,
      "speaker": null,
      "text": "В TIFF."
    },
    {
      "start": 223.28,
      "end": 223.96,
      "speaker": null,
      "text": "Файл TIFF."
    },
    {
      "start": 223.98,
      "end": 226.62,
      "speaker": null,
      "text": "Если у вас дизайнер знает, что к чему и как,"
    },
    {
      "start": 228.04,
      "end": 229.16,
      "speaker": null,
      "text": "я думаю, он поймёт и разберётся."
    },
    {
      "start": 230.43,
      "end": 231.23,
      "speaker": null,
      "text": "В каком файле?"
    },
    {
      "start": 233.72,
      "end": 234.48,
      "speaker": null,
      "text": "Файл TIFF."
    },
    {
      "start": 235.52,
      "end": 235.9,
      "speaker": null,
      "text": "TIFF."
    },
    {
      "start": 239.03,
      "end": 239.41,
      "speaker": null,
      "text": "TIFF."
    },
    {
      "start": 240.2,
      "end": 242.34,
      "speaker": null,
      "text": "Я могу прописать вам сейчас в Телеграме."
    },
    {
      "start": 242.54,
      "end": 245.98,
      "speaker": null,
      "text": "У вас номер в Телеграме, я вам написал ещё после того,"
    },
    {
      "start": 246.1,
      "end": 246.7,
      "speaker": null,
      "text": "не мог бы звонить."
    },
    {
      "start": 246.7,
      "end": 249.55,
      "speaker": null,
      "text": "Я сейчас напишу."
    },
    {
      "start": 250.03,
      "end": 251.95,
      "speaker": null,
      "text": "В Телеграме, так вы мне написали..."
    },
    {
      "start": 251.95,
      "end": 252.55,
      "speaker": null,
      "text": "Когда? Где?"
    },
    {
      "start": 252.97,
      "end": 254.17,
      "speaker": null,
      "text": "Я вам сейчас напишу."
    },
    {
      "start": 254.85,
      "end": 257.21,
      "speaker": null,
      "text": "Напишите даже вверх, когда он взлетел."
    },
    {
      "start": 257.67,
      "end": 259.77,
      "speaker": null,
      "text": "Вот он сказал, формат для макета."
    },
    {
      "start": 260.03,
      "end": 261.25,
      "speaker": null,
      "text": "А, вот, да?"
    },
    {
      "start": 261.99,
      "end": 262.21,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 262.21,
      "end": 263.37,
      "speaker": null,
      "text": "На макета, ты понял."
    },
    {
      "start": 263.53,
      "end": 263.67,
      "speaker": null,
      "text": "Ага."
    },
    {
      "start": 266.15,
      "end": 269.13,
      "speaker": null,
      "text": "У вас где сам стенд должен потом быть стоять?"
    },
    {
      "start": 269.23,
      "end": 270.33,
      "speaker": null,
      "text": "В помещении или на улице?"
    },
    {
      "start": 271.76,
      "end": 274.02,
      "speaker": null,
      "text": "Вот есть варианты и того, и другого."
    },
    {
      "start": 274.7,
      "end": 276.58,
      "speaker": null,
      "text": "На улице не стоит, это сразу нет."
    },
    {
      "start": 278.16,
      "end": 279.46,
      "speaker": null,
      "text": "В смысле, что он не устойчивый?"
    },
    {
      "start": 279.94,
      "end": 280.44,
      "speaker": null,
      "text": "Ну да."
    },
    {
      "start": 280.74,
      "end": 282.4,
      "speaker": null,
      "text": "Это будет как парусный эффект."
    },
    {
      "start": 282.5,
      "end": 283.8,
      "speaker": null,
      "text": "Получается, он у вас улетит."
    },
    {
      "start": 284.42,
      "end": 286.78,
      "speaker": null,
      "text": "Даже то, что у вас усиленная опора,"
    },
    {
      "start": 287.0,
      "end": 288.32,
      "speaker": null,
      "text": "он всё равно может улететь."
    },
    {
      "start": 289.0,
      "end": 290.24,
      "speaker": null,
      "text": "Давай так вот."
    },
    {
      "start": 291.26,
      "end": 293.24,
      "speaker": null,
      "text": "Переначально он для помещения,"
    },
    {
      "start": 295.3,
      "end": 297.66,
      "speaker": null,
      "text": "но я ещё думаю, в том числе и для улицы."
    },
    {
      "start": 297.78,
      "end": 298.94,
      "speaker": null,
      "text": "Поставить ли ты для улицы?"
    },
    {
      "start": 299.16,
      "end": 300.28,
      "speaker": null,
      "text": "Для улиц слаги."
    },
    {
      "start": 302.25,
      "end": 303.65,
      "speaker": null,
      "text": "А, про слаги я слышал, да."
    },
    {
      "start": 304.03,
      "end": 304.29,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 304.87,
      "end": 307.25,
      "speaker": null,
      "text": "Потому что на улице мы не можем знать заранее,"
    },
    {
      "start": 307.27,
      "end": 308.03,
      "speaker": null,
      "text": "какой вечер будет,"
    },
    {
      "start": 308.11,
      "end": 310.57,
      "speaker": null,
      "text": "потому что все стенды на них натягивают либо бары, либо..."
    },
    {
      "start": 310.57,
      "end": 312.15,
      "speaker": null,
      "text": "И мы улетаем."
    },
    {
      "start": 312.89,
      "end": 314.69,
      "speaker": null,
      "text": "Так, цены от производителя, да."
    },
    {
      "start": 315.87,
      "end": 316.83,
      "speaker": null,
      "text": "Забота резервная макета."
    },
    {
      "start": 317.25,
      "end": 318.35,
      "speaker": null,
      "text": "Вижу, слаги, да."
    },
    {
      "start": 318.35,
      "end": 319.27,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 319.83,
      "end": 321.67,
      "speaker": null,
      "text": "Слаги напольные, настольные."
    },
    {
      "start": 321.83,
      "end": 323.15,
      "speaker": null,
      "text": "Так, мне нужно напольные, да?"
    },
    {
      "start": 323.53,
      "end": 323.79,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 324.61,
      "end": 326.43,
      "speaker": null,
      "text": "Ну и вы смотрите именно вот ту форму,"
    },
    {
      "start": 326.47,
      "end": 327.77,
      "speaker": null,
      "text": "какая вам необходима флага."
    },
    {
      "start": 333.28,
      "end": 335.84,
      "speaker": null,
      "text": "Так, они стоят уже двух оттуда."
    },
    {
      "start": 338.1,
      "end": 341.78,
      "speaker": null,
      "text": "Объясните коротко, вот пиро, флекс, чем они отличаются?"
    },
    {
      "start": 341.8,
      "end": 342.6,
      "speaker": null,
      "text": "Это форма."
    },
    {
      "start": 342.6,
      "end": 343.84,
      "speaker": null,
      "text": "Это все форма."
    },
    {
      "start": 343.9,
      "end": 350.18,
      "speaker": null,
      "text": "То есть, флекс, пиро, крыло, парус – это капля, это форма флага."
    },
    {
      "start": 350.26,
      "end": 351.86,
      "speaker": null,
      "text": "Цена одинаковая на все, да?"
    },
    {
      "start": 353.48,
      "end": 357.26,
      "speaker": null,
      "text": "Цена зависит, во-первых, от того, какой размер вам необходим, раз,"
    },
    {
      "start": 358.02,
      "end": 362.78,
      "speaker": null,
      "text": "какая печать необходима, односторонняя, двусторонняя, какой материал необходим."
    },
    {
      "start": 362.78,
      "end": 364.46,
      "speaker": null,
      "text": "Биндер, крыло и прочее."
    },
    {
      "start": 364.78,
      "end": 368.49,
      "speaker": null,
      "text": "Не важно какую форму я выберу – это не важно, да?"
    },
    {
      "start": 368.65,
      "end": 370.39,
      "speaker": null,
      "text": "На цену влиятельности компонента, правильно?"
    },
    {
      "start": 370.63,
      "end": 371.49,
      "speaker": null,
      "text": "Да, да, да, да."
    },
    {
      "start": 372.09,
      "end": 376.45,
      "speaker": null,
      "text": "Ну и соответственно, если вы выбираете флаг, вам нужен к нему во-вторых, флагшток"
    },
    {
      "start": 376.45,
      "end": 378.23,
      "speaker": null,
      "text": "и, соответственно, еще основание."
    },
    {
      "start": 380.15,
      "end": 382.69,
      "speaker": null,
      "text": "Сколько флаг под крышей выходит?"
    },
    {
      "start": 383.29,
      "end": 386.33,
      "speaker": null,
      "text": "Ну, смотрите, какой размер, какая печать, какой материал."
    },
    {
      "start": 388.67,
      "end": 391.37,
      "speaker": null,
      "text": "Да, только от этого вы видите."
    },
    {
      "start": 391.71,
      "end": 394.87,
      "speaker": null,
      "text": "Могу вам остановиться так же, давайте сейчас поступим, чтобы будет проще."
    },
    {
      "start": 395.29,
      "end": 397.57,
      "speaker": null,
      "text": "Какой машин? Ну, давай так, я вам короче думаю."
    },
    {
      "start": 397.73,
      "end": 400.85,
      "speaker": null,
      "text": "Речь идет о франшизе автосимуляторов."
    },
    {
      "start": 401.73,
      "end": 402.55,
      "speaker": null,
      "text": "Что еще раз?"
    },
    {
      "start": 404.23,
      "end": 405.27,
      "speaker": null,
      "text": "Автосимуляторы – машинки."
    },
    {
      "start": 406.25,
      "end": 408.77,
      "speaker": null,
      "text": "Ну, как компьютеры для машины."
    },
    {
      "start": 409.07,
      "end": 410.97,
      "speaker": null,
      "text": "И мы там…"
    },
    {
      "start": 411.59,
      "end": 415.73,
      "speaker": null,
      "text": "Это такая небольшая торговая галерея, небольшая такая локальная."
    },
    {
      "start": 415.73,
      "end": 416.03,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 416.25,
      "end": 422.93,
      "speaker": null,
      "text": "И там вот перед ней прям есть пятачок, и мы, вероятно, там где-то, наверное, как-то это тоже можем подставить."
    },
    {
      "start": 423.11,
      "end": 424.33,
      "speaker": null,
      "text": "Ну, не знаю, какой там размер."
    },
    {
      "start": 425.87,
      "end": 426.99,
      "speaker": null,
      "text": "Ну, какое это такое?"
    },
    {
      "start": 427.71,
      "end": 428.75,
      "speaker": null,
      "text": "Обычно такой размер."
    },
    {
      "start": 430.17,
      "end": 432.79,
      "speaker": null,
      "text": "Это да, это не какое-то что-то огромное."
    },
    {
      "start": 432.97,
      "end": 437.63,
      "speaker": null,
      "text": "Ну, просто заявить, и это не торговый центр, а такая небольшая галерея,"
    },
    {
      "start": 437.69,
      "end": 440.23,
      "speaker": null,
      "text": "и там есть прям пятачок перед ней, там такой пешеходный."
    },
    {
      "start": 440.57,
      "end": 443.09,
      "speaker": null,
      "text": "Вот я там где-то с ними, может быть, договорюсь."
    },
    {
      "start": 443.61,
      "end": 444.07,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 444.75,
      "end": 448.93,
      "speaker": null,
      "text": "Ну, смотрите, в помещении, да, лучше все-таки даже не из баннера, а рулап рассматривать."
    },
    {
      "start": 449.64,
      "end": 451.1,
      "speaker": null,
      "text": "Проще по сборке и удобнее."
    },
    {
      "start": 452.69,
      "end": 456.91,
      "speaker": null,
      "text": "А мне они показались менее устойчивыми, ну и плюс они так по-хорошему не дороже, да?"
    },
    {
      "start": 458.4,
      "end": 460.82,
      "speaker": null,
      "text": "Даже чуть-чуть, но и более выгоднее."
    },
    {
      "start": 460.9,
      "end": 464.56,
      "speaker": null,
      "text": "В помещении, вот, допустим, рассматривайте вариант либо классик, либо каплевидный."
    },
    {
      "start": 465.7,
      "end": 467.76,
      "speaker": null,
      "text": "Размер такой же оставляется – 120 на 200."
    },
    {
      "start": 469.41,
      "end": 472.55,
      "speaker": null,
      "text": "Ну да, вот я иду сейчас, рулап классик вы сказали или какой?"
    },
    {
      "start": 473.03,
      "end": 475.43,
      "speaker": null,
      "text": "Классик, все верно. Вот же самый обычный, допустим."
    },
    {
      "start": 476.27,
      "end": 477.05,
      "speaker": null,
      "text": "120 на 200."
    },
    {
      "start": 477.05,
      "end": 482.25,
      "speaker": null,
      "text": "А они устойчивы, чем мне показалось сцену интереснее – там такая опора хорошая."
    },
    {
      "start": 482.69,
      "end": 483.73,
      "speaker": null,
      "text": "Это вам так кажется."
    },
    {
      "start": 494.7,
      "end": 495.46,
      "speaker": null,
      "text": "Да?"
    },
    {
      "start": 495.46,
      "end": 496.46,
      "speaker": null,
      "text": "Вы за компьютером смотрите или как?"
    },
    {
      "start": 497.06,
      "end": 499.88,
      "speaker": null,
      "text": "Ну, я видел, что она там вращается."
    },
    {
      "start": 500.0,
      "end": 504.26,
      "speaker": null,
      "text": "Да, вращается, то есть, смотрите, сам баннер с полотном, который будет встречаться,"
    },
    {
      "start": 504.34,
      "end": 506.38,
      "speaker": null,
      "text": "он заправляется в конструкцию, в основание."
    },
    {
      "start": 506.86,
      "end": 509.96,
      "speaker": null,
      "text": "Вытягивается и ставится штанга для фиксирования."
    },
    {
      "start": 510.16,
      "end": 512.86,
      "speaker": null,
      "text": "И ножки раздвигаются для устойчивости."
    },
    {
      "start": 513.24,
      "end": 514.62,
      "speaker": null,
      "text": "На улице такой не подойдет."
    },
    {
      "start": 514.76,
      "end": 520.6,
      "speaker": null,
      "text": "За ним, вот, за спиной его какой-то опора есть или нет?"
    },
    {
      "start": 521.07,
      "end": 522.37,
      "speaker": null,
      "text": "Опоры – это штанга."
    },
    {
      "start": 522.82,
      "end": 528.54,
      "speaker": null,
      "text": "Там стоит штанга, которая крепится вверху и ставится вниз."
    },
    {
      "start": 528.88,
      "end": 530.78,
      "speaker": null,
      "text": "Она как раскладная, алиминиевая."
    },
    {
      "start": 534.51,
      "end": 538.27,
      "speaker": null,
      "text": "Вот, если картинку покрутить, вот она прямо по центру сзади видна ее."
    },
    {
      "start": 539.44,
      "end": 540.94,
      "speaker": null,
      "text": "Не крутится сейчас рулап."
    },
    {
      "start": 541.58,
      "end": 542.84,
      "speaker": null,
      "text": "Куда мне идти? В рулап классик?"
    },
    {
      "start": 543.36,
      "end": 545.96,
      "speaker": null,
      "text": "Да, рулап классик, вы нажимаете «Подробнее»."
    },
    {
      "start": 545.96,
      "end": 549.16,
      "speaker": null,
      "text": "И сразу вначале увидите эту картинку, которую можно подключить."
    },
    {
      "start": 549.46,
      "end": 553.02,
      "speaker": null,
      "text": "Я могу вам просто даже еще фотографировать на то, чтобы посмотреть, что оно выглядит."
    },
    {
      "start": 553.5,
      "end": 554.34,
      "speaker": null,
      "text": "Подробнее вам, да."
    },
    {
      "start": 556.99,
      "end": 558.79,
      "speaker": null,
      "text": "Вот эту картинку можно прокрутить."
    },
    {
      "start": 558.93,
      "end": 560.69,
      "speaker": null,
      "text": "И вы увидите, что стоили, что за..."
    },
    {
      "start": 560.69,
      "end": 562.77,
      "speaker": null,
      "text": "Я сейчас смотрю."
    },
    {
      "start": 565.74,
      "end": 567.77,
      "speaker": null,
      "text": "Почему и на стенды перешелся?"
    },
    {
      "start": 567.87,
      "end": 569.15,
      "speaker": null,
      "text": "Мне показалось, что они грузятся."
    },
    {
      "start": 571.38,
      "end": 572.66,
      "speaker": null,
      "text": "Мне показалось, что они божные."
    },
    {
      "start": 574.41,
      "end": 577.65,
      "speaker": null,
      "text": "А вот я вижу, там есть какая-то такая..."
    },
    {
      "start": 577.65,
      "end": 579.29,
      "speaker": null,
      "text": "Она как-то вытягивается что ли?"
    },
    {
      "start": 579.29,
      "end": 579.95,
      "speaker": null,
      "text": "Да, потому что я ее не вижу."
    },
    {
      "start": 580.01,
      "end": 580.81,
      "speaker": null,
      "text": "Она раскладная."
    },
    {
      "start": 583.43,
      "end": 584.65,
      "speaker": null,
      "text": "Все это будет в комплекте."
    },
    {
      "start": 585.25,
      "end": 587.69,
      "speaker": null,
      "text": "Вот эта штанга, которая держит палкой, так сказать, по центру..."
    },
    {
      "start": 588.29,
      "end": 593.41,
      "speaker": null,
      "text": "То есть вот эта дуга, назовем ее дуга, она является прям опорой, да?"
    },
    {
      "start": 593.55,
      "end": 595.43,
      "speaker": null,
      "text": "То есть она как-то снизу, да?"
    },
    {
      "start": 595.91,
      "end": 597.87,
      "speaker": null,
      "text": "Она снизу расширяется как-то, да?"
    },
    {
      "start": 598.15,
      "end": 599.81,
      "speaker": null,
      "text": "И на нее какая-то опора идет, да?"
    },
    {
      "start": 600.71,
      "end": 602.27,
      "speaker": null,
      "text": "Да, она оставляет по самой конструкции."
    },
    {
      "start": 603.22,
      "end": 604.64,
      "speaker": null,
      "text": "Так вы же..."
    },
    {
      "start": 604.64,
      "end": 607.86,
      "speaker": null,
      "text": "Давайте я так вот на фотографии направлю, как все комплект выглядит."
    },
    {
      "start": 608.08,
      "end": 608.28,
      "speaker": null,
      "text": "Смотрите."
    },
    {
      "start": 609.95,
      "end": 613.31,
      "speaker": null,
      "text": "Вот это один из вариантов рулап классика."
    },
    {
      "start": 615.28,
      "end": 617.28,
      "speaker": null,
      "text": "Штанга, которую видите, она такая складная."
    },
    {
      "start": 618.12,
      "end": 619.38,
      "speaker": null,
      "text": "Само основание, профиль."
    },
    {
      "start": 620.24,
      "end": 623.6,
      "speaker": null,
      "text": "Баннер будет, соответственно, закреплен в профиль конструкции и в основании."
    },
    {
      "start": 623.98,
      "end": 624.58,
      "speaker": null,
      "text": "Все это будет..."
    },
    {
      "start": 624.58,
      "end": 628.1,
      "speaker": null,
      "text": "Я правильно понимаю, что вот рулапы все-таки по..."
    },
    {
      "start": 628.1,
      "end": 629.78,
      "speaker": null,
      "text": "Они просто что, подстабильнее будут, да?"
    },
    {
      "start": 630.24,
      "end": 630.44,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 633.16,
      "end": 633.78,
      "speaker": null,
      "text": "Чем баннер."
    },
    {
      "start": 633.78,
      "end": 638.82,
      "speaker": null,
      "text": "Из-за того, что у него там сзади вот такое вот все это укрепление дополнительное..."
    },
    {
      "start": 641.04,
      "end": 643.44,
      "speaker": null,
      "text": "Нет, они еще более легче на самом деле."
    },
    {
      "start": 643.6,
      "end": 646.26,
      "speaker": null,
      "text": "Их берут, вы знаете, как сказать вам..."
    },
    {
      "start": 646.26,
      "end": 651.46,
      "speaker": null,
      "text": "В магазин, если заходите в какой-нибудь там сейф перекресток или еще кто-либо."
    },
    {
      "start": 651.58,
      "end": 654.54,
      "speaker": null,
      "text": "Они с самого входа стоят и их берут как большим тиражом."
    },
    {
      "start": 654.92,
      "end": 657.64,
      "speaker": null,
      "text": "И будут как большим тиражом прямо у входа поставить на какую-то акцию рекламную."
    },
    {
      "start": 657.74,
      "end": 658.94,
      "speaker": null,
      "text": "Или в открытии не могут стоять."
    },
    {
      "start": 659.26,
      "end": 661.06,
      "speaker": null,
      "text": "Вот только на эти моменты их в основном берут."
    },
    {
      "start": 661.06,
      "end": 664.56,
      "speaker": null,
      "text": "То есть на один раз повзяли и даже ничего не меняют."
    },
    {
      "start": 665.08,
      "end": 666.12,
      "speaker": null,
      "text": "Их вот на эти моменты берут."
    },
    {
      "start": 666.36,
      "end": 668.62,
      "speaker": null,
      "text": "Если дальнейшее что-то используют, начинается рулап,"
    },
    {
      "start": 669.22,
      "end": 672.06,
      "speaker": null,
      "text": "либо какой-то просву, либо тканевый стенд."
    },
    {
      "start": 673.03,
      "end": 674.03,
      "speaker": null,
      "text": "Вот это все разбирается."
    },
    {
      "start": 674.35,
      "end": 678.11,
      "speaker": null,
      "text": "Если мобильный на несколько раз на рекламу, то рулап соответственно надо брать."
    },
    {
      "start": 678.61,
      "end": 682.37,
      "speaker": null,
      "text": "У всех рулапов, которые на сайте у нас есть, механизм один тот же."
    },
    {
      "start": 682.43,
      "end": 683.85,
      "speaker": null,
      "text": "Просто основание другое и все."
    },
    {
      "start": 685.53,
      "end": 686.49,
      "speaker": null,
      "text": "Мне нужно..."
    },
    {
      "start": 686.49,
      "end": 688.29,
      "speaker": null,
      "text": "На самом деле он там будет стоять просто."
    },
    {
      "start": 688.29,
      "end": 692.99,
      "speaker": null,
      "text": "До открытия вот будет там месяц примерно, что он там стоял."
    },
    {
      "start": 693.11,
      "end": 694.89,
      "speaker": null,
      "text": "Там есть этот китачок такое место."
    },
    {
      "start": 695.85,
      "end": 697.79,
      "speaker": null,
      "text": "Вот он будет стоять просто и сформироваться."
    },
    {
      "start": 698.45,
      "end": 700.01,
      "speaker": null,
      "text": "Ну да, то есть рулап проще."
    },
    {
      "start": 700.07,
      "end": 703.07,
      "speaker": null,
      "text": "Вы смотрите его взяли убрали, затянули в конструкцию и все."
    },
    {
      "start": 704.07,
      "end": 705.11,
      "speaker": null,
      "text": "А иксбану..."
    },
    {
      "start": 705.11,
      "end": 706.17,
      "speaker": null,
      "text": "Еще раз."
    },
    {
      "start": 706.39,
      "end": 708.79,
      "speaker": null,
      "text": "Чуть-чуть глухо я вас слышу еще раз."
    },
    {
      "start": 709.43,
      "end": 711.43,
      "speaker": null,
      "text": "Рулап, вы просто смотрите в случае чего."
    },
    {
      "start": 711.51,
      "end": 715.03,
      "speaker": null,
      "text": "Если надо брать, взяли его обратно в конструкцию заправить и все."
    },
    {
      "start": 715.63,
      "end": 717.83,
      "speaker": null,
      "text": "Иксбану мне несколько раскладывать, раскладывать."
    },
    {
      "start": 718.07,
      "end": 722.53,
      "speaker": null,
      "text": "Вы имеете в виду то, что они сборные в отличие от первых?"
    },
    {
      "start": 722.53,
      "end": 723.37,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 723.37,
      "end": 724.55,
      "speaker": null,
      "text": "Да, да, он более сборный."
    },
    {
      "start": 747.96,
      "end": 753.2,
      "speaker": null,
      "text": "Да-да-да."
    },
    {
      "start": 753.2,
      "end": 758.6,
      "speaker": null,
      "text": "185 на 200, размер макета 840 на 2030 миллиметров."
    },
    {
      "start": 760.32,
      "end": 761.16,
      "speaker": null,
      "text": "Там все расписано."
    },
    {
      "start": 762.08,
      "end": 765.68,
      "speaker": null,
      "text": "Какой размер выберите, я расскажу вам, какой макет необходим в размерах,"
    },
    {
      "start": 765.72,
      "end": 767.28,
      "speaker": null,
      "text": "чтобы ваши дизайнеры все подготовили."
    },
    {
      "start": 768.92,
      "end": 771.14,
      "speaker": null,
      "text": "Сейчас я немножко не понял."
    },
    {
      "start": 771.34,
      "end": 773.62,
      "speaker": null,
      "text": "В зависимости от размера, который я выберу,"
    },
    {
      "start": 773.7,
      "end": 775.46,
      "speaker": null,
      "text": "что вы дальше сказали какие-то?"
    },
    {
      "start": 775.46,
      "end": 777.84,
      "speaker": null,
      "text": "Направлю размеры макета, то есть"
    },
    {
      "start": 778.89,
      "end": 780.51,
      "speaker": null,
      "text": "вам нужно 120 на 200."
    },
    {
      "start": 780.93,
      "end": 782.97,
      "speaker": null,
      "text": "Макет не должен быть таких размеров."
    },
    {
      "start": 783.25,
      "end": 785.07,
      "speaker": null,
      "text": "Он должен быть совсем других размеров."
    },
    {
      "start": 786.15,
      "end": 788.25,
      "speaker": null,
      "text": "То есть если вы 120 на 200 берете,"
    },
    {
      "start": 788.51,
      "end": 791.99,
      "speaker": null,
      "text": "вам нужен, чтобы печатный вариант макета в вашей дизайнере сделали"
    },
    {
      "start": 793.13,
      "end": 795.33,
      "speaker": null,
      "text": "1190 на 2030 миллиметров."
    },
    {
      "start": 795.49,
      "end": 797.23,
      "speaker": null,
      "text": "В зависимости от размера, там чуть другие."
    },
    {
      "start": 797.93,
      "end": 798.25,
      "speaker": null,
      "text": "Все, я понял."
    },
    {
      "start": 800.41,
      "end": 801.53,
      "speaker": null,
      "text": "Скажите мне..."
    },
    {
      "start": 802.3,
      "end": 803.66,
      "speaker": null,
      "text": "Так, сейчас смотрю я."
    },
    {
      "start": 806.16,
      "end": 807.72,
      "speaker": null,
      "text": "Наверное, 85 на 200..."
    },
    {
      "start": 810.01,
      "end": 811.66,
      "speaker": null,
      "text": "Как-то странно."
    },
    {
      "start": 811.74,
      "end": 814.9,
      "speaker": null,
      "text": "80 на 200 вот 3500 стоит, а 85 на 200..."
    },
    {
      "start": 814.9,
      "end": 816.22,
      "speaker": null,
      "text": "Конструкция, да, потому что редкая."
    },
    {
      "start": 816.38,
      "end": 820.0,
      "speaker": null,
      "text": "Потому что если редко берут, конструкция более редкая."
    },
    {
      "start": 820.54,
      "end": 822.16,
      "speaker": null,
      "text": "Самоходовые два размера макета."
    },
    {
      "start": 822.5,
      "end": 825.16,
      "speaker": null,
      "text": "Это либо 100 на 200, либо 85 на 200."
    },
    {
      "start": 829.45,
      "end": 832.85,
      "speaker": null,
      "text": "Но 85 на 200 для нашей истории, наверное, достаточно?"
    },
    {
      "start": 834.75,
      "end": 835.73,
      "speaker": null,
      "text": "Я думаю, да."
    },
    {
      "start": 835.99,
      "end": 838.19,
      "speaker": null,
      "text": "Смотрите, стоимость за конструкцию и печать будет"
    },
    {
      "start": 838.19,
      "end": 839.43,
      "speaker": null,
      "text": "4500 рублей."
    },
    {
      "start": 840.3,
      "end": 842.16,
      "speaker": null,
      "text": "Так же, как я вам направлял фотографию."
    },
    {
      "start": 842.42,
      "end": 844.34,
      "speaker": null,
      "text": "Конструкция будет печать на баннере заправленная"
    },
    {
      "start": 844.34,
      "end": 846.68,
      "speaker": null,
      "text": "в саму конструкцию и все это будет в одной сумке."
    },
    {
      "start": 846.68,
      "end": 852.63,
      "speaker": null,
      "text": "В методу суммарно будет..."
    },
    {
      "start": 852.63,
      "end": 853.31,
      "speaker": null,
      "text": "Сколько вы сказали?"
    },
    {
      "start": 853.43,
      "end": 853.83,
      "speaker": null,
      "text": "4500?"
    },
    {
      "start": 854.93,
      "end": 855.73,
      "speaker": null,
      "text": "4500 рублей."
    },
    {
      "start": 856.37,
      "end": 859.29,
      "speaker": null,
      "text": "Да, 3,5, да, вижу, да."
    },
    {
      "start": 859.94,
      "end": 865.46,
      "speaker": null,
      "text": "Да, то есть чтобы не запутаться, видите, в первую очередь цена за конструкцию, а потом печать на баннере."
    },
    {
      "start": 865.56,
      "end": 868.4,
      "speaker": null,
      "text": "Почему? Потому что многие берут потом печать, делают новые."
    },
    {
      "start": 868.86,
      "end": 874.02,
      "speaker": null,
      "text": "Если вам не сложно, сделайте мне тогда вот, что нужно дизайнеру сказать на два варианта."
    },
    {
      "start": 874.08,
      "end": 876.0,
      "speaker": null,
      "text": "На 85 на 200 и на 100 на 200?"
    },
    {
      "start": 876.7,
      "end": 877.86,
      "speaker": null,
      "text": "100 на 200 еще раз, да?"
    },
    {
      "start": 878.74,
      "end": 879.78,
      "speaker": null,
      "text": "Да, и 100 на 200 тоже."
    },
    {
      "start": 879.78,
      "end": 880.42,
      "speaker": null,
      "text": "Да, да."
    },
    {
      "start": 883.16,
      "end": 886.78,
      "speaker": null,
      "text": "А по флагам я вот тоже думаю..."
    },
    {
      "start": 887.84,
      "end": 902.33,
      "speaker": null,
      "text": "А я вам сейчас, смотрите, чтобы было вам комфортно и удобнее, я вам сейчас направлю модели одним единым файлом флагов, размерную сетку в флаге сами, и от этого будем отходить по к чему как."
    },
    {
      "start": 902.33,
      "end": 903.83,
      "speaker": null,
      "text": "А я потом уже спешил на стоимость."
    },
    {
      "start": 906.45,
      "end": 908.51,
      "speaker": null,
      "text": "Ну, то есть у меня будет более визуально..."
    },
    {
      "start": 908.51,
      "end": 914.39,
      "speaker": null,
      "text": "Да, да, чтобы вот так поставить не бегать, что к чему как, я вам сейчас отдельно все распишу, чтобы упоминали."
    },
    {
      "start": 914.99,
      "end": 915.39,
      "speaker": null,
      "text": "Супер!"
    },
    {
      "start": 916.03,
      "end": 916.17,
      "speaker": null,
      "text": "Да?"
    },
    {
      "start": 916.53,
      "end": 920.05,
      "speaker": null,
      "text": "На какую дату, Михаил, на какую дату все это необходимо тебе, чтобы понимать?"
    },
    {
      "start": 920.17,
      "end": 921.27,
      "speaker": null,
      "text": "Ну, ближайше упрямо."
    },
    {
      "start": 922.81,
      "end": 924.99,
      "speaker": null,
      "text": "Ну, ближайше это сегодня-завтра."
    },
    {
      "start": 929.75,
      "end": 933.77,
      "speaker": null,
      "text": "Давай так, у вас сколько липтайм, это сколько по времени делается?"
    },
    {
      "start": 933.8,
      "end": 937.44,
      "speaker": null,
      "text": "В рулап один-два рабочих дня с момента оплаты согласования макета."
    },
    {
      "start": 937.68,
      "end": 939.62,
      "speaker": null,
      "text": "Но за один день тоже нужно порой сделать."
    },
    {
      "start": 940.02,
      "end": 942.44,
      "speaker": null,
      "text": "Если в флаге, то тут чуть-чуть подольше."
    },
    {
      "start": 942.8,
      "end": 943.3,
      "speaker": null,
      "text": "Три-четыре."
    },
    {
      "start": 944.58,
      "end": 945.1,
      "speaker": null,
      "text": "Понял."
    },
    {
      "start": 945.66,
      "end": 945.84,
      "speaker": null,
      "text": "Все!"
    },
    {
      "start": 948.18,
      "end": 953.6,
      "speaker": null,
      "text": "А у вас, смотрите, получается же как реклама будет?"
    },
    {
      "start": 953.9,
      "end": 955.04,
      "speaker": null,
      "text": "Правильно я вас понимаю, да?"
    },
    {
      "start": 956.21,
      "end": 957.8,
      "speaker": null,
      "text": "Скоро открытия там и так далее, да."
    },
    {
      "start": 958.22,
      "end": 960.1,
      "speaker": null,
      "text": "Получается полиграфить тоже будет необходимо?"
    },
    {
      "start": 960.44,
      "end": 961.32,
      "speaker": null,
      "text": "Листовки, буклеты?"
    },
    {
      "start": 962.65,
      "end": 963.45,
      "speaker": null,
      "text": "Вероятно, да."
    },
    {
      "start": 964.95,
      "end": 965.27,
      "speaker": null,
      "text": "Мы начинаемся."
    },
    {
      "start": 966.69,
      "end": 967.41,
      "speaker": null,
      "text": "Понял, учту."
    },
    {
      "start": 968.11,
      "end": 968.93,
      "speaker": null,
      "text": "Все, конечно, да."
    },
    {
      "start": 969.75,
      "end": 972.49,
      "speaker": null,
      "text": "Хорошо, в Телеграм буду писать, звоните, пишите, конечно."
    },
    {
      "start": 972.71,
      "end": 974.97,
      "speaker": null,
      "text": "Да, присылайте, быстренько к вам вернусь потом попозже."
    },
    {
      "start": 975.09,
      "end": 975.45,
      "speaker": null,
      "text": "Благодарю вас."
    },
    {
      "start": 976.03,
      "end": 977.39,
      "speaker": null,
      "text": "Все, конечно, сохраняйте дам, Михаил."
    },
    {
      "start": 977.53,
      "end": 978.31,
      "speaker": null,
      "text": "Хорошего дня, до свидания."
    },
    {
      "start": 978.33,
      "end": 978.55,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 978.55,
      "end": 979.01,
      "speaker": null,
      "text": "Спасибо."
    },
    {
      "start": 979.27,
      "end": 979.31,
      "speaker": null,
      "text": "Субтитры сделал DimaTorzok."
    },
    {
      "start": 979.33,
      "end": 979.35,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}