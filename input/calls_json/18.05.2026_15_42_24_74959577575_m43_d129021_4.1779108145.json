{
  "file": "18.05.2026_15_42_24_74959577575_m43_d129021_4.1779108145.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 862.1,
  "segments": [
    {
      "start": 1.55,
      "end": 6.79,
      "speaker": null,
      "text": "Здравствуйте. Вы позвонили в управление кадровых сервисов и университет правительства."
    },
    {
      "start": 16.24,
      "end": 20.02,
      "speaker": null,
      "text": "Алло, Георгий, это Дмитрий. Удобно говорить?"
    },
    {
      "start": 21.6,
      "end": 22.28,
      "speaker": null,
      "text": "Да, слушаю."
    },
    {
      "start": 22.92,
      "end": 33.73,
      "speaker": null,
      "text": "По поводу СТЕ. Все там подписали догс-соглашение. Там Людмила просит выставить УПД уже."
    },
    {
      "start": 36.6,
      "end": 47.66,
      "speaker": null,
      "text": "Понятное дело. Время пока у вас есть от 12... У вас же какой был 12 как ранний день, да?"
    },
    {
      "start": 49.37,
      "end": 53.07,
      "speaker": null,
      "text": "На поставку. Не помните?"
    },
    {
      "start": 54.46,
      "end": 58.28,
      "speaker": null,
      "text": "Наверное, 12... Честно не помню, надо договор смотреть."
    },
    {
      "start": 59.95,
      "end": 61.59,
      "speaker": null,
      "text": "Сейчас, сейчас я открою."
    },
    {
      "start": 65.28,
      "end": 69.52,
      "speaker": null,
      "text": "Написано дата окончания этапа 19.06. Нет."
    },
    {
      "start": 70.5,
      "end": 70.9,
      "speaker": null,
      "text": "Не то."
    },
    {
      "start": 71.18,
      "end": 74.8,
      "speaker": null,
      "text": "12.05 период поставки. 12.05."
    },
    {
      "start": 77.15,
      "end": 89.03,
      "speaker": null,
      "text": "Получается у вас с этого момента 10 рабочих дней по договору там не было."
    },
    {
      "start": 95.22,
      "end": 95.76,
      "speaker": null,
      "text": "По крайней мере."
    },
    {
      "start": 96.38,
      "end": 100.5,
      "speaker": null,
      "text": "Время пока есть. Давайте сейчас я посмотрю..."
    },
    {
      "start": 104.34,
      "end": 106.54,
      "speaker": null,
      "text": "Ну, либо давайте завтра."
    },
    {
      "start": 108.59,
      "end": 112.15,
      "speaker": null,
      "text": "Да нет, лучше я сейчас, потому что у меня куча дел после отпуска."
    },
    {
      "start": 113.5,
      "end": 123.98,
      "speaker": null,
      "text": "Я боюсь, что у вас баннер был."
    },
    {
      "start": 124.66,
      "end": 125.66,
      "speaker": null,
      "text": "А вы не смотрели, да?"
    },
    {
      "start": 127.18,
      "end": 127.66,
      "speaker": null,
      "text": "ФТЕ?"
    },
    {
      "start": 129.72,
      "end": 130.92,
      "speaker": null,
      "text": "Нет, не смотрел."
    },
    {
      "start": 130.92,
      "end": 135.24,
      "speaker": null,
      "text": "Ты вообще, знаете, как все это смотрели?"
    },
    {
      "start": 135.74,
      "end": 136.24,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 137.3,
      "end": 142.26,
      "speaker": null,
      "text": "Ну, есть... Вы же через портал Москвы работаете уже."
    },
    {
      "start": 142.64,
      "end": 148.38,
      "speaker": null,
      "text": "Ну, как сказать, работаем. В прошлый раз мне ваши коллеги помогали."
    },
    {
      "start": 149.75,
      "end": 154.05,
      "speaker": null,
      "text": "Не, ну это в прошлое понятно. А вообще вы работаете или только с нами?"
    },
    {
      "start": 154.05,
      "end": 167.21,
      "speaker": null,
      "text": "Только с вами. Ну, у нас до этого человек был, кто работал на портале. Как бы... А потом его нету и все. И особо не берем на портале новые заказы только с вами."
    },
    {
      "start": 167.21,
      "end": 174.99,
      "speaker": null,
      "text": "Вы, если зайдете сейчас... Давайте. Ну, если у вас есть время, я могу вам рассказать немножко."
    },
    {
      "start": 176.14,
      "end": 176.4,
      "speaker": null,
      "text": "Давайте."
    },
    {
      "start": 177.28,
      "end": 177.38,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 178.74,
      "end": 185.62,
      "speaker": null,
      "text": "Ну, единственное, если там нужно что-то подписывать, то у меня нету доступа. Это делает другой человек. У него флешка, он подписывается."
    },
    {
      "start": 185.62,
      "end": 188.84,
      "speaker": null,
      "text": "Я просто скажу, где СТЕшки и как смотреть."
    },
    {
      "start": 190.24,
      "end": 192.32,
      "speaker": null,
      "text": "Ну, оферты и СТЕ, правильно?"
    },
    {
      "start": 194.69,
      "end": 196.41,
      "speaker": null,
      "text": "Мои заявки на СТЕ."
    },
    {
      "start": 196.79,
      "end": 199.16,
      "speaker": null,
      "text": "Сейчас, секунду."
    },
    {
      "start": 199.16,
      "end": 199.78,
      "speaker": null,
      "text": "Да, алло."
    },
    {
      "start": 202.16,
      "end": 202.86,
      "speaker": null,
      "text": "Да, алло."
    },
    {
      "start": 203.1,
      "end": 215.3,
      "speaker": null,
      "text": "Давайте до пяти если не открываешь, то я принесу."
    },
    {
      "start": 216.94,
      "end": 217.7,
      "speaker": null,
      "text": "Ну, все, хорошо."
    },
    {
      "start": 218.46,
      "end": 218.98,
      "speaker": null,
      "text": "Я здесь."
    },
    {
      "start": 220.48,
      "end": 220.66,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 224.55,
      "end": 227.39,
      "speaker": null,
      "text": "Смотри, вы заходите на главную страницу портала."
    },
    {
      "start": 227.89,
      "end": 228.69,
      "speaker": null,
      "text": "Портал постучек."
    },
    {
      "start": 230.41,
      "end": 230.67,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 232.5,
      "end": 237.88,
      "speaker": null,
      "text": "У вас сверху, где портал постучков, такие три полосочки горизонтальные."
    },
    {
      "start": 238.14,
      "end": 242.6,
      "speaker": null,
      "text": "Вот вы их раскрываете, и порталок будет."
    },
    {
      "start": 243.58,
      "end": 245.92,
      "speaker": null,
      "text": "Вот в каталоге есть товаро-работа-услуги."
    },
    {
      "start": 245.92,
      "end": 247.24,
      "speaker": null,
      "text": "Вам нужен..."
    },
    {
      "start": 247.86,
      "end": 248.66,
      "speaker": null,
      "text": "Так, подождите."
    },
    {
      "start": 248.76,
      "end": 260.01,
      "speaker": null,
      "text": "У меня контракты, заказчики платы товара, поставщики закупки, закупки по потребностям, котировочной сессии, единый реестр закупок."
    },
    {
      "start": 260.07,
      "end": 262.99,
      "speaker": null,
      "text": "Это вы смотрите через личный кабинет?"
    },
    {
      "start": 262.99,
      "end": 267.31,
      "speaker": null,
      "text": "А если на самой главной странице, закупки.моз.ру?"
    },
    {
      "start": 267.31,
      "end": 269.95,
      "speaker": null,
      "text": "Это мне туда нужно заходить?"
    },
    {
      "start": 271.65,
      "end": 299.9,
      "speaker": null,
      "text": "Да, сейчас я зайду через личный кабинет, чтобы у меня просто там окошко сейчас скрутится в личный кабинет."
    },
    {
      "start": 299.9,
      "end": 316.72,
      "speaker": null,
      "text": "Вот, у вас слева, окошечко слева, не стало где, а именно слева, портал постучков где."
    },
    {
      "start": 317.36,
      "end": 317.8,
      "speaker": null,
      "text": "Так."
    },
    {
      "start": 318.24,
      "end": 323.35,
      "speaker": null,
      "text": "У вас должно быть раздел портала тут, верно?"
    },
    {
      "start": 323.35,
      "end": 328.3,
      "speaker": null,
      "text": "Ну вот, я нажал на портал поставщиков."
    },
    {
      "start": 328.52,
      "end": 329.26,
      "speaker": null,
      "text": "Три полосочки."
    },
    {
      "start": 329.42,
      "end": 333.62,
      "speaker": null,
      "text": "Каталог, единый реестр закупок, контракт, организация, дополнительные программы."
    },
    {
      "start": 333.64,
      "end": 335.4,
      "speaker": null,
      "text": "Вот именно каталог, если вы..."
    },
    {
      "start": 337.3,
      "end": 339.76,
      "speaker": null,
      "text": "Товары, работа, услуги и публичный доступ."
    },
    {
      "start": 340.16,
      "end": 341.74,
      "speaker": null,
      "text": "Товары, работа, услуги."
    },
    {
      "start": 341.88,
      "end": 343.4,
      "speaker": null,
      "text": "Вот у вас вот здесь по..."
    },
    {
      "start": 344.08,
      "end": 348.26,
      "speaker": null,
      "text": "Ну, у вас с нами в данном случае у вас выполнение работы."
    },
    {
      "start": 348.92,
      "end": 349.68,
      "speaker": null,
      "text": "А, работа."
    },
    {
      "start": 351.31,
      "end": 351.91,
      "speaker": null,
      "text": "Работа."
    },
    {
      "start": 355.95,
      "end": 357.99,
      "speaker": null,
      "text": "Там проваливаетесь в работу."
    },
    {
      "start": 358.51,
      "end": 359.57,
      "speaker": null,
      "text": "Смотрите все, да?"
    },
    {
      "start": 361.28,
      "end": 362.72,
      "speaker": null,
      "text": "Да, смотрите все там."
    },
    {
      "start": 366.21,
      "end": 368.79,
      "speaker": null,
      "text": "Потом вы заходите в наш договор,"
    },
    {
      "start": 370.63,
      "end": 371.15,
      "speaker": null,
      "text": "в..."
    },
    {
      "start": 372.84,
      "end": 373.36,
      "speaker": null,
      "text": "Это..."
    },
    {
      "start": 375.69,
      "end": 376.73,
      "speaker": null,
      "text": "Кническое задание."
    },
    {
      "start": 378.92,
      "end": 380.52,
      "speaker": null,
      "text": "Кническое задание у вас есть."
    },
    {
      "start": 382.86,
      "end": 383.56,
      "speaker": null,
      "text": "А-а-а..."
    },
    {
      "start": 383.56,
      "end": 385.5,
      "speaker": null,
      "text": "Ну, тут идет изготовление баннера."
    },
    {
      "start": 385.74,
      "end": 386.36,
      "speaker": null,
      "text": "Сейчас, кстати, посмотрим."
    },
    {
      "start": 386.6,
      "end": 388.7,
      "speaker": null,
      "text": "Мне кажется, эти STI не нужно делать."
    },
    {
      "start": 390.26,
      "end": 392.88,
      "speaker": null,
      "text": "Мне кажется, в прошлый раз, когда мы сделали то же самое,"
    },
    {
      "start": 393.16,
      "end": 394.4,
      "speaker": null,
      "text": "мы не делали STI."
    },
    {
      "start": 396.04,
      "end": 397.08,
      "speaker": null,
      "text": "Если вы..."
    },
    {
      "start": 397.08,
      "end": 400.24,
      "speaker": null,
      "text": "Нет, может, есть их вот как раз вот там,"
    },
    {
      "start": 400.44,
      "end": 402.08,
      "speaker": null,
      "text": "где я вам сейчас сказал, в реестре."
    },
    {
      "start": 402.47,
      "end": 406.77,
      "speaker": null,
      "text": "Если вы сейчас там ведете в поиске изготовления баннера,"
    },
    {
      "start": 407.97,
      "end": 409.97,
      "speaker": null,
      "text": "возможно, вам найдет..."
    },
    {
      "start": 411.84,
      "end": 412.46,
      "speaker": null,
      "text": "Готовый."
    },
    {
      "start": 413.76,
      "end": 414.3,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 415.46,
      "end": 417.6,
      "speaker": null,
      "text": "Если они подходят по характеристикам."
    },
    {
      "start": 419.08,
      "end": 421.94,
      "speaker": null,
      "text": "Бывает такого, что не находят."
    },
    {
      "start": 426.01,
      "end": 429.35,
      "speaker": null,
      "text": "Ну, условно, вот в этом поиске вы там пишите..."
    },
    {
      "start": 429.35,
      "end": 433.89,
      "speaker": null,
      "text": "Вы в TGF смотрите, как у вас наименование идет продукция,"
    },
    {
      "start": 434.59,
      "end": 435.75,
      "speaker": null,
      "text": "там изготовление баннера,"
    },
    {
      "start": 435.75,
      "end": 439.91,
      "speaker": null,
      "text": "вот и вводите сюда изготовление баннера в поисковую строку."
    },
    {
      "start": 440.07,
      "end": 445.35,
      "speaker": null,
      "text": "Дальше вы ищете STI по характеристикам, которые у вас прописаны в техническом задании."
    },
    {
      "start": 445.97,
      "end": 448.67,
      "speaker": null,
      "text": "Если их нет, то нужно создавать новую."
    },
    {
      "start": 449.35,
      "end": 451.21,
      "speaker": null,
      "text": "Чтобы создавать новую – это отдельная история."
    },
    {
      "start": 451.21,
      "end": 453.49,
      "speaker": null,
      "text": "Ого, понятно."
    },
    {
      "start": 453.93,
      "end": 456.29,
      "speaker": null,
      "text": "Мне кажется, просто разговариваем без этих STI."
    },
    {
      "start": 457.29,
      "end": 461.27,
      "speaker": null,
      "text": "Поставкой товара, когда у вас не именно выполнение работы, а поставкой..."
    },
    {
      "start": 461.27,
      "end": 462.31,
      "speaker": null,
      "text": "Вот там не надо, да?"
    },
    {
      "start": 462.41,
      "end": 467.23,
      "speaker": null,
      "text": "Да, когда вы подписываете оферту, и у вас сразу привязывается STI."
    },
    {
      "start": 468.11,
      "end": 471.71,
      "speaker": null,
      "text": "Ну, вот поэтому в прошлый раз мы не делали, а сейчас надо как раз, да?"
    },
    {
      "start": 471.75,
      "end": 474.57,
      "speaker": null,
      "text": "Возможно, если это была поставка товара, то его не было."
    },
    {
      "start": 475.47,
      "end": 476.93,
      "speaker": null,
      "text": "Оно автоматически подвязывается."
    },
    {
      "start": 477.53,
      "end": 481.65,
      "speaker": null,
      "text": "А при выполнении работ необходимо добавлять..."
    },
    {
      "start": 482.47,
      "end": 485.87,
      "speaker": null,
      "text": "У меня работы по изготовлению полиграфической продукции."
    },
    {
      "start": 487.22,
      "end": 488.46,
      "speaker": null,
      "text": "Я же понимаю."
    },
    {
      "start": 490.62,
      "end": 492.58,
      "speaker": null,
      "text": "Когда вы будете заполнять UPD,"
    },
    {
      "start": 494.02,
      "end": 497.14,
      "speaker": null,
      "text": "вам там потребуется предложить вести STI."
    },
    {
      "start": 497.14,
      "end": 502.47,
      "speaker": null,
      "text": "Там нужно будет вот цифры, которые я вот сейчас найду вам."
    },
    {
      "start": 503.14,
      "end": 503.96,
      "speaker": null,
      "text": "Попробую найти."
    },
    {
      "start": 505.48,
      "end": 506.96,
      "speaker": null,
      "text": "Их нужно будет добавить."
    },
    {
      "start": 507.18,
      "end": 509.82,
      "speaker": null,
      "text": "И плюс еще... Помните, я вам говорил, чтобы отказное приложили?"
    },
    {
      "start": 510.9,
      "end": 512.42,
      "speaker": null,
      "text": "Да, отказного письма нету."
    },
    {
      "start": 515.03,
      "end": 516.65,
      "speaker": null,
      "text": "Напишите от себя, что..."
    },
    {
      "start": 518.67,
      "end": 519.31,
      "speaker": null,
      "text": "Маннеры..."
    },
    {
      "start": 522.33,
      "end": 522.97,
      "speaker": null,
      "text": "Роллап..."
    },
    {
      "start": 525.96,
      "end": 530.24,
      "speaker": null,
      "text": "Я могу подгрузить сертификаты и паспорта стендов."
    },
    {
      "start": 532.59,
      "end": 536.55,
      "speaker": null,
      "text": "Сертификат пожарной безопасности, ну то, что он обработанный."
    },
    {
      "start": 537.57,
      "end": 542.17,
      "speaker": null,
      "text": "И паспорта как раз таки двух стендов ВИКа и паспорт на Альтек."
    },
    {
      "start": 544.3,
      "end": 545.28,
      "speaker": null,
      "text": "Этого будет недостаточно?"
    },
    {
      "start": 547.64,
      "end": 548.96,
      "speaker": null,
      "text": "Я думаю, что достаточно."
    },
    {
      "start": 550.5,
      "end": 551.98,
      "speaker": null,
      "text": "Ну вот, я тоже так думаю."
    },
    {
      "start": 554.9,
      "end": 558.66,
      "speaker": null,
      "text": "Просто у вас технические заданиями и там идет, подлежит или не подлежит."
    },
    {
      "start": 558.8,
      "end": 559.56,
      "speaker": null,
      "text": "Я думаю, что это..."
    },
    {
      "start": 559.56,
      "end": 563.84,
      "speaker": null,
      "text": "А в паспортах там есть вообще про сертификацию что-нибудь или там просто характеристики?"
    },
    {
      "start": 565.37,
      "end": 566.89,
      "speaker": null,
      "text": "Сейчас скачаю я."
    },
    {
      "start": 573.46,
      "end": 574.02,
      "speaker": null,
      "text": "Молодец."
    },
    {
      "start": 574.02,
      "end": 600.81,
      "speaker": null,
      "text": "Так, техническое описание, технические характеристики, требования по технической безопасности, порядок сборки, комплект поставки, гарантийное обязательство, сведения о приемке, информация о производителе. Все."
    },
    {
      "start": 600.81,
      "end": 607.26,
      "speaker": null,
      "text": "Ну это все пустое, я правильно понимаю? Там это заполнять все надо."
    },
    {
      "start": 608.12,
      "end": 609.14,
      "speaker": null,
      "text": "А пустое что именно?"
    },
    {
      "start": 610.95,
      "end": 616.05,
      "speaker": null,
      "text": "Ну, сведения о поставке, срок гарантии у вас там..."
    },
    {
      "start": 616.21,
      "end": 620.11,
      "speaker": null,
      "text": "Ну это паспорт от производителя, тот кто изготавливает."
    },
    {
      "start": 620.11,
      "end": 623.18,
      "speaker": null,
      "text": "А это не вы их задавливаете?"
    },
    {
      "start": 623.78,
      "end": 624.26,
      "speaker": null,
      "text": "Нет."
    },
    {
      "start": 635.88,
      "end": 640.32,
      "speaker": null,
      "text": "Так, ну то что я сейчас смотрю, я боюсь, что она создавается в ТЕшке."
    },
    {
      "start": 643.61,
      "end": 645.25,
      "speaker": null,
      "text": "Не вижу прям..."
    },
    {
      "start": 645.95,
      "end": 649.47,
      "speaker": null,
      "text": "Хорошо, а Дарья может мне помочь с..."
    },
    {
      "start": 650.04,
      "end": 651.27,
      "speaker": null,
      "text": "Она умеет создавать?"
    },
    {
      "start": 651.29,
      "end": 652.87,
      "speaker": null,
      "text": "Она это не умеет точно сделать."
    },
    {
      "start": 653.57,
      "end": 655.67,
      "speaker": null,
      "text": "Нет, знаете какая Дарья сейчас?"
    },
    {
      "start": 656.9,
      "end": 657.52,
      "speaker": null,
      "text": "Катрушина."
    },
    {
      "start": 659.37,
      "end": 660.53,
      "speaker": null,
      "text": "Она тоже не умеет."
    },
    {
      "start": 661.09,
      "end": 661.93,
      "speaker": null,
      "text": "Ну вряд ли."
    },
    {
      "start": 661.93,
      "end": 667.36,
      "speaker": null,
      "text": "Я не уверен, что у нее доступ на портал есть."
    },
    {
      "start": 668.33,
      "end": 669.35,
      "speaker": null,
      "text": "Я вам так скажу."
    },
    {
      "start": 670.27,
      "end": 674.17,
      "speaker": null,
      "text": "Ну, если вы можете мне помочь, я буду вам благодарен."
    },
    {
      "start": 674.25,
      "end": 677.37,
      "speaker": null,
      "text": "Я могу даже дать почту и пароль."
    },
    {
      "start": 679.43,
      "end": 680.77,
      "speaker": null,
      "text": "Да нет, мне это не нужно."
    },
    {
      "start": 681.15,
      "end": 684.58,
      "speaker": null,
      "text": "У меня есть доступ на портал."
    },
    {
      "start": 685.73,
      "end": 687.09,
      "speaker": null,
      "text": "Нет, ну вы же не можете создать?"
    },
    {
      "start": 687.09,
      "end": 688.73,
      "speaker": null,
      "text": "Потому что я сейчас смотрю..."
    },
    {
      "start": 690.27,
      "end": 692.03,
      "speaker": null,
      "text": "Ну вы же не можете это создать?"
    },
    {
      "start": 692.6,
      "end": 693.78,
      "speaker": null,
      "text": "Почему? Могу."
    },
    {
      "start": 693.88,
      "end": 694.9,
      "speaker": null,
      "text": "А, можете создать?"
    },
    {
      "start": 694.9,
      "end": 697.02,
      "speaker": null,
      "text": "Здесь у меня доступ на портал есть."
    },
    {
      "start": 697.78,
      "end": 698.54,
      "speaker": null,
      "text": "Значит, могу."
    },
    {
      "start": 698.92,
      "end": 699.92,
      "speaker": null,
      "text": "Ну я же сижу от..."
    },
    {
      "start": 704.95,
      "end": 705.51,
      "speaker": null,
      "text": "Учреждения."
    },
    {
      "start": 708.76,
      "end": 710.26,
      "speaker": null,
      "text": "Ну нет, здесь какой-то бред."
    },
    {
      "start": 710.52,
      "end": 711.98,
      "speaker": null,
      "text": "Тут я боюсь, что мы не найдем."
    },
    {
      "start": 712.16,
      "end": 714.82,
      "speaker": null,
      "text": "Да тут всегда бред пишут и выбирают."
    },
    {
      "start": 715.9,
      "end": 716.82,
      "speaker": null,
      "text": "Под конкретику."
    },
    {
      "start": 717.54,
      "end": 718.8,
      "speaker": null,
      "text": "Под конкретику, да."
    },
    {
      "start": 720.3,
      "end": 721.82,
      "speaker": null,
      "text": "Вот, но это ждать придется."
    },
    {
      "start": 722.12,
      "end": 724.0,
      "speaker": null,
      "text": "Не один-два дня."
    },
    {
      "start": 724.0,
      "end": 724.9,
      "speaker": null,
      "text": "Я знаю."
    },
    {
      "start": 725.06,
      "end": 733.38,
      "speaker": null,
      "text": "Там отправляется на проверку, если там все верно заполнено, то типа портал регистрирует эту СТЕ и только потом можно уже будет все делать."
    },
    {
      "start": 734.39,
      "end": 734.55,
      "speaker": null,
      "text": "Да?"
    },
    {
      "start": 734.93,
      "end": 743.57,
      "speaker": null,
      "text": "Я просто как-то один раз создавал их очень давно, но это очень муторно и сложно, когда я это никогда не делал."
    },
    {
      "start": 743.57,
      "end": 745.81,
      "speaker": null,
      "text": "Да нет, это на самом деле пять минут."
    },
    {
      "start": 746.58,
      "end": 750.0,
      "speaker": null,
      "text": "Ну это вам, а мне пару часов."
    },
    {
      "start": 750.58,
      "end": 759.46,
      "speaker": null,
      "text": "Потому что там когда выбираешь материал, там либо его нету, либо надо что-то выдумывать, ну короче что-то похожее выбирать."
    },
    {
      "start": 759.46,
      "end": 761.84,
      "speaker": null,
      "text": "Сейчас уже намного проще."
    },
    {
      "start": 762.32,
      "end": 762.92,
      "speaker": null,
      "text": "А-а-а."
    },
    {
      "start": 762.92,
      "end": 767.71,
      "speaker": null,
      "text": "Уже предлагают то, что есть и грубо говоря..."
    },
    {
      "start": 771.21,
      "end": 773.17,
      "speaker": null,
      "text": "Ну вы сможете это сделать?"
    },
    {
      "start": 773.47,
      "end": 774.45,
      "speaker": null,
      "text": "Хорошо, да."
    },
    {
      "start": 774.69,
      "end": 775.77,
      "speaker": null,
      "text": "Ну смотрите, день два."
    },
    {
      "start": 776.37,
      "end": 778.53,
      "speaker": null,
      "text": "Давайте вы мне послезавтра напомните."
    },
    {
      "start": 779.86,
      "end": 781.1,
      "speaker": null,
      "text": "Двадцатого утром?"
    },
    {
      "start": 781.16,
      "end": 781.74,
      "speaker": null,
      "text": "Я вам скажу."
    },
    {
      "start": 781.88,
      "end": 783.89,
      "speaker": null,
      "text": "Ну как получится."
    },
    {
      "start": 784.51,
      "end": 786.85,
      "speaker": null,
      "text": "Хорошо, давайте, хорошо договорились."
    },
    {
      "start": 787.11,
      "end": 789.31,
      "speaker": null,
      "text": "Можете на почту написать, я вам отвечу."
    },
    {
      "start": 790.04,
      "end": 794.8,
      "speaker": null,
      "text": "Ну я вам лучше позвоню, сейчас напоминалку все поставлю."
    },
    {
      "start": 796.35,
      "end": 797.95,
      "speaker": null,
      "text": "Может вы мне на мобильный позвоните?"
    },
    {
      "start": 800.1,
      "end": 801.14,
      "speaker": null,
      "text": "Так, щас..."
    },
    {
      "start": 801.14,
      "end": 803.66,
      "speaker": null,
      "text": "Да, но у меня не сохранилось."
    },
    {
      "start": 806.86,
      "end": 809.54,
      "speaker": null,
      "text": "Вроде там и по почте был мой мобильный, но не сочет."
    },
    {
      "start": 809.99,
      "end": 810.63,
      "speaker": null,
      "text": "Запишете?"
    },
    {
      "start": 811.28,
      "end": 812.12,
      "speaker": null,
      "text": "Да, секунду."
    },
    {
      "start": 827.63,
      "end": 828.51,
      "speaker": null,
      "text": "Так, записываю."
    },
    {
      "start": 830.18,
      "end": 830.7,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 833.28,
      "end": 833.96,
      "speaker": null,
      "text": "806."
    },
    {
      "start": 834.3,
      "end": 834.76,
      "speaker": null,
      "text": "Да."
    },
    {
      "start": 837.51,
      "end": 837.85,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 839.53,
      "end": 840.73,
      "speaker": null,
      "text": "56, 68."
    },
    {
      "start": 842.78,
      "end": 845.44,
      "speaker": null,
      "text": "916-806-56-68."
    },
    {
      "start": 846.79,
      "end": 847.53,
      "speaker": null,
      "text": "Да, все верно."
    },
    {
      "start": 848.2,
      "end": 849.08,
      "speaker": null,
      "text": "Все, хорошо."
    },
    {
      "start": 850.95,
      "end": 851.93,
      "speaker": null,
      "text": "Спасибо вам большое."
    },
    {
      "start": 852.45,
      "end": 853.05,
      "speaker": null,
      "text": "Угу."
    },
    {
      "start": 854.05,
      "end": 856.8,
      "speaker": null,
      "text": "Ну, надеюсь, что в среду уже все будет плохо."
    },
    {
      "start": 856.92,
      "end": 858.34,
      "speaker": null,
      "text": "Хорошо, договорились, спасибо."
    },
    {
      "start": 859.86,
      "end": 860.82,
      "speaker": null,
      "text": "И вам тоже."
    }
  ]
}