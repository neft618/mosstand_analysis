  "segments": [
    {
      "start": 0.14,
      "end": 2.88,
      "speaker": null,
      "text": "Добрый день, Валентин. Компания Мостонченко. Могу вам помочь?"
    },
    {
      "start": 3.88,
      "end": 9.92,
      "speaker": null,
      "text": "Здравствуйте, Валентина. Меня зовут Александра. Я из босса движения в углу устройства. Скажите, пожалуйста, вы работаете с коммерческими предложениями?"
    },
    {
      "start": 10.64,
      "end": 11.6,
      "speaker": null,
      "text": "Да, работаем."
    },
    {
      "start": 12.39,
      "end": 16.21,
      "speaker": null,
      "text": "Подскажите, пожалуйста, а в течение сегодняшнего дня нам спорта будет закоммерческое?"
    },
    {
      "start": 16.73,
      "end": 19.01,
      "speaker": null,
      "text": "А что за коммерческое?"
    },
    {
      "start": 19.59,
      "end": 22.49,
      "speaker": null,
      "text": "Нам нужно сделать на заказ шесть флагов."
    },
    {
      "start": 24.1,
      "end": 25.56,
      "speaker": null,
      "text": "А к какому сроку необходимо?"
    },
    {
      "start": 27.03,
      "end": 31.89,
      "speaker": null,
      "text": "Нам пока не в сроке, нам главное коммерческое, потому что мы освободим продавать закупки."
    },
    {
      "start": 33.81,
      "end": 39.61,
      "speaker": null,
      "text": "Хорошо, я вас понял. А само ТЗ уже отправили нам или..."
    },
    {
      "start": 39.61,
      "end": 45.19,
      "speaker": null,
      "text": "Запрос? Мы пока не отправляли, я пока просто вот звоню уточнить можно ли, работаете ли вы с этим или нет."
    },
    {
      "start": 45.71,
      "end": 47.47,
      "speaker": null,
      "text": "Да, конечно, конечно, работаем."
    },
    {
      "start": 48.39,
      "end": 50.55,
      "speaker": null,
      "text": "Всё, тогда я вам отправлю. Большое спасибо."
    },
    {
      "start": 51.09,
      "end": 54.61,
      "speaker": null,
      "text": "Да, Александра, а могли бы вы отправить на мою почту конкретно?"
    },
    {
      "start": 56.93,
      "end": 58.91,
      "speaker": null,
      "text": "Так, какова у вас почта?"
    },
    {
      "start": 59.47,
      "end": 63.45,
      "speaker": null,
      "text": "А вот у вас, скорее всего, общая наша почта есть, инфо."
    },
    {
      "start": 65.27,
      "end": 66.51,
      "speaker": null,
      "text": "Елсобакамотстен.ру, да."
    },
    {
      "start": 66.83,
      "end": 72.67,
      "speaker": null,
      "text": "Да, а вот всё, что перед собачкой, замените на две буквы С и И как галочка обычная."
    },
    {
      "start": 73.96,
      "end": 77.52,
      "speaker": null,
      "text": "Получается, СВ, собакамотстен.ру"
    },
    {
      "start": 77.52,
      "end": 78.6,
      "speaker": null,
      "text": "Да, всё верно."
    },
    {
      "start": 79.56,
      "end": 80.56,
      "speaker": null,
      "text": "С как доллар, правильно?"
    },
    {
      "start": 80.78,
      "end": 81.74,
      "speaker": null,
      "text": "С как русская."
    },
    {
      "start": 82.56,
      "end": 89.38,
      "speaker": null,
      "text": "С как русская, получается, СВ, как галочка, собакамотстен.ру"
    },
    {
      "start": 89.38,
      "end": 90.54,
      "speaker": null,
      "text": "Да, всё верно."
    },
    {
      "start": 91.06,
      "end": 92.18,
      "speaker": null,
      "text": "Отправить на эту почту?"
    },
    {
      "start": 92.32,
      "end": 92.9,
      "speaker": null,
      "text": "Да, да, да."
    },
    {
      "start": 93.36,
      "end": 95.58,
      "speaker": null,
      "text": "Всё, большое спасибо, тогда отправлю."
    },
    {
      "start": 96.16,
      "end": 96.52,
      "speaker": null,
      "text": "Спасибо вам."
    },
    {
      "start": 96.52,
      "end": 97.58,
      "speaker": null,
      "text": "До свидания."
    },
