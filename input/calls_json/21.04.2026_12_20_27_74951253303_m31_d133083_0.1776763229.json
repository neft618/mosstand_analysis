{
  "file": "21.04.2026_12_20_27_74951253303_m31_d133083_0.1776763229.mp3",
  "language": "ru",
  "language_probability": 1,
  "duration_seconds": 60.4,
  "segments": [
    {
      "start": 0.75,
      "end": 3.67,
      "speaker": null,
      "text": "Если вы знаете внутренний номер абонента, наберите..."
    },
    {
      "start": 15.96,
      "end": 24.42,
      "speaker": null,
      "text": "Здравствуйте, Дмитрий. Это Валерий из МОСТЭНД. Мы с вами общались по почте по поводу карманов проволочных на буклетницу."
    },
    {
      "start": 24.86,
      "end": 29.16,
      "speaker": null,
      "text": "Я вот хотела уточнить просто, вы сказали, что пока ещё ждёте, я вот..."
    },
    {
      "start": 29.16,
      "end": 30.42,
      "speaker": null,
      "text": "Оплата прошла у вас?"
    },
    {
      "start": 31.58,
      "end": 34.48,
      "speaker": null,
      "text": "Так мы не оплачивали вам данный стоимость, не называла ещё."
    },
    {
      "start": 35.22,
      "end": 38.26,
      "speaker": null,
      "text": "Ну да, значит, не надо. Так, секунду."
    },
    {
      "start": 38.26,
      "end": 50.13,
      "speaker": null,
      "text": "Мы ещё вам говорили, что у нас нет именно проволочных на визитке."
    },
    {
      "start": 51.01,
      "end": 52.87,
      "speaker": null,
      "text": "А, ну нет, пока не нужно."
    },
    {
      "start": 53.98,
      "end": 55.9,
      "speaker": null,
      "text": "Хорошо, я поняла вас."
    },
    {
      "start": 56.34,
      "end": 58.0,
      "speaker": null,
      "text": "Да, тогда всего доброго, до свидания."
    },
    {
      "start": 58.54,
      "end": 58.88,
      "speaker": null,
      "text": "Спасибо."
    }
  ]
}